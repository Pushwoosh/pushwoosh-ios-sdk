{"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","anchor":"Overview","text":"Overview"},{"inlineContent":[{"type":"text","text":"This page provides ready-to-use code examples for integrating Pushwoosh into your tvOS application. Examples cover basic setup, Rich Media configuration, custom push handling, and advanced scenarios."}],"type":"paragraph"},{"anchor":"Basic-Setup","type":"heading","level":2,"text":"Basic Setup"},{"level":3,"type":"heading","text":"Minimal AppDelegate Setup","anchor":"Minimal-AppDelegate-Setup"},{"inlineContent":[{"text":"The simplest way to integrate Pushwoosh into your tvOS app:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["import UIKit","import Pushwoosh","import PushwooshTVOS","","@main","class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(_ application: UIApplication,","                     didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","        Pushwoosh.TVoS.setAppCode(\"XXXXX-XXXXX\")","","        \/\/ Register for push notifications","        Pushwoosh.TVoS.registerForTvPushNotifications()","","        return true","    }","","    func application(_ application: UIApplication,","                     didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","        Pushwoosh.TVoS.handleTvPushToken(deviceToken)","    }","","    func application(_ application: UIApplication,","                     didFailToRegisterForRemoteNotificationsWithError error: Error) {","        Pushwoosh.TVoS.handleTvPushRegistrationFailure(error)","    }","","    func application(_ application: UIApplication,","                     didReceiveRemoteNotification userInfo: [AnyHashable: Any],","                     fetchCompletionHandler completionHandler: @escaping (UIBackgroundFetchResult) -> Void) {","        Pushwoosh.TVoS.handleTvPushReceived(userInfo: userInfo, completionHandler: completionHandler)","    }","}"],"syntax":"swift"},{"type":"heading","text":"Rich Media Configuration","anchor":"Rich-Media-Configuration","level":2},{"level":3,"anchor":"Center-Position-with-Bottom-Animation","text":"Center Position with Bottom Animation","type":"heading"},{"inlineContent":[{"type":"text","text":"Display Rich Media in the center with slide-in animation from bottom:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    Pushwoosh.TVoS.setAppCode(\"XXXXX-XXXXX\")","","    \/\/ Configure Rich Media","    Pushwoosh.TVoS.configureRichMediaWith(","        position: .center,","        presentAnimation: .fromBottom,","        dismissAnimation: .toBottom","    )","","    Pushwoosh.TVoS.configureCloseButton(true)","    Pushwoosh.TVoS.registerForTvPushNotifications()","","    return true","}"]},{"level":3,"anchor":"Left-Side-Panel","type":"heading","text":"Left Side Panel"},{"inlineContent":[{"text":"Display Rich Media as a left-side panel:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["Pushwoosh.TVoS.configureRichMediaWith(","    position: .left,","    presentAnimation: .fromLeft,","    dismissAnimation: .toLeft",")"],"type":"codeListing"},{"type":"heading","anchor":"Top-Banner","level":3,"text":"Top Banner"},{"inlineContent":[{"type":"text","text":"Display Rich Media as a top banner with slide-down animation:"}],"type":"paragraph"},{"code":["Pushwoosh.TVoS.configureRichMediaWith(","    position: .top,","    presentAnimation: .fromTop,","    dismissAnimation: .toTop",")"],"type":"codeListing","syntax":"swift"},{"text":"No Close Button","anchor":"No-Close-Button","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Hide the Close button if your Rich Media has custom dismiss logic:"}]},{"syntax":"swift","code":["Pushwoosh.TVoS.configureRichMediaWith(","    position: .center,","    presentAnimation: .fromBottom,","    dismissAnimation: .toBottom",")","","Pushwoosh.TVoS.configureCloseButton(false)"],"type":"codeListing"},{"text":"Custom Push Handling","level":2,"type":"heading","anchor":"Custom-Push-Handling"},{"type":"heading","level":3,"text":"Selective Rich Media Display","anchor":"Selective-Rich-Media-Display"},{"type":"paragraph","inlineContent":[{"text":"Display Rich Media only for specific push types:","type":"text"}]},{"code":["func application(_ application: UIApplication,","                 didReceiveRemoteNotification userInfo: [AnyHashable: Any],","                 fetchCompletionHandler completionHandler: @escaping (UIBackgroundFetchResult) -> Void) {","","    \/\/ Check if push contains Rich Media","    if let rm = userInfo[\"rm\"] as? [String: Any],","       let url = rm[\"url\"] as? String {","","        \/\/ Check URL or other criteria","        if url.contains(\"special-offer\") {","            \/\/ Display Rich Media","            if Pushwoosh.TVoS.handleTVOSPush(userInfo: userInfo) {","                completionHandler(.newData)","                return","            }","        }","    }","","    \/\/ Handle as regular push","    Pushwoosh.TVoS.handleTvPushReceived(userInfo: userInfo, completionHandler: completionHandler)","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Registration-with-Completion-Handler","text":"Registration with Completion Handler","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Register with device token and handle success\/failure:","type":"text"}]},{"code":["func application(_ application: UIApplication,","                 didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","    Pushwoosh.TVoS.registerForTvPushNotifications(withToken: deviceToken) { error in","        if let error = error {","            print(\"Failed to register: \\(error.localizedDescription)\")","        } else {","            print(\"Successfully registered for push notifications\")","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Unregister-from-Push-Notifications","type":"heading","level":2,"text":"Unregister from Push Notifications"},{"type":"paragraph","inlineContent":[{"text":"Unregister the device from receiving push notifications:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.TVoS.unregisterForTvPushNotifications { error in","    if let error = error {","        print(\"Failed to unregister: \\(error.localizedDescription)\")","    } else {","        print(\"Successfully unregistered from push notifications\")","    }","}"]},{"level":2,"anchor":"getTags-Handler","type":"heading","text":"getTags Handler"},{"inlineContent":[{"type":"text","text":"Handle tags retrieved from Rich Media:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    Pushwoosh.TVoS.setAppCode(\"XXXXX-XXXXX\")","","    \/\/ Set getTags handler","    Pushwoosh.TVoS.setRichMediaGetTagsHandler { tags in","        print(\"Received tags from Rich Media:\")","        for (key, value) in tags {","            print(\"  \\(key): \\(value)\")","        }","    }","","    Pushwoosh.TVoS.registerForTvPushNotifications()","","    return true","}"]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/Examples"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/pushwooshtvos\/examples"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshtvos\/examples"]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS"]]},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"Code samples demonstrating common tvOS integration scenarios