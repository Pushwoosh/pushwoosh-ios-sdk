{"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"inlineContent":[{"text":"This page provides ready-to-use code examples for integrating Pushwoosh into your tvOS application. Examples cover basic setup, Rich Media configuration, custom push handling, and advanced scenarios.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"Basic-Setup","text":"Basic Setup"},{"level":3,"text":"Minimal AppDelegate Setup","type":"heading","anchor":"Minimal-AppDelegate-Setup"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The simplest way to integrate Pushwoosh into your tvOS app:"}]},{"type":"codeListing","syntax":"swift","code":["import UIKit","import Pushwoosh","import PushwooshTVOS","","@main","class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(_ application: UIApplication,","                     didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","        Pushwoosh.TVoS.setAppCode(\"XXXXX-XXXXX\")","","        \/\/ Register for push notifications","        Pushwoosh.TVoS.registerForTvPushNotifications()","","        return true","    }","","    func application(_ application: UIApplication,","                     didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","        Pushwoosh.TVoS.handleTvPushToken(deviceToken)","    }","","    func application(_ application: UIApplication,","                     didFailToRegisterForRemoteNotificationsWithError error: Error) {","        Pushwoosh.TVoS.handleTvPushRegistrationFailure(error)","    }","","    func application(_ application: UIApplication,","                     didReceiveRemoteNotification userInfo: [AnyHashable: Any],","                     fetchCompletionHandler completionHandler: @escaping (UIBackgroundFetchResult) -> Void) {","        Pushwoosh.TVoS.handleTvPushReceived(userInfo: userInfo, completionHandler: completionHandler)","    }","}"]},{"level":2,"text":"Rich Media Configuration","anchor":"Rich-Media-Configuration","type":"heading"},{"anchor":"Center-Position-with-Bottom-Animation","type":"heading","level":3,"text":"Center Position with Bottom Animation"},{"inlineContent":[{"text":"Display Rich Media in the center with slide-in animation from bottom:","type":"text"}],"type":"paragraph"},{"code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    Pushwoosh.TVoS.setAppCode(\"XXXXX-XXXXX\")","","    \/\/ Configure Rich Media","    Pushwoosh.TVoS.configureRichMediaWith(","        position: .center,","        presentAnimation: .fromBottom,","        dismissAnimation: .toBottom","    )","","    Pushwoosh.TVoS.configureCloseButton(true)","    Pushwoosh.TVoS.registerForTvPushNotifications()","","    return true","}"],"type":"codeListing","syntax":"swift"},{"level":3,"anchor":"Left-Side-Panel","type":"heading","text":"Left Side Panel"},{"inlineContent":[{"type":"text","text":"Display Rich Media as a left-side panel:"}],"type":"paragraph"},{"code":["Pushwoosh.TVoS.configureRichMediaWith(","    position: .left,","    presentAnimation: .fromLeft,","    dismissAnimation: .toLeft",")"],"type":"codeListing","syntax":"swift"},{"level":3,"text":"Top Banner","anchor":"Top-Banner","type":"heading"},{"inlineContent":[{"type":"text","text":"Display Rich Media as a top banner with slide-down animation:"}],"type":"paragraph"},{"code":["Pushwoosh.TVoS.configureRichMediaWith(","    position: .top,","    presentAnimation: .fromTop,","    dismissAnimation: .toTop",")"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"No Close Button","level":3,"anchor":"No-Close-Button"},{"inlineContent":[{"type":"text","text":"Hide the Close button if your Rich Media has custom dismiss logic:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.TVoS.configureRichMediaWith(","    position: .center,","    presentAnimation: .fromBottom,","    dismissAnimation: .toBottom",")","","Pushwoosh.TVoS.configureCloseButton(false)"]},{"anchor":"Custom-Push-Handling","type":"heading","level":2,"text":"Custom Push Handling"},{"level":3,"anchor":"Selective-Rich-Media-Display","text":"Selective Rich Media Display","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Display Rich Media only for specific push types:","type":"text"}]},{"syntax":"swift","code":["func application(_ application: UIApplication,","                 didReceiveRemoteNotification userInfo: [AnyHashable: Any],","                 fetchCompletionHandler completionHandler: @escaping (UIBackgroundFetchResult) -> Void) {","","    \/\/ Check if push contains Rich Media","    if let rm = userInfo[\"rm\"] as? [String: Any],","       let url = rm[\"url\"] as? String {","","        \/\/ Check URL or other criteria","        if url.contains(\"special-offer\") {","            \/\/ Display Rich Media","            if Pushwoosh.TVoS.handleTVOSPush(userInfo: userInfo) {","                completionHandler(.newData)","                return","            }","        }","    }","","    \/\/ Handle as regular push","    Pushwoosh.TVoS.handleTvPushReceived(userInfo: userInfo, completionHandler: completionHandler)","}"],"type":"codeListing"},{"level":2,"text":"Registration with Completion Handler","anchor":"Registration-with-Completion-Handler","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Register with device token and handle success\/failure:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["func application(_ application: UIApplication,","                 didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","    Pushwoosh.TVoS.registerForTvPushNotifications(withToken: deviceToken) { error in","        if let error = error {","            print(\"Failed to register: \\(error.localizedDescription)\")","        } else {","            print(\"Successfully registered for push notifications\")","        }","    }","}"]},{"text":"Unregister from Push Notifications","level":2,"type":"heading","anchor":"Unregister-from-Push-Notifications"},{"type":"paragraph","inlineContent":[{"text":"Unregister the device from receiving push notifications:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.TVoS.unregisterForTvPushNotifications { error in","    if let error = error {","        print(\"Failed to unregister: \\(error.localizedDescription)\")","    } else {","        print(\"Successfully unregistered from push notifications\")","    }","}"]},{"level":2,"anchor":"getTags-Handler","type":"heading","text":"getTags Handler"},{"inlineContent":[{"text":"Handle tags retrieved from Rich Media:","type":"text"}],"type":"paragraph"},{"code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    Pushwoosh.TVoS.setAppCode(\"XXXXX-XXXXX\")","","    \/\/ Set getTags handler","    Pushwoosh.TVoS.setRichMediaGetTagsHandler { tags in","        print(\"Received tags from Rich Media:\")","        for (key, value) in tags {","            print(\"  \\(key): \\(value)\")","        }","    }","","    Pushwoosh.TVoS.registerForTvPushNotifications()","","    return true","}"],"syntax":"swift","type":"codeListing"}]}],"seeAlsoSections":[{"identifiers":["doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/GettingStarted","doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/HTMLGuide","doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/PushwooshTVOSImplementation","doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/PWTVOSRichMediaManager"],"title":"Related Documentation"},{"generated":true,"title":"Getting Started","identifiers":["doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/GettingStarted","do