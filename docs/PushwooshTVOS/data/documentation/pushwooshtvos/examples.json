"    func application(_ application: UIApplication,","                     didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","        Pushwoosh.TVoS.setAppCode(\"XXXXX-XXXXX\")","","        \/\/ Register for push notifications","        Pushwoosh.TVoS.registerForTvPushNotifications()","","        return true","    }","","    func application(_ application: UIApplication,","                     didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","        Pushwoosh.TVoS.handleTvPushToken(deviceToken)","    }","","    func application(_ application: UIApplication,","                     didFailToRegisterForRemoteNotificationsWithError error: Error) {","        Pushwoosh.TVoS.handleTvPushRegistrationFailure(error)","    }","","    func application(_ application: UIApplication,","                     didReceiveRemoteNotification userInfo: [AnyHashable: Any],","                     fetchCompletionHandler completionHandler: @escaping (UIBackgroundFetchResult) -> Void) {","        Pushwoosh.TVoS.handleTvPushReceived(userInfo: userInfo, completionHandler: completionHandler)","    }","}"]},{"type":"heading","level":2,"text":"Rich Media Configuration","anchor":"Rich-Media-Configuration"},{"anchor":"Center-Position-with-Bottom-Animation","level":3,"type":"heading","text":"Center Position with Bottom Animation"},{"inlineContent":[{"type":"text","text":"Display Rich Media in the center with slide-in animation from bottom:"}],"type":"paragraph"},{"syntax":"swift","code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    Pushwoosh.TVoS.setAppCode(\"XXXXX-XXXXX\")","","    \/\/ Configure Rich Media","    Pushwoosh.TVoS.configureRichMediaWith(","        position: .center,","        presentAnimation: .fromBottom,","        dismissAnimation: .toBottom","    )","","    Pushwoosh.TVoS.configureCloseButton(true)","    Pushwoosh.TVoS.registerForTvPushNotifications()","","    return true","}"],"type":"codeListing"},{"type":"heading","text":"Left Side Panel","anchor":"Left-Side-Panel","level":3},{"inlineContent":[{"type":"text","text":"Display Rich Media as a left-side panel:"}],"type":"paragraph"},{"syntax":"swift","code":["Pushwoosh.TVoS.configureRichMediaWith(","    position: .left,","    presentAnimation: .fromLeft,","    dismissAnimation: .toLeft",")"],"type":"codeListing"},{"type":"heading","text":"Top Banner","anchor":"Top-Banner","level":3},{"inlineContent":[{"type":"text","text":"Display Rich Media as a top banner with slide-down animation:"}],"type":"paragraph"},{"type":"codeListing","code":["Pushwoosh.TVoS.configureRichMediaWith(","    position: .top,","    presentAnimation: .fromTop,","    dismissAnimation: .toTop",")"],"syntax":"swift"},{"text":"No Close Button","type":"heading","level":3,"anchor":"No-Close-Button"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Hide the Close button if your Rich Media has custom dismiss logic:"}]},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.TVoS.configureRichMediaWith(","    position: .center,","    presentAnimation: .fromBottom,","    dismissAnimation: .toBottom",")","","Pushwoosh.TVoS.configureCloseButton(false)"]},{"level":2,"text":"Custom Push Handling","anchor":"Custom-Push-Handling","type":"heading"},{"anchor":"Selective-Rich-Media-Display","level":3,"text":"Selective Rich Media Display","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Display Rich Media only for specific push types:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["func application(_ application: UIApplication,","                 didReceiveRemoteNotification userInfo: [AnyHashable: Any],","                 fetchCompletionHandler completionHandler: @escaping (UIBackgroundFetchResult) -> Void) {","","    \/\/ Check if push contains Rich Media","    if let rm = userInfo[\"rm\"] as? [String: Any],","       let url = rm[\"url\"] as? String {","","        \/\/ Check URL or other criteria","        if url.contains(\"special-offer\") {","            \/\/ Display Rich Media","            if Pushwoosh.TVoS.handleTVOSPush(userInfo: userInfo) {","                completionHandler(.newData)","                return","            }","        }","    }","","    \/\/ Handle as regular push","    Pushwoosh.TVoS.handleTvPushReceived(userInfo: userInfo, completionHandler: completionHandler)","}"]},{"text":"Registration with Completion Handler","anchor":"Registration-with-Completion-Handler","type":"heading","level":2},{"inlineContent":[{"text":"Register with device token and handle success\/failure:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["func application(_ application: UIApplication,","                 didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","    Pushwoosh.TVoS.registerForTvPushNotifications(withToken: deviceToken) { error in","        if let error = error {","            print(\"Failed to register: \\(error.localizedDescription)\")","        } else {","            print(\"Successfully registered for push notifications\")","        }","    }","}"]},{"level":2,"type":"heading","text":"Unregister from Push Notifications","anchor":"Unregister-from-Push-Notifications"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unregister the device from receiving push notifications:"}]},{"code":["Pushwoosh.TVoS.unregisterForTvPushNotifications { error in","    if let error = error {","        print(\"Failed to unregister: \\(error.localizedDescription)\")","    } else {","        print(\"Successfully unregistered from push notifications\")","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":2,"text":"getTags Handler","anchor":"getTags-Handler"},{"inlineContent":[{"type":"text","text":"Handle tags retrieved from Rich Media:"}],"type":"paragraph"},{"syntax":"swift","code"