{"abstract":[{"text":"Code samples demonstrating common tvOS integration scenarios.","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS"]]},"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/GettingStarted","doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/HTMLGuide","doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/PushwooshTVOSImplementation","doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/PWTVOSRichMediaManager"]},{"title":"Getting Started","identifiers":["doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/GettingStarted","doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/HTMLGuide"],"generated":true}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/pushwooshtvos\/examples"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshtvos\/examples"]}],"metadata":{"modules":[{"name":"PushwooshTVOS"}],"title":"Examples","roleHeading":"Article","role":"article"},"sections":[],"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"This page provides ready-to-use code examples for integrating Pushwoosh into your tvOS application. Examples cover basic setup, Rich Media configuration, custom push handling, and advanced scenarios."}],"type":"paragraph"},{"anchor":"Basic-Setup","type":"heading","text":"Basic Setup","level":2},{"anchor":"Minimal-AppDelegate-Setup","level":3,"type":"heading","text":"Minimal AppDelegate Setup"},{"type":"paragraph","inlineContent":[{"text":"The simplest way to integrate Pushwoosh into your tvOS app:","type":"text"}]},{"code":["import UIKit","import Pushwoosh","import PushwooshTVOS","","@main","class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(_ application: UIApplication,","                     didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","        Pushwoosh.TVoS.setAppCode(\"XXXXX-XXXXX\")","","        \/\/ Register for push notifications","        Pushwoosh.TVoS.registerForTvPushNotifications()","","        return true","    }","","    func application(_ application: UIApplication,","                     didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","        Pushwoosh.TVoS.handleTvPushToken(deviceToken)","    }","","    func application(_ application: UIApplication,","                     didFailToRegisterForRemoteNotificationsWithError error: Error) {","        Pushwoosh.TVoS.handleTvPushRegistrationFailure(error)","    }","","    func application(_ application: UIApplication,","                     didReceiveRemoteNotification userInfo: [AnyHashable: Any],","                     fetchCompletionHandler completionHandler: @escaping (UIBackgroundFetchResult) -> Void) {","        Pushwoosh.TVoS.handleTvPushReceived(userInfo: userInfo, completionHandler: completionHandler)","    }","}"],"syntax":"swift","type":"codeListing"},{"level":2,"text":"Rich Media Configuration","type":"heading","anchor":"Rich-Media-Configuration"},{"text":"Center Position with Bottom Animation","type":"heading","anchor":"Center-Position-with-Bottom-Animation","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Display Rich Media in the center with slide-in animation from bottom:"}]},{"code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    Pushwoosh.TVoS.setAppCode(\"XXXXX-XXXXX\")","","    \/\/ Configure Rich Media","    Pushwoosh.TVoS.configureRichMediaWith(","        position: .center,","        presentAnimation: .fromBottom,","        dismissAnimation: .toBottom","    )","","    Pushwoosh.TVoS.configureCloseButton(true)","    Pushwoosh.TVoS.registerForTvPushNotifications()","","    return true","}"],"syntax":"swift","type":"codeListing"},{"level":3,"text":"Left Side Panel","anchor":"Left-Side-Panel","type":"heading"},{"inlineContent":[{"text":"Display Rich Media as a left-side panel:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["Pushwoosh.TVoS.configureRichMediaWith(","    position: .left,","    presentAnimation: .fromLeft,","    dismissAnimation: .toLeft",")"],"syntax":"swift"},{"text":"Top Banner","level":3,"type":"heading","anchor":"Top-Banner"},{"inlineContent":[{"type":"text","text":"Display Rich Media as a top banner with slide-down animation:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.TVoS.configureRichMediaWith(","    position: .top,","    presentAnimation: .fromTop,","    dismissAnimation: .toTop",")"]},{"level":3,"text":"No Close Button","type":"heading","anchor":"No-Close-Button"},{"inlineContent":[{"text":"Hide the Close button if your Rich Media has custom dismiss logic:","type":"text"}],"type":"paragraph"},{"code":["Pushwoosh.TVoS.configureRichMediaWith(","    position: .center,","    presentAnimation: .fromBottom,","    dismissAnimation: .toBottom",")","","Pushwoosh.TVoS.configureCloseButton(false)"],"syntax":"swift","type":"codeListing"},{"level":2,"type":"heading","text":"Custom Push Handling","anchor":"Custom-Push-Handling"},{"text":"Selective Rich Media Display","type":"heading","level":3,"anchor":"Selective-Rich-Media-Display"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Display Rich Media only for specific push types:"}]},{"syntax":"swift","code":["func application(_ application: UIApplication,","                 didReceiveRemoteNotification userInfo: [AnyHashable: Any],","                 fetchCompletionHandler completionHandler: @escaping (UIBackgroundFetchResult) -> Void) {","","    \/\/ Check if push contains Rich Media","    if let rm = userInfo[\"rm\"] as? [String: Any],","       let url = rm[\"url\"] as? String {","","        \/\/ Check URL or other criteria","        if url.contains(\"special-offer\") {","            \/\/ Display Rich Media","            if Pushwoosh.TVoS.handleTVOSPush(userInfo: userInfo) {","                completionHandler(.newData)","                return","            }","        }","    }","","    \/\/ Handle as regular push","    Pushwoosh.TVoS.handleTvPushReceived(userInfo: userInfo, completionHandler: completionHandler)","}"],"type":"codeListing"},{"anchor":"Registration-with-Completion-Handler","level":2,"type":"heading","text":"Registration with Completion Handler"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register with device token and handle success\/failure:"}]},{"type":"codeListing","code":["func application(_ application: UIApplication,","                 didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","    Pushwoosh.TVoS.registerForTvPushNotifications(withToken: deviceToken) { error in","        if let error = error {","            print(\"Failed to register: \\(error.localizedDescription)\")","        } else {","            print(\"Successfully registered for push notifications\")","        }","    }","}"],"syntax":"swift"},{"type":"heading","text":"Unregister from Push Notifications","level":2,"anchor":"Unregister-from-Push-Notifications"},{"inlineContent":[{"type":"text","text":"Unregister the device from receiving push notifications:"}],"type":"paragraph"},{"code":["Pushwoosh.TVoS.unregisterForTvPushNotifications { error in","    if let error = error {","        print(\"Failed to unregister: \\(error.localizedDescription)\")","    } else {","        print(\"Successfully unregistered from push notifications\")","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"heading","text":"getTags Handler","anchor":"getTags-Handler","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle tags retrieved from Rich Media:"}]},{"code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    Pushwoosh.TVoS.setAppCode(\"XXXXX-XXXXX\")","","    \/\/ Set getTags handler","    Pushwoosh.TVoS.setRichMediaGetTagsHandler { tags in","        print(\"Received tags from Rich Media:\")","        for (key, value) in tags {","            print(\"  \\(key): \\(value)\")","        }","    }","","    Pushwoosh.TVoS.registerForTvPushNotifications()","","    return true","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/Examples","interfaceLanguage":"swift"},"kind":"article","references":{"doc://com.pushwoosh.PushwooshTVOS/documentation/PushwooshTVOS/HTMLGuide":{"title":"HTML Guide for tvOS Rich Media","abstract":[{"text":"Create Rich Media content using Unlayer HTML format for tvOS.","type":"text"}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/HTMLGuide","url":"\/documentation\/pushwooshtvos\/htmlguide","role":"article","kind":"article"},"doc://com.pushwoosh.PushwooshTVOS/documentation/PushwooshTVOS/PWTVOSRichMediaManager":{"type":"topic","url":"\/documentation\/pushwooshtvos\/pwtvosrichmediamanager","navigatorTitle":[{"kind":"identifier","text":"PWTVOSRichMediaManager"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/PWTVOSRichMediaManager","title":"PWTVOSRichMediaManager","role":"symbol","abstract":[{"type":"text","text":"Manager for displaying Rich Media content on tvOS."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"PWTVOSRichMediaManager"}]},"doc://com.pushwoosh.PushwooshTVOS/documentation/PushwooshTVOS/PushwooshTVOSImplementation":{"navigatorTitle":[{"kind":"identifier","text":"PushwooshTVOSImple