{"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"role":"article","modules":[{"name":"PushwooshTVOS"}],"title":"Examples","roleHeading":"Article"},"seeAlsoSections":[{"identifiers":["doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/GettingStarted","doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/HTMLGuide","doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/PushwooshTVOSImplementation","doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/PWTVOSRichMediaManager"],"title":"Related Documentation"},{"title":"Getting Started","identifiers":["doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/GettingStarted","doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/HTMLGuide"],"generated":true}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/Examples"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS"]]},"primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"This page provides ready-to-use code examples for integrating Pushwoosh into your tvOS application. Examples cover basic setup, Rich Media configuration, custom push handling, and advanced scenarios."}],"type":"paragraph"},{"text":"Basic Setup","type":"heading","anchor":"Basic-Setup","level":2},{"anchor":"Minimal-AppDelegate-Setup","level":3,"text":"Minimal AppDelegate Setup","type":"heading"},{"inlineContent":[{"text":"The simplest way to integrate Pushwoosh into your tvOS app:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["import UIKit","import Pushwoosh","import PushwooshTVOS","","@main","class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(_ application: UIApplication,","                     didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","        Pushwoosh.TVoS.setAppCode(\"XXXXX-XXXXX\")","","        \/\/ Register for push notifications","        Pushwoosh.TVoS.registerForTvPushNotifications()","","        return true","    }","","    func application(_ application: UIApplication,","                     didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","        Pushwoosh.TVoS.handleTvPushToken(deviceToken)","    }","","    func application(_ application: UIApplication,","                     didFailToRegisterForRemoteNotificationsWithError error: Error) {","        Pushwoosh.TVoS.handleTvPushRegistrationFailure(error)","    }","","    func application(_ application: UIApplication,","                     didReceiveRemoteNotification userInfo: [AnyHashable: Any],","                     fetchCompletionHandler completionHandler: @escaping (UIBackgroundFetchResult) -> Void) {","        Pushwoosh.TVoS.handleTvPushReceived(userInfo: userInfo, completionHandler: completionHandler)","    }","}"]},{"level":2,"type":"heading","anchor":"Rich-Media-Configuration","text":"Rich Media Configuration"},{"text":"Center Position with Bottom Animation","level":3,"type":"heading","anchor":"Center-Position-with-Bottom-Animation"},{"type":"paragraph","inlineContent":[{"text":"Display Rich Media in the center with slide-in animation from bottom:","type":"text"}]},{"syntax":"swift","code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    Pushwoosh.TVoS.setAppCode(\"XXXXX-XXXXX\")","","    \/\/ Configure Rich Media","    Pushwoosh.TVoS.configureRichMediaWith(","        position: .center,","        presentAnimation: .fromBottom,","        dismissAnimation: .toBottom","    )","","    Pushwoosh.TVoS.configureCloseButton(true)","    Pushwoosh.TVoS.registerForTvPushNotifications()","","    return true","}"],"type":"codeListing"},{"level":3,"text":"Left Side Panel","type":"heading","anchor":"Left-Side-Panel"},{"type":"paragraph","inlineContent":[{"text":"Display Rich Media as a left-side panel:","type":"text"}]},{"code":["Pushwoosh.TVoS.configureRichMediaWith(","    position: .left,","    presentAnimation: .fromLeft,","    dismissAnimation: .toLeft",")"],"syntax":"swift","type":"codeListing"},{"anchor":"Top-Banner","level":3,"type":"heading","text":"Top Banner"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Display Rich Media as a top banner with slide-down animation:"}]},{"type":"codeListing","code":["Pushwoosh.TVoS.configureRichMediaWith(","    position: .top,","    presentAnimation: .fromTop,","    dismissAnimation: .toTop",")"],"syntax":"swift"},{"type":"heading","text":"No Close Button","level":3,"anchor":"No-Close-Button"},{"inlineContent":[{"text":"Hide the Close button if your Rich Media has custom dismiss logic:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["Pushwoosh.TVoS.configureRichMediaWith(","    position: .center,","    presentAnimation: .fromBottom,","    dismissAnimation: .toBottom",")","","Pushwoosh.TVoS.configureCloseButton(false)"],"type":"codeListing"},{"anchor":"Custom-Push-Handling","text":"Custom Push Handling","type":"heading","level":2},{"anchor":"Selective-Rich-Media-Display","level":3,"text":"Selective Rich Media Display","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Display Rich Media only for specific push types:"}]},{"syntax":"swift","type":"codeListing","code":["func application(_ application: UIApplication,","                 didReceiveRemoteNotification userInfo: [AnyHashable: Any],","                 fetchCompletionHandler completionHandler: @escaping (UIBackgroundFetchResult) -> Void) {","","    \/\/ Check if push contains Rich Media","    if let rm = userInfo[\"rm\"] as? [String: Any],","       let url = rm[\"url\"] as? String {","","        \/\/ Check URL or other criteria","        if url.contains(\"special-offer\") {","            \/\/ Display Rich Media","            if Pushwoosh.TVoS.handleTVOSPush(userInfo: userInfo) {","                completionHandler(.newData)","                return","            }","        }","    }","","    \/\/ Handle as regular push","    Pushwoosh.TVoS.handleTvPushReceived(userInfo: userInfo, completionHandler: completionHandler)","}"]},{"anchor":"Registration-with-Completion-Handler","text":"Registration with Completion Handler","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register with device token and handle success\/failure:"}]},{"code":["func application(_ application: UIApplication,","                 didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","    Pushwoosh.TVoS.registerForTvPushNotifications(withToken: deviceToken) { error in","        if let error = error {","            print(\"Failed to register: \\(error.localizedDescription)\")","        } else {","            print(\"Successfully registered for push notifications\")","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","anchor":"Unregister-from-Push-Notifications","level":2,"text":"Unregister from Push Notifications"},{"inlineContent":[{"type":"text","text":"Unregister the device from receiving push notifications:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.TVoS.unregisterForTvPushNotifications { error in","    if let error = error {","        print(\"Failed to unregister: \\(error.localizedDescription)\")","    } else {","        print(\"Successfully unregistered from push notifications\")","    }","}"]},{"level":2,"text":"getTags Handler","type":"heading","anchor":"getTags-Handler"},{"inlineContent":[{"text":"Handle tags retrieved from Rich Media:","type":"text"}],"type":"paragraph"},{"code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    Pushwoosh.TVoS.setAppCode(\"XXXXX-XXXXX\")","","    \/\/ Set getTags handler","    Pushwoosh.TVoS.setRichMediaGetTagsHandler { tags in","        print(\"Received tags from Rich Media:\")","        for (key, value) in tags {","            print(\"  \\(key): \\(value)\")","        }","    }","","    Pushwoosh.TVoS.registerForTvPushNotifications()","","    return true","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"abstract":[{"type":"text","text":"Code samples demonstrating common tvOS integration scenarios."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/pushwooshtvos\/examples"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshtvos\/examples"]}],"kind":"article","sections":[],"references":{"doc://com.pushwoosh.PushwooshTVOS/documentation/PushwooshTVOS":{"identifier":"doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS","abstract":[{"text":"Push notifications and Rich Media for tvOS apps.","type":"text"}],"kind":"symbol","url":"\/documentation\/pushwooshtvos","role":"collection","title":"PushwooshTVOS","type":"topic"},"doc://com.pushwoosh.PushwooshTVOS/documentation/PushwooshTVOS/HTMLGuide":{"identifier":"doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/HTMLGuide","role":"article","url":"\/documentation\/pushwooshtvos\/htmlguide","type":"topic","abstract":[{"type":"text","text":"Create Rich Media content using Unlayer HTML format for tvOS."}],"title":"HTML Guide for tvOS Rich Media","kind":"article"},"doc://com.pushwoosh.PushwooshTVOS/documentation/PushwooshTVOS/PWTVOSRichMediaManager":{"url":"\/documentation\/pushwooshtvos\/pwtvosrichmediamanager","title":"PWTVOSRichMediaManager","navigatorTitle":[{"text":"PWTVOSRichMediaManager","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"PWTVOSRichMediaManager","kind":"identifier"}],"role":"symbol","type":"topic","abstract":[{"text":"