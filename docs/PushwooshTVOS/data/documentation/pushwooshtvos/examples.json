{"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This page provides ready-to-use code examples for integrating Pushwoosh into your tvOS application. Examples cover basic setup, Rich Media configuration, custom push handling, and advanced scenarios."}]},{"type":"heading","level":2,"text":"Basic Setup","anchor":"Basic-Setup"},{"text":"Minimal AppDelegate Setup","level":3,"anchor":"Minimal-AppDelegate-Setup","type":"heading"},{"inlineContent":[{"type":"text","text":"The simplest way to integrate Pushwoosh into your tvOS app:"}],"type":"paragraph"},{"code":["import UIKit","import Pushwoosh","import PushwooshTVOS","","@main","class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(_ application: UIApplication,","                     didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","        Pushwoosh.TVoS.setAppCode(\"XXXXX-XXXXX\")","","        \/\/ Register for push notifications","        Pushwoosh.TVoS.registerForTvPushNotifications()","","        return true","    }","","    func application(_ application: UIApplication,","                     didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","        Pushwoosh.TVoS.handleTvPushToken(deviceToken)","    }","","    func application(_ application: UIApplication,","                     didFailToRegisterForRemoteNotificationsWithError error: Error) {","        Pushwoosh.TVoS.handleTvPushRegistrationFailure(error)","    }","","    func application(_ application: UIApplication,","                     didReceiveRemoteNotification userInfo: [AnyHashable: Any],","                     fetchCompletionHandler completionHandler: @escaping (UIBackgroundFetchResult) -> Void) {","        Pushwoosh.TVoS.handleTvPushReceived(userInfo: userInfo, completionHandler: completionHandler)","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"Rich Media Configuration","level":2,"anchor":"Rich-Media-Configuration"},{"anchor":"Center-Position-with-Bottom-Animation","text":"Center Position with Bottom Animation","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Display Rich Media in the center with slide-in animation from bottom:"}]},{"type":"codeListing","syntax":"swift","code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    Pushwoosh.TVoS.setAppCode(\"XXXXX-XXXXX\")","","    \/\/ Configure Rich Media","    Pushwoosh.TVoS.configureRichMediaWith(","        position: .center,","        presentAnimation: .fromBottom,","        dismissAnimation: .toBottom","    )","","    Pushwoosh.TVoS.configureCloseButton(true)","    Pushwoosh.TVoS.registerForTvPushNotifications()","","    return true","}"]},{"anchor":"Left-Side-Panel","type":"heading","level":3,"text":"Left Side Panel"},{"type":"paragraph","inlineContent":[{"text":"Display Rich Media as a left-side panel:","type":"text"}]},{"code":["Pushwoosh.TVoS.configureRichMediaWith(","    position: .left,","    presentAnimation: .fromLeft,","    dismissAnimation: .toLeft",")"],"type":"codeListing","syntax":"swift"},{"anchor":"Top-Banner","text":"Top Banner","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Display Rich Media as a top banner with slide-down animation:"}]},{"type":"codeListing","code":["Pushwoosh.TVoS.configureRichMediaWith(","    position: .top,","    presentAnimation: .fromTop,","    dismissAnimation: .toTop",")"],"syntax":"swift"},{"type":"heading","level":3,"text":"No Close Button","anchor":"No-Close-Button"},{"inlineContent":[{"type":"text","text":"Hide the Close button if your Rich Media has custom dismiss logic:"}],"type":"paragraph"},{"code":["Pushwoosh.TVoS.configureRichMediaWith(","    position: .center,","    presentAnimation: .fromBottom,","    dismissAnimation: .toBottom",")","","Pushwoosh.TVoS.configureCloseButton(false)"],"syntax":"swift","type":"codeListing"},{"anchor":"Custom-Push-Handling","type":"heading","text":"Custom Push Handling","level":2},{"type":"heading","level":3,"anchor":"Selective-Rich-Media-Display","text":"Selective Rich Media Display"},{"inlineContent":[{"type":"text","text":"Display Rich Media only for specific push types:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["func application(_ application: UIApplication,","                 didReceiveRemoteNotification userInfo: [AnyHashable: Any],","                 fetchCompletionHandler completionHandler: @escaping (UIBackgroundFetchResult) -> Void) {","","    \/\/ Check if push contains Rich Media","    if let rm = userInfo[\"rm\"] as? [String: Any],","       let url = rm[\"url\"] as? String {","","        \/\/ Check URL or other criteria","        if url.contains(\"special-offer\") {","            \/\/ Display Rich Media","            if Pushwoosh.TVoS.handleTVOSPush(userInfo: userInfo) {","                completionHandler(.newData)","                return","            }","        }","    }","","    \/\/ Handle as regular push","    Pushwoosh.TVoS.handleTvPushReceived(userInfo: userInfo, completionHandler: completionHandler)","}"]},{"type":"heading","anchor":"Registration-with-Completion-Handler","level":2,"text":"Registration with Completion Handler"},{"inlineContent":[{"text":"Register with device token and handle success\/failure:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["func application(_ application: UIApplication,","                 didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","    Pushwoosh.TVoS.registerForTvPushNotifications(withToken: deviceToken) { error in","        if let error = error {","            print(\"Failed to register: \\(error.localizedDescription)\")","        } else {","            print(\"Successfully registered for push notifications\")","        }","    }","}"],"syntax":"swift"},{"level":2,"type":"heading","anchor":"Unregister-from-Push-Notifications","text":"Unregister from Push Notifications"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unregister the device from receiving push notifications:"}]},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.TVoS.unregisterForTvPushNotifications { error in","    if let error = error {","        print(\"Failed to unregister: \\(error.localizedDescription)\")","    } else {","        print(\"Successfully unregistered from push notifications\")","    }","}"]},{"type":"heading","text":"getTags Handler","anchor":"getTags-Handler","level":2},{"inlineContent":[{"type":"text","text":"Handle tags retrieved from Rich Media:"}],"type":"paragraph"},{"syntax":"swift","code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    Pushwoosh.TVoS.setAppCode(\"XXXXX-XXXXX\")","","    \/\/ Set getTags handler","    Pushwoosh.TVoS.setRichMediaGetTagsHandler { tags in","        print(\"Received tags from Rich Media:\")","        for (key, value) in tags {","            print(\"  \\(key): \\(value)\")","        }","    }","","    Pushwoosh.TVoS.registerForTvPushNotifications()","","    return true","}"],"type":"codeListing"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS"]]},"metadata":{"modules":[{"name":"PushwooshTVOS"}],"title":"Examples","roleHeading":"Article","role":"article"},"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/GettingStarted","doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/HTMLGuide","doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/Pus