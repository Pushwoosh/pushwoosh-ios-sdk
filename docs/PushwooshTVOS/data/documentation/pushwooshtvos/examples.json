e(\"XXXXX-XXXXX\")","","        \/\/ Register for push notifications","        Pushwoosh.TVoS.registerForTvPushNotifications()","","        return true","    }","","    func application(_ application: UIApplication,","                     didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","        Pushwoosh.TVoS.handleTvPushToken(deviceToken)","    }","","    func application(_ application: UIApplication,","                     didFailToRegisterForRemoteNotificationsWithError error: Error) {","        Pushwoosh.TVoS.handleTvPushRegistrationFailure(error)","    }","","    func application(_ application: UIApplication,","                     didReceiveRemoteNotification userInfo: [AnyHashable: Any],","                     fetchCompletionHandler completionHandler: @escaping (UIBackgroundFetchResult) -> Void) {","        Pushwoosh.TVoS.handleTvPushReceived(userInfo: userInfo, completionHandler: completionHandler)","    }","}"]},{"text":"Rich Media Configuration","level":2,"type":"heading","anchor":"Rich-Media-Configuration"},{"anchor":"Center-Position-with-Bottom-Animation","level":3,"type":"heading","text":"Center Position with Bottom Animation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Display Rich Media in the center with slide-in animation from bottom:"}]},{"code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    Pushwoosh.TVoS.setAppCode(\"XXXXX-XXXXX\")","","    \/\/ Configure Rich Media","    Pushwoosh.TVoS.configureRichMediaWith(","        position: .center,","        presentAnimation: .fromBottom,","        dismissAnimation: .toBottom","    )","","    Pushwoosh.TVoS.configureCloseButton(true)","    Pushwoosh.TVoS.registerForTvPushNotifications()","","    return true","}"],"syntax":"swift","type":"codeListing"},{"text":"Left Side Panel","type":"heading","level":3,"anchor":"Left-Side-Panel"},{"inlineContent":[{"type":"text","text":"Display Rich Media as a left-side panel:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["Pushwoosh.TVoS.configureRichMediaWith(","    position: .left,","    presentAnimation: .fromLeft,","    dismissAnimation: .toLeft",")"]},{"type":"heading","anchor":"Top-Banner","level":3,"text":"Top Banner"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Display Rich Media as a top banner with slide-down animation:"}]},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.TVoS.configureRichMediaWith(","    position: .top,","    presentAnimation: .fromTop,","    dismissAnimation: .toTop",")"]},{"level":3,"anchor":"No-Close-Button","type":"heading","text":"No Close Button"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Hide the Close button if your Rich Media has custom dismiss logic:"}]},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.TVoS.configureRichMediaWith(","    position: .center,","    presentAnimation: .fromBottom,","    dismissAnimation: .toBottom",")","","Pushwoosh.TVoS.configureCloseButton(false)"]},{"type":"heading","level":2,"anchor":"Custom-Push-Handling","text":"Custom Push Handling"},{"type":"heading","text":"Selective Rich Media Display","anchor":"Selective-Rich-Media-Display","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Display Rich Media only for specific push types:"}]},{"type":"codeListing","syntax":"swift","code":["func application(_ application: UIApplication,","                 didReceiveRemoteNotification userInfo: [AnyHashable: Any],","                 fetchCompletionHandler completionHandler: @escaping (UIBackgroundFetchResult) -> Void) {","","    \/\/ Check if push contains Rich Media","    if let rm = userInfo[\"rm\"] as? [String: Any],","       let url = rm[\"url\"] as? String {","","        \/\/ Check URL or other criteria","        if url.contains(\"special-offer\") {","            \/\/ Display Rich Media","            if Pushwoosh.TVoS.handleTVOSPush(userInfo: userInfo) {","                completionHandler(.newData)","                return","            }","        }","    }","","    \/\/ Handle as regular push","    Pushwoosh.TVoS.handleTvPushReceived(userInfo: userInfo, completionHandler: completionHandler)","}"]},{"level":2,"text":"Registration with Completion Handler","type":"heading","anchor":"Registration-with-Completion-Handler"},{"type":"paragraph","inlineContent":[{"text":"Register with device token and handle success\/failure:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["func application(_ application: UIApplication,","                 didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","    Pushwoosh.TVoS.registerForTvPushNotifications(withToken: deviceToken) { error in","        if let error = error {","            print(\"Failed to register: \\(error.localizedDescription)\")","        } else {","            print(\"Successfully registered for push notifications\")","        }","    }","}"]},{"anchor":"Unregister-from-Push-Notifications","text":"Unregister from Push Notifications","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unregister the device from receiving push notifications:"}]},{"syntax":"swift","type":"codeListing","code":["Pushwoosh.TVoS.unregisterForTvPushNotifications { error in","    if let error = error {","        print(\"Failed to unregister: \\(error.localizedDescription)\")","    } else {","        print(\"Successfully unregistered from push notifications\")","    }","}"]},{"text":"getTags Handler","level":2,"type":"heading","anchor":"getTags-Handler"},{"type":"paragraph","inlineContent":[{"text":"Handle tags retrieved from Rich Media:","type":"text"}]},{"code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    Pushwoosh.TVoS.setAppCode(\"XXXXX-XXXXX\")","","    \/\/ Set getTags handler","    Pushwoosh.TVoS.setRichMediaGetTagsHandler { tags in","        print(\"Received tags from Rich Media:\")","        for (key, value) in tags {","            print(\"  \\(key): \\(value)\")","        }","    }","","    Pushwoosh.TVoS.registerForTvPushNotifications()","","    return true","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"metadata":{"title":"Examples","role":"article","modules":[{"name":"PushwooshTVOS"}],"roleHeading":"Article"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/Examples"},"kind":"article","sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS"]]},"references":{"doc://com.pushwoosh.PushwooshTVOS/documentation/PushwooshTVOS/HTMLGuide":{"abstract":[{"type":"text","text":"Create Rich Media content using Unlayer HTML format for tvOS."}],"url":"\/documentation\/pushwooshtvos\/htmlguide","title":"HTML Guide for tvOS Rich Media","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/HTMLGuide","role":"article","kind":"article"},"doc://com.pushwoosh.PushwooshTVOS/documentation/PushwooshTVOS":{"identifier":"doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS","title":"PushwooshTVOS","url":"\/documentation\/pushwooshtvos","kind":"symbol","abstract":[{"text":"Push notifications and Rich Media for tvOS apps.","type":"text"}],"type":"topic","role":"collection"},"doc://com.pushwoosh.PushwooshTVOS/documentation/PushwooshTVOS/PushwooshTVOSImplementation":{"abstract":[{"type":"text","text":"Main implementation class for tvOS push notifications and Rich Media."}],"navigatorTitle":[{"text":"PushwooshTVOSImplementation","kind":"identifier"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/PushwooshTVOSImplementation","role":"symbol","type":"topic","url":"\/documenta