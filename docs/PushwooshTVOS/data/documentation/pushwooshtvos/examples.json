y]?) -> Bool {","","    Pushwoosh.TVoS.setAppCode(\"XXXXX-XXXXX\")","","    \/\/ Set getTags handler","    Pushwoosh.TVoS.setRichMediaGetTagsHandler { tags in","        print(\"Received tags from Rich Media:\")","        for (key, value) in tags {","            print(\"  \\(key): \\(value)\")","        }","    }","","    Pushwoosh.TVoS.registerForTvPushNotifications()","","    return true","}"],"type":"codeListing"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS"]]},"abstract":[{"type":"text","text":"Code samples demonstrating common tvOS integration scenarios."}],"metadata":{"roleHeading":"Article","title":"Examples","modules":[{"name":"PushwooshTVOS"}],"role":"article"},"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://com.pushwoosh.PushwooshTVOS/documentation/PushwooshTVOS":{"abstract":[{"text":"Push notifications and Rich Media for tvOS apps.","type":"text"}],"kind":"symbol","type":"topic","url":"\/documentation\/pushwooshtvos","title":"PushwooshTVOS","identifier":"doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS","role":"collection"},"doc://com.pushwoosh.PushwooshTVOS/documentation/PushwooshTVOS/GettingStarted":{"abstract":[{"type":"text","text":"Integrate Modal Rich Media for your tvOS app."}],"kind":"article","type":"topic","url":"\/documentation\/pushwooshtvos\/gettingstarted","title":"Getting Started","identifier":"doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/GettingStarted","role":"article"},"doc://com.pushwoosh.PushwooshTVOS/documentation/PushwooshTVOS/HTMLGuide":{"kind":"article","abstract":[{"type":"text","text":"Create Rich Media content using Unlayer HTML format for tvOS."}],"type":"topic","url":"\/documentation\/pushwooshtvos\/htmlguide","title":"HTML Guide for tvOS Rich Media","identifier":"doc:\/\/com.pushwoosh.PushwooshTVOS\/documentation\/PushwooshTVOS\/HTMLGuide","role":"article"},"doc://com.pushwoosh.PushwooshTVOS/documentati