{"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"inlineContent":[{"text":"Modal Rich Media for tvOS provides interactive HTML-based content display optimized for Apple TV’s remote control navigation. Starting from SDK version 6.11.0, you can deliver rich media to tvOS devices.","type":"text"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Important"}],"type":"strong"},{"type":"text","text":": Traditional push notifications are not supported on Apple TV. Only silent notifications with rich media content work on tvOS."}]}],"type":"aside","name":"Note","style":"note"},{"level":2,"anchor":"Installation","text":"Installation","type":"heading"},{"type":"tabNavigator","tabs":[{"content":[{"inlineContent":[{"type":"text","text":"In Xcode, use the following URL to add the Pushwoosh dependency:"}],"type":"paragraph"},{"type":"codeListing","code":["https:\/\/github.com\/Pushwoosh\/Pushwoosh-XCFramework"],"syntax":null},{"type":"paragraph","inlineContent":[{"type":"text","text":"Select the required modules in your target:"}]},{"inlineContent":[],"type":"paragraph"},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Important"}]},{"type":"text","text":": The modules PushwooshFramework, PushwooshCore, PushwooshBridge, and PushwooshTVOS are required."}]}]}],"title":"Swift Package Manager"},{"title":"CocoaPods","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add to your Podfile:"}]},{"syntax":"ruby","type":"codeListing","code":["platform :tvos, '11.0'","use_frameworks!","","target 'YourTVOSApp' do","  pod 'PushwooshXCFramework'","  pod 'PushwooshXCFramework\/PushwooshTVOS'","end"]},{"type":"paragraph","inlineContent":[{"text":"Then run:","type":"text"}]},{"code":["pod install"],"type":"codeListing","syntax":"bash"}]}]},{"anchor":"Prerequisit