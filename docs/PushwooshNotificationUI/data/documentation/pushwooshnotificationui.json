{"sections":[],"kind":"symbol","abstract":[{"text":"A ready-made full-screen “stories” UI for an expanded push notification.","type":"text"}],"hierarchy":{"paths":[[]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"roleHeading":"Framework","role":"collection","externalID":"PushwooshNotificationUI","modules":[{"name":"PushwooshNotificationUI"}],"symbolKind":"module","title":"PushwooshNotificationUI"},"topicSections":[{"title":"Stories UI","identifiers":["doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI\/PushwooshStoriesViewController"]},{"title":"Payload model","identifiers":["doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI\/StoryPage"]},{"identifiers":["doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI\/PushwooshStoriesDelegate"],"title":"Analytics"},{"title":"Media pre-cache","identifiers":["doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI\/PushwooshStoriesMediaPrefetcher"]}],"variants":[{"paths":["\/documentation\/pushwooshnotificationui"],"traits":[{"interfaceLanguage":"swift"}]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshnotificationui"]}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"PushwooshNotificationUI provides "},{"identifier":"doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI\/PushwooshStoriesViewController","isActive":true,"type":"reference"},{"text":" — a drop-in","type":"text"},{"type":"text","text":" "},{"code":"UNNotificationContentExtension","type":"codeVoice"},{"text":" view controller that renders an Instagram-style","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"stories experience: full-bleed images, top progress bars, auto-advance, tap-zone"},{"type":"text","text":" "},{"type":"text","text":"navigation, per-frame title\/subtitle, and an optional deep-link button."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The module links only UIKit, UserNotifications, and UserNotificationsUI (plus"},{"type":"text","text":" "},{"text":"CryptoKit for a stable cache key), so it adds no Pushwoosh Core\/Framework weight","type":"text"},{"type":"text","text":" "},{"text":"to your memory-constrained extension process.","type":"text"}]},{"text":"Usage","anchor":"Usage","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"In your Notification Content Extension:"}]},{"code":["import PushwooshNotificationUI","","class NotificationViewController: PushwooshStoriesViewController {}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then set these keys in the extension’s Info.plist:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"UNNotificationExtensionCategory","type":"codeVoice"},{"text":" = ","type":"text"},{"type":"codeVoice","code":"PW_STORIES"},{"type":"text","text":" (must match "},{"code":"aps.category","type":"codeVoice"},{"text":")","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"UNNotificationExtensionUserInteractionEnabled","type":"codeVoice"},{"text":" = ","type":"text"},{"code":"YES","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNNotificationExtensionDefaultContentHidden"},{"type":"text","text":" = "},{"type":"codeVoice","code":"YES"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNNotificationExtensionInitialContentSizeRatio"},{"type":"text","text":" = e.g. "},{"type":"codeVoice","code":"1.5"},{"type":"text","text":" (keep in sync with "},{"type":"reference","identifier":"doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI\/PushwooshStoriesViewController\/storyAspectRatio","isActive":true},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NSExtensionPrincipalClass"},{"type":"text","text":" = "},{"code":"$(PRODUCT_MODULE_NAME).NotificationViewController","type":"codeVoice"},{"type":"text","text":" (code-only, no storyboard)"}]}]}],"type":"unorderedList"},{"level":2,"type":"heading","text":"Payload","anchor":"Payload"},{"inlineContent":[{"text":"The stories are described by a ","type":"text"},{"code":"pw_stories","type":"codeVoice"},{"text":" block, alongside an ","type":"text"},{"type":"codeVoice","code":"aps.category"},{"text":" ","type":"text"},{"type":"text","text":"matching "},{"type":"codeVoice","code":"UNNotificationExtensionCategory"},{"type":"text","text":". The parser accepts the block either at"},{"type":"text","text":" "},{"text":"the ","type":"text"},{"type":"strong","inlineContent":[{"text":"payload root","type":"text"}]},{"text":" (e.g. via the Pushwoosh API ","type":"text"},{"type":"codeVoice","code":"ios_root_params"},{"text":") or inside the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"custom-data container "},{"type":"codeVoice","code":"u"},{"text":" \/ ","type":"text"},{"code":"userdata","type":"codeVoice"},{"text":" (the Pushwoosh API ","type":"text"},{"type":"codeVoice","code":"data"},{"text":" field — delivered as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a dictionary or a JSON-encoded string). The root form on the device looks like this:"}],"type":"paragraph"},{"code":["{","  \"aps\": { \"category\": \"PW_STORIES\" },","  \"pw_stories\": { \"pages\": [","    { \"image\": \"https:\/\/...\/1.jpg\", \"duration\": 5.0,","      \"link\": \"myapp:\/\/sale\", \"button_title\": \"Buy\",","      \"title\": \"Summer Sale\", \"subtitle\": \"Up to 70% off\" },","    { \"image\": \"https:\/\/...\/2.jpg\" }","  ]}","}"],"type":"codeListing","syntax":"json"},{"type":"paragraph","inlineContent":[{"text":"Sent through the ","type":"text"},{"code":"data","type":"codeVoice"},{"text":" API field instead (recommended, since it does not depend on","type":"text"},{"text":" ","type":"text"},{"code":"ios_root_params","type":"codeVoice"},{"type":"text","text":"), the same block arrives nested under "},{"type":"codeVoice","code":"u"},{"text":" — while ","type":"text"},{"type":"codeVoice","code":"aps.category"},{"text":" ","type":"text"},{"text":"(and ","type":"text"},{"code":"mutable-content","type":"codeVoice"},{"type":"text","text":" for the pre-cache path) still go through "},{"code":"ios_root_params.aps","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"as there is no dedicated request field for them. The relevant createMessage fields:","type":"text"}]},{"type":"codeListing","syntax":"json","code":["{","  \"ios_root_params\": { \"aps\": { \"category\": \"PW_STORIES\", \"mutable-content\": 1 } },","  \"data\": { \"pw_stories\": { \"pages\": [ { \"image\": \"https:\/\/...\/1.jpg\" } ] } }","}"]},{"inlineContent":[{"type":"text","text":"The parser tries the root first, then "},{"code":"u","type":"codeVoice"},{"type":"text","text":" \/ "},{"code":"userdata","type":"codeVoice"},{"text":", so both delivery styles work","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and old pushes keep rendering."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Every field except "},{"type":"codeVoice","code":"image"},{"type":"text","text":" is optional. "},{"code":"link","type":"codeVoice"},{"type":"text","text":" (like "},{"type":"codeVoice","code":"image"},{"text":") must include a URL","type":"text"},{"type":"text","text":" "},{"text":"scheme. A missing, empty, or malformed payload falls back to the default content","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(the alert body) without crashing — override "},{"isActive":true,"identifier":"doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI\/PushwooshStoriesViewController\/showDefaultContent(for:)","type":"reference"},{"type":"text","text":"."}]},{"anchor":"Analytics","text":"Analytics","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Set "},{"isActive":true,"identifier":"doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI\/PushwooshStoriesViewController\/storiesDelegate","type":"reference"},{"text":" to observe lifecycle and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"engagement and forward it to your analytics (the module itself sends nothing):"}]},{"code":["class NotificationViewController: PushwooshStoriesViewController, PushwooshStoriesDelegate {","    override func viewDidLoad() {","        super.viewDidLoad()","        storiesDelegate = self","    }","    func storiesViewController(_ c: PushwooshStoriesViewController, didTapActionFor page: StoryPage, at index: Int) {","        \/\/ forward the per-page click to your backend","    }","}"],"type":"codeListing","syntax":"swift"},{"level":2,"type":"heading","text":"Instant \/ offline first frame (App Group pre-cache)","anchor":"Instant--offline-first-frame-App-Group-pre-cache"},{"type":"paragraph","inlineContent":[{"text":"To make the first frame appear instantly (and offline), pre-download the media in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a Notification "},{"inlineContent":[{"text":"Service","type":"text"}],"type":"strong"},{"text":" Extension into a shared App Group container that the","type":"text"},{"type":"text","text":" "},{"text":"Content Extension reads from:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Enable the ","type":"text"},{"type":"strong","inlineContent":[{"text":"App Groups","type":"text"}]},{"text":" capability (same id) on both the Service and Content","type":"text"},{"type":"text","text":" "},{"type":"text","text":"extensions, and override "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI\/PushwooshStoriesViewController\/appGroupIdentifier"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"From the Service Extension’s "},{"code":"didReceive(_:withContentHandler:)","type":"codeVoice"},{"type":"text","text":", call"},{"type":"text","text":" "},{"identifier":"doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI\/PushwooshStoriesMediaPrefetcher\/prefetch(userInfo:appGroupIdentifier:completion:)","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Send the push with "},{"type":"codeVoice","code":"mutable-content: 1"},{"text":" so the Service Extension runs.","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Without this, the module still works — images download on display instead."}]}]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI","interfaceLanguage":"swift"},"references":{"doc://com.pushwoosh.PushwooshNotificationUI/documentation/PushwooshNotificationUI/PushwooshNotificationUIVersionString":{"title":"PushwooshNotificationUIVersionString","url":"\/documentation\/pushwooshnotificationui\/pushwooshnotificationuiversionstring","role":"symbol","type":"topic","abstract":[{"text":"Project version string for PushwooshNotificationUI.","type":"text"}],"fragments":[{"text":"PushwooshNotificationUIVersionString","kind":"identifier"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI\/PushwooshNotificationUIVersionString","kind":"symbol"},"doc://com.pushwoosh.PushwooshNotificationUI/documentation/PushwooshNotificationUI/PushwooshStoriesViewController/storyAspectRatio":{"title":"storyAspectRatio","fragme