{"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"topicSections":[{"title":"Stories UI","identifiers":["doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI\/PushwooshStoriesViewController"]},{"title":"Payload model","identifiers":["doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI\/StoryPage"]},{"title":"Analytics","identifiers":["doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI\/PushwooshStoriesDelegate"]},{"title":"Media pre-cache","identifiers":["doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI\/PushwooshStoriesMediaPrefetcher"]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI","interfaceLanguage":"swift"},"hierarchy":{"paths":[[]]},"abstract":[{"type":"text","text":"A ready-made full-screen “stories” UI for an expanded push notification."}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"PushwooshNotificationUI provides "},{"identifier":"doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI\/PushwooshStoriesViewController","type":"reference","isActive":true},{"type":"text","text":" — a drop-in"},{"type":"text","text":" "},{"code":"UNNotificationContentExtension","type":"codeVoice"},{"text":" view controller that renders an Instagram-style","type":"text"},{"type":"text","text":" "},{"type":"text","text":"stories experience: full-bleed images, top progress bars, auto-advance, tap-zone"},{"type":"text","text":" "},{"text":"navigation, per-frame title\/subtitle, and an optional deep-link button.","type":"text"}]},{"inlineContent":[{"text":"The module links only UIKit, UserNotifications, and UserNotificationsUI (plus","type":"text"},{"text":" ","type":"text"},{"text":"CryptoKit for a stable cache key), so it adds no Pushwoosh Core\/Framework weight","type":"text"},{"text":" ","type":"text"},{"text":"to your memory-constrained extension process.","type":"text"}],"type":"paragraph"},{"type":"heading","level":2,"text":"Usage","anchor":"Usage"},{"type":"paragraph","inlineContent":[{"text":"In your Notification Content Extension:","type":"text"}]},{"type":"codeListing","code":["import PushwooshNotificationUI","","class NotificationViewController: PushwooshStoriesViewController {}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"Then set these keys in the extension’s Info.plist:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"code":"UNNotificationExtensionCategory","type":"codeVoice"},{"text":" = ","type":"text"},{"type":"codeVoice","code":"PW_STORIES"},{"text":" (must match ","type":"text"},{"code":"aps.category","type":"codeVoice"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNNotificationExtensionUserInteractionEnabled"},{"text":" = ","type":"text"},{"code":"YES","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UNNotificationExtensionDefaultContentHidden","type":"codeVoice"},{"type":"text","text":" = "},{"type":"codeVoice","code":"YES"}]}]},{"content":[{"inlineContent":[{"code":"UNNotificationExtensionInitialContentSizeRatio","type":"codeVoice"},{"type":"text","text":" = e.g. "},{"type":"codeVoice","code":"1.5"},{"type":"text","text":" (keep in sync with "},{"identifier":"doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI\/PushwooshStoriesViewController\/storyAspectRatio","isActive":true,"type":"reference"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"NSExtensionPrincipalClass"},{"type":"text","text":" = "},{"type":"codeVoice","code":"$(PRODUCT_MODULE_NAME).NotificationViewController"},{"text":" (code-only, no storyboard)","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"heading","level":2,"anchor":"Payload","text":"Payload"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The stories are described by a "},{"code":"pw_stories","type":"codeVoice"},{"type":"text","text":" block, alongside an "},{"type":"codeVoice","code":"aps.category"},{"text":" ","type":"text"},{"text":"matching ","type":"text"},{"type":"codeVoice","code":"UNNotificationExtensionCategory"},{"text":". The parser accepts the block either at","type":"text"},{"type":"text","text":" "},{"text":"the ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"payload root"}]},{"type":"text","text":" (e.g. via the Pushwoosh API "},{"type":"codeVoice","code":"ios_root_params"},{"type":"text","text":") or inside the"},{"text":" ","type":"text"},{"text":"custom-data container ","type":"text"},{"type":"codeVoice","code":"u"},{"text":" \/ ","type":"text"},{"type":"codeVoice","code":"userdata"},{"type":"text","text":" (the Pushwoosh API "},{"code":"data","type":"codeVoice"},{"type":"text","text":" field — delivered as"},{"type":"text","text":" "},{"type":"text","text":"a dictionary or a JSON-encoded string). The root form on the device looks like this:"}]},{"syntax":"json","code":["{","  \"aps\": { \"category\": \"PW_STORIES\" },","  \"pw_stories\": { \"pages\": [","    { \"image\": \"https:\/\/...\/1.jpg\", \"duration\": 5.0,","      \"link\": \"myapp:\/\/sale\", \"button_title\": \"Buy\",","      \"title\": \"Summer Sale\", \"subtitle\": \"Up to 70% off\" },","    { \"image\": \"https:\/\/...\/2.jpg\" }","  ]}","}"],"type":"codeListing"},{"inlineContent":[{"text":"Sent through the ","type":"text"},{"type":"codeVoice","code":"data"},{"type":"text","text":" API field instead (recommended, since it does not depend on"},{"text":" ","type":"text"},{"code":"ios_root_params","type":"codeVoice"},{"type":"text","text":"), the same block arrives nested under "},{"code":"u","type":"codeVoice"},{"text":" — while ","type":"text"},{"code":"aps.category","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"(and "},{"type":"codeVoice","code":"mutable-content"},{"text":" for the pre-cache path) still go through ","type":"text"},{"type":"codeVoice","code":"ios_root_params.aps"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"as there is no dedicated request field for them. The relevant createMessage fields:"}],"type":"paragraph"},{"code":["{","  \"ios_root_params\": { \"aps\": { \"category\": \"PW_STORIES\", \"mutable-content\": 1 } },","  \"data\": { \"pw_stories\": { \"pages\": [ { \"image\": \"https:\/\/...\/1.jpg\" } ] } }","}"],"type":"codeListing","syntax":"json"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The parser tries the root first, then "},{"type":"codeVoice","code":"u"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"userdata"},{"text":", so both delivery styles work","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and old pushes keep rendering."}]},{"inlineContent":[{"text":"Every field except ","type":"text"},{"type":"codeVoice","code":"image"},{"type":"text","text":" is optional. "},{"type":"codeVoice","code":"link"},{"text":" (like ","type":"text"},{"code":"image","type":"codeVoice"},{"text":") must include a URL","type":"text"},{"type":"text","text":" "},{"type":"text","text":"scheme. A missing, empty, or malformed payload falls back to the default content"},{"type":"text","text":" "},{"text":"(the alert body) without crashing — override ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI\/PushwooshStoriesViewController\/showDefaultContent(for:)","type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"Analytics","anchor":"Analytics"},{"inlineContent":[{"text":"Set ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI\/PushwooshStoriesViewController\/storiesDelegate"},{"type":"text","text":" to observe lifecycle and"},{"type":"text","text":" "},{"type":"text","text":"engagement and forward it to your analytics (the module itself sends nothing):"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class NotificationViewController: PushwooshStoriesViewController, PushwooshStoriesDelegate {","    override func viewDidLoad() {","        super.viewDidLoad()","        storiesDelegate = self","    }","    func storiesViewController(_ c: PushwooshStoriesViewController, didTapActionFor page: StoryPage, at index: Int) {","        \/\/ forward the per-page click to your backend","    }","}"]},{"anchor":"Instant--offline-first-frame-App-Group-pre-cache","level":2,"text":"Instant \/ offline first frame (App Group pre-cache)","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To make the first frame appear instantly (and offline), pre-download the media in"},{"type":"text","text":" "},{"text":"a Notification ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Service"}]},{"type":"text","text":" Extension into a shared App Group container that the"},{"type":"text","text":" "},{"text":"Content Extension reads from:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Enable the "},{"type":"strong","inlineContent":[{"type":"text","text":"App Groups"}]},{"text":" capability (same id) on both the Service and Content","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"extensions, and override "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI\/PushwooshStoriesViewController\/appGroupIdentifier"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"From the Service Extension’s "},{"type":"codeVoice","code":"didReceive(_:withContentHandler:)"},{"type":"text","text":", call"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI\/PushwooshStoriesMediaPrefetcher\/prefetch(userInfo:appGroupIdentifier:completion:)","isActive":true},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Send the push with "},{"code":"mutable-content: 1","type":"codeVoice"},{"type":"text","text":" so the Service Extension runs."}]}]}],"type":"orderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Without this, the module still works — images download on display instead."}]}]}],"metadata":{"modules":[{"name":"PushwooshNotificationUI"}],"role":"collection","externalID":"PushwooshNotificationUI","roleHeading":"Framework","symbolKind":"module","title":"PushwooshNotificationUI"},"variants":[{"paths":["\/documentation\/pushwooshnotificationui"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/pushwooshnotificationui"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshNotificationUI/documentation/PushwooshNotificationUI/PushwooshStoriesDelegate":{"title":"PushwooshStoriesDelegate","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PushwooshStoriesDelegate","kind":"identifier"}],"type":"topic","abstract":[{"type":"text","text":"Optional analytics \/ lifecycle hooks for "},{"type":"reference","identifier":"doc:\/\/com.pushwoosh.PushwooshNotificationUI\/documentation\/PushwooshNotificationUI\/PushwooshStoriesViewController","isActive":true},{"type":"text","text":"."}],"kind":"symbol","url":"\/documentation\/pushwooshnotificationui\/pushwooshstoriesdelegate","navigatorTitle":[{"text":"PushwooshStoriesDelegate","kind":"identifier"}],"identifier":"doc:\/\/com.pushwoosh.Pushwoos