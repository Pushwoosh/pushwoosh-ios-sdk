{"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Starting from version 6.10.0, PushwooshForegroundPush enables customization of foreground push notifications when native iOS system alerts are disabled. This module creates animated push banners that appear at the top of your app with rich visual effects, haptic feedback, and interactive capabilities.","type":"text"}]},{"inlineContent":[{"text":"The module offers extensive customization options including gradient backgrounds, custom colors and fonts, multiple animation styles, and modern iOS 26+ Liquid Glass effects.","type":"text"}],"type":"paragraph"}]}],"topicSections":[{"title":"Getting Started","identifiers":["doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/GettingStarted","doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/Examples"]},{"identifiers":["doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/ForegroundPushConfiguration","doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/PushwooshForegroundPushImplementation"],"title":"Classes"},{"title":"Protocols","identifiers":["doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/PWForegroundPushDelegate"]},{"title":"Extended Modules","identifiers":["doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/PushwooshBridge"]}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[[]]},"kind":"symbol","variants":[{"paths":["\/documentation\/pushwooshforegroundpush"],"traits":[{"interfaceLanguage":"swift"}]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshforegroundpush"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/Pus