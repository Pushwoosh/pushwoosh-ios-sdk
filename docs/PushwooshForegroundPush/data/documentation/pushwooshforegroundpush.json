{"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Starting from version 6.10.0, PushwooshForegroundPush enables customization of foreground push notifications when native iOS system alerts are disabled. This module creates animated push banners that appear at the top of your app with rich visual effects, haptic feedback, and interactive capabilities."}],"type":"paragraph"},{"inlineContent":[{"text":"The module offers extensive customization options including gradient backgrounds, custom colors and fonts, multiple animation styles, and modern iOS 26+ Liquid Glass effects.","type":"text"}],"type":"paragraph"}]}],"abstract":[{"type":"text","text":"Customizable foreground push notifications for iOS applications."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/pushwooshforegroundpush"]},{"paths":["\/documentation\/pushwooshforegroundpush"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush","interfaceLanguage":"swift"},"metadata":{"role":"collection","modules":[{"name":"PushwooshForegroundPush"}],"title":"PushwooshForegroundPush","externalID":"PushwooshForegroundPush","symbolKind":"module","roleHeading":"Framework"},"kind":"symbol","hierarchy":{"paths":[[]]},"sections":[],"topicSections":[{"title":"Getting Started","identifiers":["doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/GettingStarted","doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/Examples"]},{"title":"Classes","identifiers":["doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/ForegroundPushConfiguration","doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/PushwooshForegrou