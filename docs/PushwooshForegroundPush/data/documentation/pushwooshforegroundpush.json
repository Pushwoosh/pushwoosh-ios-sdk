{"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"inlineContent":[{"type":"text","text":"Starting from version 6.10.0, PushwooshForegroundPush enables customization of foreground push notifications when native iOS system alerts are disabled. This module creates animated push banners that appear at the top of your app with rich visual effects, haptic feedback, and interactive capabilities."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The module offers extensive customization options including gradient backgrounds, custom colors and fonts, multiple animation styles, and modern iOS 26+ Liquid Glass effects."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"role":"collection","symbolKind":"module","title":"PushwooshForegroundPush","modules":[{"name":"PushwooshForegroundPush"}],"roleHeading":"Framework","externalID":"PushwooshForegroundPush"},"abstract":[{"text":"Customizable foreground push notifications for iOS applications.","type":"text"}],"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/GettingStarted","doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/Examples"],"title":"Getting Started"},{"title":"Classes","identifiers":["doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/ForegroundPushConfiguration","doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/PushwooshForegroundPushImplementation"]},{"identifiers":["doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/PWForegroundPushDelegate"],"title":"Protocols"},{"title":"Extended Modules","identifiers":["doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/PushwooshBridge"]}],"sections":[],"identifier":{"interfaceLanguage":"swift