{"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"Overview","level":2,"type":"heading"},{"inlineContent":[{"text":"This guide provides working code examples for customizing PushwooshForegroundPush appearance, animations, and user interactions.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Basic-Setup","text":"Basic Setup","type":"heading"},{"text":"Minimal Configuration","anchor":"Minimal-Configuration","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The simplest configuration with default appearance:"}]},{"type":"codeListing","syntax":"swift","code":["import UIKit","import PushwooshFramework","import PushwooshForegroundPush","","@main","class AppDelegate: UIResponder, UIApplicationDelegate, PWForegroundPushDelegate {","","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","","        Pushwoosh.ForegroundPush.foregroundNotificationWith(","            style: .style1,","            duration: 5,","            vibration: .notification,","            disappearedPushAnimation: .balls","        )","","        Pushwoosh.ForegroundPush.delegate = self","","        return true","    }","","    func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","        print(\"Foreground custom push: \\(userInfo)\")","    }","}"]},{"text":"Appearance Customization","level":2,"type":"heading","anchor":"Appearance-Customization"},{"level":3,"anchor":"Custom-Gradient-Background","type":"heading","text":"Custom Gradient Background"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a vibrant gradient background with custom text colors:"}]},{"type":"codeListing","code":["Pushwoosh.ForegroundPush.gradientColors = [.red, .orange, .yellow]","Pushwoosh.ForegroundPush.titlePushColor = .white","Pushwoosh.ForegroundPush.messagePushColor = .white"],"syntax":"swift"},{"inlineContent":[{"identifier":"ios-foreground-custom-3.gif","type":"image"}],"type":"paragraph"},{"text":"Solid Background Color","anchor":"Solid-Background-Color","level":3,"type":"heading"},{"inlineContent":[{"text":"Use a solid color instead of gradient:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["Pushwoosh.ForegroundPush.backgroundColor = UIColor(red: 0.1, green: 0.1, blue: 0.1, alpha: 0.95)","Pushwoosh.ForegroundPush.gradientColors = nil"],"type":"codeListing"},{"anchor":"Custom-Fonts","level":3,"text":"Custom Fonts","type":"heading"},{"inlineContent":[{"text":"Use custom fonts for title and message:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["Pushwoosh.ForegroundPush.backgroundColor = .systemPurple","Pushwoosh.ForegroundPush.titlePushFont = UIFont(name: \"YourCustomFont-Bold\", size: 18)","Pushwoosh.ForegroundPush.messagePushFont = UIFont(name: \"YourCustomFont-Regular\", size: 15)","Pushwoosh.ForegroundPush.titlePushColor = .white","Pushwoosh.ForegroundPush.messagePushColor = .white"]},{"type":"paragraph","inlineContent":[{"identifier":"ios-foreground-custom-4.gif","type":"image"}]},{"anchor":"Rich-Media-Support","type":"heading","level":2,"text":"Rich Media Support"},{"type":"heading","text":"Push with Image Attachment","level":3,"anchor":"Push-with-Image-Attachment"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Foreground push notifications support image attachments:"}]},{"type":"paragraph","inlineContent":[{"identifier":"ios-foreground-custom-2.gif","type":"image"}]},{"level":3,"type":"heading","anchor":"Push-with-GIF-Attachment","text":"Push with GIF Attachment"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Animated GIF images are supported:"}]},{"type":"paragraph","inlineContent":[{"identifier":"ios-foreground-custom-1.gif","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The attachment URL is specified in the push notification payload. The SDK automatically downloads and displays the media content."}]},{"type":"heading","anchor":"Animation-Customization","level":2,"text":"Animation Customization"},{"type":"heading","level":3,"text":"Disable Entry Animation","anchor":"Disable-Entry-Animation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Show push instantly without slide animation:"}]},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.ForegroundPush.usePushAnimation = false"]},{"type":"paragraph","inlineContent":[{"identifier":"ios-foreground-custom-4.gif","type":"image"}]},{"level":3,"type":"heading","text":"Particle Explosion Effect","anchor":"Particle-Explosion-Effect"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use particle explosion when push disappears:"}]},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .balls",")"]},{"type":"heading","text":"Regular Push Animation","anchor":"Regular-Push-Animation","level":3},{"type":"paragraph","inlineContent":[{"text":"Use standard upward slide animation:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .regularPush",")"]},{"level":3,"text":"Liquid Glass Effect (iOS 26+)","type":"heading","anchor":"Liquid-Glass-Effect-iOS-26+"},{"inlineContent":[{"type":"text","text":"Enable modern Liquid Glass visual effect:"}],"type":"paragraph"},{"type":"codeListing","code":["Pushwoosh.ForegroundPush.useLiquidView = true"],"syntax":"swift"},{"inlineContent":[{"identifier":"ios-foreground-custom-5.gif","type":"image"}],"type":"paragraph"},{"type":"aside","name":"Note","content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Important"}],"type":"strong"},{"type":"text","text":": Liquid Glass requires iOS 26+ and Swift 5.13+. On earlier iOS versions, standard UIView-based notifications are displayed. Swift versions below 5.13 use blurred UIVisualEffectView."}],"type":"paragraph"}],"style":"note"},{"level":2,"type":"heading","anchor":"Haptic-Feedback-Options","text":"Haptic Feedback Options"},{"text":"No Vibration","anchor":"No-Vibration","type":"heading","level":3},{"inlineContent":[{"text":"For silent notifications:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .none,","    disappearedPushAnimation: .balls",")"],"type":"codeListing"},{"text":"Strong Haptic","level":3,"anchor":"Strong-Haptic","type":"heading"},{"inlineContent":[{"text":"For important notifications:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 7,","    vibration: .heavy,","    disappearedPushAnimation: .balls",")"]},{"anchor":"System-Notification-Haptic","type":"heading","level":3,"text":"System Notification Haptic"},{"inlineContent":[{"type":"text","text":"Use system notification-style haptic:"}],"type":"paragraph"},{"code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .balls",")"],"syntax":"swift","type":"codeListing"},{"type":"heading","level":2,"anchor":"Handling-User-Interactions","text":"Handling User Interactions"},{"level":3,"type":"heading","text":"Implementing Delegate","anchor":"Implementing-Delegate"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle user taps through the delegate method:"}]},{"type":"codeListing","syntax":"swift","code":["class AppDelegate: UIResponder, UIApplicationDelegate, PWForegroundPushDelegate {","","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","        Pushwoosh.ForegroundPush.delegate = self","        return true","    }","","    func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","        print(\"Foreground custom push tapped: \\(userInfo)\")","","        if let customData = userInfo[\"custom\"] as? [String: Any],","           let screenId = customData[\"screen_id\"] as? String {","            navigateToScreen(screenId)","        }","    }","}"]},{"type":"heading","text":"Deep Link Handling","level":3,"anchor":"Deep-Link-Handling"},{"type":"paragraph","inlineContent":[{"text":"Handle deep links from push notifications:","type":"text"}]},{"syntax":"swift","code":["func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","    if let deepLink = userInfo[\"deep_link\"] as? String,","       let url = URL(string: deepLink) {","        UIApplication.shared.open(url, options: [:]) { success in","            print(\"Deep link opened: \\(success)\")","        }","    }","}"],"type":"codeListing"},{"anchor":"Complete-Custom-Setup","text":"Complete Custom Setup","type":"heading","level":2},{"type":"heading","level":3,"anchor":"Branded-Notification","text":"Branded Notification"},{"inlineContent":[{"text":"Full customization with brand identity:","type":"text"}],"type":"paragraph"},{"code":["func configureBrandedForegroundPush() {","    Pushwoosh.ForegroundPush.gradientColors = [","        UIColor(red: 0.18, green: 0.31, blue: 0.64, alpha: 1.0),","        UIColor(red: 0.44, green: 0.26, blue: 0.63, alpha: 1.0)","    ]","","    Pushwoosh.ForegroundPush.titlePushColor = .white","    Pushwoosh.ForegroundPush.messagePushColor = UIColor(white: 0.95, alpha: 1.0)","","    Pushwoosh.ForegroundPush.titlePushFont = UIFont(name: \"Helvetica-Bold\", size: 18)","    Pushwoosh.ForegroundPush.messagePushFont = UIFont(name: \"Helvetica\", size: 15)","","    Pushwoosh.ForegroundPush.usePushAnimation = true","    Pushwoosh.ForegroundPush.useLiquidView = true","","    Pushwoosh.ForegroundPush.foregroundNotificationWith(","        style: .style1,","        duration: 6,","        vibration: .notification,","        disappearedPushAnimation: .balls","    )","","    Pushwoosh.ForegroundPush.delegate = self","}"],"type":"codeListing","syntax":"swift"},{"text":"Dark Mode Support","level":2,"type":"heading","anchor":"Dark-Mode-Support"},{"level":3,"text":"Adaptive Colors","anchor":"Adaptive-Colors","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Adjust colors based on user interface style:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["func configureForegroundPushColors() {","    if #available(iOS 13.0, *) {","        let isDarkMode = UITraitCollection.current.userInterfaceStyle == .dark","","        if isDarkMode {","            Pushwoosh.ForegroundPush.gradientColors = [","                UIColor(red: 0.15, green: 0.15, blue: 0.15, alpha: 1.0),","                UIColor(red: 0.25, green: 0.25, blue: 0.25, alpha: 1.0)","            ]","            Pushwoosh.ForegroundPush.titlePushColor = .white","            Pushwoosh.ForegroundPush.messagePushColor = UIColor(white: 0.85, alpha: 1.0)","        } else {","            Pushwoosh.ForegroundPush.gradientColors = [","                UIColor(red: 0.95, green: 0.95, blue: 0.95, alpha: 1.0),","                UIColor(red: 0.85, green: 0.85, blue: 0.85, alpha: 1.0)","            ]","            Pushwoosh.ForegroundPush.titlePushColor = .black","            Pushwoosh.ForegroundPush.messagePushColor = UIColor(white: 0.15, alpha: 1.0)","        }","    }","}"]},{"level":2,"anchor":"Next-Steps","text":"Next Steps","type":"heading"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/GettingStarted","isActive":true},{"type":"text","text":" - Quick start guide"}],"type":"paragraph"}]},{"