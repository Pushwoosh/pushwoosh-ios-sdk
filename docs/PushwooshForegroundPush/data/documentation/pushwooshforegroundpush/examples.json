= true"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"identifier":"ios-foreground-custom-5.gif","type":"image"}],"type":"paragraph"},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Important"}]},{"text":": Liquid Glass requires iOS 26+ and Swift 5.13+. On earlier iOS versions, standard UIView-based notifications are displayed. Swift versions below 5.13 use blurred UIVisualEffectView.","type":"text"}]}],"name":"Note"},{"text":"Haptic Feedback Options","type":"heading","level":2,"anchor":"Haptic-Feedback-Options"},{"level":3,"text":"No Vibration","anchor":"No-Vibration","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"For silent notifications:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .none,","    disappearedPushAnimation: .balls",")"]},{"level":3,"text":"Strong Haptic","anchor":"Strong-Haptic","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"For important notifications:","type":"text"}]},{"code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 7,","    vibration: .heavy,","    disappearedPushAnimation: .balls",")"],"syntax":"swift","type":"codeListing"},{"anchor":"System-Notification-Haptic","type":"heading","text":"System Notification Haptic","level":3},{"inlineContent":[{"type":"text","text":"Use system notification-style haptic:"}],"type":"paragraph"},{"syntax":"swift","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .balls",")"],"type":"codeListing"},{"text":"Handling User Interactions","type":"heading","anchor":"Handling-User-Interactions","level":2},{"text":"Implementing Delegate","type":"heading","level":3,"anchor":"Implementing-Delegate"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle user taps through the delegate method:"}]},{"type":"codeListing","syntax":"swift","code":["class AppDelegate: UIResponder, UIApplicationDelegate, PWForegroundPushDelegate {","","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","        Pushwoosh.ForegroundPush.delegate = self","        return true","    }","","    func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","        print(\"Foreground custom push tapped: \\(userInfo)\")","","        if let customData = userInfo[\"custom\"] as? [String: Any],","           let screenId = customData[\"screen_id\"] as? String {","            navigateToScreen(screenId)","        }","    }","}"]},{"type":"heading","level":3,"text":"Deep Link Handling","anchor":"Deep-Link-Handling"},{"type":"paragraph","inlineContent":[{"text":"Handle deep links from push notifications:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","    if let deepLink = userInfo[\"deep_link\"] as? String,","       let url = URL(string: deepLink) {","        UIApplication.shared.open(url, options: [:]) { success in","            print(\"Deep link opened: \\(success)\")","        }","    }","}"]},{"type":"heading","text":"Complete Custom Setup","level":2,"anchor":"Complete-Custom-Setup"},{"type":"heading","level":3,"text":"Branded Notification","anchor":"Branded-Notification"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Full customization with brand identity:"}]},{"code":["func configureBrandedForegroundPush() {","    Pushwoosh.ForegroundPush.gradientColors = [","        UIColor(red: 0.18, green: 0.31, blue: 0.64, alpha: 1.0),","        UIColor(red: 0.44, green: 0.26, blue: 0.63, alpha: 1.0)","    ]","","    Pushwoosh.ForegroundPush.titlePushColor = .white","    Pushwoosh.ForegroundPush.messagePushColor = UIColor(white: 0.95, alpha: 1.0)","","    Pushwoosh.ForegroundPush.titlePushFont = UIFont(name: \"Helvetica-Bold\", size: 18)","    Pushwoosh.ForegroundPush.messagePushFont = UIFont(name: \"Helvetica\", size: 15)","","    Pushwoosh.ForegroundPush.usePushAnimation = true","    Pushwoosh.ForegroundPush.useLiquidView = true","","    Pushwoosh.ForegroundPush.foregroundNotificationWith(","        style: .style1,","        duration: 6,","        vibration: .notification,","        disappearedPushAnimation: .balls","    )","","    Pushwoosh.ForegroundPush.delegate = self","}"],"type":"codeListing","syntax":"swift"},{"text":"Dark Mode Support","level":2,"anchor":"Dark-Mode-Support","type":"heading"},{"text":"Adaptive Colors","type":"heading","level":3,"anchor":"Adaptive-Colors"},{"inlineContent":[{"type":"text","text":"Adjust colors based on user interface style:"}],"type":"paragraph"},{"syntax":"swift","code":["func configureForegroundPushColors() {","    if #available(iOS 13.0, *) {","        let isDarkMode = UITraitCollection.current.userInterfaceStyle == .dark","","        if isDarkMode {","            Pushwoosh.ForegroundPush.gradientColors = [","                UIColor(red: 0.15, green: 0.15, blue: 0.15, alpha: 1.0),","                UIColor(red: 0.25, green: 0.25, blue: 0.25, alpha: 1.0)","            ]","            Pushwoosh.ForegroundPush.titlePushColor = .white","            Pushwoosh.ForegroundPush.messagePushColor = UIColor(white: 0.85, alpha: 1.0)","        } else {","            Pushwoosh.ForegroundPush.gradientColors = [","                UIColor(red: 0.95, green: 0.95, blue: 0.95, alpha: 1.0),","                UIColor(red: 0.85, green: 0.85, blue: 0.85, alpha: 1.0)","            ]","            Pushwoosh.ForegroundPush.titlePushColor = .black","            Pushwoosh.ForegroundPush.messagePushColor = UIColor(white: 0.15, alpha: 1.0)","        }","    }","}"],"type":"codeListing"},{"anchor":"Next-Steps","text":"Next Steps"