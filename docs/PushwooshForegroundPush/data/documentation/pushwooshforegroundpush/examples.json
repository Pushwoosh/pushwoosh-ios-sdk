{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/Examples","interfaceLanguage":"swift"},"kind":"article","abstract":[{"type":"text","text":"Practical examples for common foreground push notification scenarios."}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"metadata":{"modules":[{"name":"PushwooshForegroundPush"}],"title":"Code Examples","roleHeading":"Article","role":"article"},"seeAlsoSections":[{"generated":true,"title":"Getting Started","identifiers":["doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/GettingStarted"]}],"primaryContentSections":[{"content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This guide provides working code examples for customizing PushwooshForegroundPush appearance, animations, and user interactions."}]},{"text":"Basic Setup","type":"heading","anchor":"Basic-Setup","level":2},{"text":"Minimal Configuration","level":3,"type":"heading","anchor":"Minimal-Configuration"},{"inlineContent":[{"text":"The simplest configuration with default appearance:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["import UIKit","import PushwooshFramework","import PushwooshForegroundPush","","@main","class AppDelegate: UIResponder, UIApplicationDelegate, PWForegroundPushDelegate {","","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","","        Pushwoosh.ForegroundPush.foregroundNotificationWith(","            style: .style1,","            duration: 5,","            vibration: .notification,","            disappearedPushAnimation: .balls","        )","","        Pushwoosh.ForegroundPush.delegate = self","","        return true","    }","","    func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","        print(\"Foreground custom push: \\(userInfo)\")","    }","}"]},{"level":2,"text":"Appearance Customization","anchor":"Appearance-Customization","type":"heading"},{"anchor":"Custom-Gradient-Background","level":3,"text":"Custom Gradient Background","type":"heading"},{"inlineContent":[{"text":"Create a vibrant gradient background with custom text colors:","type":"text"}],"type":"paragraph"},{"code":["Pushwoosh.ForegroundPush.gradientColors = [.red, .orange, .yellow]","Pushwoosh.ForegroundPush.titlePushColor = .white","Pushwoosh.ForegroundPush.messagePushColor = .white"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"image","identifier":"ios-foreground-custom-3.gif"}],"type":"paragraph"},{"anchor":"Solid-Background-Color","type":"heading","level":3,"text":"Solid Background Color"},{"inlineContent":[{"type":"text","text":"Use a solid color instead of gradient:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["Pushwoosh.ForegroundPush.backgroundColor = UIColor(red: 0.1, green: 0.1, blue: 0.1, alpha: 0.95)","Pushwoosh.ForegroundPush.gradientColors = nil"]},{"text":"Custom Fonts","type":"heading","level":3,"anchor":"Custom-Fonts"},{"inlineContent":[{"text":"Use custom fonts for title and message:","type":"text"}],"type":"paragraph"},{"code":["Pushwoosh.ForegroundPush.backgroundColor = .systemPurple","Pushwoosh.ForegroundPush.titlePushFont = UIFont(name: \"YourCustomFont-Bold\", size: 18)","Pushwoosh.ForegroundPush.messagePushFont = UIFont(name: \"YourCustomFont-Regular\", size: 15)","Pushwoosh.ForegroundPush.titlePushColor = .white","Pushwoosh.ForegroundPush.messagePushColor = .white"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"ios-foreground-custom-4.gif"}]},{"text":"Rich Media Support","level":2,"anchor":"Rich-Media-Support","type":"heading"},{"anchor":"Push-with-Image-Attachment","type":"heading","level":3,"text":"Push with Image Attachment"},{"inlineContent":[{"type":"text","text":"Foreground push notifications support image attachments:"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"identifier":"ios-foreground-custom-2.gif","type":"image"}]},{"text":"Push with GIF Attachment","level":3,"anchor":"Push-with-GIF-Attachment","type":"heading"},{"inlineContent":[{"type":"text","text":"Animated GIF images are supported:"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"ios-foreground-custom-1.gif"}]},{"inlineContent":[{"text":"The attachment URL is specified in the push notification payload. The SDK automatically downloads and displays the media content.","type":"text"}],"type":"paragraph"},{"text":"Animation Customization","level":2,"anchor":"Animation-Customization","type":"heading"},{"anchor":"Disable-Entry-Animation","text":"Disable Entry Animation","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Show push instantly without slide animation:","type":"text"}]},{"syntax":"swift","code":["Pushwoosh.ForegroundPush.usePushAnimation = false"],"type":"codeListing"},{"inlineContent":[{"identifier":"ios-foreground-custom-4.gif","type":"image"}],"type":"paragraph"},{"level":3,"text":"Particle Explosion Effect","anchor":"Particle-Explosion-Effect","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Use particle explosion when push disappears:","type":"text"}]},{"syntax":"swift","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .balls",")"],"type":"codeListing"},{"anchor":"Regular-Push-Animation","text":"Regular Push Animation","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Use standard upward slide animation:","type":"text"}]},{"type":"codeListing","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .regularPush",")"],"syntax":"swift"},{"type":"heading","text":"Liquid Glass Effect (iOS 26+)","anchor":"Liquid-Glass-Effect-iOS-26+","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Enable modern Liquid Glass visual effect:"}]},{"syntax":"swift","code":["Pushwoosh.ForegroundPush.useLiquidView = true"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"identifier":"ios-foreground-custom-5.gif","type":"image"}]},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Important","type":"text"}]},{"text":": Liquid Glass requires iOS 26+ and Swift 5.13+. On earlier iOS versions, standard UIView-based notifications are displayed. Swift versions below 5.13 use blurred UIVisualEffectView.","type":"text"}]}],"type":"aside"},{"level":2,"type":"heading","anchor":"Haptic-Feedback-Options","text":"Haptic Feedback Options"},{"level":3,"anchor":"No-Vibration","text":"No Vibration","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"For silent notifications:","type":"text"}]},{"syntax":"swift","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .none,","    disappearedPushAnimation: .balls",")"],"type":"codeListing"},{"text":"Strong Haptic","type":"heading","level":3,"anchor":"Strong-Haptic"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For important notifications:"}]},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 7,","    vibration: .heavy,","    disappearedPushAnimation: .balls",")"]},{"anchor":"System-Notification-Haptic","type":"heading","level":3,"text":"System Notification Haptic"},{"type":"paragraph","inlineContent":[{"text":"Use system notification-style haptic:","type":"text"}]},{"syntax":"swift","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .balls",")"],"type":"codeListing"},{"level":2,"text":"Handling User Interactions","type":"heading","anchor":"Handling-User-Interactions"},{"anchor":"Implementing-Delegate","level":3,"type":"heading","text":"Implementing Delegate"},{"inlineContent":[{"type":"text","text":"Handle user taps through the delegate method:"}],"type":"paragraph"},{"syntax":"swift","code":["class AppDelegate: UIResponder, UIApplicationDelegate, PWForegroundPushDelegate {","","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","        Pushwoosh.ForegroundPush.delegate = self","        return true","    }","","    func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","        print(\"Foreground custom push tapped: \\(userInfo)\")","","        if let customData = userInfo[\"custom\"] as? [String: Any],","           let screenId = customData[\"screen_id\"] as? String {","            navigateToScreen(screenId)","        }","    }","}"],"type":"codeListing"},{"level":3,"anchor":"Deep-Link-Handling","text":"Deep Link Handling","type":"heading"},{"inlineContent":[{"text":"Handle deep links from push notifications:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","    if let deepLink = userInfo[\"deep_link\"] as? String,","       let url = URL(string: deepLink) {","        UIApplication.shared.open(url, options: [:]) { success in","            print(\"Deep link opened: \\(success)\")","        }","    }","}"]},{"anchor":"Complete-Custom-Setup","level":2,"type":"heading","text":"Complete Custom Setup"},{"level":3,"type":"heading","anchor":"Branded-Notification","text":"Branded Notification"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Full customization with brand identity:"}]},{"syntax":"swift","type":"codeListing","code":["func configureBrandedForegroundPush() {","    Pushwoosh.ForegroundPush.gradientColors = [","        UIColor(red: 0.18, green: 0.31, blue: 0.64, alpha: 1.0),","        UIColor(red: 0.44, green: 0.26, blue: 0.63, alpha: 1.0)","    ]","","    Pushwoosh.ForegroundPush.titlePushColor = .white","    Pushwoosh.ForegroundPush.messagePushColor = UIColor(white: 0.95, alpha: 1.0)","","    Pushwoosh.ForegroundPush.titlePushFont = UIFont(name: \"Helvetica-Bold\", size: 18)","    Pushwoosh.ForegroundPush.messagePushFont = UIFont(name: \"Helvetica\", size: 15)","","    Pushwoosh.ForegroundPush.usePushAnimation = true","    Pushwoosh.ForegroundPush.useLiquidView = true","","    Pushwoosh.ForegroundPush.foregroundNotificationWith(","        style: .style1,","        duration: 6,","        vibration: .notification,","        disappearedPushAnimation: .balls","    )","","    Pushwoosh.ForegroundPush.delegate = self","}"]},{"level":2,"anchor":"Dark-Mode-Support","text":"Dark Mode Support","type":"heading"},{"type":"heading","text":"Adaptive Colors","level":3,"anchor":"Adaptive-Colors"},{"inlineContent":[{"type":"text","text":"Adjust colors based on user interface style:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["func configureForegroundPushColors() {","    if #available(iOS 13.0, *) {","        let isDarkMode = UITraitCollection.current.userInterfaceStyle == .dark","","        if isDarkMode {","            Pushwoosh.ForegroundPush.gradientColors = [","                UIColor(red: 0.15, green: 0.15, blue: 0.15, alpha: 1.0),","                UIColor(red: 0.25, green: 0.25, blue: 0.25, alpha: 1.0)","            ]","            Pushwoosh.ForegroundPush.titlePushColor = .white","            Pushwoosh.ForegroundPush.messagePushColor = UIColor(white: 0.85, alpha: 1.0)","        } else {","            Pushwoos