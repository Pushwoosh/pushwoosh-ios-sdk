":"paragraph"},{"type":"aside","content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Important"}]},{"type":"text","text":": Liquid Glass requires iOS 26+ and Swift 5.13+. On earlier iOS versions, standard UIView-based notifications are displayed. Swift versions below 5.13 use blurred UIVisualEffectView."}],"type":"paragraph"}],"name":"Note","style":"note"},{"anchor":"Haptic-Feedback-Options","level":2,"text":"Haptic Feedback Options","type":"heading"},{"text":"No Vibration","type":"heading","level":3,"anchor":"No-Vibration"},{"inlineContent":[{"text":"For silent notifications:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .none,","    disappearedPushAnimation: .balls",")"]},{"anchor":"Strong-Haptic","type":"heading","text":"Strong Haptic","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"For important notifications:"}]},{"type":"codeListing","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 7,","    vibration: .heavy,","    disappearedPushAnimation: .balls",")"],"syntax":"swift"},{"type":"heading","anchor":"System-Notification-Haptic","level":3,"text":"System Notification Haptic"},{"inlineContent":[{"type":"text","text":"Use system notification-style haptic:"}],"type":"paragraph"},{"code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .balls",")"],"syntax":"swift","type":"codeListing"},{"level":2,"text":"Handling User Interactions","type":"heading","anchor":"Handling-User-Interactions"},{"type":"heading","level":3,"anchor":"Implementing-Delegate","text":"Implementing Delegate"},{"inlineContent":[{"type":"text","text":"Handle user taps through the delegate method:"}],"type":"paragraph"},{"code":["class AppDelegate: UIResponder, UIApplicationDelegate, PWForegroundPushDelegate {","","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","        Pushwoosh.ForegroundPush.delegate = self","        return true","    }","","    func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","        print(\"Foreground custom push tapped: \\(userInfo)\")","","        if let customData = userInfo[\"custom\"] as? [String: Any],","           let screenId = customData[\"screen_id\"] as? String {","            navigateToScreen(screenId)","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"heading","level":3,"anchor":"Deep-Link-Handling","text":"Deep Link Handling"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle deep links from push notifications:"}]},{"syntax":"swift","code":["func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","    if let deepLink = userInfo[\"deep_link\"] as? String,","       let url = URL(string: deepLink) {","        UIApplication.shared.open(url, options: [:]) { success in","            print(\"Deep link opened: \\(success)\")","        }","    }","}"],"type":"codeListing"},{"text":"Complete Custom Setup","level":2,"type":"heading","anchor":"Complete-Custom-Setup"},{"anchor":"Branded-Notification","level":3,"text":"Branded Notification","type":"heading"},{"inlineContent":[{"type":"text","text":"Full customization with brand identity:"}],"type":"paragraph"},{"type":"codeListing","code":["func configureBrandedForegroundPush() {","    Pushwoosh.ForegroundPush.gradientColors = [","        UIColor(red: 0.18, green: 0.31, blue: 0.64, alpha: 1.0),","        UIColor(red: 0.44, green: 0.26, blue: 0.63, alpha: 1.0)","    ]","","    Pushwoosh.ForegroundPush.titlePushColor = .white","    Pushwoosh.ForegroundPush.messagePushColor = UIColor(white: 0.95, alpha: 1.0)","","    Pushwoosh.ForegroundPush.titlePush