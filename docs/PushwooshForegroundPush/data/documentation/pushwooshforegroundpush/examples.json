:"swift"},{"level":3,"text":"System Notification Haptic","anchor":"System-Notification-Haptic","type":"heading"},{"inlineContent":[{"text":"Use system notification-style haptic:","type":"text"}],"type":"paragraph"},{"code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .balls",")"],"syntax":"swift","type":"codeListing"},{"text":"Handling User Interactions","level":2,"anchor":"Handling-User-Interactions","type":"heading"},{"type":"heading","text":"Implementing Delegate","anchor":"Implementing-Delegate","level":3},{"type":"paragraph","inlineContent":[{"text":"Handle user taps through the delegate method:","type":"text"}]},{"code":["class AppDelegate: UIResponder, UIApplicationDelegate, PWForegroundPushDelegate {","","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","        Pushwoosh.ForegroundPush.delegate = self","        return true","    }","","    func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","        print(\"Foreground custom push tapped: \\(userInfo)\")","","        if let customData = userInfo[\"custom\"] as? [String: Any],","           let screenId = customData[\"screen_id\"] as? String {","            navigateToScreen(screenId)","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"Deep Link Handling","level":3,"anchor":"Deep-Link-Handling"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle deep links from push notifications:"}]},{"code":["func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","    if let deepLink = userInfo[\"deep_link\"] as? String,","       let url = URL(string: deepLink) {","        UIApplication.shared.open(url, options: [:]) { success in","            print(\"Deep link opened: \\(success)\")","        }","    }","}"],"type":"cod