":"paragraph"},{"text":"Push with GIF Attachment","anchor":"Push-with-GIF-Attachment","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Animated GIF images are supported:"}]},{"inlineContent":[{"type":"image","identifier":"ios-foreground-custom-1.gif"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The attachment URL is specified in the push notification payload. The SDK automatically downloads and displays the media content."}]},{"type":"heading","text":"Animation Customization","level":2,"anchor":"Animation-Customization"},{"anchor":"Disable-Entry-Animation","type":"heading","level":3,"text":"Disable Entry Animation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Show push instantly without slide animation:"}]},{"code":["Pushwoosh.ForegroundPush.usePushAnimation = false"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"image","identifier":"ios-foreground-custom-4.gif"}],"type":"paragraph"},{"type":"heading","text":"Particle Explosion Effect","anchor":"Particle-Explosion-Effect","level":3},{"inlineContent":[{"text":"Use particle explosion when push disappears:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .balls",")"]},{"level":3,"anchor":"Regular-Push-Animation","type":"heading","text":"Regular Push Animation"},{"type":"paragraph","inlineContent":[{"text":"Use standard upward slide animation:","type":"text"}]},{"syntax":"swift","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .regularPush",")"],"type":"codeListing"},{"text":"Liquid Glass Effect (iOS 26+)","level":3,"anchor":"Liquid-Glass-Effect-iOS-26+","type":"heading"},{"type":"paragraph","inlineConte