{"metadata":{"modules":[{"name":"PushwooshForegroundPush"}],"roleHeading":"Article","title":"Code Examples","role":"article"},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/Examples","interfaceLanguage":"swift"},"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/pushwooshforegroundpush\/examples"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshforegroundpush\/examples"]}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"inlineContent":[{"type":"text","text":"This guide provides working code examples for customizing PushwooshForegroundPush appearance, animations, and user interactions."}],"type":"paragraph"},{"text":"Basic Setup","type":"heading","level":2,"anchor":"Basic-Setup"},{"type":"heading","text":"Minimal Configuration","level":3,"anchor":"Minimal-Configuration"},{"type":"paragraph","inlineContent":[{"text":"The simplest configuration with default appearance:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import UIKit","import PushwooshFramework","import PushwooshForegroundPush","","@main","class AppDelegate: UIResponder, UIApplicationDelegate, PWForegroundPushDelegate {","","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","","        Pushwoosh.ForegroundPush.foregroundNotificationWith(","            style: .style1,","            duration: 5,","            vibration: .notification,","            disappearedPushAnimation: .balls","        )","","        Pushwoosh.ForegroundPush.delegate = self","","        return true","    }","","    func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","        print(\"Foreground custom push: \\(userInfo)\")","    }","}"]},{"anchor":"Appearance-Customization","level":2,"type":"heading","text":"Appearance Customization"},{"text":"Custom Gradient Background","anchor":"Custom-Gradient-Background","level":3,"type":"heading"},{"inlineContent":[{"text":"Create a vibrant gradient background with custom text colors:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["Pushwoosh.ForegroundPush.gradientColors = [.red, .orange, .yellow]","Pushwoosh.ForegroundPush.titlePushColor = .white","Pushwoosh.ForegroundPush.messagePushColor = .white"],"type":"codeListing"},{"inlineContent":[{"identifier":"ios-foreground-custom-3.gif","type":"image"}],"type":"paragraph"},{"text":"Solid Background Color","level":3,"type":"heading","anchor":"Solid-Background-Color"},{"inlineContent":[{"type":"text","text":"Use a solid color instead of gradient:"}],"type":"paragraph"},{"syntax":"swift","code":["Pushwoosh.ForegroundPush.backgroundColor = UIColor(red: 0.1, green: 0.1, blue: 0.1, alpha: 0.95)","Pushwoosh.ForegroundPush.gradientColors = nil"],"type":"codeListing"},{"text":"Custom Fonts","level":3,"anchor":"Custom-Fonts","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Use custom fonts for title and message:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.ForegroundPush.backgroundColor = .systemPurple","Pushwoosh.ForegroundPush.titlePushFont = UIFont(name: \"YourCustomFont-Bold\", size: 18)","Pushwoosh.ForegroundPush.messagePushFont = UIFont(name: \"YourCustomFont-Regular\", size: 15)","Pushwoosh.ForegroundPush.titlePushColor = .white","Pushwoosh.ForegroundPush.messagePushColor = .white"]},{"inlineContent":[{"type":"image","identifier":"ios-foreground-custom-4.gif"}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"Rich-Media-Support","text":"Rich Media Support"},{"text":"Push with Image Attachment","anchor":"Push-with-Image-Attachment","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Foreground push notifications support image attachments:"}],"type":"paragraph"},{"inlineContent":[{"identifier":"ios-foreground-custom-2.gif","type":"image"}],"type":"paragraph"},{"anchor":"Push-with-GIF-Attachment","level":3,"type":"heading","text":"Push with GIF Attachment"},{"inlineContent":[{"type":"text","text":"Animated GIF images are supported:"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"identifier":"ios-foreground-custom-1.gif","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The attachment URL is specified in the push notification payload. The SDK automatically downloads and displays the media content."}]},{"anchor":"Animation-Customization","type":"heading","level":2,"text":"Animation Customization"},{"level":3,"anchor":"Disable-Entry-Animation","type":"heading","text":"Disable Entry Animation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Show push instantly without slide animation:"}]},{"syntax":"swift","type":"codeListing","code":["Pushwoosh.ForegroundPush.usePushAnimation = false"]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"ios-foreground-custom-4.gif"}]},{"type":"heading","level":3,"text":"Particle Explosion Effect","anchor":"Particle-Explosion-Effect"},{"type":"paragraph","inlineContent":[{"text":"Use particle explosion when push disappears:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .balls",")"]},{"anchor":"Regular-Push-Animation","type":"heading","level":3,"text":"Regular Push Animation"},{"inlineContent":[{"type":"text","text":"Use standard upward slide animation:"}],"type":"paragraph"},{"code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .regularPush",")"],"type":"codeListing","syntax":"swift"},{"level":3,"anchor":"Liquid-Glass-Effect-iOS-26+","type":"heading","text":"Liquid Glass Effect (iOS 26+)"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Enable modern Liquid Glass visual effect:"}]},{"code":["Pushwoosh.ForegroundPush.useLiquidView = true"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"ios-foreground-custom-5.gif"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Important","type":"text"}]},{"text":": Liquid Glass requires iOS 26+ and Swift 5.13+. On earlier iOS versions, standard UIView-based notifications are displayed. Swift versions below 5.13 use blurred UIVisualEffectView.","type":"text"}]}],"name":"Note","style":"note","type":"aside"},{"text":"Haptic Feedback Options","type":"heading","anchor":"Haptic-Feedback-Options","level":2},{"level":3,"type":"heading","text":"No Vibration","anchor":"No-Vibration"},{"inlineContent":[{"text":"For silent notifications:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .none,","    disappearedPushAnimation: .balls",")"],"syntax":"swift"},{"anchor":"Strong-Haptic","text":"Strong Haptic","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"For important notifications:","type":"text"}]},{"code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 7,","    vibration: .heavy,","    disappearedPushAnimation: .balls",")"],"type":"codeListing","syntax":"swift"},{"anchor":"System-Notification-Haptic","type":"heading","level":3,"text":"System Notification Haptic"},{"inlineContent":[{"text":"Use system notification-style haptic:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .balls",")"],"syntax":"swift"},{"type":"heading","level":2,"text":"Handling User Interactions","anchor":"Handling-User-Interactions"},{"text":"Implementing Delegate","type":"heading","anchor":"Implementing-Delegate","level":3},{"type":"paragraph","inlineContent":[{"text":"Handle user taps through the delegate method:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class AppDelegate: UIResponder, UIApplicationDelegate, PWForegroundPushDelegate {","","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","        Pushwoosh.ForegroundPush.delegate = self","        return true","    }","","    func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","        print(\"Foreground custom push tapped: \\(userInfo)\")","","        if let customData = userInfo[\"custom\"] as? [String: Any],","           let screenId = customData[\"screen_id\"] as? String {","            navigateToScreen(screenId)","        }","    }","}"]},{"anchor":"Deep-Link-Handling","type":"heading","text":"Deep Link Handling","level":3},{"inlineContent":[{"type":"text","text":"Handle deep links from push notifications:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","    if let deepLink = userInfo[\"deep_link\"] as? String,","       let url = URL(string: deepLink) {","        UIApplication.shared.open(url, options: [:]) { success in","            print(\"Deep link opened: \\(success)\")","        }","    }","}"]},{"type":"heading","text":"Complete Custom Setup","level":2,"anchor":"Complete-Custom-Setup"},{"level":3,"type":"heading","anchor":"Branded-Notification","text":"Branded Notification"},{"inlineContent":[{"text":"Full customization with brand identity:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["func configureBrandedForegroundPush() {","    Pushwoosh.ForegroundPush.gradientColors = [","        UIColor(red: 0.18, green: 0.31, blue: 0.64, alpha: 1.0),","        UIColor(red: 0.44, green: 0.26, blue: 0.63, alpha: 1.0)","    ]","","    Pushwoosh.ForegroundPush.titlePushColor = .white","    Pushwoosh.ForegroundPush.messagePushColor = UIColor(white: 0.95, alpha: 1.0)","","    Pushwoosh.ForegroundPush.titlePushFont = UIFont(name: \"Helvetica-Bold\", size: 18)","    Pushwoosh.ForegroundPush.messagePushFont = UIFont(name: \"Helvetica\", size: 15)","","    Pushwoosh.ForegroundPush.usePushAnimation = true","    Pushwoosh.ForegroundPush.useLiquidView = true","","    Pushwoosh.ForegroundPush.foregroundNotificationWith(","        style: .style1,","        duration: 6,","        vibration: .notification,","        disappearedPushAnimation: .balls","    )","","    Pushwoosh.ForegroundPush.delegate = self","}"]},{"text":"Dark Mode Support","type":"heading","anchor":"Dark-Mode-Support","level":2},{"anchor":"Adaptive-Colors","text":"Adaptive Colors","type":"heading","level":3},{"inlineContent":[{"text":"Adjust colors based on user interface style:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["func configureForegroundPushColors() {","    if #available(iOS 13.0, *) {","        let isDarkMode = UITraitCollection.current.userInterfaceStyle == .dark","","        if isDarkMode {","            Pushwoosh.ForegroundPush.gradientColors = [","                UIColor(red: 0.15, green: 0.15, blue: 0.15, alpha: 1.0),","                UIColor(red: 0.25, green: 0.25, blue: 0.25, alpha: 1.0)","            ]","            Pushwoosh.ForegroundPush.titlePushColor = .white","            Pushwoosh.ForegroundPush.messagePushColor = UIColor(white: 0.85, alpha: 1.0)","        } else {","            Pushwoosh.ForegroundPush.gradientColors = [","                UIColor(red: 0.95, green: 0.95, blue: 0.95, alpha: 1.0),","                UIColor(red: 0.85, green: 0.85, blue: 0.85, alpha: 1.0)","            ]","            Pushwoosh.ForegroundPush.titlePushColor = .black","            Pushwoosh.ForegroundPush.messagePushColor = UIColor(white: 0.15, alpha: 1.0)","        }","    }","}"]},{"anchor":"Next-Steps","level":2,"type":"heading","text":"Next Steps"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/GettingStarted"},{"type":"text","text":" - Quick start guide"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/PushwooshForegroundPushImplementation","isActive":true,"type":"reference"},{"type":"text","text":" - Full API reference"}]}]}]}]}],"seeAlsoSections":[{"generated":true,"title":"Getting Started","identifiers":["doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/GettingStarted"]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush"]]},"abstract":[{"type":"text","text":"Practical examples for common foreground push notification scenarios."}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"ios-foreground-custom-4.gif":{"variants":[{"url":"\/images\/ios-foreground-custom-4.gif","traits":["1x","light"]}],"alt":"Foreground push with no animation","type":"image","identifier":"ios-foreground-custom-4.gif"},"doc://com.pushwoosh.PushwooshForegroundPush/documentation/PushwooshForegroundPush/GettingStarted":{"url":"\/documentation\/pushwooshforegroundpush\/gettingstarted","identifier":"doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/GettingStarted","type":"topic","title":"Getting Started","role":"article","abstract":[{"type":"text","text":"Customize foreground push notifications when native iOS system alerts are disabled."}],"kind":"article"},"ios-foreground-custom-1.gif