{"abstract":[{"type":"text","text":"Practical examples for common foreground push notification scenarios."}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush"]]},"primaryContentSections":[{"content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"This guide provides working code examples for customizing PushwooshForegroundPush appearance, animations, and user interactions."}],"type":"paragraph"},{"type":"heading","anchor":"Basic-Setup","level":2,"text":"Basic Setup"},{"level":3,"text":"Minimal Configuration","anchor":"Minimal-Configuration","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The simplest configuration with default appearance:"}]},{"code":["import UIKit","import PushwooshFramework","import PushwooshForegroundPush","","@main","class AppDelegate: UIResponder, UIApplicationDelegate, PWForegroundPushDelegate {","","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","","        Pushwoosh.ForegroundPush.foregroundNotificationWith(","            style: .style1,","            duration: 5,","            vibration: .notification,","            disappearedPushAnimation: .balls","        )","","        Pushwoosh.ForegroundPush.delegate = self","","        return true","    }","","    func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","        print(\"Foreground custom push: \\(userInfo)\")","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"Appearance Customization","level":2,"anchor":"Appearance-Customization"},{"text":"Custom Gradient Background","level":3,"type":"heading","anchor":"Custom-Gradient-Background"},{"inlineContent":[{"type":"text","text":"Create a vibrant gradient background with custom text colors:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.ForegroundPush.gradientColors = [.red, .orange, .yellow]","Pushwoosh.ForegroundPush.titlePushColor = .white","Pushwoosh.ForegroundPush.messagePushColor = .white"]},{"inlineContent":[{"type":"image","identifier":"ios-foreground-custom-3.gif"}],"type":"paragraph"},{"anchor":"Solid-Background-Color","text":"Solid Background Color","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use a solid color instead of gradient:"}]},{"type":"codeListing","code":["Pushwoosh.ForegroundPush.backgroundColor = UIColor(red: 0.1, green: 0.1, blue: 0.1, alpha: 0.95)","Pushwoosh.ForegroundPush.gradientColors = nil"],"syntax":"swift"},{"anchor":"Custom-Fonts","level":3,"text":"Custom Fonts","type":"heading"},{"inlineContent":[{"text":"Use custom fonts for title and message:","type":"text"}],"type":"paragraph"},{"code":["Pushwoosh.ForegroundPush.backgroundColor = .systemPurple","Pushwoosh.ForegroundPush.titlePushFont = UIFont(name: \"YourCustomFont-Bold\", size: 18)","Pushwoosh.ForegroundPush.messagePushFont = UIFont(name: \"YourCustomFont-Regular\", size: 15)","Pushwoosh.ForegroundPush.titlePushColor = .white","Pushwoosh.ForegroundPush.messagePushColor = .white"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"identifier":"ios-foreground-custom-4.gif","type":"image"}],"type":"paragraph"},{"anchor":"Rich-Media-Support","type":"heading","text":"Rich Media Support","level":2},{"level":3,"anchor":"Push-with-Image-Attachment","text":"Push with Image Attachment","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Foreground push notifications support image attachments:"}]},{"inlineContent":[{"identifier":"ios-foreground-custom-2.gif","type":"image"}],"type":"paragraph"},{"anchor":"Push-with-GIF-Attachment","text":"Push with GIF Attachment","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Animated GIF images are supported:"}]},{"inlineContent":[{"type":"image","identifier":"ios-foreground-custom-1.gif"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The attachment URL is specified in the push notification payload. The SDK automatically downloads and displays the media content.","type":"text"}]},{"anchor":"Animation-Customization","type":"heading","level":2,"text":"Animation Customization"},{"level":3,"type":"heading","anchor":"Disable-Entry-Animation","text":"Disable Entry Animation"},{"inlineContent":[{"text":"Show push instantly without slide animation:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.ForegroundPush.usePushAnimation = false"]},{"type":"paragraph","inlineContent":[{"identifier":"ios-foreground-custom-4.gif","type":"image"}]},{"text":"Particle Explosion Effect","anchor":"Particle-Explosion-Effect","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use particle explosion when push disappears:"}]},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .balls",")"]},{"level":3,"text":"Regular Push Animation","anchor":"Regular-Push-Animation","type":"heading"},{"inlineContent":[{"type":"text","text":"Use standard upward slide animation:"}],"type":"paragraph"},{"code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .regularPush",")"],"syntax":"swift","type":"codeListing"},{"anchor":"Liquid-Glass-Effect-iOS-26+","text":"Liquid Glass Effect (iOS 26+)","level":3,"type":"heading"},{"inlineContent":[{"text":"Enable modern Liquid Glass visual effect:","type":"text"}],"type":"paragraph"},{"code":["Pushwoosh.ForegroundPush.useLiquidView = true"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"ios-foreground-custom-5.gif"}]},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Important"}]},{"text":": Liquid Glass requires iOS 26+ and Swift 5.13+. On earlier iOS versions, standard UIView-based notifications are displayed. Swift versions below 5.13 use blurred UIVisualEffectView.","type":"text"}]}],"type":"aside"},{"text":"Haptic Feedback Options","type":"heading","level":2,"anchor":"Haptic-Feedback-Options"},{"text":"No Vibration","type":"heading","level":3,"anchor":"No-Vibration"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For silent notifications:"}]},{"syntax":"swift","type":"codeListing","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .none,","    disappearedPushAnimation: .balls",")"]},{"level":3,"type":"heading","anchor":"Strong-Haptic","text":"Strong Haptic"},{"type":"paragraph","inlineContent":[{"text":"For important notifications:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 7,","    vibration: .heavy,","    disappearedPushAnimation: .balls",")"]},{"text":"System Notification Haptic","anchor":"System-Notification-Haptic","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Use system notification-style haptic:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .balls",")"]},{"type":"heading","text":"Handling User Interactions","anchor":"Handling-User-Interactions","level":2},{"text":"Implementing Delegate","anchor":"Implementing-Delegate","level":3,"type":"heading"},{"inlineContent":[{"text":"Handle user taps through the delegate method:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class AppDelegate: UIResponder, UIApplicationDelegate, PWForegroundPushDelegate {","","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","        Pushwoosh.ForegroundPush.delegate = self","        return true","    }","","    func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","        print(\"Foreground custom push tapped: \\(userInfo)\")","","        if let customData = userInfo[\"custom\"] as? [String: Any],","           let screenId = customData[\"screen_id\"] as? String {","            navigateToScreen(screenId)","        }","    }","}"]},{"type":"heading","text":"Deep Link Handling","level":3,"anchor":"Deep-Link-Handling"},{"type":"paragraph","inlineContent":[{"text":"Handle deep links from push notifications:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","    if let deepLink = userInfo[\"deep_link\"] as? String,","       let url = URL(string: deepLink) {","        UIApplication.shared.open(url, options: [:]) { success in","            print(\"Deep link opened: \\(success)\")","        }","    }","}"]},{"anchor":"Complete-Custom-Setup","type":"heading","text":"Complete Custom Setup","level":2},{"text":"Branded Notification","anchor":"Branded-Notification","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Full customization with brand identity:"}],"type":"paragraph"},{"type":"codeListing","code":["func configureBrandedForegroundPush() {","    Pushwoosh.ForegroundPush.gradientColors = [","        UIColor(red: 0.18, green: 0.31, blue: 0.64, alpha: 1.0),","        UIColor(red: 0.44, green: 0.26, blue: 0.63, alpha: 1.0)","    ]","","    Pushwoosh.ForegroundPush.titlePushColor = .white","    Pushwoosh.ForegroundPush.messagePushColor = UIColor(white: 0.95, alpha: 1.0)","","    Pushwoosh.ForegroundPush.titlePushFont = UIFont(name: \"Helvetica-Bold\", size: 18)","    Pushwoosh.ForegroundPush.messagePushFont = UIFont(name: \"Helvetica\", size: 15)","","    Pushwoosh.ForegroundPush.usePushAnimation = true","    Pushwoosh.ForegroundPush.useLiquidView = true","","    Pushwoosh.ForegroundPush.foregroundNotificationWith(","        style: .style1,","        duration: 6,","        vibration: .notification,","        disappearedPushAnimation: .balls","    )","","    Pushwoosh.ForegroundPush.delegate = self","}"],"syntax":"swift"},{"type":"heading","level":2,"text":"Dark Mode Support","anchor":"Dark-Mode-Support"},{"type":"heading","text":"Adaptive Colors","anchor":"Adaptive-Colors","level":3},{"inlineContent":[{"type":"text","text":"Adjust colors based on user interface style:"}],"type":"paragraph"},{"code":["func configureForegroundPushColors() {","    if #available(iOS 13.0, *) {","        let isDarkMode = UITraitCollection.current.userInterfaceStyle == .dark","","        if isDarkMode {","            Pushwoosh.ForegroundPush.gradientColors = [","                UIColor(red: 0.15, green: 0.15, blue: 0.15, alpha: 1.0),","                UIColor(red: 0.25, green: 0.25, blue: 0.25, alpha: 1.0)","            ]","            Pushwoosh.ForegroundPush.titlePushColor = .white","            Pushwoosh.ForegroundPush.messagePushColor = UIColor(white: 0.85, alpha: 1.0)","        } else {","            Pushwoosh.ForegroundPush.gradientColors = [","                UIColor(red: 0.95, green: 0.95, blue: 0.95, alpha: 1.0),","                UIColor(red: 0.85, green: 0.85, blue: 0.85, alpha: 1.0)","            ]","            Pushwoosh.ForegroundPush.titlePushColor = .black","            Pushwoosh.ForegroundPush.messagePushColor = UIColor(white: 0.15, alpha: 1.0)","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Next-Steps","level":2,"type":"heading","text":"Next Steps"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","ide