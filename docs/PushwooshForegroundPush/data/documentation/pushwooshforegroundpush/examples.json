{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/Examples","interfaceLanguage":"swift"},"metadata":{"title":"Code Examples","role":"article","modules":[{"name":"PushwooshForegroundPush"}],"roleHeading":"Article"},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"primaryContentSections":[{"content":[{"text":"Overview","level":2,"anchor":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"This guide provides working code examples for customizing PushwooshForegroundPush appearance, animations, and user interactions."}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"Basic-Setup","text":"Basic Setup"},{"level":3,"type":"heading","text":"Minimal Configuration","anchor":"Minimal-Configuration"},{"inlineContent":[{"text":"The simplest configuration with default appearance:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["import UIKit","import PushwooshFramework","import PushwooshForegroundPush","","@main","class AppDelegate: UIResponder, UIApplicationDelegate, PWForegroundPushDelegate {","","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","","        Pushwoosh.ForegroundPush.foregroundNotificationWith(","            style: .style1,","            duration: 5,","            vibration: .notification,","            disappearedPushAnimation: .balls","        )","","        Pushwoosh.ForegroundPush.delegate = self","","        return true","    }","","    func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","        print(\"Foreground custom push: \\(userInfo)\")","    }","}"]},{"anchor":"Appearance-Customization","text":"Appearance Customization","type":"heading","level":2},{"text":"Custom Gradient Background","type":"heading","level":3,"anchor":"Custom-Gradient-Background"},{"type":"paragraph","inlineContent":