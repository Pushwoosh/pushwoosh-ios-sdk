ing","syntax":"swift","code":["Pushwoosh.ForegroundPush.useLiquidView = true"]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"ios-foreground-custom-5.gif"}]},{"type":"aside","content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Important"}]},{"text":": Liquid Glass requires iOS 26+ and Swift 5.13+. On earlier iOS versions, standard UIView-based notifications are displayed. Swift versions below 5.13 use blurred UIVisualEffectView.","type":"text"}],"type":"paragraph"}],"name":"Note","style":"note"},{"text":"Haptic Feedback Options","type":"heading","level":2,"anchor":"Haptic-Feedback-Options"},{"anchor":"No-Vibration","level":3,"text":"No Vibration","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For silent notifications:"}]},{"code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .none,","    disappearedPushAnimation: .balls",")"],"syntax":"swift","type":"codeListing"},{"text":"Strong Haptic","type":"heading","level":3,"anchor":"Strong-Haptic"},{"inlineContent":[{"text":"For important notifications:","type":"text"}],"type":"paragraph"},{"code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 7,","    vibration: .heavy,","    disappearedPushAnimation: .balls",")"],"type":"codeListing","syntax":"swift"},{"level":3,"anchor":"System-Notification-Haptic","text":"System Notification Haptic","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use system notification-style haptic:"}]},{"code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .balls",")"],"syntax":"swift","type":"codeListing"},{"type":"heading","level":2,"anchor":"Handling-User-Interactions","text":"Handling User Interactions"},{"text":"Implementing Delegate","level":3,"type":"heading","