{"abstract":[{"type":"text","text":"Practical examples for common foreground push notification scenarios."}],"sections":[],"metadata":{"title":"Code Examples","modules":[{"name":"PushwooshForegroundPush"}],"role":"article","roleHeading":"Article"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/pushwooshforegroundpush\/examples"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshforegroundpush\/examples"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"content":[{"text":"Overview","anchor":"Overview","level":2,"type":"heading"},{"inlineContent":[{"text":"This guide provides working code examples for customizing PushwooshForegroundPush appearance, animations, and user interactions.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"Basic Setup","anchor":"Basic-Setup"},{"level":3,"anchor":"Minimal-Configuration","text":"Minimal Configuration","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The simplest configuration with default appearance:"}]},{"code":["import UIKit","import PushwooshFramework","import PushwooshForegroundPush","","@main","class AppDelegate: UIResponder, UIApplicationDelegate, PWForegroundPushDelegate {","","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","","        Pushwoosh.ForegroundPush.foregroundNotificationWith(","            style: .style1,","            duration: 5,","            vibration: .notification,","            disappearedPushAnimation: .balls","        )","","        Pushwoosh.ForegroundPush.delegate = self","","        return true","    }","","    func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","        print(\"Foreground custom push: \\(userInfo)\")","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":2,"anchor":"Appearance-Customization","text":"Appearance Customization"},{"anchor":"Custom-Gradient-Background","level":3,"text":"Custom Gradient Background","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a vibrant gradient background with custom text colors:"}]},{"code":["Pushwoosh.ForegroundPush.gradientColors = [.red, .orange, .yellow]","Pushwoosh.ForegroundPush.titlePushColor = .white","Pushwoosh.ForegroundPush.messagePushColor = .white"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"ios-foreground-custom-3.gif"}]},{"text":"Solid Background Color","anchor":"Solid-Background-Color","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use a solid color instead of gradient:"}]},{"syntax":"swift","type":"codeListing","code":["Pushwoosh.ForegroundPush.backgroundColor = UIColor(red: 0.1, green: 0.1, blue: 0.1, alpha: 0.95)","Pushwoosh.ForegroundPush.gradientColors = nil"]},{"level":3,"anchor":"Custom-Fonts","type":"heading","text":"Custom Fonts"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use custom fonts for title and message:"}]},{"syntax":"swift","code":["Pushwoosh.ForegroundPush.backgroundColor = .systemPurple","Pushwoosh.ForegroundPush.titlePushFont = UIFont(name: \"YourCustomFont-Bold\", size: 18)","Pushwoosh.ForegroundPush.messagePushFont = UIFont(name: \"YourCustomFont-Regular\", size: 15)","Pushwoosh.ForegroundPush.titlePushColor = .white","Pushwoosh.ForegroundPush.messagePushColor = .white"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"identifier":"ios-foreground-custom-4.gif","type":"image"}]},{"anchor":"Rich-Media-Support","type":"heading","text":"Rich Media Support","level":2},{"text":"Push with Image Attachment","level":3,"anchor":"Push-with-Image-Attachment","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Foreground push notifications support image attachments:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"ios-foreground-custom-2.gif"}]},{"text":"Push with GIF Attachment","level":3,"anchor":"Push-with-GIF-Attachment","type":"heading"},{"inlineContent":[{"type":"text","text":"Animated GIF images are supported:"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"ios-foreground-custom-1.gif"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The attachment URL is specified in the push notification payload. The SDK automatically downloads and displays the media content."}]},{"anchor":"Animation-Customization","text":"Animation Customization","type":"heading","level":2},{"text":"Disable Entry Animation","type":"heading","level":3,"anchor":"Disable-Entry-Animation"},{"inlineContent":[{"type":"text","text":"Show push instantly without slide animation:"}],"type":"paragraph"},{"type":"codeListing","code":["Pushwoosh.ForegroundPush.usePushAnimation = false"],"syntax":"swift"},{"inlineContent":[{"identifier":"ios-foreground-custom-4.gif","type":"image"}],"type":"paragraph"},{"text":"Particle Explosion Effect","type":"heading","level":3,"anchor":"Particle-Explosion-Effect"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use particle explosion when push disappears:"}]},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .balls",")"]},{"level":3,"type":"heading","text":"Regular Push Animation","anchor":"Regular-Push-Animation"},{"type":"paragraph","inlineContent":[{"text":"Use standard upward slide animation:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .regularPush",")"]},{"type":"heading","anchor":"Liquid-Glass-Effect-iOS-26+","level":3,"text":"Liquid Glass Effect (iOS 26+)"},{"inlineContent":[{"text":"Enable modern Liquid Glass visual effect:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.ForegroundPush.useLiquidView = true"]},{"inlineContent":[{"identifier":"ios-foreground-custom-5.gif","type":"image"}],"type":"paragraph"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Important","type":"text"}]},{"text":": Liquid Glass requires iOS 26+ and Swift 5.13+. On earlier iOS versions, standard UIView-based notifications are displayed. Swift versions below 5.13 use blurred UIVisualEffectView.","type":"text"}]}],"name":"Note","style":"note"},{"anchor":"Haptic-Feedback-Options","type":"heading","text":"Haptic Feedback Options","level":2},{"type":"heading","text":"No Vibration","level":3,"anchor":"No-Vibration"},{"type":"paragraph","inlineContent":[{"text":"For silent notifications:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .none,","    disappearedPushAnimation: .balls",")"]},{"anchor":"Strong-Haptic","type":"heading","text":"Strong Haptic","level":3},{"inlineContent":[{"type":"text","text":"For important notifications:"}],"type":"paragraph"},{"type":"codeListing","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 7,","    vibration: .heavy,","    disappearedPushAnimation: .balls",")"],"syntax":"swift"},{"type":"heading","text":"System Notification Haptic","level":3,"anchor":"System-Notification-Haptic"},{"type":"paragraph","inlineContent":[{"text":"Use system notification-style haptic:","type":"text"}]},{"type":"codeListing","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .balls",")"],"syntax":"swift"},{"anchor":"Handling-User-Interactions","level":2,"type":"heading","text":"Handling User Interactions"},{"type":"heading","anchor":"Implementing-Delegate","level":3,"text":"Implementing Delegate"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle user taps through the delegate method:"}]},{"syntax":"swift","code":["class AppDelegate: UIResponder, UIApplicationDelegate, PWForegroundPushDelegate {","","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","        Pushwoosh.ForegroundPush.delegate = self","        return true","    }","","    func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","        print(\"Foreground custom push tapped: \\(userInfo)\")","","        if let customData = userInfo[\"custom\"] as? [String: Any],","           let screenId = customData[\"screen_id\"] as? String {","            navigateToScreen(screenId)","        }","    }","}"],"type":"codeListing"},{"anchor":"Deep-Link-Handling","level":3,"text":"Deep Link Handling","type":"heading"},{"inlineContent":[{"type":"text","text":"Handle deep links from push notifications:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","    if let deepLink = userInfo[\"deep_link\"] as? String,","       let url = URL(string: deepLink) {","        UIApplication.shared.open(url, options: [:]) { success in","            print(\"Deep link opened: \\(success)\")","        }","    }","}"]},{"level":2,"text":"Complete Custom Setup","type":"heading","anchor":"Complete-Custom-Setup"},{"level":3,"type":"heading","anchor":"Branded-Notification","text":"Branded Notification"},{"inlineContent":[{"text":"Full customization with brand identity:","type":"text"}],"type":"paragraph"},{"code":["func configureBrandedForegroundPush() {","    Pushwoosh.ForegroundPush.gradientColors = [","        UIColor(red: 0.18, green: 0.31, blue: 0.64, alpha: 1.0),","        UIColor(red: 0.44, green: 0.26, blue: 0.63, alpha: 1.0)","    ]","","    Pushwoosh.ForegroundPush.titlePushColor = .white","    Pushwoosh.ForegroundPush.messagePushColor = UIColor(white: 0.95, alpha: 1.0)","","    Pushwoosh.ForegroundPush.titlePushFont = UIFont(name: \"Helvetica-Bold\", size: 18)","    Pushwoosh.ForegroundPush.messagePushFont = UIFont(name: \"Helvetica\", size: 15)","","    Pushwoosh.ForegroundPush.usePushAnimation = true","    Pushwoosh.ForegroundPush.useLiquidView = true","","    Pushwoosh.ForegroundPush.foregroundNotificationWith(","        style: .style1,","        duration: 6,","        vibration: .notification,","        disappearedPushAnimation: .balls","    )","","    Pushwoosh.ForegroundPush.delegate = self","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Dark-Mode-Support","type":"heading","level":2,"text":"Dark Mode Support"},{"level":3,"text":"Adaptive Colors","type":"heading","anchor":"Adaptive-Colors"},{"inlineContent":[{"text":"Adjust colors based on user interface style:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["func configureForegroundPushColors() {","    if #available(iOS 13.0, *) {","        let isDarkMode = UITraitCollection.current.userInterfaceStyle == .dark","","        if isDarkMode {","            Pushwoosh.ForegroundPush.gradientColors = [","                UIColor(red: 0.15, green: 0.15, blue: 0.15, alpha: 1.0),","                UIColor(red: 0.25, green: 0.25, blue: 0.25, alpha: 1.0)","            ]","            Pushwoosh.ForegroundPush.titlePushColor = .white","            Pushwoosh.ForegroundPush.messagePushColor = UIColor(white: 0.85, alpha: 1.0)","        } else {","            Pushwoosh.ForegroundPush.gradientColors = [","                UIColor(red: 0.95, green: 0.95, blue: 0.95, alpha: 1.0),","                UIColor(red: 0.85, green: 0.85, blue: 0.85, alpha: 1.0)","            ]","            Pushwoosh.ForegroundPush.titlePushColor = .black","            Pushwoosh.ForegroundPush.messagePushColor = UIColor(white: 0.15, alpha: 1.0)","        }","    }","}"]},{"anchor":"Next-Steps","level":2,"text":"Next Steps","type":"heading"},{"items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/GettingStarted","isActive":true,"type":"reference"},{"text":" - Quick start guide","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/PushwooshForegroundPushImplementation"},{"text":" - Full API reference","type":"text"}]}]}],"type":"unorderedList"}],"kind":"content"}],"kind":"article","seeAlsoSections":[{"identifiers":["doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/GettingStarted"],"title":"Getting Started","generated":true}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/Examples","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush"]]},"references":{"ios-foreground-custom-2.gif":{"identifier":"ios-foreground-custom-2.gif","variants":[{"traits":["1x","light"],"url":"\/images\/ios-foreground-custom-2.gif"}],"type":"image","alt":"Foreground push with card image attachment"},"doc://com.pushwoosh.PushwooshForegroundPush/documentation/PushwooshForegroundPush":{"kind":"symbol","abstract":[{"text":"Customizable foreground push notifications for iOS applications.","type":"text"}],"url":"\/documentation\/pushwooshforegroundpush","role":"collection","title":"PushwooshForegroundPush","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush"},"ios-foreground-custom-5.gif":{"variants":[{"traits":["1x","light"],"url":"