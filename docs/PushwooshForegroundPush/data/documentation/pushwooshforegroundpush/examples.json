{"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This guide provides working code examples for customizing PushwooshForegroundPush appearance, animations, and user interactions."}]},{"type":"heading","anchor":"Basic-Setup","text":"Basic Setup","level":2},{"text":"Minimal Configuration","type":"heading","anchor":"Minimal-Configuration","level":3},{"inlineContent":[{"type":"text","text":"The simplest configuration with default appearance:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["import UIKit","import PushwooshFramework","import PushwooshForegroundPush","","@main","class AppDelegate: UIResponder, UIApplicationDelegate, PWForegroundPushDelegate {","","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","","        Pushwoosh.ForegroundPush.foregroundNotificationWith(","            style: .style1,","            duration: 5,","            vibration: .notification,","            disappearedPushAnimation: .balls","        )","","        Pushwoosh.ForegroundPush.delegate = self","","        return true","    }","","    func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","        print(\"Foreground custom push: \\(userInfo)\")","    }","}"]},{"anchor":"Appearance-Customization","level":2,"text":"Appearance Customization","type":"heading"},{"text":"Custom Gradient Background","type":"heading","level":3,"anchor":"Custom-Gradient-Background"},{"type":"paragraph","inlineContent":[{"text":"Create a vibrant gradient background with custom text colors:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.ForegroundPush.gradientColors = [.red, .orange, .yellow]","Pushwoosh.ForegroundPush.titlePushColor = .white","Pushwoosh.ForegroundPush.messagePushColor = .white"]},{"inlineContent":[{"type":"image","identifier":"ios-foreground-custom-3.gif"}],"type":"paragraph"},{"anchor":"Solid-Background-Color","level":3,"type":"heading","text":"Solid Background Color"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use a solid color instead of gradient:"}]},{"code":["Pushwoosh.ForegroundPush.backgroundColor = UIColor(red: 0.1, green: 0.1, blue: 0.1, alpha: 0.95)","Pushwoosh.ForegroundPush.gradientColors = nil"],"type":"codeListing","syntax":"swift"},{"anchor":"Custom-Fonts","type":"heading","text":"Custom Fonts","level":3},{"type":"paragraph","inlineContent":[{"text":"Use custom fonts for title and message:","type":"text"}]},{"type":"codeListing","code":["Pushwoosh.ForegroundPush.backgroundColor = .systemPurple","Pushwoosh.ForegroundPush.titlePushFont = UIFont(name: \"YourCustomFont-Bold\", size: 18)","Pushwoosh.ForegroundPush.messagePushFont = UIFont(name: \"YourCustomFont-Regular\", size: 15)","Pushwoosh.ForegroundPush.titlePushColor = .white","Pushwoosh.ForegroundPush.messagePushColor = .white"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"ios-foreground-custom-4.gif"}]},{"type":"heading","level":2,"text":"Rich Media Support","anchor":"Rich-Media-Support"},{"anchor":"Push-with-Image-Attachment","text":"Push with Image Attachment","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Foreground push notifications support image attachments:"}]},{"type":"paragraph","inlineContent":[{"identifier":"ios-foreground-custom-2.gif","type":"image"}]},{"type":"heading","text":"Push with GIF Attachment","anchor":"Push-with-GIF-Attachment","level":3},{"inlineContent":[{"text":"Animated GIF images are supported:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"ios-foreground-custom-1.gif"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The attachment URL is specified in the push notification payload. The SDK automatically downloads and displays the media content.","type":"text"}]},{"anchor":"Animation-Customization","text":"Animation Customization","type":"heading","level":2},{"level":3,"anchor":"Disable-Entry-Animation","text":"Disable Entry Animation","type":"heading"},{"inlineContent":[{"text":"Show push instantly without slide animation:","type":"text"}],"type":"paragraph"},{"code":["Pushwoosh.ForegroundPush.usePushAnimation = false"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"identifier":"ios-foreground-custom-4.gif","type":"image"}]},{"anchor":"Particle-Explosion-Effect","level":3,"text":"Particle Explosion Effect","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Use particle explosion when push disappears:","type":"text"}]},{"type":"codeListing","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .balls",")"],"syntax":"swift"},{"text":"Regular Push Animation","type":"heading","level":3,"anchor":"Regular-Push-Animation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use standard upward slide animation:"}]},{"syntax":"swift","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .regularPush",")"],"type":"codeListing"},{"type":"heading","level":3,"anchor":"Liquid-Glass-Effect-iOS-26+","text":"Liquid Glass Effect (iOS 26+)"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Enable modern Liquid Glass visual effect:"}]},{"code":["Pushwoosh.ForegroundPush.useLiquidView = true"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"identifier":"ios-foreground-custom-5.gif","type":"image"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Important"}]},{"text":": Liquid Glass requires iOS 26+ and Swift 5.13+. On earlier iOS versions, standard UIView-based notifications are displayed. Swift versions below 5.13 use blurred UIVisualEffectView.","type":"text"}]}],"name":"Note","style":"note","type":"aside"},{"anchor":"Haptic-Feedback-Options","text":"Haptic Feedback Options","type":"heading","level":2},{"text":"No Vibration","level":3,"type":"heading","anchor":"No-Vibration"},{"inlineContent":[{"type":"text","text":"For silent notifications:"}],"type":"paragraph"},{"type":"codeListing","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .none,","    disappearedPushAnimation: .balls",")"],"syntax":"swift"},{"anchor":"Strong-Haptic","level":3,"type":"heading","text":"Strong Haptic"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For important notifications:"}]},{"syntax":"swift","code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 7,","    vibration: .heavy,","    disappearedPushAnimation: .balls",")"],"type":"codeListing"},{"text":"System Notification Haptic","type":"heading","level":3,"anchor":"System-Notification-Haptic"},{"inlineContent":[{"text":"Use system notification-style haptic:","type":"text"}],"type":"paragraph"},{"code":["Pushwoosh.ForegroundPush.foregroundNotificationWith(","    style: .style1,","    duration: 5,","    vibration: .notification,","    disappearedPushAnimation: .balls",")"],"syntax":"swift","type":"codeListing"},{"text":"Handling User Interactions","type":"heading","anchor":"Handling-User-Interactions","level":2},{"text":"Implementing Delegate","anchor":"Implementing-Delegate","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Handle user taps through the delegate method:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["class AppDelegate: UIResponder, UIApplicationDelegate, PWForegroundPushDelegate {","","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","        Pushwoosh.ForegroundPush.delegate = self","        return true","    }","","    func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","        print(\"Foreground custom push tapped: \\(userInfo)\")","","        if let customData = userInfo[\"custom\"] as? [String: Any],","           let screenId = customData[\"screen_id\"] as? String {","            navigateToScreen(screenId)","        }","    }","}"]},{"level":3,"text":"Deep Link Handling","type":"heading","anchor":"Deep-Link-Handling"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle deep links from push notifications:"}]},{"syntax":"swift","type":"codeListing","code":["func didTapForegroundPush(_ userInfo: [AnyHashable: Any]) {","    if let deepLink = userInfo[\"deep_link\"] as? String,","       let url = URL(string: deepLink) {","        UIApplication.shared.open(url, options: [:]) { success in","            print(\"Deep link opened: \\(success)\")","        }","    }","}"]},{"type":"heading","level":2,"text":"Complete Custom Setup","anchor":"Complete-Custom-Setup"},{"type":"heading","text":"Branded Notification","anchor":"Branded-Notification","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Full customization with brand identity:"}]},{"syntax":"swift","code":["func configureBrandedForegroundPush() {","    Pushwoosh.ForegroundPush.gradientColors = [","        UIColor(red: 0.18, green: 0.31, blue: 0.64, alpha: 1.0),","        UIColor(red: 0.44, green: 0.26, blue: 0.63, alpha: 1.0)","    ]","","    Pushwoosh.ForegroundPush.titlePushColor = .white","    Pushwoosh.ForegroundPush.messagePushColor = UIColor(white: 0.95, alpha: 1.0)","","    Pushwoosh.ForegroundPush.titlePushFont = UIFont(name: \"Helvetica-Bold\", size: 18)","    Pushwoosh.ForegroundPush.messagePushFont = UIFont(name: \"Helvetica\", size: 15)","","    Pushwoosh.ForegroundPush.usePushAnimation = true","    Pushwoosh.ForegroundPush.useLiquidView = true","","    Pushwoosh.ForegroundPush.foregroundNotificationWith(","        style: .style1,","        duration: 6,","        vibration: .notification,","        disappearedPushAnimation: .balls","    )","","    Pushwoosh.ForegroundPush.delegate = self","}"],"type":"codeListing"},{"text":"Dark Mode Support","type":"heading","level":2,"anchor":"Dark-Mode-Support"},{"text":"Adaptive Colors","level":3,"type":"heading","anchor":"Adaptive-Colors"},{"inlineContent":[{"text":"Adjust colors based on user interface style:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["func configureForegroundPushColors() {","    if #available(iOS 13.0, *) {","        let isDarkMode = UITraitCollection.current.userInterfaceStyle == .dark","","        if isDarkMode {","            Pushwoosh.ForegroundPush.gradientColors = [","                UIColor(red: 0.15, green: 0.15, blue: 0.15, alpha: 1.0),","                UIColor(red: 0.25, green: 0.25, blue: 0.25, alpha: 1.0)","            ]","            Pushwoosh.ForegroundPush.titlePushColor = .white","            Pushwoosh.ForegroundPush.messagePushColor = UIColor(white: 0.85, alpha: 1.0)","        } else {","            Pushwoosh.ForegroundPush.gradientColors = [","                UIColor(red: 0.95, green: 0.95, blue: 0.95, alpha: 1.0),","                UIColor(red: 0.85, green: 0.85, blue: 0.85, alpha: 1.0)","            ]","            Pushwoosh.ForegroundPush.titlePushColor = .black","            Pushwoosh.ForegroundPush.messagePushColor = UIColor(white: 0.15, alpha: 1.0)","        }","    }","}"]},{"text":"Next Steps","type":"heading","anchor":"Next-Steps","level":2},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.pushwoosh.PushwooshForegroundPush\/documentation\/PushwooshForegroundPush\/GettingStarted","isActive":true,"type":"reference"},{"type":"text","text":" - Quick start guide"}]}]},{"content":[{"type":"para