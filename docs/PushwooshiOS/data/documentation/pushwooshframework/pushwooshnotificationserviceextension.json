{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Drop-in base class for a Notification Service Extension. Subclass it (or set it directly as"},{"type":"text","text":" "},{"text":"the extension’s ","type":"text"},{"code":"NSExtensionPrincipalClass","type":"codeVoice"},{"text":") and Pushwoosh handles everything required for a","type":"text"},{"text":" ","type":"text"},{"text":"push: sending the message delivery event, badge counting, downloading the media attachment,","type":"text"},{"text":" ","type":"text"},{"text":"and the mandatory ","type":"text"},{"type":"codeVoice","code":"serviceExtensionTimeWillExpire"},{"text":" fallback.","type":"text"}],"topicSections":[{"title":"Instance Methods","identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshNotificationServiceExtension\/pushwooshAppGroupsName()","doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshNotificationServiceExtension\/pushwooshPrepare(for:completion:)"]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PushwooshNotificationServiceExtension"}]}]},{"content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Minimal integration — no code required beyond the subclass:"}]},{"syntax":"swift","code":["import PushwooshFramework","","class NotificationService: PushwooshNotificationServiceExtension {}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Or point the extension’s Info.plist "},{"code":"NSExtensionPrincipalClass","type":"codeVoice"},{"type":"text","text":" at"},{"text":" ","type":"text"},{"type":"codeVoice","code":"PushwooshNotificationServiceExtension"},{"type":"text","text":" directly and write no Swift\/Obj-C at all."}]},{"inlineContent":[{"type":"text","text":"Requirements:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"Pushwoosh_APPID","type":"codeVoice"},{"text":" in the main app Info.plist. You do not need to duplicate it in the extension","type":"text"},{"type":"text","text":" "},{"text":"Info.plist — when missing there, Pushwoosh inherits it (and other ","type":"text"},{"type":"codeVoice","code":"Pushwoosh_*"},{"type":"text","text":" keys) from the"},{"text":" ","type":"text"},{"text":"host app. Set it explicitly in the extension Info.plist only to override the host.","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"mutable-content: 1","type":"codeVoice"},{"type":"text","text":" in the push payload (so the extension is invoked)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"App Group shared between the app and the extension for badge \/ reverse-proxy sync","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(set "},{"type":"codeVoice","code":"PW_APP_GROUPS_NAME"},{"type":"text","text":" in Info.plist or override "},{"code":"pushwooshAppGroupsName","type":"codeVoice"},{"type":"text","text":")."},{"text":" ","type":"text"},{"text":"Note: if the host app uses a reverse proxy (","type":"text"},{"code":"Pushwoosh_ALLOW_REVERSE_PROXY","type":"codeVoice"},{"text":"), the extension","type":"text"},{"type":"text","text":" "},{"text":"needs this App Group to read the proxy URL the app stored there — otherwise the delivery event","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is held back (it will not bypass the proxy). Add the App Group capability to the extension target."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Customization, from least to most control:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Override ","type":"text"},{"type":"codeVoice","code":"pushwooshAppGroupsName"},{"type":"text","text":" to set the App Group programmatically."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Override ","type":"text"},{"type":"codeVoice","code":"pushwooshPrepareForRequest:completion:"},{"text":" to run async preparation before processing","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(e.g. Push Stories media prefetch) without touching the standard "},{"type":"codeVoice","code":"didReceive"},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Override the standard "},{"type":"codeVoice","code":"didReceiveNotificationRequest:withContentHandler:"},{"type":"text","text":" to customize the"},{"text":" ","type":"text"},{"type":"text","text":"content before it is shown: call "},{"type":"codeVoice","code":"super"},{"type":"text","text":" with your own content handler, mutate the content"},{"type":"text","text":" "},{"type":"text","text":"inside it, then forward to the original handler. Pushwoosh still runs the delivery event,"},{"text":" ","type":"text"},{"type":"text","text":"badge, attachment and timeout fallback."}],"type":"paragraph"},{"syntax":"swift","code":["override func didReceive(_ request: UNNotificationRequest,","                         withContentHandler contentHandler: @escaping (UNNotificationContent) -> Void) {","    super.didReceive(request) { content in","        let mutable = (content.mutableCopy() as? UNMutableNotificationContent) ?? content","        \/\/ customize `mutable` here","        contentHandler(mutable)","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"For full control, skip ","type":"text"},{"type":"codeVoice","code":"super"},{"text":" and drive everything yourself (in that case send the delivery","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"event via "},{"type":"codeVoice","code":"PWNotificationExtensionManager"},{"type":"text","text":