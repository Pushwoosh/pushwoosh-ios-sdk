"    }","","    let errorHandler: PushwooshErrorHandler = { error in","        self.logger.error(\"Failed to load preferences: \\(error?.localizedDescription ?? \"Unknown error\")\")","    }","","    Pushwoosh.configure.getTags(successHandler, onFailure: errorHandler)","}"],"type":"codeListing"}]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshGetTagsHandler","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/pushwooshframework\/pushwooshgettagshandler"],"traits":[{"interfaceLanguage":"swift"}]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshframework\/pushwooshgettagshandler"]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"metadata":{"title":"PushwooshGetTagsHandler","navigatorTitle":[{"text":"PushwooshGetTagsHandler","kind":"identifier"}],"modules":[{"name":"PushwooshFramework"}],"fragments":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"text":"PushwooshGetTagsHandler","kind":"identifier"}],"externalID":"c:PushNotificationManager.h@T@PushwooshGetTagsHandler","symbolKind":"typealias","roleHeading":"Type Alias","role":"symbol"},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"abstract":[{"text":"Completion handler called when tags are successfully retrieved from the server.","type":"text"}],"seeAlsoSections":[{"identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler","doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/Pushwoosh\/getTags(_:onFailure:)"],"title":"Related Documentation"}],"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshGetTagsHandler":{"url":"\/documentation\/pushwooshframework\/pushwooshgettagshandler","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshGetTagsHandler","abstract":[{"type":"text"