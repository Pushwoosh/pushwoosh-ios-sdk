ies = tags[\"favorite_categories\"] as? [String] {","            self.userSettings.favoriteCategories = favoriteCategories","        }","","        if let notificationsEnabled = tags[\"notifications_enabled\"] as? Bool {","            self.userSettings.notificationsEnabled = notificationsEnabled","        }","","        self.refreshUI()","    }","","    let errorHandler: PushwooshErrorHandler = { error in","        self.logger.error(\"Failed to load preferences: \\(error?.localizedDescription ?? \"Unknown error\")\")","    }","","    Pushwoosh.configure.getTags(successHandler, onFailure: errorHandler)","}"]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/pushwooshframework\/pushwooshgettagshandler"]},{"paths":["\/documentation\/pushwooshframework\/pushwooshgettagshandler"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshGetTagsHandler"},"metadata":{"symbolKind":"typealias","fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"text":"PushwooshGetTagsHandler","kind":"identifier"}],"navigatorTitle":[{"text":"PushwooshGetTagsHandler","kind":"identifier"}],"role":"symbol","title":"PushwooshGetTagsHandler","roleHeading":"Type Alias","modules":[{"name":"PushwooshFramework"}],"externalID":"c:PushNotificationManager.h@T@PushwooshGetTagsHandler"},"abstract":[{"type":"text","text":"Completion handler called when tags are successfully retrieved from the server."}],"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/Pushwoosh/getTags(_:onFailure:)":{"navigatorTitle":[{"kind":"identifier","text":"getTags:onFailure:"}],"role":"symbol","abstract":[{"type":"text","text":"Retrieves the current device’s tags from the Pushwoosh server."}],"identifier