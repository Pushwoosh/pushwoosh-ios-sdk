mple","anchor":"Example"},{"inlineContent":[{"type":"text","text":"Sync user preferences from Pushwoosh tags:"}],"type":"paragraph"},{"syntax":"swift","code":["func loadUserPreferences() {","    let successHandler: PushwooshGetTagsHandler = { tags in","        guard let tags = tags else { return }","","        if let subscriptionTier = tags[\"subscription_tier\"] as? String {","            self.userSettings.subscriptionTier = subscriptionTier","        }","","        if let favoriteCategories = tags[\"favorite_categories\"] as? [String] {","            self.userSettings.favoriteCategories = favoriteCategories","        }","","        if let notificationsEnabled = tags[\"notifications_enabled\"] as? Bool {","            self.userSettings.notificationsEnabled = notificationsEnabled","        }","","        self.refreshUI()","    }","","    let errorHandler: PushwooshErrorHandler = { error in","        self.logger.error(\"Failed to load preferences: \\(error?.localizedDescription ?? \"Unknown error\")\")","    }","","    Pushwoosh.configure.getTags(successHandler, onFailure: errorHandler)","}"],"type":"codeListing"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/pushwooshframework\/pushwooshgettagshandler"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/pushwooshframework\/pushwooshgettagshandler"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"abstract":[{"type":"text","text":"Completion handler called when tags are successfully retrieved from the server."}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework":{"identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework","title":"PushwooshFramework","role":"collection","abstract":[{"type":"text","text":"Push notification SDK for iOS applications."}],"kind":"symbo