 favoriteCategories","        }","","        if let notificationsEnabled = tags[\"notifications_enabled\"] as? Bool {","            self.userSettings.notificationsEnabled = notificationsEnabled","        }","","        self.refreshUI()","    }","","    let errorHandler: PushwooshErrorHandler = { error in","        self.logger.error(\"Failed to load preferences: \\(error?.localizedDescription ?? \"Unknown error\")\")","    }","","    Pushwoosh.configure.getTags(successHandler, onFailure: errorHandler)","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"metadata":{"role":"symbol","modules":[{"name":"PushwooshFramework"}],"title":"PushwooshGetTagsHandler","roleHeading":"Type Alias","navigatorTitle":[{"text":"PushwooshGetTagsHandler","kind":"identifier"}],"externalID":"c:PushNotificationManager.h@T@PushwooshGetTagsHandler","symbolKind":"typealias","fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"text":"PushwooshGetTagsHandler","kind":"identifier"}]},"abstract":[{"type":"text","text":"Completion handler called when tags are successfully retrieved from the server."}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshGetTagsHandler","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/pushwooshframework\/pushwooshgettagshandler"]},{"paths":["\/documentation\/pushwooshframework\/pushwooshgettagshandler"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshGetTagsHandler":{"type":"topic","role":"symbol","kind":"symbol","navigatorTitle":[{"text":"PushwooshGetTagsHandler","kind":"identifier"}],"abstract":[{"type":"text","text":"Completion handler called when tags are successfu