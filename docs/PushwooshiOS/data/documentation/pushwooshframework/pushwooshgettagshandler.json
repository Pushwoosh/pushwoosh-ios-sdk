Example","level":2,"anchor":"Example","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Sync user preferences from Pushwoosh tags:"}]},{"type":"codeListing","code":["func loadUserPreferences() {","    let successHandler: PushwooshGetTagsHandler = { tags in","        guard let tags = tags else { return }","","        if let subscriptionTier = tags[\"subscription_tier\"] as? String {","            self.userSettings.subscriptionTier = subscriptionTier","        }","","        if let favoriteCategories = tags[\"favorite_categories\"] as? [String] {","            self.userSettings.favoriteCategories = favoriteCategories","        }","","        if let notificationsEnabled = tags[\"notifications_enabled\"] as? Bool {","            self.userSettings.notificationsEnabled = notificationsEnabled","        }","","        self.refreshUI()","    }","","    let errorHandler: PushwooshErrorHandler = { error in","        self.logger.error(\"Failed to load preferences: \\(error?.localizedDescription ?? \"Unknown error\")\")","    }","","    Pushwoosh.configure.getTags(successHandler, onFailure: errorHandler)","}"],"syntax":"swift"}],"kind":"content"}],"abstract":[{"text":"Completion handler called when tags are successfully retrieved from the server.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/pushwooshframework\/pushwooshgettagshandler"]},{"paths":["\/documentation\/pushwooshframework\/pushwooshgettagshandler"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshGetTagsHandler"},"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshGetTagsHandler":{"role":"symbol","fragments":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PushwooshGetTagsHandler"}],"abstract":[{"type":"text","text":"Completion handler c