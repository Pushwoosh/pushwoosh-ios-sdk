{"abstract":[{"type":"text","text":"Completion handler called when tags are successfully retrieved from the server."}],"metadata":{"fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"PushwooshGetTagsHandler"}],"roleHeading":"Type Alias","modules":[{"name":"PushwooshFramework"}],"navigatorTitle":[{"text":"PushwooshGetTagsHandler","kind":"identifier"}],"symbolKind":"typealias","externalID":"c:PushNotificationManager.h@T@PushwooshGetTagsHandler","title":"PushwooshGetTagsHandler","role":"symbol"},"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler","doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/Pushwoosh\/getTags(_:onFailure:)"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/pushwooshframework\/pushwooshgettagshandler"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/pushwooshframework\/pushwooshgettagshandler"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"text":"PushwooshGetTagsHandler","kind":"identifier"},{"kind":"text","text":" = (["},{"preciseIdentifier":"s:s11AnyHashableV","text":"AnyHashable","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"text":"Any","kind":"keyword"},{"text":"]?) -> ","kind":"text"},{"preciseIdentifier":"s:s4Voida","kind":"typeIdentifier","text":"Void"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"This closure is called when the ","type":"text"},{"code":"getTags:onFailure:","type":"codeVoice"},{"type":"text","text":" method successfully retrieves device tags from Pushwoosh servers."}]},{"inlineContent":[{"text":"The handler receives a dictionary where keys are tag names and values are the corresponding tag values. The dictionary can contain various types including strings, numbers, booleans, dates, and arrays.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Example","anchor":"Example","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Sync user preferences from Pushwoosh tags:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["func loadUserPreferences() {","    let successHandler: PushwooshGetTagsHandler = { tags in","        guard let tags = tags else { return }","","        if let subscriptionTier = tags[\"subscription_tier\"] as? String {","            self.userSettings.subscriptionTier = subscriptionTier","        }","","        if let favoriteCategories = tags[\"favorite_categories\"] as? [String] {","            self.userSettings.favoriteCategories = favoriteCategories","        }","","        if let notificationsEnabled = tags[\"notifications_enabled\"] as? Bool {","            self.userSettings.notificationsEnabled = notificationsEnabled","        }","","        self.refreshUI()","    }","","    let errorHandler: PushwooshErrorHandler = { error in","        self.logger.error(\"Failed to load preferences: \\(error?.localizedDescription ?? \"Unknown error\")\")","    }","","    Pushwoosh.configure.getTags(successHandler, onFailure: errorHandler)","}"]}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshGetTagsHandler","interfaceLanguage":"swift"},"sections":[],"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework":{"abstract":[{"text":"Push notification SDK for iOS applications.","type":"text"}],"title":"PushwooshFramework","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework","kind":"symbol","type":"topic","u