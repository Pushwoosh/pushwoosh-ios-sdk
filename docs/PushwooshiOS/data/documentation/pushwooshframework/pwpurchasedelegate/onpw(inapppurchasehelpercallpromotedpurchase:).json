{"abstract":[{"type":"text","text":"Tells the delegate that a user initiates an IAP buy from the App Store."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"optional"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onPW"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"inAppPurchaseHelperCallPromotedPurchase"},{"text":" ","kind":"text"},{"text":"identifier","kind":"internalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"kind":"text","text":"?)"}]}],"kind":"declarations"},{"content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"text":"This method is called when a user initiates an in-app purchase directly from the App Store (promoted IAP). Use this to handle the promoted purchase flow and start the transaction.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Promoted purchases allow users to discover and buy in-app purchases directly from the App Store product page, before even launching your app."}],"type":"paragraph"},{"text":"Example","anchor":"Example","level":2,"type":"heading"},{"inlineContent":[{"text":"Handle promoted purchase from App Store:","type":"text"}],"type":"paragraph"},{"code":["class PurchaseManager: NSObject, PWPurchaseDelegate {","","    func onPW(inAppPurchaseHelperCallPromotedPurchase identifier: String) {","        analytics.track(\"promoted_purchase_initiated\", properties: [","            \"product_id\": identifier","        ])","","        if shouldDeferPurchase(identifier) {","            storeDeferredPurchase(identifier)","            showOnboardingFlow()","        } else {","            startPurchaseFlow(productIdentifier: identifier)","        }","    }","","    private func shouldDeferPurchase(_ identifier: String) -> Bool {","        return !userManager.isLoggedIn || !onboardingManager.isComplete","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/pushwooshframework\/pwpurchasedelegate\/onpw(inapppurchasehelpercallpromotedpurchase:)"]},{"paths":["\/documentation\/pushwooshframework\/pwpurchasedelegate\/onpw(inapppurchasehelpercallpromotedpurchase:)"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"modules":[{"name":"PushwooshFramework"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"onPW","kind":"identifier"},{"text":"(","kind":"text"},{"text":"inAppPurchaseHelperCallPromotedPurchase","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":"?)","kind":"text"}],"roleHeading":"Instance Method","role":"symbol","required":true,"title":"onPW(inAppPurchaseHelperCallPromotedPurchase:)","externalID":"c:objc(pl)PWPurchaseDelegate(im)onPWInAppPurchaseHelperCallPromotedPurchase:","symbolKind":"method","navigatorTitle":[{"kind":"identifier","text":"onPWInAppPurchaseHelperCallPromotedPurchase:"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWPurchaseDelegate\/onPW(inAppPurchaseHelperCallPromotedPurchase:)"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework","doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWPurchaseDelegate"]]},"kind":"symbol","sections":[],"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PWPurchaseDelegate/onPW(inAppPurchaseHelperCallPromotedPurchase:)":{"abstract":[{"type":"text","text":"Tells the delegate that a user initiates an IAP buy from the App Store."}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"onPW","kind":"identifier"},{"text"