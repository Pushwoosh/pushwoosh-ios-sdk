:"This method is called when a user initiates an in-app purchase directly from the App Store (promoted IAP). Use this to handle the promoted purchase flow and start the transaction."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Promoted purchases allow users to discover and buy in-app purchases directly from the App Store product page, before even launching your app."}],"type":"paragraph"},{"type":"heading","text":"Example","level":2,"anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle promoted purchase from App Store:"}]},{"type":"codeListing","syntax":"swift","code":["class PurchaseManager: NSObject, PWPurchaseDelegate {","","    func onPW(inAppPurchaseHelperCallPromotedPurchase identifier: String) {","        analytics.track(\"promoted_purchase_initiated\", properties: [","            \"product_id\": identifier","        ])","","        if shouldDeferPurchase(identifier) {","            storeDeferredPurchase(identifier)","            showOnboardingFlow()","        } else {","            startPurchaseFlow(productIdentifier: identifier)","        }","    }","","    private func shouldDeferPurchase(_ identifier: String) -> Bool {","        return !userManager.isLoggedIn || !onboardingManager.isComplete","    }","}"]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework","doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWPurchaseDelegate"]]},"abstract":[{"type":"text","text":"Tells the delegate that a user initiates an IAP buy from the App Store."}],"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PWPurchaseDelegate":{"url":"\/documentation\/pushwooshframework\/pwpurchasedelegate","title":"PWPurchaseDelegate","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWPurchaseDelegate","type":"topic","role":"symbol","navigatorTitle":[{"text":"PWPurchaseDelegate","kind":"ident