ow()","        } else {","            startPurchaseFlow(productIdentifier: identifier)","        }","    }","","    private func shouldDeferPurchase(_ identifier: String) -> Bool {","        return !userManager.isLoggedIn || !onboardingManager.isComplete","    }","}"],"syntax":"swift"}],"kind":"content"}],"metadata":{"externalID":"c:objc(pl)PWPurchaseDelegate(im)onPWInAppPurchaseHelperCallPromotedPurchase:","modules":[{"name":"PushwooshFramework"}],"symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onPW","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"inAppPurchaseHelperCallPromotedPurchase"},{"kind":"text","text":": "},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":"?)","kind":"text"}],"role":"symbol","required":true,"navigatorTitle":[{"kind":"identifier","text":"onPWInAppPurchaseHelperCallPromotedPurchase:"}],"roleHeading":"Instance Method","title":"onPW(inAppPurchaseHelperCallPromotedPurchase:)"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework","doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWPurchaseDelegate"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/pushwooshframework\/pwpurchasedelegate\/onpw(inapppurchasehelpercallpromotedpurchase:)"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshframework\/pwpurchasedelegate\/onpw(inapppurchasehelpercallpromotedpurchase:)"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework":{"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework","type":"topic","role":"collection","abstract":[{"text":"Push notification SDK for iOS applications.","type":"text"}],"title":"PushwooshFramework","url":"\/documentation\/pushwooshframework"},