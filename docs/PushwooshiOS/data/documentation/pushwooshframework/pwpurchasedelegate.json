 return }","","        Analytics.log(\"purchase_complete\", [\"product\": identifier])","        PremiumManager.shared.unlock(productId: identifier)","    }","","    func onPWInAppPurchaseHelperPaymentFailed(productIdentifier identifier: String?, error: Error?) {","        Analytics.log(\"purchase_failed\", [","            \"product\": identifier ?? \"\",","            \"error\": error?.localizedDescription ?? \"\"","        ])","    }","","    func onPWInAppPurchaseHelperCallPromotedPurchase(_ identifier: String?) {","        guard let identifier = identifier else { return }","","        showPurchaseConfirmation(for: identifier)","    }","","    func onPWInAppPurchaseHelperRestoreCompletedTransactionsFailed(_ error: Error?) {","        showError(\"Failed to restore purchases: \\(error?.localizedDescription ?? \"Unknown error\")\")","    }","}"]}],"kind":"content"}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWPurchaseDelegate","interfaceLanguage":"swift"},"sections":[],"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PWPurchaseDelegate":{"abstract":[{"type":"text","text":"Delegate protocol for handling in-app purchase events from rich media."}],"navigatorTitle":[{"text":"PWPurchaseDelegate","kind":"identifier"}],"role":"symbol","url":"\/documentation\/pushwooshframework\/pwpurchasedelegate","type":"topic","title":"PWPurchaseDelegate","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"PWPurchaseDelegate","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWPurchaseDelegate"},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PWPurchaseDelegate/onPW(inAppPurchaseHelperCallPromotedPurchase:)":{"title":"onPW(inAppPurchaseHelperCallPromotedPurchase:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onPW","kind":"identifier"},{"kind":"te