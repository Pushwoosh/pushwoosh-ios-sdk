pe":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"This method is invoked when a user explicitly taps on a notification banner or notification in the Notification Center. Use this method to:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Navigate to relevant content","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Open deep links","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Track user engagement with notifications","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Perform actions based on notification type"}]}]}]},{"text":"Timing","level":2,"anchor":"Timing","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"This method is called:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"When user taps notification while app is in background"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"When user taps notification while app is terminated (app is launched first)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"NOT called for silent\/background notifications","type":"text"}]}]}]},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"inlineContent":[{"type":"text","text":"Handle deep links from notification:"}],"type":"paragraph"},{"syntax":"swift","code":["func pushwoosh(_ pushwoosh: Pushwoosh, onMessageOpened message: PWMessage) {","    Analytics.log(\"push_opened\", [","        \"campaign_id\": message.customData?[\"campaign_id\"] ?? \"\"","    ])","","    guard let customData = message.customData else { return }","","    if let deepLink = customData[\"deep_link\"] as? String,","       let url = URL(string: deepLink) {","        DeepLinkRouter.shared.handle(url)","        return","    }","","    if let screen = customData[\"screen\"] as? String {","        navigateToScreen(screen, params: customData)","    }","}","","private func navigateToScreen(_ screen: String, params: [AnyHashable: Any]) {","    switch screen {","    case \"order_details\":","        if let orderId = params[\"order_id\"] as? String {","            router.push(OrderDetailsViewController(orderId: orderId))","        }","    case \"product\":","        if let productId = params[\"product_id\"] as? String {","            router.push(ProductViewController(productId: productId))","        }","    case \"promo\":","        if let promoCode = params[\"promo_code\"] as? String {","            router.push(PromoViewController(code: promoCode))","        }","    default:","        break","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Open specific tab when notification is tapped:","type":"text"}]},{"code":["func pushwoosh(_ pushwoosh: Pushwoosh, onMessageOpened message: PWMessage) {","    guard let tabIndex = message.customData?[\"tab\"] as? Int else { return }","","    if let tabBarController = window?.rootViewController as? UITabBarController {","        tabBarController.selectedIndex = tabIndex","    }","}"],"syntax":"swift","type":"codeListing"}]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWMessagingDelegate\/pushwoosh(_:onMessageOpened:)","interfaceLanguage":"swift"},"seeAlsoSections":[{"identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWMessagingDelegate\/pushwoosh(_:onMessageReceived:)","doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/Pushwoosh\/delegate"],"title":"Related Documentation"},{"identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWMessagingDelegate\/pushwoosh(_:onMessageReceived:)"],"generated":true,"title":"Handling Notifications"}],"kind":"symbol","variants":[{"paths":["\/documentation\/pushwooshframework\/pwmessagingdelegate\