h","preciseIdentifier":"c:objc(cs)Pushwoosh","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"onMessageOpened","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"message","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"PWMessage","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)PWMessage"},{"kind":"text","text":")"}],"languages":["swift"],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"This method is invoked when a user explicitly taps on a notification banner or notification in the Notification Center. Use this method to:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Navigate to relevant content"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Open deep links","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Track user engagement with notifications"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Perform actions based on notification type"}]}]}],"type":"unorderedList"},{"text":"Timing","level":2,"type":"heading","anchor":"Timing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method is called:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"When user taps notification while app is in background","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When user taps notification while app is terminated (app is launched first)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"NOT called for silent\/background notifications"}]}]}]},{"type":"heading","text":"Example","anchor":"Example","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle deep links from notification:"}]},{"type":"codeListing","code":["func pushwoosh(_ pushwoosh: Pushwoosh, onMessageOpened message: PWMessage) {","    Analytics.log(\"push_opened\", [","        \"campaign_id\": message.customData?[\"campaign_id\"] ?? \"\"","    ])","","    guard let customData = message.customData else { return }","","    if let deepLink = customData[\"deep_link\"] as? String,","       let url = URL(string: deepLink) {","        DeepLinkRouter.shared.handle(url)","        return","    }","","    if let screen = customData[\"screen\"] as? String {","        navigateToScreen(screen, params: customData)","    }","}","","private func navigateToScreen(_ screen: String, params: [AnyHashable: Any]) {","    switch screen {","    case \"order_details\":","        if let orderId = params[\"order_id\"] as? String {","            router.push(OrderDetailsViewController(orderId: orderId))","        }","    case \"product\":","        if let productId = params[\"product_id\"] as? String {","            router.push(ProductViewController(productId: productId))","        }","    case \"promo\":","        if let promoCode = params[\"promo_code\"] as? String {","            router.push(PromoViewController(code: promoCode))","        }","    default:","        break","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Open specific tab when notification is tapped:","type":"text"}]},{"code":["func pushwoosh(_ pushwoosh: Pushwoosh, onMessageOpened message: PWMessage) {","    guard let tabIndex = message.customData?[\"tab\"] as? Int else { return }","","    if let tabBarController = window?.rootViewController as? UITabBarController {","        tabBarController.selectedIndex = tabIndex","    }","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"kind":"symbol","abstract":[{"type":"text","text":"Called when the user taps on a push notification."}],"seeAlsoSections":[{"identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWMessagingDelegate\/pushwoosh(_:onMessageReceived:)","doc:\/\/com.push