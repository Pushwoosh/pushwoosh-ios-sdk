pe":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When user taps notification while app is terminated (app is launched first)"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"NOT called for silent\/background notifications"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"text":"Example","type":"heading","anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle deep links from notification:"}]},{"code":["func pushwoosh(_ pushwoosh: Pushwoosh, onMessageOpened message: PWMessage) {","    Analytics.log(\"push_opened\", [","        \"campaign_id\": message.customData?[\"campaign_id\"] ?? \"\"","    ])","","    guard let customData = message.customData else { return }","","    if let deepLink = customData[\"deep_link\"] as? String,","       let url = URL(string: deepLink) {","        DeepLinkRouter.shared.handle(url)","        return","    }","","    if let screen = customData[\"screen\"] as? String {","        navigateToScreen(screen, params: customData)","    }","}","","private func navigateToScreen(_ screen: String, params: [AnyHashable: Any]) {","    switch screen {","    case \"order_details\":","        if let orderId = params[\"order_id\"] as? String {","            router.push(OrderDetailsViewController(orderId: orderId))","        }","    case \"product\":","        if let productId = params[\"product_id\"] as? String {","            router.push(ProductViewController(productId: productId))","        }","    case \"promo\":","        if let promoCode = params[\"promo_code\"] as? String {","            router.push(PromoViewController(code: promoCode))","        }","    default:","        break","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Open specific tab when notification is tapped:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["func pushwoosh(_ pushwoosh: Pushwoosh, onMessageOpened message: PWMessage) {","    guard let tabIndex = message.customData?[\"tab\"] as? Int else { return }","","    if let tabBarController = window?.rootViewController as? UITabBarController {","        tabBarController.selectedIndex = tabIndex","    }","}"]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework":{"type":"topic","kind":"symbol","title":"PushwooshFramework","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework","url":"\/documentation\/pushwooshframework","role":"collection","abstract":[{"type":"text","text":"Push notification SDK for iOS applications."}]},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/Pushwoosh":{"url":"\/documentation\/pushwooshframework\/pushwoosh","role":"symbol","title":"Pushwoosh","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/Pushwoosh","type":"topic","kind":"symbol","navigatorTitle":[{"text":"Pushwoosh","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Pushwoosh","kind":"identifier"}],"abstract":[{"type":"text","text":"Main SDK interface for push notification management."}]},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/Pushwoosh/delegate":{"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"delegate","kind":"identifier"},{"kind":"text","text":": (any "},{"text":"PWMessagingDelegate","kind":"typeIdentifier","preciseIdentifier":"c:objc(pl)PWMessagingDelegate"},{"kind":"text","text":")?"}],"type":"topic","url":"\/documentation\/pushwooshframework\/pushwoosh\/delegate","abstract":[{"text":"Delegate that receives push notification events.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"delegate"}],"role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/Pushwoosh\/delegate","kind":"symbol","title":"delegate"},"doc://com.pushwoo