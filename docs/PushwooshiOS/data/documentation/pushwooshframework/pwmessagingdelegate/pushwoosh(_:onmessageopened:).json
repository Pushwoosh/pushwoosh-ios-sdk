otification while app is in background","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When user taps notification while app is terminated (app is launched first)"}]}]},{"content":[{"inlineContent":[{"text":"NOT called for silent\/background notifications","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","text":"Example","anchor":"Example","level":2},{"inlineContent":[{"type":"text","text":"Handle deep links from notification:"}],"type":"paragraph"},{"type":"codeListing","code":["func pushwoosh(_ pushwoosh: Pushwoosh, onMessageOpened message: PWMessage) {","    Analytics.log(\"push_opened\", [","        \"campaign_id\": message.customData?[\"campaign_id\"] ?? \"\"","    ])","","    guard let customData = message.customData else { return }","","    if let deepLink = customData[\"deep_link\"] as? String,","       let url = URL(string: deepLink) {","        DeepLinkRouter.shared.handle(url)","        return","    }","","    if let screen = customData[\"screen\"] as? String {","        navigateToScreen(screen, params: customData)","    }","}","","private func navigateToScreen(_ screen: String, params: [AnyHashable: Any]) {","    switch screen {","    case \"order_details\":","        if let orderId = params[\"order_id\"] as? String {","            router.push(OrderDetailsViewController(orderId: orderId))","        }","    case \"product\":","        if let productId = params[\"product_id\"] as? String {","            router.push(ProductViewController(productId: productId))","        }","    case \"promo\":","        if let promoCode = params[\"promo_code\"] as? String {","            router.push(PromoViewController(code: promoCode))","        }","    default:","        break","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Open specific tab when notification is tapped:"}]},{"code":["func pushwoosh(_ pushwoosh: Pushwoosh, onMessageOpened message: PWMessage) {","    guard let tabIndex = message.customData?[\"tab\"] as? Int else { return }","","    if let tabBarController = window?.rootViewController as? UITabBarController {","        tabBarController.selectedIndex = tabIndex","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"seeAlsoSections":[{"identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWMessagingDelegate\/pushwoosh(_:onMessageReceived:)","doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/Pushwoosh\/delegate"],"title":"Related Documentation"},{"title":"Handling Notifications","identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWMessagingDelegate\/pushwoosh(_:onMessageReceived:)"],"generated":true}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework","doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWMessagingDelegate"]]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWMessagingDelegate\/pushwoosh(_:onMessageOpened:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Called when the user taps on a push notification."}],"metadata":{"roleHeading":"Instance Method","externalID":"c:objc(pl)PWMessagingDelegate(im)pushwoosh:onMessageOpened:","role":"symbol","navigatorTitle":[{"text":"pushwoosh:onMessageOpened:","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"pushwoosh"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)Pushwoosh","text":"Pushwoosh","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"onMessageOpened","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:objc(cs)PWMessage","kind":"typeIdentifier","text":"PWMessage"},{"text":")","kind":"text"}],"required":true,"symbolKind":"method","modules":[{"name":"PushwooshFramework"}],"title":"pushwoosh(_:onMessageOpe