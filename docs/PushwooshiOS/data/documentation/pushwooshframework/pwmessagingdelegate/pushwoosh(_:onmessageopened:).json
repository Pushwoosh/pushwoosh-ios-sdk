{"abstract":[{"type":"text","text":"Called when the user taps on a push notification."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework","doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWMessagingDelegate"]]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWMessagingDelegate\/pushwoosh(_:onMessageOpened:)","interfaceLanguage":"swift"},"metadata":{"externalID":"c:objc(pl)PWMessagingDelegate(im)pushwoosh:onMessageOpened:","roleHeading":"Instance Method","title":"pushwoosh(_:onMessageOpened:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"pushwoosh"},{"kind":"text","text":"("},{"text":"Pushwoosh","preciseIdentifier":"c:objc(cs)Pushwoosh","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"onMessageOpened","kind":"externalParam"},{"kind":"text","text":": "},{"text":"PWMessage","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)PWMessage"},{"kind":"text","text":")"}],"navigatorTitle":[{"text":"pushwoosh:onMessageOpened:","kind":"identifier"}],"modules":[{"name":"PushwooshFramework"}],"symbolKind":"method","role":"symbol"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/pushwooshframework\/pwmessagingdelegate\/pushwoosh(_:onmessageopened:)"]},{"paths":["\/documentation\/pushwooshframework\/pwmessagingdelegate\/pushwoosh(_:onmessageopened:)"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"seeAlsoSections":[{"identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWMessagingDelegate\/pushwoosh(_:onMessageReceived:)","doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/Pushwoosh\/delegate"],"title":"Related Documentation"},{"identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWMessagingDelegate\/pushwoosh