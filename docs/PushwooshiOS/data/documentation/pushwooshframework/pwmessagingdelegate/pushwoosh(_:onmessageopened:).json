in the Notification Center. Use this method to:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"text":"Navigate to relevant content","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Open deep links"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Track user engagement with notifications","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Perform actions based on notification type"}]}]}],"type":"unorderedList"},{"text":"Timing","level":2,"type":"heading","anchor":"Timing"},{"type":"paragraph","inlineContent":[{"text":"This method is called:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"When user taps notification while app is in background","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When user taps notification while app is terminated (app is launched first)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"NOT called for silent\/background notifications","type":"text"}]}]}]},{"level":2,"type":"heading","anchor":"Example","text":"Example"},{"type":"paragraph","inlineContent":[{"text":"Handle deep links from notification:","type":"text"}]},{"code":["func pushwoosh(_ pushwoosh: Pushwoosh, onMessageOpened message: PWMessage) {","    Analytics.log(\"push_opened\", [","        \"campaign_id\": message.customData?[\"campaign_id\"] ?? \"\"","    ])","","    guard let customData = message.customData else { return }","","    if let deepLink = customData[\"deep_link\"] as? String,","       let url = URL(string: deepLink) {","        DeepLinkRouter.shared.handle(url)","        return","    }","","    if let screen = customData[\"screen\"] as? String {","        navigateToScreen(screen, params: customData)","    }","}","","private func navigateToScreen(_ screen: String, params: [AnyHashable: Any]) {","    switch screen {","    case \"order_details\":","        if let orderId = params[\"order_id\"] as? String {","            router.push(OrderDetailsViewController(orderId: orderId))","        }","    case \"product\":","        if let productId = params[\"product_id\"] as? String {","            router.push(ProductViewController(productId: productId))","        }","    case \"promo\":","        if let promoCode = params[\"promo_code\"] as? String {","            router.push(PromoViewController(code: promoCode))","        }","    default:","        break","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Open specific tab when notification is tapped:","type":"text"}]},{"code":["func pushwoosh(_ pushwoosh: Pushwoosh, onMessageOpened message: PWMessage) {","    guard let tabIndex = message.customData?[\"tab\"] as? Int else { return }","","    if let tabBarController = window?.rootViewController as? UITabBarController {","        tabBarController.selectedIndex = tabIndex","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"abstract":[{"type":"text","text":"Called when the user taps on a push notification."}],"kind":"symbol","metadata":{"roleHeading":"Instance Method","required":true,"title":"pushwoosh(_:onMessageOpened:)","externalID":"c:objc(pl)PWMessagingDelegate(im)pushwoosh:onMessageOpened:","role":"symbol","modules":[{"name":"PushwooshFramework"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"pushwoosh"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)Pushwoosh","text":"Pushwoosh","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"onMessageOpened"},{"text":": ","kind":"text"},{"text":"PWMessage","preciseIdentifier":"c:objc(cs)PWMessage","kind":"typeIdentifier"},{"kind":"text","text":")"}],"navigatorTitle":[{"text":"pushwoosh:onMessageOpened:","kind":"identifier"}],"symbolKind":"method"},"variants":[{"paths":["\/documentation\/