{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWMessagingDelegate\/pushwoosh(_:onMessageOpened:)"},"metadata":{"role":"symbol","externalID":"c:objc(pl)PWMessagingDelegate(im)pushwoosh:onMessageOpened:","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"pushwoosh","kind":"identifier"},{"text":"(","kind":"text"},{"text":"Pushwoosh","preciseIdentifier":"c:objc(cs)Pushwoosh","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"onMessageOpened","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:objc(cs)PWMessage","kind":"typeIdentifier","text":"PWMessage"},{"text":")","kind":"text"}],"roleHeading":"Instance Method","title":"pushwoosh(_:onMessageOpened:)","symbolKind":"method","required":true,"modules":[{"name":"PushwooshFramework"}],"navigatorTitle":[{"text":"pushwoosh:onMessageOpened:","kind":"identifier"}]},"kind":"symbol","seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWMessagingDelegate\/pushwoosh(_:onMessageReceived:)","doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/Pushwoosh\/delegate"]},{"identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWMessagingDelegate\/pushwoosh(_:onMessageReceived:)"],"title":"Handling Notifications","generated":true}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework","doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWMessagingDelegate"]]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"optional"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"pushwoosh"},{"kind":"text","text":"("},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"kind":"internalParam","text":"pushwoosh"},{"kind":"text","text":": "},{"identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/Pushwoosh","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)Pushwoosh","text":"Pushwoosh"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"onMessageOpened"},{"text":" ","kind":"text"},{"text":"message","kind":"internalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:objc(cs)PWMessage","text":"PWMessage","kind":"typeIdentifier"},{"text":")","kind":"text"}]}]},{"content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method is invoked when a user explicitly taps on a notification banner or notification in the Notification Center. Use this method to:"}]},{"items":[{"content":[{"inlineContent":[{"text":"Navigate to relevant content","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Open deep links","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Track user engagement with notifications"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Perform actions based on notification type"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Timing","type":"heading","level":2,"text":"Timing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method is called:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"When user taps notification while app is in background","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"When user taps notification while app is terminated (app is launched first)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"NOT called for silent\/background notifications"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Example","level":2,"text":"Example","type":"heading"},{"inlineContent":[{"text":"Handle deep links from notification:","type":"text"}],"type":"paragraph"},{"code":["func pushwoosh(_ pushwoosh: Pushwoosh, onMessageOpened message: PWMessage) {","    Analytics.log(\"push_opened\", [","        \"campaign_id\": message.customData?[\"campaign_id\"] ?? \"\"","    ])","","    guard let customData = message.customData else { return }","","    if let deepLink = customData[\"deep_link\"] as? String,","       let url = URL(string: deepLink) {","        DeepLinkRouter.shared.handle(url)","        return","    }","","    if let screen = customData[\"screen\"] as? String {","        navigateToScreen(screen, params: customData)","    }","}","","private func navigateToScreen(_ screen: String, params: [AnyHashable: Any]) {","    switch screen {","    case \"order_details\":","        if let orderId = params[\"order_id\"] as? String {","            router.push(OrderDetailsViewController(orderId: orderId))","        }","    case \"product\":","        if let productId = params[\"product_id\"] as? String {","            router.push(ProductViewController(productId: productId))","        }","    case \"promo\":","        if let promoCode = params[\"promo_code\"] as? String {","            router.push(PromoViewController(code: promoCode))","        }","    default:","        break","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Open specific tab when notification is tapped:"}]},{"code":["func pushwoosh(_ pushwoosh: Pushwoosh, onMessageOpened message: PWMessage) {","    guard let tabIndex = message.customData?[\"tab\"] as? Int else { return }","","    if let tabBarController = window?.rootViewController as? UITabBarController {","        tabBarController.selectedIndex = tabIndex","    }","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"abstract":[{"text":"Called when the user taps on a push notification.","type":"text"}],"variants":[{"traits":[{"interfaceLangua