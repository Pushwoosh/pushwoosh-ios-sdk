{"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"optional"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"pushwoosh"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"kind":"text","text":" "},{"kind":"internalParam","text":"pushwoosh"},{"text":": ","kind":"text"},{"text":"Pushwoosh","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/Pushwoosh","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)Pushwoosh"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"onMessageOpened"},{"text":" ","kind":"text"},{"kind":"internalParam","text":"message"},{"kind":"text","text":": "},{"preciseIdentifier":"c:objc(cs)PWMessage","kind":"typeIdentifier","text":"PWMessage"},{"text":")","kind":"text"}],"languages":["swift"],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"inlineContent":[{"text":"This method is invoked when a user explicitly taps on a notification banner or notification in the Notification Center. Use this method to:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Navigate to relevant content","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Open deep links"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Track user engagement with notifications"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Perform actions based on notification type"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"text":"Timing","anchor":"Timing","type":"heading"},{"inlineContent":[{"type":"text","text":"This method is called:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"When user taps notification while app is in background","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"When user taps notification while app is terminated (app is launched first)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"NOT called for silent\/background notifications","type":"text"}],"type":"paragraph"}]}]},{"text":"Example","type":"heading","anchor":"Example","level":2},{"inlineContent":[{"text":"Handle deep links from notification:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["func pushwoosh(_ pushwoosh: Pushwoosh, onMessageOpened message: PWMessage) {","    Analytics.log(\"push_opened\", [","        \"campaign_id\": message.customData?[\"campaign_id\"] ?? \"\"","    ])","","    guard let customData = message.customData else { return }","","    if let deepLink = customData[\"deep_link\"] as? String,","       let url = URL(string: deepLink) {","        DeepLinkRouter.shared.handle(url)","        return","    }","","    if let screen = customData[\"screen\"] as? String {","        navigateToScreen(screen, params: customData)","    }","}","","private func navigateToScreen(_ screen: String, params: [AnyHashable: Any]) {","    switch screen {","    case \"order_details\":","        if let orderId = params[\"order_id\"] as? String {","            router.push(OrderDetailsViewController(orderId: orderId))","        }","    case \"product\":","        if let productId = params[\"product_id\"] as? String {","            router.push(ProductViewController(productId: productId))","        }","    case \"promo\":","        if let promoCode = params[\"promo_code\"] as? String {","            router.push(PromoViewController(code: promoCode))","        }","    default:","        break","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Open specific tab when notification is tapped:"}]},{"type":"codeListing","syntax":"swift","code":["func pushwoosh(_ pushwoosh: Pushwoosh, onMessageOpened message: PWMessage) {","    guard let tabIndex = message.customData?[\"tab\"] as? Int else { return }","","    if let tabBarController = window?.rootViewController as? UITabBarController {","        tabBarController.selectedIndex = tabIndex","    }","}"]}]}],"abstract":[{"text":"Called when the user taps on a push notification.","type":"text"}],"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWMessagingDelegate\/pushwoosh(_:onMessageReceived:)","doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/Pushwoosh\/delegate"]},{"title":"Handling Notifications","generated":true,"identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWMessagingDelegate\/pushwoosh(_:onMessageReceived:)"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/pushwooshframework\/pwmessagingdelegate\/pushwoosh(_:onmessageopened:)"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshframework\/pwmessagingdelegate\/pushwoosh(_:onmessageopened:)"]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework","doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PWMessagingDelegate"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"role":"symbol","modules":[{"name":"PushwooshFramework"}],"symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"pushwoosh"},{"kind":"text","text":"("},{"text":"Pushwoosh","preciseIdentifier":"c:objc(cs)Pushwoosh","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"onMessageOpened","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"PWMessage","preciseIdentifier":"c:objc(cs)PWMessage"},{"kind":"text","text":")"}],"roleHeading":"Instance Method","externalID":"c:objc(pl)PWMessagingDelegate(im)pushwoosh:onMessageOpened:","title":"pushwoo