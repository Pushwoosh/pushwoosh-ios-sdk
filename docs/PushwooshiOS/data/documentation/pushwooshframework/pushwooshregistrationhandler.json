{"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshframework\/pushwooshregistrationhandler"]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"abstract":[{"text":"Completion handler called when push notification registration completes.","type":"text"}],"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshRegistrationHandler"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"text":"typedef","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"typeIdentifier","text":"void (^)(NSString *, NSError *)","preciseIdentifier":"c:BFv(#*$objc(cs)NSString#*$objc(cs)NSError)"},{"text":" ","kind":"text"},{"text":"PushwooshRegistrationHandler","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"]}]},{"content":[{"type":"heading","anchor":"Overview","text":"Overview","level":2},{"inlineContent":[{"type":"text","text":"This closure is called when the device registration process finishes, either successfully or with an error."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The handler receives two parameters:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"token","type":"text"}]},{"type":"text","text":": The push token string if registration succeeded, or "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" if it failed"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"error"}]},{"text":": An error object if registration failed, or ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" if it succeeded","type":"text"}]}]}]},{"type":"heading","anchor":"Example","text":"Example","level":2},{"type":"paragraph","inlineContent":[{"text":"Handle registration result with UI updates and backend sync:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["func registerForNotifications() {","    let registrationHandler: PushwooshRegistrationHandler = { token, error in","        if let error = error {","            self.logger.error(\"Push registration failed: \\(error.localizedDescription)\")","            self.updateNotificationStatus(.failed)","            return","        }","","        guard let token = token else { return }","","        self.logger.info(\"Push token received: \\(token.prefix(20))...\")","        self.updateNotificationStatus(.registered)","","        self.syncPushTokenWithBackend(token)","    }","","    Pushwoosh.configure.registerForPushNotifications(withCompletion: registrationHandler)","}","","func syncPushTokenWithBackend(_ token: String) {","    let hwid = Pushwoosh.configure.getHWID()","    apiClient.post(\"\/devices\/register\", body: [","        \"push_token\": token,","        \"hwid\": hwid,","        \"platform\": \"ios\"","    ])","}"]}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler"]}],"metadata":{"role":"symbol","modules":[{"name":"PushwooshFramework"}],"fragments":[{"text":"PushwooshRegistrationHandler","kind":"identifier"}],"roleHeading":"Type Alias","symbolKind":"typealias","externalID":"c:PWTypes.h@T@PushwooshRegistrationHandler","navigatorTitle":[{"kind":"identifier","text":"PushwooshRegistrationHandler"}],"title":"PushwooshRegistrationHandler"},"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework":{"title":"PushwooshFramework","url":"\/documentation\/pushwooshframework","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework","abstract":[{"text":"Push notification SDK for iOS applications.","type":"text"}],"type"