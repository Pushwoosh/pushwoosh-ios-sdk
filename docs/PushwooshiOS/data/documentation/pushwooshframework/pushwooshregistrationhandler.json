{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshRegistrationHandler","interfaceLanguage":"occ"},"metadata":{"fragments":[{"kind":"identifier","text":"PushwooshRegistrationHandler"}],"symbolKind":"typealias","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"PushwooshRegistrationHandler"}],"roleHeading":"Type Alias","modules":[{"name":"PushwooshFramework"}],"externalID":"c:PWTypes.h@T@PushwooshRegistrationHandler","title":"PushwooshRegistrationHandler"},"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"kind":"symbol","seeAlsoSections":[{"identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler"],"title":"Related Documentation"}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"typedef","kind":"keyword"},{"text":" ","kind":"text"},{"text":"void (^)(NSString *, NSError *)","preciseIdentifier":"c:BFv(#*$objc(cs)NSString#*$objc(cs)NSError)","kind":"typeIdentifier"},{"kind":"text","text":" "},{"kind":"identifier","text":"PushwooshRegistrationHandler"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"This closure is called when the device registration process finishes, either successfully or with an error."}],"type":"paragraph"},{"inlineContent":[{"text":"The handler receives two parameters:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"token"}]},{"type":"text","text":": The push token string if registration succeeded, or "},{"type":"codeVoice","code":"nil"},{"text":" if it failed","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"error"}]},{"text":": An error object if registration failed, or ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" if it succeeded"}],"type":"paragraph"}]}]},{"text":"Example","anchor":"Example","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Handle registration result with UI updates and backend sync:"}],"type":"paragraph"},{"code":["func registerForNotifications() {","    let registrationHandler: PushwooshRegistrationHandler = { token, error in","        if let error = error {","            self.logger.error(\"Push registration failed: \\(error.localizedDescription)\")","            self.updateNotificationStatus(.failed)","            return","        }","","        guard let token = token else { return }","","        self.logger.info(\"Push token received: \\(token.prefix(20))...\")","        self.updateNotificationStatus(.registered)","","        self.syncPushTokenWithBackend(token)","    }","","    Pushwoosh.configure.registerForPushNotifications(withCompletion: registrationHandler)","}","","func syncPushTokenWithBackend(_ token: String) {","    let hwid = Pushwoosh.configure.getHWID()","    apiClient.post(\"\/devices\/register\", body: [","        \"push_token\": token,","        \"hwid\": hwid,","        \"platform\": \"ios\"","    ])","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"abstract":[{"type":"text","text":"Completion handler called when push notification registration completes."}],"variants":[{"paths":["\/documentation\/pushwooshframework\/pushwooshregistrationhandler"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshErrorHandler":{"fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"PushwooshErrorHandler"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler",