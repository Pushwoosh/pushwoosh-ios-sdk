{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshRegistrationHandler","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"typedef","kind":"keyword"},{"kind":"text","text":" "},{"text":"void (^)(NSString *, NSError *)","preciseIdentifier":"c:BFv(#*$objc(cs)NSString#*$objc(cs)NSError)","kind":"typeIdentifier"},{"kind":"text","text":" "},{"text":"PushwooshRegistrationHandler","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"text":"This closure is called when the device registration process finishes, either successfully or with an error.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The handler receives two parameters:"}]},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"token","type":"text"}],"type":"strong"},{"text":": The push token string if registration succeeded, or ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" if it failed","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"error","type":"text"}]},{"type":"text","text":": An error object if registration failed, or "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" if it succeeded"}]}]}],"type":"unorderedList"},{"text":"Example","anchor":"Example","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Handle registration result with UI updates and backend sync:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["func registerForNotifications() {","    let registrationHandler: PushwooshRegistrationHandler = { token, error in","        if let error = error {","            self.logger.error(\"Push registration failed: \\(error.localizedDescription)\")","            self.updateNotificationStatus(.failed)","            return","        }","","        guard let token = token else { return }","","        self.logger.info(\"Push token received: \\(token.prefix(20))...\")","        self.updateNotificationStatus(.registered)","","        self.syncPushTokenWithBackend(token)","    }","","    Pushwoosh.configure.registerForPushNotifications(withCompletion: registrationHandler)","}","","func syncPushTokenWithBackend(_ token: String) {","    let hwid = Pushwoosh.configure.getHWID()","    apiClient.post(\"\/devices\/register\", body: [","        \"push_token\": token,","        \"hwid\": hwid,","        \"platform\": \"ios\"","    ])","}"]}],"kind":"content"}],"sections":[],"metadata":{"navigatorTitle":[{"text":"PushwooshRegistrationHandler","kind":"identifier"}],"symbolKind":"typealias","role":"symbol","externalID":"c:PWTypes.h@T@PushwooshRegistrationHandler","fragments":[{"kind":"identifier","text":"PushwooshRegistrationHandler"}],"modules":[{"name":"PushwooshFramework"}],"title":"PushwooshRegistrationHandler","roleHeading":"Type Alias"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshframework\/pushwooshregistrationhandler"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Completion handler called when push notification registration completes."}],"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler"]}],"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshRegistrationHandler":{"identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshRegistrationHandler","kind":"symbol","role":"symbol","type":"topic","fragments":[{"text":"PushwooshRegistrationHandler","kind":"identifier"