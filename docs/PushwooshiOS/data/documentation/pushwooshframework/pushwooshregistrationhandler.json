{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshRegistrationHandler","interfaceLanguage":"occ"},"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler"]}],"abstract":[{"type":"text","text":"Completion handler called when push notification registration completes."}],"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"navigatorTitle":[{"text":"PushwooshRegistrationHandler","kind":"identifier"}],"title":"PushwooshRegistrationHandler","symbolKind":"typealias","fragments":[{"kind":"identifier","text":"PushwooshRegistrationHandler"}],"modules":[{"name":"PushwooshFramework"}],"role":"symbol","externalID":"c:PWTypes.h@T@PushwooshRegistrationHandler","roleHeading":"Type Alias"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"typedef","kind":"keyword"},{"text":" ","kind":"text"},{"text":"void (^)(NSString *, NSError *)","kind":"typeIdentifier","preciseIdentifier":"c:BFv(#*$objc(cs)NSString#*$objc(cs)NSError)"},{"kind":"text","text":" "},{"kind":"identifier","text":"PushwooshRegistrationHandler"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This closure is called when the device registration process finishes, either successfully or with an error."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The handler receives two parameters:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"token"}],"type":"strong"},{"text":": The push token string if registration succeeded, or ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" if it failed","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"error","type":"text"}]},{"text":": An error object if registration failed, or ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" if it succeeded","type":"text"}]}]}]},{"anchor":"Example","level":2,"text":"Example","type":"heading"},{"inlineContent":[{"type":"text","text":"Handle registration result with UI updates and backend sync:"}],"type":"paragraph"},{"code":["func registerForNotifications() {","    let registrationHandler: PushwooshRegistrationHandler = { token, error in","        if let error = error {","            self.logger.error(\"Push registration failed: \\(error.localizedDescription)\")","            self.updateNotificationStatus(.failed)","            return","        }","","        guard let token = token else { return }","","        self.logger.info(\"Push token received: \\(token.prefix(20))...\")","        self.updateNotificationStatus(.registered)","","        self.syncPushTokenWithBackend(token)","    }","","    Pushwoosh.configure.registerForPushNotifications(withCompletion: registrationHandler)","}","","func syncPushTokenWithBackend(_ token: String) {","    let hwid = Pushwoosh.configure.getHWID()","    apiClient.post(\"\/devices\/register\", body: [","        \"push_token\": token,","        \"hwid\": hwid,","        \"platform\": \"ios\"","    ])","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshframework\/pushwooshregistrationhandler"]}],"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshRegistrationHandler":{"kind":"symbol","fragments":[{"kind":"identifier","text":"PushwooshRegistrationHandler"}],"type":"topic","abstract":[{"text":"Completion handler called when push notification registration completes.","type":"text"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshRegistrationHandler","title":"PushwooshRegistrationHandler","url":"\/documentation\/pushwooshframework\/pushwooshregistrationhandler","role":"symbol"},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshErrorHandler":{"kind":"symbol","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"text":"PushwooshErrorHandler","kind":"identifier"}],"type":"topic","abstract":[{"type":"text","text":"Completion handler called when an operation fails."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler","navigatorTitle":[{"kind":"identifier","text":"PushwooshErrorHandler"}],"url":"\/documentation\/pushwooshframework\/pushwoosherrorhandler","title":"PushwooshErrorHandler","role":"symbol"},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework":{"type":"topic","kind":"symbol","title":"PushwooshFramework","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework","url":"\/documentation\/pushwooshframework","role":"collection","abstract":[{"type":"text","text":"Push notification SDK for iOS applications."}]}},"variantOverrides":[{"patch":[{"path":"\/references\/doc:~1~1com.pushwoosh.PushwooshiOS~1documentation~1PushwooshFramework~1PushwooshErrorHandler\/title","value":"PushwooshErrorHandler","op":"replace"},{"path":"\/references\/doc:~1~1com.pushwoosh.PushwooshiOS~1documentation~1PushwooshFramework~1PushwooshErrorHandler\/fragments","value":[{"text":"PushwooshErrorHandler","kind":"identifier"}],"op":"replace"}],"traits":[{"interfaceLanguage":"occ"}]}]}