{"sections":[],"abstract":[{"text":"Completion handler called when push notification registration completes.","type":"text"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"seeAlsoSections":[{"identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler"],"title":"Related Documentation"}],"kind":"symbol","variants":[{"paths":["\/documentation\/pushwooshframework\/pushwooshregistrationhandler"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshRegistrationHandler","interfaceLanguage":"occ"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"typedef","kind":"keyword"},{"kind":"text","text":" "},{"text":"void (^)(NSString *, NSError *)","kind":"typeIdentifier","preciseIdentifier":"c:BFv(#*$objc(cs)NSString#*$objc(cs)NSError)"},{"kind":"text","text":" "},{"kind":"identifier","text":"PushwooshRegistrationHandler"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}]},{"content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"inlineContent":[{"type":"text","text":"This closure is called when the device registration process finishes, either successfully or with an error."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The handler receives two parameters:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"token","type":"text"}]},{"text":": The push token string if registration succeeded, or ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" if it failed","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"error"}]},{"type":"text","text":": An error object if registration failed, or "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" if it succeeded"}]}]}]},{"text":"Example","level":2,"type":"heading","anchor":"Example"},{"type":"paragraph","inlineContent":[{"text":"Handle registration result with UI updates and backend sync:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["func registerForNotifications() {","    let registrationHandler: PushwooshRegistrationHandler = { token, error in","        if let error = error {","            self.logger.error(\"Push registration failed: \\(error.localizedDescription)\")","            self.updateNotificationStatus(.failed)","            return","        }","","        guard let token = token else { return }","","        self.logger.info(\"Push token received: \\(token.prefix(20))...\")","        self.updateNotificationStatus(.registered)","","        self.syncPushTokenWithBackend(token)","    }","","    Pushwoosh.configure.registerForPushNotifications(withCompletion: registrationHandler)","}","","func syncPushTokenWithBackend(_ token: String) {","    let hwid = Pushwoosh.configure.getHWID()","    apiClient.post(\"\/devices\/register\", body: [","        \"push_token\": token,","        \"hwid\": hwid,","        \"platform\": \"ios\"","    ])","}"]}],"kind":"content"}],"metadata":{"navigatorTitle":[{"text":"PushwooshRegistrationHandler","kind":"identifier"}],"fragments":[{"kind":"identifier","text":"PushwooshRegistrationHandler"}],"modules":[{"name":"PushwooshFramework"}],"externalID":"c:PWTypes.h@T@PushwooshRegistrationHandler","role":"symbol","roleHeading":"Type Alias","title":"PushwooshRegistrationHandler","symbolKind":"typealias"},"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshRegistrationHandler":{"role":"symbol","title":"PushwooshRegistrationHandler","abstract":[{"text":"Completion handler called when push notification registration completes.","type":"text"}],"fragments":[{"text":"PushwooshRegistrationHandler","kind":"identifier"}],"url":"\/documentation\/pushwooshframework\/pushwooshregistrationhandler","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshRegistrationHandler","type":"topic"},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework":{"url":"\/documentation\/pushwooshframework","abstract":[{"text":"Push notification SDK for iOS applications.","type":"text"}],"role":"collection","kind":"symbol","type":"topic","title":"PushwooshFramework","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshErrorHandler":{"abstract":[{"type":"text","text":"Completion handler called when an operation fails."}],"kind":"symbol","url":"\/documentation\/pushwooshframework\/pushwoosherrorhandler","navigatorTitle":[{"text":"PushwooshErrorHandler","kind":"identifier"}],"title":"PushwooshErrorHandler","fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"text":"PushwooshErrorHandler","kind":"identifier"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler","type":"topic","role":"symbol"}},"variantOverrides":[{"traits":[{"interfaceLanguage":"occ"}],"patch":[{"op":"replace","value":"PushwooshErrorHandler","path":"\/references\/doc:~1~1com.pushwoosh.PushwooshiOS~1documentation~1PushwooshFramework~1PushwooshErrorHandler\/title"},{"value":[{"text":"PushwooshErrorHandler","kind":"identifier"}],"path":"\/references\/doc:~1~1com.pushwoosh.PushwooshiOS~1documentation~1PushwooshFramework~1PushwooshErrorHandler\/fragments","op":"replace"}]}]}