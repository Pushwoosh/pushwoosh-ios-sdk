{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshRegistrationHandler","interfaceLanguage":"occ"},"sections":[],"abstract":[{"type":"text","text":"Completion handler called when push notification registration completes."}],"seeAlsoSections":[{"identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler"],"title":"Related Documentation"}],"metadata":{"fragments":[{"kind":"identifier","text":"PushwooshRegistrationHandler"}],"symbolKind":"typealias","navigatorTitle":[{"kind":"identifier","text":"PushwooshRegistrationHandler"}],"role":"symbol","roleHeading":"Type Alias","externalID":"c:PWTypes.h@T@PushwooshRegistrationHandler","title":"PushwooshRegistrationHandler","modules":[{"name":"PushwooshFramework"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"typedef"},{"text":" ","kind":"text"},{"text":"void (^)(NSString *, NSError *)","preciseIdentifier":"c:BFv(#*$objc(cs)NSString#*$objc(cs)NSError)","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PushwooshRegistrationHandler"},{"text":";","kind":"text"}]}]},{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This closure is called when the device registration process finishes, either successfully or with an error."}]},{"inlineContent":[{"type":"text","text":"The handler receives two parameters:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"token"}],"type":"strong"},{"text":": The push token string if registration succeeded, or ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" if it failed"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"error"}],"type":"strong"},{"text":": An error object if registration failed, or ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" if it succeeded","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle registration result with UI updates and backend sync:"}]},{"type":"codeListing","syntax":"swift","code":["func registerForNotifications() {","    let registrationHandler: PushwooshRegistrationHandler = { token, error in","        if let error = error {","            self.logger.error(\"Push registration failed: \\(error.localizedDescription)\")","            self.updateNotificationStatus(.failed)","            return","        }","","        guard let token = token else { return }","","        self.logger.info(\"Push token received: \\(token.prefix(20))...\")","        self.updateNotificationStatus(.registered)","","        self.syncPushTokenWithBackend(token)","    }","","    Pushwoosh.configure.registerForPushNotifications(withCompletion: registrationHandler)","}","","func syncPushTokenWithBackend(_ token: String) {","    let hwid = Pushwoosh.configure.getHWID()","    apiClient.post(\"\/devices\/register\", body: [","        \"push_token\": token,","        \"hwid\": hwid,","        \"platform\": \"ios\"","    ])","}"]}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshframework\/pushwooshregistrationhandler"]}],"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshErrorHandler":{"url":"\/documentation\/pushwooshframework\/pushwoosherrorhandler","kind":"symbol","title":"PushwooshErrorHandler","abstract":[{"type":"text","text":"Completion handler called when an operation fails."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler","type":"topic","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"PushwooshErrorHandler"}],"navigatorTitle":[{"text":"PushwooshErrorHandler","kind":"identifier"}],"role":"symbol"},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework":{"url":"\/documentation\/pushwooshframework","kind":"symbol","type":"topic","title":"PushwooshFramework","role":"collection","abstract":[{"text":"Push notification SDK for iOS applications.","type":"text"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshRegistrationHandler":{"fragments":[{"text":"PushwooshRegistrationHandler","kind":"identifier"}],"role":"symbol","kind":"symbol","type":"topic","url":"\/documentation\/pushwooshframework\/pushwooshregistrationhandler","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshRegistrationHandler","title":"PushwooshRegistrationHandler","abstract":[{"type":"text","text":"Completion handler called when push notification registration completes."}]}},"variantOverrides":[{"patch":[{"value":"PushwooshErrorHandler","op":"replace","path":"\/references\/doc:~1~1com.pushwoosh.PushwooshiOS~1documentation~1PushwooshFramework~1PushwooshErrorHandler\/title"},{"op":"replace","value":[{"text":"PushwooshErrorHandler","kind":"identifier"}],"path":"\/references\/doc:~1~1com.pushwoosh.PushwooshiOS~1documentation~1PushwooshFramework~1PushwooshErrorHandler\/fragments"}],"traits":[{"interfaceLanguage":"occ"}]}]}