{"metadata":{"title":"PushwooshRegistrationHandler","roleHeading":"Type Alias","symbolKind":"typealias","navigatorTitle":[{"text":"PushwooshRegistrationHandler","kind":"identifier"}],"role":"symbol","fragments":[{"kind":"identifier","text":"PushwooshRegistrationHandler"}],"externalID":"c:PWTypes.h@T@PushwooshRegistrationHandler","modules":[{"name":"PushwooshFramework"}]},"variants":[{"paths":["\/documentation\/pushwooshframework\/pushwooshregistrationhandler"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Completion handler called when push notification registration completes."}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"seeAlsoSections":[{"identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler"],"title":"Related Documentation"}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshRegistrationHandler","interfaceLanguage":"occ"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"typedef"},{"text":" ","kind":"text"},{"preciseIdentifier":"c:BFv(#*$objc(cs)NSString#*$objc(cs)NSError)","kind":"typeIdentifier","text":"void (^)(NSString *, NSError *)"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PushwooshRegistrationHandler"},{"kind":"text","text":";"}]}]},{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This closure is called when the device registration process finishes, either successfully or with an error."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The handler receives two parameters:"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"token","type":"text"}]},{"text":": The push token string if registration succeeded, or ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" if it failed","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"error","type":"text"}],"type":"strong"},{"type":"text","text":": An error object if registration failed, or "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" if it succeeded"}]}]}],"type":"unorderedList"},{"level":2,"type":"heading","anchor":"Example","text":"Example"},{"inlineContent":[{"text":"Handle registration result with UI updates and backend sync:","type":"text"}],"type":"paragraph"},{"code":["func registerForNotifications() {","    let registrationHandler: PushwooshRegistrationHandler = { token, error in","        if let error = error {","            self.logger.error(\"Push registration failed: \\(error.localizedDescription)\")","            self.updateNotificationStatus(.failed)","            return","        }","","        guard let token = token else { return }","","        self.logger.info(\"Push token received: \\(token.prefix(20))...\")","        self.updateNotificationStatus(.registered)","","        self.syncPushTokenWithBackend(token)","    }","","    Pushwoosh.configure.registerForPushNotifications(withCompletion: registrationHandler)","}","","func syncPushTokenWithBackend(_ token: String) {","    let hwid = Pushwoosh.configure.getHWID()","    apiClient.post(\"\/devices\/register\", body: [","        \"push_token\": token,","        \"hwid\": hwid,","        \"platform\": \"ios\"","    ])","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework":{"role":"collection","url":"\/documentation\/pushwooshframework","title":"PushwooshFramework","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework","type":"topic","abstract":[{"type":"text","text":"Push notification SDK for iOS applications."}],"kind":"symbol"},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshRegistrationHandler":{"title":"PushwooshRegistrationHandler","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Completion handler called when push notification registration completes."}],"role":"symbol","url":"\/documentation\/pushwooshframework\/pushwooshregistrationhandler","fragments":[{"text":"PushwooshRegistrationHandler","kind":"identifier"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshRegistrationHandler"},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshErrorHandler":{"fragments":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"text":"PushwooshErrorHandler","kind":"identifier"}],"abstract":[{"text":"Completion handler called when an operation fails.","type":"text"}],"title":"PushwooshErrorHandler","url":"\/documentation\/pushwooshframework\/pushwoosherrorhandler","role":"symbol","navigatorTitle":[{"text":"PushwooshErrorHandler","kind":"identifier"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler"}},"variantOverrides":[{"traits":[{"interfaceLanguage":"occ"}],"patch":[{"path":"\/references\/doc:~1~1com.pushwoosh.PushwooshiOS~1documentation~1PushwooshFramework~1PushwooshErrorHandler\/title","op":"replace","value":"PushwooshErrorHandler"},{"path":"\/references\/doc:~1~1com.pushwoosh.PushwooshiOS~1documentation~1PushwooshFramework~1PushwooshErrorHandler\/fragments","value":[{"kind":"identifier","text":"PushwooshErrorHandler"}],"op":"replace"}]}]}