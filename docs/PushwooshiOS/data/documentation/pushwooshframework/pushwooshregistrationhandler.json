{"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"metadata":{"role":"symbol","fragments":[{"text":"PushwooshRegistrationHandler","kind":"identifier"}],"title":"PushwooshRegistrationHandler","modules":[{"name":"PushwooshFramework"}],"symbolKind":"typealias","externalID":"c:PWTypes.h@T@PushwooshRegistrationHandler","navigatorTitle":[{"kind":"identifier","text":"PushwooshRegistrationHandler"}],"roleHeading":"Type Alias"},"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler"]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshRegistrationHandler","interfaceLanguage":"occ"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"typedef","kind":"keyword"},{"text":" ","kind":"text"},{"text":"void (^)(NSString *, NSError *)","kind":"typeIdentifier","preciseIdentifier":"c:BFv(#*$objc(cs)NSString#*$objc(cs)NSError)"},{"text":" ","kind":"text"},{"text":"PushwooshRegistrationHandler","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"This closure is called when the device registration process finishes, either successfully or with an error.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The handler receives two parameters:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"token","type":"text"}]},{"type":"text","text":": The push token string if registration succeeded, or "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" if it failed"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"error","type":"text"}],"type":"strong"},{"text":": An error object if registration failed, or ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" if it succeeded","type":"text"}],"type":"paragraph"}]}]},{"anchor":"Example","type":"heading","text":"Example","level":2},{"inlineContent":[{"text":"Handle registration result with UI updates and backend sync:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["func registerForNotifications() {","    let registrationHandler: PushwooshRegistrationHandler = { token, error in","        if let error = error {","            self.logger.error(\"Push registration failed: \\(error.localizedDescription)\")","            self.updateNotificationStatus(.failed)","            return","        }","","        guard let token = token else { return }","","        self.logger.info(\"Push token received: \\(token.prefix(20))...\")","        self.updateNotificationStatus(.registered)","","        self.syncPushTokenWithBackend(token)","    }","","    Pushwoosh.configure.registerForPushNotifications(withCompletion: registrationHandler)","}","","func syncPushTokenWithBackend(_ token: String) {","    let hwid = Pushwoosh.configure.getHWID()","    apiClient.post(\"\/devices\/register\", body: [","        \"push_token\": token,","        \"hwid\": hwid,","        \"platform\": \"ios\"","    ])","}"],"type":"codeListing"}]}],"kind":"symbol","sections":[],"abstract":[{"type":"text","text":"Completion handler called when push notification registration completes."}],"variants":[{"paths":["\/documentation\/pushwooshframework\/pushwooshregistrationhandler"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework":{"identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework","title":"PushwooshFramework","type":"topic","kind":"symbol","abstract":[{"text":"Push notification SDK for iOS applications.","type":"text"}],"url":"\/documentation\/pushwooshframework","role":"collection"},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshRegistrationHandler":{"identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshRegistrationHandler","url":"\/documentation\/pushwooshframework\/pushwooshregistrationhandler","abstract":[{"text":"Completion handler called when push notification registration completes.","type":"text"}],"role":"symbol","title":"PushwooshRegistrationHandler","type":"topic","kind":"symbol","fragments":[{"kind":"identifier","text":"PushwooshRegistrationHandler"}]},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshErrorHandler":{"role":"symbol","abstract":[{"text":"Completion handler called when an operation fails.","type":"text"}],"url":"\/documentation\/pushwooshframework\/pushwoosherrorhandler","navigatorTitle":[{"text":"PushwooshErrorHandler","kind":"identifier"}],"type":"topic","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"text":"PushwooshErrorHandler","kind":"identifier"}],"title":"PushwooshErrorHandler"}},"variantOverrides":[{"traits":[{"interfaceLanguage":"occ"}],"patch":[{"path":"\/references\/doc:~1~1com.pushwoosh.PushwooshiOS~1documentation~1PushwooshFramework~1PushwooshErrorHandler\/title","op":"replace","value":"PushwooshErrorHandler"},{"op":"replace","path":"\/references\/doc:~1~1com.pushwoosh.PushwooshiOS~1documentation~1PushwooshFramework~1PushwooshErrorHandler\/fragments","value":[{"kind":"identifier","text":"PushwooshErrorHandler"}]}]}]}