{"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler"]}],"metadata":{"navigatorTitle":[{"text":"PushwooshRegistrationHandler","kind":"identifier"}],"title":"PushwooshRegistrationHandler","roleHeading":"Type Alias","role":"symbol","modules":[{"name":"PushwooshFramework"}],"symbolKind":"typealias","externalID":"c:PWTypes.h@T@PushwooshRegistrationHandler","fragments":[{"kind":"identifier","text":"PushwooshRegistrationHandler"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"typedef","kind":"keyword"},{"kind":"text","text":" "},{"text":"void (^)(NSString *, NSError *)","kind":"typeIdentifier","preciseIdentifier":"c:BFv(#*$objc(cs)NSString#*$objc(cs)NSError)"},{"text":" ","kind":"text"},{"text":"PushwooshRegistrationHandler","kind":"identifier"},{"kind":"text","text":";"}],"languages":["occ"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"Overview","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"This closure is called when the device registration process finishes, either successfully or with an error.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The handler receives two parameters:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"token","type":"text"}]},{"type":"text","text":": The push token string if registration succeeded, or "},{"type":"codeVoice","code":"nil"},{"text":" if it failed","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"error"}],"type":"strong"},{"text":": An error object if registration failed, or ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" if it succeeded","type":"text"}],"type":"paragraph"}]}]},{"text":"Example","type":"heading","level":2,"anchor":"Example"},{"inlineContent":[{"text":"Handle registration result with UI updates and backend sync:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["func registerForNotifications() {","    let registrationHandler: PushwooshRegistrationHandler = { token, error in","        if let error = error {","            self.logger.error(\"Push registration failed: \\(error.localizedDescription)\")","            self.updateNotificationStatus(.failed)","            return","        }","","        guard let token = token else { return }","","        self.logger.info(\"Push token received: \\(token.prefix(20))...\")","        self.updateNotificationStatus(.registered)","","        self.syncPushTokenWithBackend(token)","    }","","    Pushwoosh.configure.registerForPushNotifications(withCompletion: registrationHandler)","}","","func syncPushTokenWithBackend(_ token: String) {","    let hwid = Pushwoosh.configure.getHWID()","    apiClient.post(\"\/devices\/register\", body: [","        \"push_token\": token,","        \"hwid\": hwid,","        \"platform\": \"ios\"","    ])","}"],"type":"codeListing"}]}],"abstract":[{"type":"text","text":"Completion handler called when push notification registration completes."}],"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshRegistrationHandler"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshframework\/pushwooshregistrationhandler"]}],"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework":{"identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework","title":"PushwooshFramework","role":"collection","abstract":[{"type":"text","text":"Push notification SDK for iOS applications."}],"kind":"symbol","url":"\/documentation\/pushwooshframework","type":"topic"},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshRegistrationHandler":{"identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshRegistrationHandler","type":"topic","url":"\/documentation\/pushwooshframework\/pushwooshregistrationhandler","title":"PushwooshRegistrationHandler","abstract":[{"type":"text","text":"Completion handler called when push notification registration completes."}],"role":"symbol","fragments":[{"kind":"identifier","text":"PushwooshRegistrationHandler"}],"kind":"symbol"},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshErrorHandler":{"identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler","type":"topic","url":"\/documentation\/pushwooshframework\/pushwoosherrorhandler","title":"PushwooshErrorHandler","abstract":[{"text":"Completion handler called when an operation fails.","type":"text"}],"role":"symbol","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PushwooshErrorHandler","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"PushwooshErrorHandler"}]}},"variantOverrides":[{"patch":[{"value":"PushwooshErrorHandler","op":"replace","path":"\/references\/doc:~1~1com.pushwoosh.PushwooshiOS~1documentation~1PushwooshFramework~1PushwooshErrorHandler\/title"},{"op":"replace","value":[{"text":"PushwooshErrorHandler","kind":"identifier"}],"path":"\/references\/doc:~1~1com.pushwoosh.PushwooshiOS~1documentation~1PushwooshFramework~1PushwooshErrorHandler\/fragments"}],"traits":[{"interfaceLanguage":"occ"}]}]}