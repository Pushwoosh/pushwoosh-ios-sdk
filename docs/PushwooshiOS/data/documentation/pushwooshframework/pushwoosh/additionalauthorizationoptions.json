ype":"text","text":"When the SDK calls "},{"type":"codeVoice","code":"registerForPushNotifications"},{"type":"text","text":", it automatically requests these permissions:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":".badge","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":".sound"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":".alert","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"code":".carPlay","type":"codeVoice"}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"Use ","type":"text"},{"type":"codeVoice","code":"setAdditionalAuthorizationOptions"},{"text":" to request extra capabilities on top of the defaults. The options are combined (bitwise OR) with the defaults before being passed to ","type":"text"},{"type":"codeVoice","code":"UNUserNotificationCenter.requestAuthorization(options:)"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"heading","level":3,"text":"Available Options","anchor":"Available-Options"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Option"}]}],[{"type":"paragraph","inlineContent":[{"text":"iOS","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".provisional"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"12+"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Deliver notifications quietly without showing a permission dialog. Users see them in Notification Center and decide whether to keep or disable."}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".criticalAlert"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"12+","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bypass Do Not Disturb and the mute switch. Requires a special entitlement from Apple. For medical, health, safety, and public security apps."}]}]],[[{"inlineContent":[{"code":".providesAppNotificationSettings","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"12+","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Adds a “Configure in App” button in the system notification settings. When tapped, iOS calls "},{"code":"userNotificationCenter(_:openSettingsFor:)","type":"codeVoice"},{"type":"text","text":" on your delegate."}]}]],[[{"inlineContent":[{"code":".announcement","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"13+"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Allows Siri to read notifications aloud through AirPods and compatible headphones."}]}]]],"header":"row","type":"table"},{"type":"heading","level":2,"anchor":"Important","text":"Important"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call "},{"code":"setAdditionalAuthorizationOptions","type":"codeVoice"},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"before"}]},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/Pushwoosh\/registerForPushNotifications()","isActive":true},{"text":". Options set after registration have no effect until the next authorization request.","type":"text"}]},{"type":"heading","text":"Provisional (Soft Opt-In)","anchor":"Provisional-Soft-Opt-In","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Deliver notifications silently without prompting the user for permission. This is useful to demonstrate value before asking for full notification access:"}]},{"type":"codeListing","syntax":"swift","code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional])","    }","","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}"]},{"type":"heading","level":2,"text":"In-App Notification Settings","anchor":"In-App-Notification-Settings"},{"type":"paragraph","inlineContent":[{"text":"Add a “Configure in App” button to the system Settings > Notifications screen for your app. When the user taps it, implement the ","type":"text"},{"type":"codeVoice","code":"openSettingsFor"},{"type":"text","text":" callback to navigate to your custom settings screen:"}]},{"syntax":"swift","type":"codeListing","code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.providesAppNotificationSettings])","    }","","    Pushwoosh.configure.addNotificationCenterDelegate(self)","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}","","\/\/ Called when user taps \"Configure in App\" in system notification settings","func userNotificationCenter(_ center: UNUserNotificationCenter,","                            openSettingsFor notification: UNNotification?) {","    \/\/ Navigate to your in-app notification settings screen","}"]},{"level":2,"anchor":"Critical-Alerts","type":"heading","text":"Critical Alerts"},{"type":"paragraph","inlineContent":[{"text":"For medical, health, and safety apps that need to bypass Do Not Disturb and the mute switch. Requires a special entitlement approved by Apple:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["if #available(iOS 12.0, *) {","    Pushwoosh.configure.setAdditionalAuthorizationOptions([.criticalAlert])","}","","Pushwoosh.configure.registerForPushNotifications()"]},{"text":"Combining Multiple Options","anchor":"Combining-Multiple-Options","level":2,"type":"heading"},{"inli