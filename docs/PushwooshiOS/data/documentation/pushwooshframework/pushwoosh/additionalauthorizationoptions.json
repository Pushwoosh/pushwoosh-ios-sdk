ications screen for your app. When the user taps it, implement the ","type":"text"},{"type":"codeVoice","code":"openSettingsFor"},{"text":" callback to navigate to your custom settings screen:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.providesAppNotificationSettings])","    }","","    Pushwoosh.configure.addNotificationCenterDelegate(self)","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}","","\/\/ Called when user taps \"Configure in App\" in system notification settings","func userNotificationCenter(_ center: UNUserNotificationCenter,","                            openSettingsFor notification: UNNotification?) {","    \/\/ Navigate to your in-app notification settings screen","}"]},{"level":2,"text":"Critical Alerts","type":"heading","anchor":"Critical-Alerts"},{"type":"paragraph","inlineContent":[{"text":"For medical, health, and safety apps that need to bypass Do Not Disturb and the mute switch. Requires a special entitlement approved by Apple:","type":"text"}]},{"syntax":"swift","code":["if #available(iOS 12.0, *) {","    Pushwoosh.configure.setAdditionalAuthorizationOptions([.criticalAlert])","}","","Pushwoosh.configure.registerForPushNotifications()"],"type":"codeListing"},{"text":"Combining Multiple Options","anchor":"Combining-Multiple-Options","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Options can be combined:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["if #available(iOS 12.0, *) {","    Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional, .providesAppNotificationSettings])","}"]},{"inlineContent":[{"text":"Objective-C:","type":"text"}],"type":"paragraph"}