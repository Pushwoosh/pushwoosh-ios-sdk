ypeIdentifier","preciseIdentifier":"c:@E@UNAuthorizationOptions"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"keyword"},{"kind":"text","text":" }"}]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"Overview","text":"Overview"},{"inlineContent":[{"type":"text","text":"When the SDK calls "},{"type":"codeVoice","code":"registerForPushNotifications"},{"type":"text","text":", it automatically requests these permissions:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".badge"}]}]},{"content":[{"inlineContent":[{"code":".sound","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".alert"}]}]},{"content":[{"inlineContent":[{"code":".carPlay","type":"codeVoice"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"setAdditionalAuthorizationOptions"},{"text":" to request extra capabilities on top of the defaults. The options are combined (bitwise OR) with the defaults before being passed to ","type":"text"},{"type":"codeVoice","code":"UNUserNotificationCenter.requestAuthorization(options:)"},{"text":".","type":"text"}]},{"level":3,"text":"Available Options","type":"heading","anchor":"Available-Options"},{"type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Option"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"iOS"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"inlineContent":[{"type":"codeVoice","code":".provisional"}],"type":"paragraph"}],[{"inlineContent":[{"text":"12+","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Deliver notifications quietly without showing a permission dialog. Users see them in Notification Center and decide whether to keep or