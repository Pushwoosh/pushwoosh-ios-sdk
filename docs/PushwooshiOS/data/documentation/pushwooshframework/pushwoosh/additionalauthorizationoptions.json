{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework","doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/Pushwoosh"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"additionalAuthorizationOptions","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@E@UNAuthorizationOptions","text":"UNAuthorizationOptions","kind":"typeIdentifier"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" "},{"kind":"keyword","text":"set"},{"text":" }","kind":"text"}],"languages":["swift"],"platforms":["iOS"]}]},{"content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"When the SDK calls ","type":"text"},{"code":"registerForPushNotifications","type":"codeVoice"},{"text":", it automatically requests these permissions:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":".badge","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":".sound","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":".alert","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".carPlay"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"code":"setAdditionalAuthorizationOptions","type":"codeVoice"},{"type":"text","text":" to request extra capabilities on top of the defaults. The options are combined (bitwise OR) with the defaults before being passed to "},{"type":"codeVoice","code":"UNUserNotificationCenter.requestAuthorization(options:)"},{"text":".","type":"text"}]},{"level":3,"anchor":"Available-Options","type":"heading","text":"Available Options"},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Option","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"iOS","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Description","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".provisional"}]}],[{"inlineContent":[{"type":"text","text":"12+"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Deliver notifications quietly without showing a permission dialog. Users see them in Notification Center and decide whether to keep or disable.","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".criticalAlert","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"12+"}]}],[{"inlineContent":[{"text":"Bypass Do Not Disturb and the mute switch. Requires a special entitlement from Apple. For medical, health, safety, and public security apps.","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".providesAppNotificationSettings"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"12+"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Adds a “Configure in App” button in the system notification settings. When tapped, iOS calls "},{"type":"codeVoice","code":"userNotificationCenter(_:openSettingsFor:)"},{"type":"text","text":" on your delegate."}]}]],[[{"type":"paragraph","inlineContent":[{"code":".announcement","type":"codeVoice"}]}],[{"inlineContent":[{"type":"text","text":"13+"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Allows Siri to read notifications aloud through AirPods and compatible headphones."}],"type":"paragraph"}]]]},{"type":"heading","anchor":"Important","level":2,"text":"Important"},{"type":"paragraph","inlineContent":[{"text":"Call ","type":"text"},{"code":"setAdditionalAuthorizationOptions","type":"codeVoice"},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"before"}],"type":"strong"},{"type":"text","text":" "},{"identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/Pushwoosh\/registerForPushNotifications()","type":"reference","isActive":true},{"text":". Options set after registration have no effect until the next authorization request.","type":"text"}]},{"type":"heading","text":"Provisional (Soft Opt-In)","level":2,"anchor":"Provisional-Soft-Opt-In"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Deliver notifications silently without prompting the user for permission. This is useful to demonstrate value before asking for full notification access:"}]},{"syntax":"swift","code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional])","    }","","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}"],"type":"codeListing"},{"level":2,"text":"In-App Notification Settings","type":"heading","anchor":"In-App-Notification-Settings"},{"inlineContent":[{"type":"text","text":"Add a “Configure in App” button to the system Settings > Notifications screen for your app. When the user taps it, implement the "},{"code":"openSettingsFor","type":"codeVoice"},{"text":" callback to navigate to your custom settings screen:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.providesAppNotificationSettings])","    }","","    Pushwoosh.configure.addNotificationCenterDelegate(self)","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}","","\/\/ Called when user taps \"Configure in App\" in system notification settings","f