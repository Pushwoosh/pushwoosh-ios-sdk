ailable-Options"},{"rows":[[[{"inlineContent":[{"text":"Option","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"iOS"}]}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".provisional"}]}],[{"inlineContent":[{"type":"text","text":"12+"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Deliver notifications quietly without showing a permission dialog. Users see them in Notification Center and decide whether to keep or disable."}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".criticalAlert"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"12+"}]}],[{"inlineContent":[{"type":"text","text":"Bypass Do Not Disturb and the mute switch. Requires a special entitlement from Apple. For medical, health, safety, and public security apps."}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"code":".providesAppNotificationSettings","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"12+"}]}],[{"inlineContent":[{"text":"Adds a “Configure in App” button in the system notification settings. When tapped, iOS calls ","type":"text"},{"code":"userNotificationCenter(_:openSettingsFor:)","type":"codeVoice"},{"type":"text","text":" on your delegate."}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".announcement"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"13+","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Allows Siri to read notifications aloud through AirPods and compatible headphones.","type":"text"}]}]]],"header":"row","type":"table"},{"anchor":"Important","level":2,"text":"Important","type":"heading"},{"inlineContent":[{"text":"Call ","type":"text"},{"type":"codeVoice","code":"setAdditionalAuthorizationOptions"},{"type":"text","text":" "},{"type":"strong","i