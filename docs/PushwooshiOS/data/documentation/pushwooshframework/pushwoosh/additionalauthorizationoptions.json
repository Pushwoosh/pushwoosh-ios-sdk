":".sound"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":".alert","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":".carPlay"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"setAdditionalAuthorizationOptions"},{"text":" to request extra capabilities on top of the defaults. The options are combined (bitwise OR) with the defaults before being passed to ","type":"text"},{"type":"codeVoice","code":"UNUserNotificationCenter.requestAuthorization(options:)"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"heading","anchor":"Available-Options","level":3,"text":"Available Options"},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Option"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"iOS"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".provisional","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"12+"}]}],[{"inlineContent":[{"text":"Deliver notifications quietly without showing a permission dialog. Users see them in Notification Center and decide whether to keep or disable.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".criticalAlert"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"12+","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bypass Do Not Disturb and the mute switch. Requires a special entitlement from Apple. For medical, health, safety, and public security apps."}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".providesAppNotificationSettings"}]}],[{"inlineContent":[{"text":"12+","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Adds a “Configure in App” button in the system notification settings. When tapped, iOS calls "