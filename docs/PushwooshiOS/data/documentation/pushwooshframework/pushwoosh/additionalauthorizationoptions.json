 }","kind":"text"}],"languages":["swift"]}]},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"When the SDK calls "},{"type":"codeVoice","code":"registerForPushNotifications"},{"type":"text","text":", it automatically requests these permissions:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":".badge","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":".sound","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".alert"}]}]},{"content":[{"inlineContent":[{"code":".carPlay","type":"codeVoice"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"code":"setAdditionalAuthorizationOptions","type":"codeVoice"},{"type":"text","text":" to request extra capabilities on top of the defaults. The options are combined (bitwise OR) with the defaults before being passed to "},{"code":"UNUserNotificationCenter.requestAuthorization(options:)","type":"codeVoice"},{"text":".","type":"text"}]},{"anchor":"Available-Options","text":"Available Options","type":"heading","level":3},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Option","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"iOS"}]}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".provisional"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"12+"}]}],[{"inlineContent":[{"type":"text","text":"Deliver notifications quietly without showing a permission dialog. Users see them in Notification Center and decide whether to keep or disable."}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"code":".criticalAlert","type":"codeVoice"}]}],[{"inlineContent":[{"text":"12+","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bypass Do Not Disturb and the mute switch. Requires a special entitlement from Apple. For medical, health, safety, and public security apps."}]}]],[[{"inlineContent":[{"type":"codeVoice","code":".providesAppNotificationSettings"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"12+"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Adds a “Configure in App” button in the system notification settings. When tapped, iOS calls ","type":"text"},{"type":"codeVoice","code":"userNotificationCenter(_:openSettingsFor:)"},{"type":"text","text":" on your delegate."}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".announcement"}]}],[{"inlineContent":[{"text":"13+","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Allows Siri to read notifications aloud through AirPods and compatible headphones."}]}]]]},{"anchor":"Important","type":"heading","level":2,"text":"Important"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call "},{"type":"codeVoice","code":"setAdditionalAuthorizationOptions"},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"text":"before","type":"text"}]},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/Pushwoosh\/registerForPushNotifications()"},{"type":"text","text":". Options set after registration have no effect until the next authorization request."}]},{"text":"Provisional (Soft Opt-In)","type":"heading","level":2,"anchor":"Provisional-Soft-Opt-In"},{"type":"paragraph","inlineContent":[{"text":"Deliver notifications silently without prompting the user for permission. This is useful to demonstrate value before asking for full notification access:","type":"text"}]},{"code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOpti