","content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"This method combines device registration and tag assignment, providing a callback when the operation completes. Use this when you need to know whether registration succeeded and want to set initial tags.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The tags are only set if registration succeeds. If registration fails, the tags will not be applied."}]},{"level":2,"anchor":"Example","text":"Example","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Register with user profile data and handle result:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["func completeUserSignup(user: User) {","    let userTags: [String: Any] = [","        \"user_id\": user.id,","        \"subscription_plan\": user.subscriptionPlan,","        \"account_type\": user.accountType,","        \"signup_date\": Date()","    ]","","    Pushwoosh.configure.registerForPushNotifications(with: userTags) { token, error in","        if let error = error {","            self.logger.error(\"Registration failed: \\(error.localizedDescription)\")","            self.analytics.track(\"push_registration_failed\")","            return","        }","","        self.logger.info(\"Push registration successful\")","        self.analytics.track(\"push_registration_success\", properties: [","            \"has_token\": token != nil","        ])","","        self.updateOnboardingProgress(.notificationsEnabled)","    }","}"]}]}],"metadata":{"externalID":"c:objc(cs)Pushwoosh(im)registerForPushNotificationsWith:completion:","symbolKind":"method","roleHeading":"Instance Method","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"registerForPushNotificationsWith:completion:"}],"title":"registerForPushNotifications(with:completion:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text