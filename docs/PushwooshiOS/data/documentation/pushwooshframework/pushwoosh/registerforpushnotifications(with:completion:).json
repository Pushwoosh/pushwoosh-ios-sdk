 ]","","    Pushwoosh.configure.registerForPushNotifications(with: userTags) { token, error in","        if let error = error {","            self.logger.error(\"Registration failed: \\(error.localizedDescription)\")","            self.analytics.track(\"push_registration_failed\")","            return","        }","","        self.logger.info(\"Push registration successful\")","        self.analytics.track(\"push_registration_success\", properties: [","            \"has_token\": token != nil","        ])","","        self.updateOnboardingProgress(.notificationsEnabled)","    }","}"]}]}],"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshRegistrationHandler":{"kind":"symbol","title":"PushwooshRegistrationHandler","url":"\/documentation\/pushwooshframework\/pushwooshregistrationhandler","abstract":[{"text":"Completion handler called when push notification registration completes.","type":"text"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshRegistrationHandler","role":"symbol","type":"topic","fragments":[{"kind":"identifier","text":"PushwooshRegistrationHandler"}]},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/Pushwoosh":{"identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/Pushwoosh","type":"topic","url":"\/documentation\/pushwooshframework\/pushwoosh","abstract":[{"type":"text","text":"Main SDK interface for push notification management."}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Pushwoosh","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"Pushwoosh"}],"title":"Pushwoosh","role":"symbol","kind":"symbol"},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/Pushwoosh/registerForPushNotifications(with:completion:)":{"title":"registerForPushNotifications(with:completion:)","navigatorTitle":[{"text":"registerForPushNotificationsWith:completion:","kind":"iden