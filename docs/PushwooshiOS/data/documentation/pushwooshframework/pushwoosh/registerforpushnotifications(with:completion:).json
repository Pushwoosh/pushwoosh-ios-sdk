.registerForPushNotifications(with: userTags) { token, error in","        if let error = error {","            self.logger.error(\"Registration failed: \\(error.localizedDescription)\")","            self.analytics.track(\"push_registration_failed\")","            return","        }","","        self.logger.info(\"Push registration successful\")","        self.analytics.track(\"push_registration_success\", properties: [","            \"has_token\": token != nil","        ])","","        self.updateOnboardingProgress(.notificationsEnabled)","    }","}"]}],"kind":"content"}],"sections":[],"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/Pushwoosh/registerForPushNotifications(with:)":{"kind":"symbol","navigatorTitle":[{"text":"registerForPushNotificationsWith:","kind":"identifier"}],"role":"symbol","title":"registerForPushNotifications(with:)","type":"topic","url":"\/documentation\/pushwooshframework\/pushwoosh\/registerforpushnotifications(with:)","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/Pushwoosh\/registerForPushNotifications(with:)","abstract":[{"type":"text","text":"Registers the device for push notifications and sets initial tags."}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"registerForPushNotifications","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"with"},{"text":": [","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:s11AnyHashableV","text":"AnyHashable"},{"kind":"text","text":" : "},{"text":"Any","kind":"keyword"},{"text":"])","kind":"text"}]},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/Pushwoosh":{"identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/Pushwoosh","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Pushwoosh"}],"abstract":[{"text":"Main SDK interface for push notifica