{"abstract":[{"type":"text","text":"Registers the device for push notifications with initial tags and a completion handler."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"registerForPushNotifications","kind":"identifier"},{"kind":"text","text":"("},{"text":"with","kind":"externalParam"},{"text":" ","kind":"text"},{"kind":"internalParam","text":"tags"},{"kind":"text","text":": ["},{"preciseIdentifier":"s:s11AnyHashableV","text":"AnyHashable","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"kind":"keyword","text":"Any"},{"kind":"text","text":"], "},{"text":"completion","kind":"externalParam"},{"kind":"text","text":": "},{"text":"PushwooshRegistrationHandler","preciseIdentifier":"c:PWTypes.h@T@PushwooshRegistrationHandler","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshRegistrationHandler","kind":"typeIdentifier"},{"text":"? = nil)","kind":"text"}],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","anchor":"Overview","level":2,"type":"heading"},{"inlineContent":[{"text":"This method combines device registration and tag assignment, providing a callback when the operation completes. Use this when you need to know whether registration succeeded and want to set initial tags.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The tags are only set if registration succeeds. If registration fails, the tags will not be applied.","type":"text"}]},{"type":"heading","anchor":"Example","level":2,"text":"Example"},{"type":"paragraph","inlineContent":[{"text":"Register with user profile data and handle result:","type":"text"}]},{"syntax":"swift","code":["func completeUserSignup(user: User) {","    let userTags: [String: Any] = [","        \"user_id\": user.id,","        \"subscription_plan\": user.subscriptionPlan,","        \"account_type\": user.accountType,","        \"signup_date\": Date()","    ]","","    Pushwoosh.configure.registerForPushNotifications(with: userTags) { token, error in","        if let error = error {","            self.logger.error(\"Registration failed: \\(error.localizedDescription)\")","            self.analytics.track(\"push_registration_failed\")","            return","        }","","        self.logger.info(\"Push registration successful\")","        self.analytics.track(\"push_registration_success\", properties: [","            \"has_token\": token != nil","        ])","","        self.updateOnboardingProgress(.notificationsEnabled)","    }","}"],"type":"codeListing"}]}],"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/Pushwoosh\/registerForPushNotifications(with:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/Pushwoosh\/registerForPushNotifications(with:completion:)"},"metadata":{"title":"registerForPushNotifications(with:completion:)","navigatorTitle":[{"text":"registerForPushNotificationsWith:completion:","kind":"identifier"}],"roleHeading":"Instance Method","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"registerForPushNotifications","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"with"},{"text":": [","kind":"text"},{"kind":"typeIdentifier","text":"AnyHashable","preciseIdentifier":"s:s11AnyHashableV"},{"text":" : ","kind":"text"},{"kind":"keyword","text":"Any"},{"kind":"text","text":"], "},{"kind":"externalParam","text":"completion"},{"kind":"text","text":": "},{"preciseIdentifier":"c:PWTypes.h@T@PushwooshRegistrationHandler","kind":"typeIdentifier","text":"PushwooshRegistrationHandler"},{"text":"?)","kind":"text"}],"symbolKind":"method","externalID":"c:objc(cs)Pushwoosh(im)registerForPushNotificationsWith:completion:","modules":[{"name":