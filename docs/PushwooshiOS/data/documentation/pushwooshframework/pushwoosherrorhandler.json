t < 3 {","                DispatchQueue.main.asyncAfter(deadline: .now() + 2.0) {","                    self.setUserPreferences(preferences, retryCount: retryCount + 1)","                }","            } else {","                self.showAlert(title: \"Sync Error\", message: \"Could not save preferences. Please try again later.\")","            }","        }","    }","","    Pushwoosh.configure.setTags(preferences, onFailure: errorHandler)","}"],"type":"codeListing"}],"kind":"content"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/pushwooshframework\/pushwoosherrorhandler"]},{"paths":["\/documentation\/pushwooshframework\/pushwoosherrorhandler"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"modules":[{"name":"PushwooshFramework"}],"symbolKind":"typealias","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"text":"PushwooshErrorHandler","kind":"identifier"}],"roleHeading":"Type Alias","externalID":"c:PushNotificationManager.h@T@PushwooshErrorHandler","navigatorTitle":[{"kind":"identifier","text":"PushwooshErrorHandler"}],"role":"symbol","title":"PushwooshErrorHandler"},"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshErrorHandler":{"navigatorTitle":[{"kind":"identifier","text":"PushwooshErrorHandler"}],"type":"topic","title":"PushwooshErrorHandler","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler","url":"\/documentation\/pushwooshframework\/pushwoosherrorhandler","kind":"symbol","abstract":[{"text":"Completion handler called when an operation fails.","type":"text"}],"role":"symbol","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"PushwooshErrorHandler"}]},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework":{"kind":"