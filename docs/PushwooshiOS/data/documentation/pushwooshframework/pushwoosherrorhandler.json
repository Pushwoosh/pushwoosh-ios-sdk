 ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":", the operation succeeded (though typically success handlers use different callback types)."}]},{"level":2,"anchor":"Example","text":"Example","type":"heading"},{"inlineContent":[{"type":"text","text":"Handle tag setting errors with retry logic:"}],"type":"paragraph"},{"type":"codeListing","code":["func setUserPreferences(_ preferences: [String: Any], retryCount: Int = 0) {","    let errorHandler: PushwooshErrorHandler = { error in","        if let error = error {","            self.logger.error(\"Failed to set tags: \\(error.localizedDescription)\")","","            if retryCount < 3 {","                DispatchQueue.main.asyncAfter(deadline: .now() + 2.0) {","                    self.setUserPreferences(preferences, retryCount: retryCount + 1)","                }","            } else {","                self.showAlert(title: \"Sync Error\", message: \"Could not save preferences. Please try again later.\")","            }","        }","    }","","    Pushwoosh.configure.setTags(preferences, onFailure: errorHandler)","}"],"syntax":"swift"}]}],"abstract":[{"type":"text","text":"Completion handler called when an operation fails."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshGetTagsHandler":{"role":"symbol","fragments":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PushwooshGetTagsHandler"}],"abstract":[{"type":"text","text":"Completion handler called when tags are successfully retrieved from the server."}],"title":"PushwooshGetTagsHandler","kind":"symbol","url":"\/documentation\/pushwooshframework\/pushwooshgettagshandler","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshGetTagsHandler","type":"topic","navigatorTitle":[{"text":"PushwooshGetTagsHandler","kind":"identifier"}]},"doc://com.pushwoosh.PushwooshiOS/do