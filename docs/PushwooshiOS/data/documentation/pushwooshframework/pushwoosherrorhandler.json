ferences, retryCount: retryCount + 1)","                }","            } else {","                self.showAlert(title: \"Sync Error\", message: \"Could not save preferences. Please try again later.\")","            }","        }","    }","","    Pushwoosh.configure.setTags(preferences, onFailure: errorHandler)","}"]}]}],"metadata":{"role":"symbol","symbolKind":"typealias","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PushwooshErrorHandler","kind":"identifier"}],"navigatorTitle":[{"text":"PushwooshErrorHandler","kind":"identifier"}],"modules":[{"name":"PushwooshFramework"}],"roleHeading":"Type Alias","title":"PushwooshErrorHandler","externalID":"c:PushNotificationManager.h@T@PushwooshErrorHandler"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/pushwooshframework\/pushwoosherrorhandler"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshframework\/pushwoosherrorhandler"]}],"seeAlsoSections":[{"identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshGetTagsHandler"],"title":"Related Documentation"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework":{"type":"topic","kind":"symbol","title":"PushwooshFramework","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework","url":"\/documentation\/pushwooshframework","role":"collection","abstract":[{"type":"text","text":"Push notification SDK for iOS applications."}]},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshRegistrationHandler":{"kind":"symbol","fragments":[{"kind":"identifier","text":"PushwooshRegistrationHandler"}],"type":"topic","abstract":[{"text":"Completion handler called when push notification registration completes.","type":"text"}],"identifier":"doc:\/\/com.pushwoosh.Pushw