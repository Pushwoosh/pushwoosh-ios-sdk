{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler"},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","metadata":{"role":"symbol","symbolKind":"typealias","fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"text":"PushwooshErrorHandler","kind":"identifier"}],"title":"PushwooshErrorHandler","modules":[{"name":"PushwooshFramework"}],"navigatorTitle":[{"text":"PushwooshErrorHandler","kind":"identifier"}],"externalID":"c:PushNotificationManager.h@T@PushwooshErrorHandler","roleHeading":"Type Alias"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshGetTagsHandler"]}],"sections":[],"abstract":[{"text":"Completion handler called when an operation fails.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PushwooshErrorHandler","kind":"identifier"},{"text":" = ((any ","kind":"text"},{"preciseIdentifier":"s:s5ErrorP","text":"Error","kind":"typeIdentifier"},{"kind":"text","text":")?) -> "},{"preciseIdentifier":"s:s4Voida","text":"Void","kind":"typeIdentifier"}],"languages":["swift"]}]},{"content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"This closure is called when a Pushwoosh operation fails, providing an error object describing what went wrong.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The handler receives an optional "},{"code":"NSError","type":"codeVoice"},{"type":"text","text":" parameter. If the error is "},{"code":"nil","type":"codeVoice"},{"text":", the operation succeeded (though typically success handlers use different callback types).","type":"text"}]},{"type":"heading","text":"Example","level":2,"anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle tag setting errors with retry logic:"}]},{"type":"codeListing","syntax":"swift","code":["func setUserPreferences(_ preferences: [String: Any], retryCount: Int = 0) {","    let errorHandler: PushwooshErrorHandler = { error in","        if let error = error {","            self.logger.error(\"Failed to set tags: \\(error.localizedDescription)\")","","            if retryCount < 3 {","                DispatchQueue.main.asyncAfter(deadline: .now() + 2.0) {","                    self.setUserPreferences(preferences, retryCount: retryCount + 1)","                }","            } else {","                self.showAlert(title: \"Sync Error\", message: \"Could not save preferences. Please try again later.\")","            }","        }","    }","","    Pushwoosh.configure.setTags(preferences, onFailure: errorHandler)","}"]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/pushwooshframework\/pushwoosherrorhandler"],"traits":[{"interfaceLanguage":"swift"}]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshframework\/pushwoosherrorhandler"]}],"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshErrorHandler":{"navigatorTitle":[{"kind":"identifier","text":"PushwooshErrorHandler"}],"abstract":[{"type":"text","text":"Completion handler called when an operation fails."}],"fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PushwooshErrorHandler","kind":"identifier"}],"url":"\/documentation\/pushwooshframework\/pushwoosherrorhandler","role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler","title":"PushwooshErrorHandler","type":"topic","kind":"symbol"},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework":{"kind":"