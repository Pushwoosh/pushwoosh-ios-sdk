ain later.\")","            }","        }","    }","","    Pushwoosh.configure.setTags(preferences, onFailure: errorHandler)","}"],"type":"codeListing"}],"kind":"content"}],"metadata":{"externalID":"c:PushNotificationManager.h@T@PushwooshErrorHandler","modules":[{"name":"PushwooshFramework"}],"roleHeading":"Type Alias","navigatorTitle":[{"kind":"identifier","text":"PushwooshErrorHandler"}],"fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PushwooshErrorHandler"}],"role":"symbol","title":"PushwooshErrorHandler","symbolKind":"typealias"},"kind":"symbol","abstract":[{"type":"text","text":"Completion handler called when an operation fails."}],"seeAlsoSections":[{"identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshGetTagsHandler"],"title":"Related Documentation"}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/pushwooshframework\/pushwoosherrorhandler"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshframework\/pushwoosherrorhandler"]}],"sections":[],"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshErrorHandler":{"url":"\/documentation\/pushwooshframework\/pushwoosherrorhandler","type":"topic","role":"symbol","title":"PushwooshErrorHandler","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler","kind":"symbol","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PushwooshErrorHandler","kind":"identifier"}],"abstract":[{"text":"Completion handler called when an operation fails.","type":"text"}],"navigatorTitle":[{"text":"PushwooshErrorHandler","kind":"identifier"}]},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework":{"title":