{"metadata":{"role":"symbol","symbolKind":"typealias","title":"PushwooshErrorHandler","fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"PushwooshErrorHandler"}],"roleHeading":"Type Alias","navigatorTitle":[{"text":"PushwooshErrorHandler","kind":"identifier"}],"externalID":"c:PushNotificationManager.h@T@PushwooshErrorHandler","modules":[{"name":"PushwooshFramework"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PushwooshErrorHandler"},{"kind":"text","text":" = ((any "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5ErrorP","text":"Error"},{"text":")?) -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"}],"platforms":["iOS"],"languages":["swift"]}]},{"content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"text":"This closure is called when a Pushwoosh operation fails, providing an error object describing what went wrong.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The handler receives an optional "},{"code":"NSError","type":"codeVoice"},{"text":" parameter. If the error is ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", the operation succeeded (though typically success handlers use different callback types).","type":"text"}]},{"type":"heading","text":"Example","anchor":"Example","level":2},{"inlineContent":[{"type":"text","text":"Handle tag setting errors with retry logic:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["func setUserPreferences(_ preferences: [String: Any], retryCount: Int = 0) {","    let errorHandler: PushwooshErrorHandler = { error in","        if let error = error {","            self.logger.error(\"Failed to set tags: \\(error.localizedDescription)\")","","            if retryCount < 3 {","                DispatchQueue.main.asyncAfter(deadline: .now() + 2.0) {","                    self.setUserPreferences(preferences, retryCount: retryCount + 1)","                }","            } else {","                self.showAlert(title: \"Sync Error\", message: \"Could not save preferences. Please try again later.\")","            }","        }","    }","","    Pushwoosh.configure.setTags(preferences, onFailure: errorHandler)","}"]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/pushwooshframework\/pushwoosherrorhandler"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshframework\/pushwoosherrorhandler"]}],"abstract":[{"type":"text","text":"Completion handler called when an operation fails."}],"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler"},"seeAlsoSections":[{"identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshGetTagsHandler"],"title":"Related Documentation"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework":{"type":"topic","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework","abstract":[{"text":"Push notification SDK for iOS applications.","type":"text"}],"url":"\/documentation\/pushwooshframework","role":"collection","title":"PushwooshFramework"},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshRegistrationHandler":{"fragments":[{"kind":"identifier","text":"PushwooshRegistrationHandler"}],"abstract":[{"text":"Completion handler called when push notification registration completes.","type":"text"}],"url":"\/documentation\/pushwooshframework\/pushwooshregistrationhandler