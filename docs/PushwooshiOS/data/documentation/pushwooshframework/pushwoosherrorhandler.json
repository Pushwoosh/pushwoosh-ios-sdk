{"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"text":"PushwooshErrorHandler","kind":"identifier"},{"kind":"text","text":" = ((any "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5ErrorP","text":"Error"},{"text":")?) -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"}],"languages":["swift"],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This closure is called when a Pushwoosh operation fails, providing an error object describing what went wrong."}]},{"type":"paragraph","inlineContent":[{"text":"The handler receives an optional ","type":"text"},{"type":"codeVoice","code":"NSError"},{"text":" parameter. If the error is ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":", the operation succeeded (though typically success handlers use different callback types)."}]},{"text":"Example","type":"heading","level":2,"anchor":"Example"},{"inlineContent":[{"type":"text","text":"Handle tag setting errors with retry logic:"}],"type":"paragraph"},{"syntax":"swift","code":["func setUserPreferences(_ preferences: [String: Any], retryCount: Int = 0) {","    let errorHandler: PushwooshErrorHandler = { error in","        if let error = error {","            self.logger.error(\"Failed to set tags: \\(error.localizedDescription)\")","","            if retryCount < 3 {","                DispatchQueue.main.asyncAfter(deadline: .now() + 2.0) {","                    self.setUserPreferences(preferences, retryCount: retryCount + 1)","                }","            } else {","                self.showAlert(title: \"Sync Error\", message: \"Could not save preferences. Please try again later.\")","            }","        }","    }","","    Pushwoosh.configure.setTags(preferences, onFailure: errorHandler)","}"],"type":"codeListing"}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshGetTagsHandler"]}],"abstract":[{"text":"Completion handler called when an operation fails.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/pushwooshframework\/pushwoosherrorhandler"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshframework\/pushwoosherrorhandler"]}],"kind":"symbol","metadata":{"navigatorTitle":[{"kind":"identifier","text":"PushwooshErrorHandler"}],"role":"symbol","roleHeading":"Type Alias","externalID":"c:PushNotificationManager.h@T@PushwooshErrorHandler","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PushwooshErrorHandler"}],"symbolKind":"typealias","modules":[{"name":"PushwooshFramework"}],"title":"PushwooshErrorHandler"},"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshGetTagsHandler":{"url":"\/documentation\/pushwooshframework\/pushwooshgettagshandler","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshGetTagsHandler","abstract":[{"type":"text","text":"Completion handler called when tags are successfully retrieved from the server."}],"kind":"symbol","navigatorTitle":[{"text":"PushwooshGetTagsHandler","kind":"identifier"}],"role":"symbol","fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"text":"PushwooshGetTagsHandler","kind":"identifier"}],"title":"PushwooshGetTagsHandler","type":"topic"},"doc://com.pushwoosh.PushwooshiOS/do