success handlers use different callback types)."}]},{"anchor":"Example","type":"heading","level":2,"text":"Example"},{"type":"paragraph","inlineContent":[{"text":"Handle tag setting errors with retry logic:","type":"text"}]},{"type":"codeListing","code":["func setUserPreferences(_ preferences: [String: Any], retryCount: Int = 0) {","    let errorHandler: PushwooshErrorHandler = { error in","        if let error = error {","            self.logger.error(\"Failed to set tags: \\(error.localizedDescription)\")","","            if retryCount < 3 {","                DispatchQueue.main.asyncAfter(deadline: .now() + 2.0) {","                    self.setUserPreferences(preferences, retryCount: retryCount + 1)","                }","            } else {","                self.showAlert(title: \"Sync Error\", message: \"Could not save preferences. Please try again later.\")","            }","        }","    }","","    Pushwoosh.configure.setTags(preferences, onFailure: errorHandler)","}"],"syntax":"swift"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/pushwooshframework\/pushwoosherrorhandler"]},{"paths":["\/documentation\/pushwooshframework\/pushwoosherrorhandler"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshRegistrationHandler":{"fragments":[{"text":"PushwooshRegistrationHandler","kind":"identifier"}],"abstract":[{"text":"Completion handler called when push notification registration completes.","type":"text"}],"title":"PushwooshRegistrationHandler","role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshRegistrationHandler","kind":"symbol","type":"topic","url":"\/documentation\/pushwooshframework\/pushwooshregistrationhandler"},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshGetTagsHandler":{"abstract":[{"type":"text","text":"Completion handler called whe