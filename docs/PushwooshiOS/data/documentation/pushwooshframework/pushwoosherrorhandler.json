"text":"The handler receives an optional "},{"type":"codeVoice","code":"NSError"},{"text":" parameter. If the error is ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", the operation succeeded (though typically success handlers use different callback types).","type":"text"}],"type":"paragraph"},{"anchor":"Example","level":2,"text":"Example","type":"heading"},{"inlineContent":[{"type":"text","text":"Handle tag setting errors with retry logic:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["func setUserPreferences(_ preferences: [String: Any], retryCount: Int = 0) {","    let errorHandler: PushwooshErrorHandler = { error in","        if let error = error {","            self.logger.error(\"Failed to set tags: \\(error.localizedDescription)\")","","            if retryCount < 3 {","                DispatchQueue.main.asyncAfter(deadline: .now() + 2.0) {","                    self.setUserPreferences(preferences, retryCount: retryCount + 1)","                }","            } else {","                self.showAlert(title: \"Sync Error\", message: \"Could not save preferences. Please try again later.\")","            }","        }","    }","","    Pushwoosh.configure.setTags(preferences, onFailure: errorHandler)","}"]}]}],"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework":{"role":"collection","abstract":[{"text":"Push notification SDK for iOS applications.","type":"text"}],"title":"PushwooshFramework","type":"topic","url":"\/documentation\/pushwooshframework","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshErrorHandler":{"fragments":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"text":"PushwooshErrorHandler","kind":"identifier"}],"navigatorTitle":[{"text":"PushwooshErrorHandler","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.Pushwoosh