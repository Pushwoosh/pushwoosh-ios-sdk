{"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"sections":[],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshErrorHandler","interfaceLanguage":"swift"},"metadata":{"navigatorTitle":[{"kind":"identifier","text":"PushwooshErrorHandler"}],"externalID":"c:PushNotificationManager.h@T@PushwooshErrorHandler","role":"symbol","roleHeading":"Type Alias","symbolKind":"typealias","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"PushwooshErrorHandler"}],"title":"PushwooshErrorHandler","modules":[{"name":"PushwooshFramework"}]},"kind":"symbol","abstract":[{"type":"text","text":"Completion handler called when an operation fails."}],"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshGetTagsHandler"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"text":"PushwooshErrorHandler","kind":"identifier"},{"kind":"text","text":" = ((any "},{"preciseIdentifier":"s:s5ErrorP","text":"Error","kind":"typeIdentifier"},{"kind":"text","text":")?) -> "},{"text":"Void","preciseIdentifier":"s:s4Voida","kind":"typeIdentifier"}],"languages":["swift"],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This closure is called when a Pushwoosh operation fails, providing an error object describing what went wrong."}]},{"type":"paragraph","inlineContent":[{"text":"The handler receives an optional ","type":"text"},{"code":"NSError","type":"codeVoice"},{"type":"text","text":" parameter. If the error is "},{"code":"nil","type":"codeVoice"},{"text":", the operation succeeded (though typically success handlers use different callback types).","type":"text"}]},{"text":"Example","type":"heading","level":2,"anchor":"Example"},{"inlineContent":[{"text":"Handle tag setting errors with retry logic:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["func setUserPreferences(_ preferences: [String: Any], retryCount: Int = 0) {","    let errorHandler: PushwooshErrorHandler = { error in","        if let error = error {","            self.logger.error(\"Failed to set tags: \\(error.localizedDescription)\")","","            if retryCount < 3 {","                DispatchQueue.main.asyncAfter(deadline: .now() + 2.0) {","                    self.setUserPreferences(preferences, retryCount: retryCount + 1)","                }","            } else {","                self.showAlert(title: \"Sync Error\", message: \"Could not save preferences. Please try again later.\")","            }","        }","    }","","    Pushwoosh.configure.setTags(preferences, onFailure: errorHandler)","}"]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/pushwooshframework\/pushwoosherrorhandler"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshframework\/pushwoosherrorhandler"]}],"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework":{"url":"\/documentation\/pushwooshframework","abstract":[{"text":"Push notification SDK for iOS applications.","type":"text"}],"role":"collection","kind":"symbol","type":"topic","title":"PushwooshFramework","identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshRegistrationHandler":{"role":"symbol","title":"PushwooshRegistrationHandler","abstract":[{"text":"Completion handler called when push notification registration completes.","type":"text"}],"fragments":[{"text":"PushwooshRegistrationHandler","kind":"identifier"}],"url":"\/document