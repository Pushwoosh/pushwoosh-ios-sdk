"text":", the operation succeeded (though typically success handlers use different callback types)."}]},{"level":2,"anchor":"Example","text":"Example","type":"heading"},{"inlineContent":[{"type":"text","text":"Handle tag setting errors with retry logic:"}],"type":"paragraph"},{"code":["func setUserPreferences(_ preferences: [String: Any], retryCount: Int = 0) {","    let errorHandler: PushwooshErrorHandler = { error in","        if let error = error {","            self.logger.error(\"Failed to set tags: \\(error.localizedDescription)\")","","            if retryCount < 3 {","                DispatchQueue.main.asyncAfter(deadline: .now() + 2.0) {","                    self.setUserPreferences(preferences, retryCount: retryCount + 1)","                }","            } else {","                self.showAlert(title: \"Sync Error\", message: \"Could not save preferences. Please try again later.\")","            }","        }","    }","","    Pushwoosh.configure.setTags(preferences, onFailure: errorHandler)","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework"]]},"abstract":[{"type":"text","text":"Completion handler called when an operation fails."}],"references":{"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshRegistrationHandler":{"kind":"symbol","title":"PushwooshRegistrationHandler","url":"\/documentation\/pushwooshframework\/pushwooshregistrationhandler","abstract":[{"text":"Completion handler called when push notification registration completes.","type":"text"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshiOS\/documentation\/PushwooshFramework\/PushwooshRegistrationHandler","role":"symbol","type":"topic","fragments":[{"kind":"identifier","text":"PushwooshRegistrationHandler"}]},"doc://com.pushwoosh.PushwooshiOS/documentation/PushwooshFramework/PushwooshErrorHandler":{"url":"\/documentation\/pushwooshframework\/pushwoosherrorhandler"