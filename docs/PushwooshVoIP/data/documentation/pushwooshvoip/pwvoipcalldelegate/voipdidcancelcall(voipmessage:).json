{"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"Called when a call is remotely cancelled via VoIP push before the user answers.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"@objc","kind":"attribute"},{"text":" ","kind":"text"},{"text":"optional","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"voipDidCancelCall"},{"text":"(","kind":"text"},{"text":"voipMessage","kind":"externalParam"},{"kind":"text","text":": "},{"identifier":"doc:\/\/com.pushwoosh.PushwooshVoIP\/documentation\/PushwooshVoIP\/PWVoIPMessage","preciseIdentifier":"c:@M@PushwooshVoIP@objc(cs)PWVoIPMessage","text":"PWVoIPMessage","kind":"typeIdentifier"},{"kind":"text","text":")"}],"languages":["swift"]}]},{"parameters":[{"name":"voipMessage","content":[{"type":"paragraph","inlineContent":[{"text":"The VoIP message containing call information. Use ","type":"text"},{"type":"codeVoice","code":"voipMessage.callId"},{"text":" to identify which call was cancelled.","type":"text"}]}]}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"This method is invoked when the remote party cancels their outgoing call before the local user has a chance to answer."},{"text":" ","type":"text"},{"type":"text","text":"The SDK automatically dismisses the CallKit incoming call UI when this occurs."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To enable call cancellation, include these fields in your VoIP push payload:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"callId"},{"type":"text","text":" - A unique server-provided identifier for the call"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"cancelCall"},{"text":" - Set to ","type":"text"},