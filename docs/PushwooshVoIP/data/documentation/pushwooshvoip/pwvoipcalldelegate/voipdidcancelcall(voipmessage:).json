{"abstract":[{"text":"Called when a call is remotely cancelled via VoIP push before the user answers.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"@objc","kind":"attribute"},{"text":" ","kind":"text"},{"text":"optional","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"voipDidCancelCall"},{"kind":"text","text":"("},{"kind":"externalParam","text":"voipMessage"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@M@PushwooshVoIP@objc(cs)PWVoIPMessage","kind":"typeIdentifier","text":"PWVoIPMessage","identifier":"doc:\/\/com.pushwoosh.PushwooshVoIP\/documentation\/PushwooshVoIP\/PWVoIPMessage"},{"kind":"text","text":")"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"voipMessage","content":[{"type":"paragraph","inlineContent":[{"text":"The VoIP message containing call information. Use ","type":"text"},{"code":"voipMessage.callId","type":"codeVoice"},{"text":" to identify which call was cancelled.","type":"text"}]}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method is invoked when the remote party cancels their outgoing call before the local user has a chance to answer."},{"text":" ","type":"text"},{"type":"text","text":"The SDK automatically dismisses the CallKit incoming call UI when this occurs."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To enable call cancellation, include these fields in your VoIP push payload:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"callId"},{"type":"text","text":" - A unique server-provided identifier for the call"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"cancelCall","type":"codeVoice"},{"type":"text","text":" - Set to "},{"code":"true","type":"codeVoice"},{"text":" for cancellation requests","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"The SDK matches cancellation requests to active calls using the "},{"type":"codeVoice","code":"callId"},{"type":"text","text":" field. When a cancellation push is received,"},{"type":"text","text":" "},{"type":"text","text":"CallKit UI is automatically dismissed with "},{"type":"codeVoice","code":"CXCallEndedReason.remoteEnded"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"aside","name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"This is an optional delegate method. If not implemented, the SDK will still automatically dismiss the CallKit UI.","type":"text"}]}]},{"type":"aside","name":"Important","style":"important","content":[{"inlineContent":[{"type":"text","text":"Cancellation only works for calls that haven’t been answered yet. Once answered, cancellation requests are ignored."}],"type":"paragraph"}]}]}],"variants":[{"paths":["\/documentation\/pushwooshvoip\/pwvoipcalldelegate\/voipdidcancelcall(voipmessage:)"],"traits":[{"interfaceLanguage":"swift"}]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshvoip\/pwvoipcalldelegate\/voipdidcancelcall(voipmessage:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pushwoosh.PushwooshVoIP\/documentation\/PushwooshVoIP\/PWVoIPCallDelegate\/voipDidCancelCall(voipMessage:)"},"sections":[],"metadata":{"navigatorTitle":[{"text":"voipDidCancelCallWithVoipMessage:","kind":"identifier"}],"roleHeading":"Instance Method","symbolKind":"method","modules":[{"name":"PushwooshVoIP"}],"externalID":"c:@M@PushwooshVoIP@objc(pl)PWVoIPCallDelegate(im)voipDidCancelCallWithVoipMessage:","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"voipDidCancelCall","kind":"identifier"},{"text":"(","kind":"text"},{"text":"voipMessage","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"