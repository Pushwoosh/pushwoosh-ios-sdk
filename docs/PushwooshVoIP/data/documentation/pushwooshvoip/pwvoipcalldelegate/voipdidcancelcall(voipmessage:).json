{"metadata":{"role":"symbol","title":"voipDidCancelCall(voipMessage:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"voipDidCancelCall","kind":"identifier"},{"kind":"text","text":"("},{"text":"voipMessage","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@M@PushwooshVoIP@objc(cs)PWVoIPMessage","text":"PWVoIPMessage","kind":"typeIdentifier"},{"kind":"text","text":")"}],"roleHeading":"Instance Method","navigatorTitle":[{"kind":"identifier","text":"voipDidCancelCallWithVoipMessage:"}],"symbolKind":"method","externalID":"c:@M@PushwooshVoIP@objc(pl)PWVoIPCallDelegate(im)voipDidCancelCallWithVoipMessage:","modules":[{"name":"PushwooshVoIP"}]},"sections":[],"abstract":[{"type":"text","text":"Called when a call is remotely cancelled via VoIP push before the user answers."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pushwoosh.PushwooshVoIP\/documentation\/PushwooshVoIP\/PWVoIPCallDelegate\/voipDidCancelCall(voipMessage:)"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshVoIP\/documentation\/PushwooshVoIP","doc:\/\/com.pushwoosh.PushwooshVoIP\/documentation\/PushwooshVoIP\/PWVoIPCallDelegate"]]},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"text":"@objc","kind":"attribute"},{"kind":"text","text":" "},{"kind":"keyword","text":"optional"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"voipDidCancelCall"},{"text":"(","kind":"text"},{"text":"voipMessage","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/com.pushwoosh.PushwooshVoIP\/documentation\/PushwooshVoIP\/PWVoIPMessage","preciseIdentifier":"c:@M@PushwooshVoIP@objc(cs)PWVoIPMessage","kind":"typeIdentifier","text":"PWVoIPMessage"},{"kind":"text","text":")"}]}]},{"kind":"parameters","parameters":[{"name":"voipMessage","content":[{"inlineContent":[{"type":"text","text":"The VoIP message containing call information. Use "},{"code":"voipMessage.callId","type":"codeVoice"},{"type":"text","text":" to identify which call was cancelled."}],"type":"paragraph"}]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"text":"This method is invoked when the remote party cancels their outgoing call before the local user has a chance to answer.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The SDK automatically dismisses the CallKit incoming call UI when this occurs."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To enable call cancellation, include these fields in your VoIP push payload:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"callId"},{"text":" - A unique server-provided identifier for the call","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"cancelCall"},{"text":" - Set to ","type":"text"},{"code":"true","type":"codeVoice"},{"type":"text","text":" for cancellation requests"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The SDK matches cancellation requests to active calls using the "},{"type":"codeVoice","code":"callId"},{"text":" field. When a cancellation push is received,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"CallKit UI is automatically dismissed with "},{"code":"CXCallEndedReason.remoteEnded","type":"codeVoice"},{"text":".","type":"text"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"This is an optional delegate method. If not implemented, the SDK will still automatically dismiss the CallKit UI.","type":"text"}]}],"name":"Note","type":"aside","style":"note"},{"type":"aside","name":"Important","style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"Cancellation only works for calls that haven’t been answ