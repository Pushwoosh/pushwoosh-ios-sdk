{"abstract":[{"text":"Called when a call is remotely cancelled via VoIP push before the user answers.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/pushwooshvoip\/pwvoipcalldelegate\/voipdidcancelcall(voipmessage:)"]},{"paths":["\/documentation\/pushwooshvoip\/pwvoipcalldelegate\/voipdidcancelcall(voipmessage:)"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@objc"},{"text":" ","kind":"text"},{"text":"optional","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"voipDidCancelCall"},{"kind":"text","text":"("},{"text":"voipMessage","kind":"externalParam"},{"kind":"text","text":": "},{"text":"PWVoIPMessage","preciseIdentifier":"c:@M@PushwooshVoIP@objc(cs)PWVoIPMessage","kind":"typeIdentifier","identifier":"doc:\/\/com.pushwoosh.PushwooshVoIP\/documentation\/PushwooshVoIP\/PWVoIPMessage"},{"text":")","kind":"text"}],"platforms":["iOS"],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The VoIP message containing call information. Use "},{"code":"voipMessage.callId","type":"codeVoice"},{"text":" to identify which call was cancelled.","type":"text"}]}],"name":"voipMessage"}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method is invoked when the remote party cancels their outgoing call before the local user has a chance to answer."},{"text":" ","type":"text"},{"type":"text","text":"The SDK automatically dismisses the CallKit incoming call UI when this occurs."}]},{"type":"paragraph","inlineContent":[{"text":"To enable call cancellation, include these fields in your VoIP push payloa