 which call was cancelled."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"text":"This method is invoked when the remote party cancels their outgoing call before the local user has a chance to answer.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The SDK automatically dismisses the CallKit incoming call UI when this occurs."}],"type":"paragraph"},{"inlineContent":[{"text":"To enable call cancellation, include these fields in your VoIP push payload:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"callId"},{"type":"text","text":" - A unique server-provided identifier for the call"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"cancelCall","type":"codeVoice"},{"type":"text","text":" - Set to "},{"code":"true","type":"codeVoice"},{"type":"text","text":" for cancellation requests"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The SDK matches cancellation requests to active calls using the "},{"code":"callId","type":"codeVoice"},{"type":"text","text":" field. When a cancellation push is received,"},{"type":"text","text":" "},{"text":"CallKit UI is automatically dismissed with ","type":"text"},{"type":"codeVoice","code":"CXCallEndedReason.remoteEnded"},{"type":"text","text":"."}]},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This is an optional delegate method. If not implemented, the SDK will still automatically dismiss the CallKit UI."}]}],"type":"aside"},{"style":"important","type":"aside","name":"Important","content":[{"inlineContent":[{"type":"text","text":"Cancellation only works for calls that haven’t been answered yet. Once answered, cancellation requests are ignored."}],"type":"paragraph"}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pus