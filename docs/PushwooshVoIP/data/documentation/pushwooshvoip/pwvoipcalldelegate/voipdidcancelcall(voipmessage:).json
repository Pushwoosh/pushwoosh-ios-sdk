{"abstract":[{"text":"Called when a call is remotely cancelled via VoIP push before the user answers.","type":"text"}],"variants":[{"paths":["\/documentation\/pushwooshvoip\/pwvoipcalldelegate\/voipdidcancelcall(voipmessage:)"],"traits":[{"interfaceLanguage":"swift"}]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshvoip\/pwvoipcalldelegate\/voipdidcancelcall(voipmessage:)"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@objc"},{"text":" ","kind":"text"},{"text":"optional","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"voipDidCancelCall","kind":"identifier"},{"text":"(","kind":"text"},{"text":"voipMessage","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"PWVoIPMessage","kind":"typeIdentifier","preciseIdentifier":"c:@M@PushwooshVoIP@objc(cs)PWVoIPMessage","identifier":"doc:\/\/com.pushwoosh.PushwooshVoIP\/documentation\/PushwooshVoIP\/PWVoIPMessage"},{"kind":"text","text":")"}],"languages":["swift"],"platforms":["iOS"]}],"kind":"declarations"},{"parameters":[{"name":"voipMessage","content":[{"type":"paragraph","inlineContent":[{"text":"The VoIP message containing call information. Use ","type":"text"},{"type":"codeVoice","code":"voipMessage.callId"},{"text":" to identify which call was cancelled.","type":"text"}]}]}],"kind":"parameters"},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method is invoked when the remote party cancels their outgoing call before the local user has a chance to answer."},{"type":"text","text":" "},{"text":"The SDK automatically dismisses the CallKit incoming call UI when this occurs.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To enable call cancellation, include these fields in your VoIP push payload:"}]},{"type":"uno