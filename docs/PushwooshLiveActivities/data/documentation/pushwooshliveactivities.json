{"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"inlineContent":[{"text":"PushwooshLiveActivities integrates Apple’s ActivityKit framework to deliver real-time updates to Live Activities on the Lock Screen and Dynamic Island. Live Activities provide persistent, glanceable information that users can track without opening your app.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The module handles token registration, activity lifecycle management, and push notification delivery automatically. It supports both custom activity attributes and a default configuration for cross-platform scenarios."}]}]}],"sections":[],"metadata":{"role":"collection","title":"PushwooshLiveActivities","externalID":"PushwooshLiveActivities","modules":[{"name":"PushwooshLiveActivities"}],"symbolKind":"module","roleHeading":"Framework"},"kind":"symbol","identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshLiveActivities\/documentation\/PushwooshLiveActivities","interfaceLanguage":"swift"},"topicSections":[{"title":"Getting Started","identifiers":["doc:\/\/com.pushwoosh.PushwooshLiveActivities\/documentation\/PushwooshLiveActivities\/GettingStarted","doc:\/\/com.pushwoosh.PushwooshLiveActivities\/documentation\/PushwooshLiveActivities\/Examples"]},{"identifiers":["doc:\/\/com.pushwoosh.PushwooshLiveActivities\/documentation\/PushwooshLiveActivities\/PushwooshLiveActivitiesImplementationSetup"],"title":"Classes"},{"title":"Protocols","identifiers":["doc:\/\/com.pushwoosh.PushwooshLiveActivities\/documentation\/PushwooshLiveActivities\/PushwooshLiveActivityAttributes","doc:\/\/com.pushwoosh.PushwooshLiveActivities\/documentation\/PushwooshLiveActivities\/PushwooshLiveActivityContentState"]},{"identifiers":["doc:\/\/com.pushwoosh.PushwooshLiveActivities\/documentation\/PushwooshLiveActivities\/AnyCodable","doc:\/\/com.pushwoosh.PushwooshLiveActivities\/documentation\/PushwooshL