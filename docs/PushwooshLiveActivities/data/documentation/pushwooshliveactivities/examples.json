{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.pushwoosh.PushwooshLiveActivities\/documentation\/PushwooshLiveActivities\/Examples"},"sections":[],"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"text":"This guide provides working code examples for typical use cases with PushwooshLiveActivities.","type":"text"}],"type":"paragraph"},{"type":"heading","anchor":"Delivery-Tracking","text":"Delivery Tracking","level":2},{"text":"Activity Attributes","type":"heading","anchor":"Activity-Attributes","level":3},{"type":"codeListing","syntax":"swift","code":["import ActivityKit","import PushwooshLiveActivities","","struct DeliveryActivityAttributes: PushwooshLiveActivityAttributes {","    var pushwoosh: PushwooshLiveActivityAttributeData","","    var orderNumber: String","    var driverName: String","    var deliveryAddress: String","","    struct ContentState: PushwooshLiveActivityContentState {","        var pushwoosh: PushwooshLiveActivityContentStateData?","","        enum DeliveryStatus: String, Codable {","            case preparing","            case enRoute","            case nearBy","            case delivered","        }","","        var status: DeliveryStatus","        var estimatedArrival: Date","        var currentLocation: String","    }","}"]},{"type":"heading","level":3,"anchor":"Starting-Delivery-Tracking","text":"Starting Delivery Tracking"},{"syntax":"swift","type":"codeListing","code":["import ActivityKit","import PushwooshLiveActivities","","func startDeliveryTracking(orderNumber: String, driverName: String, address: String) {","    guard #available(iOS 16.1, *) else { return }","","    let attributes = DeliveryActivityAttributes(","        pushwoosh: .create(activityId: \"delivery-\\(orderNumber)\"),","        orderNumber: orderNumber,","        driverName: driverName,","        deliveryAddress: address","    )","","    let contentState = DeliveryActivityAttributes