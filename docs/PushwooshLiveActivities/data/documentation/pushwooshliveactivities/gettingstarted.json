ured in your Pushwoosh project with Token-Based Authentication"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Your Pushwoosh Application Code from the Control Panel"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"iOS 16.1+ deployment target (iOS 17.2+ for push-to-start feature)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"PushwooshFramework, PushwooshCore, and PushwooshBridge frameworks integrated in your project"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A Widget Extension target in your Xcode project"}]}]}],"type":"unorderedList"},{"type":"aside","name":"Note","content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Important"}]},{"type":"text","text":": Live Activities require iOS 16.1+. Push-to-start functionality requires iOS 17.2+. Only token-based configuration is supported (certificate-based is not supported)."}],"type":"paragraph"}],"style":"note"},{"type":"heading","level":2,"anchor":"Step-1-Add-Required-Capabilities","text":"Step 1: Add Required Capabilities"},{"inlineContent":[{"type":"text","text":"In Xcode:"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Select your ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"app target"}]},{"text":" (not widget extension)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Go to ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Signing & Capabilities"}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Click "},{"type":"strong","inlineContent":[{"text":"+ Capability","type":"text"}]},{"type":"text","text":" and add "},{"type":"strong","inlineContent":[{"type":"text","text":"Push Notifications"}]}]}]},{"content":[{"inlineContent":[{"text":"Click ","type":"text"},{"inlineContent":[{"type":"text","text":"+ Capability"}],"type":"strong"},{"text":" and add ","type":"text"},{"inlineContent":[{"type":"text","text":"Background Modes"}],"type":"strong"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"In Background Modes, enable ","type":"text"},{"inlineContent":[{"text":"Remote notifications","type":"text"}],"type":"strong"},{"type":"text","text":" checkbox"}]}]}]},{"level":2,"anchor":"Step-2-Configure-Infoplist","text":"Step 2: Configure Info.plist","type":"heading"},{"inlineContent":[{"type":"text","text":"Add Live Activities support to your app’s Info.plist:"}],"type":"paragraph"},{"code":["<key>NSSupportsLiveActivities<\/key>","<true\/>"],"type":"codeListing","syntax":"xml"},{"level":2,"type":"heading","anchor":"Step-3-Create-Widget-Extension","text":"Step 3: Create Widget Extension"},{"inlineContent":[{"type":"text","text":"If you don’t have a Widget Extension:"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"In Xcode: ","type":"text"},{"inlineContent":[{"type":"text","text":"File → New → Target"}],"type":"strong"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Select "},{"type":"strong","inlineContent":[{"type":"text","text":"Widget Extension"}]}]}]},{"content":[{"inlineContent":[{"text":"Enable ","type":"text"},{"inlineContent":[{"text":"Include Live Activity","type":"text"}],"type":"strong"},{"text":" checkbox","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Name it (e.g., “MyAppWidgets”)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Add PushwooshLiveActivities to your Widget Extension target dependencies","type":"text"}],"type":"paragraph"}]}]},{"level":2,"anchor":"Step-4-Define-Activity-Attributes","text":"Step 4: Define Activity Attributes","type":"heading"},{"inlineContent":[{"text":"Create a struct conforming to ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pushwoosh.PushwooshLiveActivities\/documentation\/PushwooshLiveActivities\/PushwooshLiveActivityAttributes"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["import WidgetKit","import SwiftUI","import ActivityKit","import PushwooshFramework","import PushwooshLiveActivities","","struct FoodDeliveryAttributes: PushwooshLiveActivityAttributes {","    public struct ContentState: PushwooshLiveActivityContentState {","        var status: String","        var estimatedTime: String","        var emoji: String","        var pushwoosh: PushwooshLiveActivityContentStateData?","    }","","    var orderNumber: String","    var pushwoosh: PushwooshLiveActivityAttributeData","}"]},{"type":"heading","text":"Step 5: Create Widget","anchor":"Step-5-Create-Widget","level":2},{"type":"paragraph","inlineContent":[{"text":"In your Widget Extension:","type":"text"}]},{"code":["import WidgetKit","import SwiftUI","import ActivityKit","","@main","struct FoodDeliveryWidget: Widget {","    var body: some WidgetConfiguration {","        ActivityConfiguration(for: FoodDeliveryAttributes.self) { context in","            VStack(alignment: .leading, spacing: 8) {","                HStack {","                    Text(\"Order #\\(context.attributes.orderNumber)\")","                        .font(.headline)","                    Spacer()","                    Text(context.state.emoji)","                        .font(.title)","                }","","                Text(context.state.status)","                    .font(.subheadline)","","                HStack {","                    Image(systemName: \"clock\")","                    Text(context.state.estimatedTime)","                }","                .font(.caption)","            }","            .padding()","        } dynamicIsland: { context in","            DynamicIsland {","                DynamicIslandExpandedRegion(.leading) {","                    Text(context.state.emoji)","                        .font(.title)","                }","                DynamicIslandExpandedRegion(.trailing) {","                    Text(context.state.estimatedTime)","                        .font(.caption)","                }","                DynamicIslandExpandedRegion(.center) {","                    Text(context.state.status)","                        .font(.caption)","                }","            } compactLeading: {","                Text(context.state.emoji)","            } compactTrailing: {","                Text(context.state.estimatedTime)","                    .font(.caption2)","            } minimal: {","                Text(context.state.emoji)","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"level":2,"type":"heading","anchor":"Step-6-Initialize-in-AppDelegate","text":"Step 6: Initialize in AppDelegate"},{"code":["import UIKit","import PushwooshFramework","import PushwooshLiveActivities","","@main","class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","","        if #available(iOS 16.1, *) {","            Pushwoosh.LiveActivities.setup(FoodDeliveryAttributes.self)","        }","","        return true","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"setup()","type":"codeVoice"},{"type":"text","text":" method handles the entire lifecycle of Live Activities:"}]},{"items":[{"content":[{"inlineContent":[{"text":"Automatically listens for push-to-start token updates (iOS 17.2+)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Automatically listens for activity token updates"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Registers tokens with Pushwoosh server"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Step 7: Create Live Activity Manager","type":"heading","anchor":"Step-7-Create-Live-Activity-Manager","level":2},{"code":["import Foundation","import ActivityKit","import UIKit","import PushwooshFramework","import PushwooshLiveActivities","","class LiveActivityManager: NSObject, ObservableObject {","    public static let shared = LiveActivityManager()","    private var currentActivity: Activity<FoodDeliveryAttributes>?","","    func startActivity() {","        guard ActivityAuthorizationInfo().areActivitiesEnabled else {","            print(\"Live Activities are not enabled\")","            return","        }","","        do {","            let pushwooshData = PushwooshLiveActivityAttributeData(","                activityId: \"order_123\"","            )","","            let attribute = FoodDeliveryAttributes(","                orderNumber: \"1234567\",","                pushwoosh: pushwooshData","            )","","            let initialState = FoodDeliveryAttributes.ContentState(","                status: \"Preparing your meal\",","                estimatedTime: \"25 min\",","                emoji: \"👨‍🍳\",","                pushwoosh: nil","            )","","            let activity = try Activity<FoodDeliveryAttributes>.request(","                attributes: attribute,","                content: .init(state: initialState, staleDate: nil),","                pushType: .token","            )","","            self.currentActivity = activity","","            Task {","                for await pushToken in activity.pushTokenUpdates {","                    let pushTokenString = pushToken.reduce(\"\") {","                        $0 + String(format: \"%02x\", $1)","                    }","","                    print(\"Activity push token: \\(pushTokenString)\")","","                    Pushwoosh.LiveActivities.startLiveActivity(","                        token: pushTokenString,","                        activityId: \"order_123\"","                    )","                }","            }","        } catch {","            print(\"Start Activity Error: \\(error.localizedDescription)\")","        }","    }","","    func endActivity() async {","        guard let activity = currentActivity else { return }","","        await activity.end(nil, dismissalPolicy: .immediate)","","        Pushwoosh.LiveActivities.stopLiveActivity(activityId: \"order_123\")","    }","}"],"syntax":"swift","type":"codeListing"},{"text":"Step 8: Start Activity from UI","anchor":"Step-8-Start-Activity-from-UI","level":2,"type":"heading"},{"code":["import SwiftUI","","struct ContentView: View {","    var body: some View {","        VStack(spacing: 20) {","            Button(action: {","                LiveActivityManager.shared.startActivity()","            }) {","                Text(\"Start Live Activity\")","                    .foregroundColor(.white)","                    .padding()","                    .background(Color.blue)","                    .cornerRadius(10)","            }","","            Button(action: {","                Task {","                    await LiveActivityManager.shared.endActivity()","                }","            }) {","                Text(\"End Live Activity\")","                    .foregroundColor(.white)","                    .padding()","                    .background(Color.red)","                    .cornerRadius(10)","            }","        }","        .padding()","    }","}"],"type":"codeListing","syntax":"swift"},{"level":2,"text":"Step 9: Send Push Notifications via Pushwoosh API","anchor":"Step-9-Send-Push-Notifications-via-Pushwoosh-API","type":"heading"},{"inlineContent":[{"type":"text","text":"Use Pushwoosh REST API to send Live Activity updates from your server."}],"type":"paragraph"},{"type":"heading","text":"Start Live Activity (Push-to-Start for iOS 17.2+)","anchor":"Start-Live-Activity-Push-to-Start-for-iOS-172+","level":3},{"inlineContent":[{"type":"codeVoice","code":"POST https:\/\/api.pushwoosh.com\/json\/1.3\/startLiveActivity"}],"type":"paragraph"},{"code":["{","  \"request\": {","    \"application\": \"YOUR-APP-CODE\",","    \"auth\": \"YOUR-API-TOKEN\",","    \"notifications\": [","      {","        \"content\": \"Your order is being prepared!\",","        \"live_activity\": {","          \"event\": \"start\",","          \"content-state\": {","            \"status\": \"Preparing your meal\",","            \"estimatedTime\": \"25 min\",","            \"emoji\": \"👨‍🍳\"","          },","          \"attributes-type\": \"FoodDeliveryAttributes\",","          \"attributes\": {","            \"orderNumber\": \"1234567\"","          }","        },","        \"live_activity_id\": \"order_123\",","        \"filter_code\": \"user_segment_code\"","      }","    ]","  }","}"],"type":"codeListing","syntax":"json"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Targeting Options:","type":"text"}]}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"filter_code","type":"codeVoice"},{"type":"text","text":": Target specific user segment"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"devices"},{"type":"text","text":": Array of push tokens or HWIDs (max 1000)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"users","type":"codeVoice"},{"type":"text","text":": Array of User IDs (max 1000)"}]}]}]},{"type":"heading","text":"Update Live Activity","level":3,"anchor":"Update-Live-Activity"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"POST https:\/\/api.pushwoosh.com\/json\/1.3\/updateLiveActivity"}]},{"code":["{","  \"request\": {","    \"application\": \"YOUR-APP-CODE\",","    \"auth\": \"YOUR-API-TOKEN\",","    \"notifications\": [","      {","        \"live_activity\": {","          \"event\": \"update\",","          \"content-state\": {","            \"status\": \"On the way\",","            \"estimatedTime\": \"10 min\",","            \"emoji\": \"🚚\"","          },","          \"stale-date\": 1234567890","        },","        \"live_activity_id\": \"order_123\"","      }","    ]","  }","}"],"syntax":"json","type":"codeListing"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Optional Parameters:"}],"type":"strong"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"stale-date","type":"codeVoice"},{"text":": Unix timestamp when content becomes stale","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"dismissal-date"},{"text":": Unix timestamp when to dismiss (use with “end” event)","type":"text"}]}]}]},{"level":3,"text":"End Live Activity","anchor":"End-Live-Activity","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"POST https:\/\/api.pushwoosh.com\/json\/1.3\/updateLiveActivity"}]},{"type":"codeListing","syntax":"json","code":["{","  \"request\": {","    \"application\": \"YOUR-APP-CODE\",","    \"auth\": \"YOUR-API-TOKEN\",","    \"notifications\": [","      {","        \"live_activity\": {","          \"event\": \"end\",","          \"dismissal-date\": 1234567890","        },","        \"live_activity_id\": \"order_123\"","      }","    ]","  }","}"]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Note:"}],"type":"strong"},{"type":"text","text":" For push-to-start functionality (iOS 17.2+), the "},{"type":"codeVoice","code":"setup()"},{"text":" method automatically handles token registration. No additional code is needed in the app.","type":"text"}]},{"anchor":"Available-SDK-Methods","level":2,"type":"heading","text":"Available SDK Methods"},{"inlineContent":[{"text":"The PushwooshLiveActivities module provides the following methods:","type":"text"}],"type":"paragraph"},{"text":"Setup Methods","type":"heading","anchor":"Setup-Methods","level":3},{"code":["\/\/ Setup with custom attri