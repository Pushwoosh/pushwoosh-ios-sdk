l":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a struct conforming to "},{"isActive":true,"identifier":"doc:\/\/com.pushwoosh.PushwooshLiveActivities\/documentation\/PushwooshLiveActivities\/PushwooshLiveActivityAttributes","type":"reference"},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["import WidgetKit","import SwiftUI","import ActivityKit","import PushwooshFramework","import PushwooshLiveActivities","","struct FoodDeliveryAttributes: PushwooshLiveActivityAttributes {","    public struct ContentState: PushwooshLiveActivityContentState {","        var status: String","        var estimatedTime: String","        var emoji: String","        var pushwoosh: PushwooshLiveActivityContentStateData?","    }","","    var orderNumber: String","    var pushwoosh: PushwooshLiveActivityAttributeData","}"]},{"level":2,"text":"Step 5: Create Widget","anchor":"Step-5-Create-Widget","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In your Widget Extension:"}]},{"code":["import WidgetKit","import SwiftUI","import ActivityKit","","@main","struct FoodDeliveryWidget: Widget {","    var body: some WidgetConfiguration {","        ActivityConfiguration(for: FoodDeliveryAttributes.self) { context in","            VStack(alignment: .leading, spacing: 8) {","                HStack {","                    Text(\"Order #\\(context.attributes.orderNumber)\")","                        .font(.headline)","                    Spacer()","                    Text(context.state.emoji)","                        .font(.title)","                }","","                Text(context.state.status)","                    .font(.subheadline)","","                HStack {","                    Image(systemName: \"clock\")","                    Text(context.state.estimatedTime)","                }","                .font(.caption)","            }","            .padding()","        } dynamicIsland: { context in","            DynamicIsland {","                DynamicIslandExpandedRegion(.leading) {","                    Text(context.state.emoji)","                        .font(.title)","                }","                DynamicIslandExpandedRegion(.trailing) {","                    Text(context.state.estimatedTime)","                        .font(.caption)","                }","                DynamicIslandExpandedRegion(.center) {","                    Text(context.state.status)","                        .font(.caption)","                }","            } compactLeading: {","                Text(context.state.emoji)","            } compactTrailing: {","                Text(context.state.estimatedTime)","                    .font(.caption2)","            } minimal: {","                Text(context.state.emoji)","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Step-6-Initialize-in-AppDelegate","level":2,"type":"heading","text":"Step 6: Initialize in AppDelegate"},{"syntax":"swift","type":"codeListing","code":["import UIKit","import PushwooshFramework","import PushwooshLiveActivities","","@main","class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","","        if #available(iOS 16.1, *) {","            Pushwoosh.LiveActivities.setup(FoodDeliveryAttributes.self)","        }","","        return true","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"setup()","type":"codeVoice"},{"text":" method handles the entire lifecycle of Live Activities:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Automatically listens for push-to-start token updates (iOS 17.2+)"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Automatically listens for activity token updates"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Registers tokens with Pushwoosh server","type":"text"}],"type":"paragraph"}]}]},{"anchor":"Step-7-Create-Live-Activity-Manager","level":2,"type":"heading","text":"Step 7: Create Live Activity Manager"},{"type":"codeListing","syntax":"swift","code":["import Foundation","import ActivityKit","import UIKit","import PushwooshFramework","import PushwooshLiveActivities","","class LiveActivityManager: NSObject, ObservableObject {","    public static let shared = LiveActivityManager()","    private var currentActivity: Activity<FoodDeliveryAttributes>?","","    func startActivity() {","        guard ActivityAuthorizationInfo().areActivitiesEnabled else {","            print(\"Live Activities are not enabled\")","            return","        }","","        do {","            let pushwooshData = PushwooshLiveActivityAttributeData(","                activityId: \"order_123\"","            )","","            let attribute = FoodDeliveryAttributes(","                orderNumber: \"1234567\",","                pushwoosh: pushwooshData","            )","","            let initialState = FoodDeliveryAttributes.ContentState(","                status: \"Preparing your meal\",","                estimatedTime: \"25 min\",","                emoji: \"👨‍🍳\",","                pushwoosh: nil","            )","","            let activity = try Activity<FoodDeliveryAttributes>.request(","                attributes: attribute,","                content: .init(state: initialState, staleDate: nil),","                pushType: .token","            )","","            self.currentActivity = activity","","            Task {","                for await pushToken in activity.pushTokenUpdates {","                    let pushTokenString = pushToken.reduce(\"\") {","                        $0 + String(format: \"%02x\", $1)","                    }","","                    print(\"Activity push token: \\(pushTokenString)\")","","                    Pushwoosh.LiveActivities.startLiveActivity(","                        token: pushTokenString,","                        activityId: \"order_123\"","                    )","                }","            }","        } catch {","            print(\"Start Activity Error: \\(error.localizedDescription)\")","        }","    }","","    func endActivity() async {","        guard let activity = currentActivity else { return }","","        await activity.end(nil, dismissalPolicy: .immediate)","","        Pushwoosh.LiveActivities.stopLiveActivity(activityId: \"order_123\")","    }","}"]},{"text":"Step 8: Start Activity from UI","level":2,"anchor":"Step-8-Start-Activity-from-UI","type":"heading"},{"syntax":"swift","code":["import SwiftUI","","struct ContentView: View {","    var body: some View {","        VStack(spacing: 20) {","            Button(action: {","                LiveActivityManager.shared.startActivity()","            }) {","                Text(\"Start Live Activity\")","                    .foregroundColor(.white)","                    .padding()","                    .background(Color.blue)","                    .cornerRadius(10)","            }","","            Button(action: {","                Task {","                    await LiveActivityManager.shared.endActivity()","                }","            }) {","                Text(\"End Live Activity\")","                    .foregroundColor(.white)","                    .padding()","                    .background(Color.red)","                    .cornerRadius(10)","            }","        }","        .padding()","    }","}"],"type":"codeListing"},{"type":"heading","level":2,"text":"Step 9: Send Push Notifications via Pushwoosh API","anchor":"Step-9-Send-Push-Notifications-via-Pushwoosh-API"},{"type":"paragraph","inlineContent":[{"text":"Use Pushwoosh REST API to send Live Activity updates from your server.","type":"text"}]},{"level":3,"text":"Start Live Activity (Push-to-Start for iOS 17.2+)","type":"heading","anchor":"Start-Live-Activity-Push-to-Start-for-iOS-172+"},{"type":"paragraph","inlineContent":[{"code":"POST https:\/\/api.pushwoosh.com\/json\/1.3\/startLiveActivity","type":"codeVoice"}]},{"syntax":"json","type":"codeListing","code":["{","  \"request\": {","    \"application\": \"YOUR-APP-CODE\",","    \"auth\": \"YOUR-API-TOKEN\",","    \"notifications\": [","      {","        \"content\": \"Your order is being prepared!\",","        \"live_activity\": {","          \"event\": \"start\",","          \"content-state\": {","            \"status\": \"Preparing your meal\",","            \"estimatedTime\": \"25 min\",","            \"emoji\": \"👨‍🍳\"","          },","          \"attributes-type\": \"FoodDeliveryAttributes\",","          \"attributes\": {","            \"orderNumber\": \"1234567\"","          }","        },","        \"live_activity_id\": \"order_123\",","        \"filter_code\": \"user_segment_code\"","      }","    ]","  }","}"]},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Targeting Options:","type":"text"}]}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"filter_code"},{"type":"text","text":": Target specific user segment"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"devices","type":"codeVoice"},{"type":"text","text":": Array of push tokens or HWIDs (max 1000)"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"users"},{"type":"text","text":": Array of User IDs (max 1000)"}],"type":"paragraph"}]}]},{"type":"heading","level":3,"text":"Update Live Activity","anchor":"Update-Live-Activity"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"POST https:\/\/api.pushwoosh.com\/json\/1.3\/updateLiveActivity"}]},{"code":["{","  \"request\": {","    \"application\": \"YOUR-APP-CODE\",","    \"auth\": \"YOUR-API-TOKEN\",","    \"notifications\": [","      {","        \"live_activity\": {","          \"event\": \"update\",","          \"content-state\": {","            \"status\": \"On the way\",","            \"estimatedTime\": \"10 min\",","            \"emoji\": \"🚚\"","          },","          \"stale-date\": 1234567890","        },","        \"live_activity_id\": \"order_123\"","      }","    ]","  }","}"],"type":"codeListing","syntax":"json"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Optional Parameters:"}]}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"stale-date"},{"text":": Unix timestamp when content becomes stale","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"dismissal-date"},{"type":"text","text":": Unix timestamp when to dismiss (use with “end” event)"}],"type":"paragraph"}]}]},{"text":"End Live Activity","level":3,"type":"heading","anchor":"End-Live-Activity"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"POST https:\/\/api.pushwoosh.com\/json\/1.3\/updateLiveActivity"}]},{"syntax":"json","type":"codeListing","code":["{","  \"request\": {","    \"application\": \"YOUR-APP-CODE\",","    \"auth\": \"YOUR-API-TOKEN\",","    \"notifications\": [","      {","        \"live_activity\": {","          \"event\": \"end\",","          \"dismissal-date\": 1234567890","        },","        \"live_activity_id\": \"order_123\"","      }","    ]","  }","}"]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Note:","type":"text"}]},{"text":" For push-to-start functionality (iOS 17.2+), the ","type":"text"},{"code":"setup()","type":"codeVoice"},{"type":"text","text":" method automatically handles token registration. No additional code is needed in the app."}]},{"text":"Available SDK Methods","type":"heading","anchor":"Available-SDK-Methods","level":2},{"type":"paragraph","inlineContent":[{"text":"The PushwooshLiveActivities module provides the following methods:","type":"tex