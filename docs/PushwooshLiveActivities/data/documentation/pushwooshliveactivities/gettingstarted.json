activity_id\": \"order_123\"","      }","    ]","  }","}"],"syntax":"json"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Optional Parameters:","type":"text"}],"type":"strong"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"stale-date","type":"codeVoice"},{"text":": Unix timestamp when content becomes stale","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"dismissal-date"},{"text":": Unix timestamp when to dismiss (use with “end” event)","type":"text"}]}]}]},{"anchor":"End-Live-Activity","text":"End Live Activity","type":"heading","level":3},{"inlineContent":[{"type":"codeVoice","code":"POST https:\/\/api.pushwoosh.com\/json\/1.3\/updateLiveActivity"}],"type":"paragraph"},{"syntax":"json","code":["{","  \"request\": {","    \"application\": \"YOUR-APP-CODE\",","    \"auth\": \"YOUR-API-TOKEN\",","    \"notifications\": [","      {","        \"live_activity\": {","          \"event\": \"end\",","          \"dismissal-date\": 1234567890","        },","        \"live_activity_id\": \"order_123\"","      }","    ]","  }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Note:"}],"type":"strong"},{"type":"text","text":" For push-to-start functionality (iOS 17.2+), the "},{"type":"codeVoice","code":"setup()"},{"text":" method automatically handles token registration. No additional code is needed in the app.","type":"text"}]},{"text":"Available SDK Methods","anchor":"Available-SDK-Methods","type":"heading","level":2},{"inlineContent":[{"text":"The PushwooshLiveActivities module provides the following methods:","type":"text"}],"type":"paragraph"},{"anchor":"Setup-Methods","type":"heading","level":3,"text":"Setup Methods"},{"code":["\/\/ Setup with custom attributes (iOS 16.1+)","static func setup<Attributes: PushwooshLiveActivityAttributes>(","    _ activityType: Attributes.Type",")","","\/\/ Setup with default