 push-to-start functionality (iOS 17.2+), the ","type":"text"},{"type":"codeVoice","code":"setup()"},{"type":"text","text":" method automatically handles token registration. No additional code is needed in the app."}]},{"type":"heading","level":2,"text":"Available SDK Methods","anchor":"Available-SDK-Methods"},{"inlineContent":[{"text":"The PushwooshLiveActivities module provides the following methods:","type":"text"}],"type":"paragraph"},{"text":"Setup Methods","type":"heading","anchor":"Setup-Methods","level":3},{"syntax":"swift","code":["\/\/ Setup with custom attributes (iOS 16.1+)","static func setup<Attributes: PushwooshLiveActivityAttributes>(","    _ activityType: Attributes.Type",")","","\/\/ Setup with default attributes (iOS 16.1+)","static func defaultSetup()"],"type":"codeListing"},{"text":"Token Management","type":"heading","level":3,"anchor":"Token-Management"},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Important"}],"type":"strong"},{"type":"text","text":": These methods are only needed if you are "},{"inlineContent":[{"type":"text","text":"NOT"}],"type":"strong"},{"text":" using ","type":"text"},{"type":"codeVoice","code":"setup()"},{"type":"text","text":" or "},{"code":"defaultSetup()","type":"codeVoice"},{"type":"text","text":". The setup methods automatically manage all token registration and lifecycle. Use these methods only for manual token management scenarios."}]}],"name":"Note","type":"aside","style":"note"},{"syntax":"swift","code":["\/\/ Send push-to-start token (iOS 17.2+)","static func sendPushToStartLiveActivity(token: String)","static func sendPushToStartLiveActivity(","    token: String,","    completion: @escaping (Error?) -> Void",")","","\/\/ Register activity token","static func startLiveActivity(token: String, activityId: String)","static func startLiveActivity(","    token: String,","    activityId: String,","    completion: @escaping (Error?) -> Void",")"],"type":"codeListing"},{"ty