k ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"+ Capability"}]},{"type":"text","text":" and add "},{"type":"strong","inlineContent":[{"text":"Push Notifications","type":"text"}]}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Click "},{"inlineContent":[{"text":"+ Capability","type":"text"}],"type":"strong"},{"type":"text","text":" and add "},{"type":"strong","inlineContent":[{"type":"text","text":"Background Modes"}]}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"In Background Modes, enable "},{"inlineContent":[{"type":"text","text":"Remote notifications"}],"type":"strong"},{"type":"text","text":" checkbox"}],"type":"paragraph"}]}],"type":"orderedList"},{"anchor":"Step-2-Configure-Infoplist","type":"heading","text":"Step 2: Configure Info.plist","level":2},{"type":"paragraph","inlineContent":[{"text":"Add Live Activities support to your app’s Info.plist:","type":"text"}]},{"type":"codeListing","code":["<key>NSSupportsLiveActivities<\/key>","<true\/>"],"syntax":"xml"},{"text":"Step 3: Create Widget Extension","level":2,"type":"heading","anchor":"Step-3-Create-Widget-Extension"},{"inlineContent":[{"type":"text","text":"If you don’t have a Widget Extension:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In Xcode: "},{"inlineContent":[{"type":"text","text":"File → New → Target"}],"type":"strong"}]}]},{"content":[{"inlineContent":[{"text":"Select ","type":"text"},{"inlineContent":[{"type":"text","text":"Widget Extension"}],"type":"strong"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Enable ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Include Live Activity"}]},{"type":"text","text":" checkbox"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Name it (e.g., “MyAppWidgets”)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Add PushwooshLiveActivities to your Widget Extension target dependencies"}],"type":"paragraph"}]}],"type":"orderedList"},{"text":"Step 4: Define Activity Attributes","type":"heading","anchor":"Step-4-Define-Activity-Attributes","level":2},{"inlineContent":[{"text":"Create a struct conforming to ","type":"text"},{"identifier":"doc:\/\/com.pushwoosh.PushwooshLiveActivities\/documentation\/PushwooshLiveActivities\/PushwooshLiveActivityAttributes","isActive":true,"type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["import WidgetKit","import SwiftUI","import ActivityKit","import PushwooshFramework","import PushwooshLiveActivities","","struct FoodDeliveryAttributes: PushwooshLiveActivityAttributes {","    public struct ContentState: PushwooshLiveActivityContentState {","        var status: String","        var estimatedTime: String","        var emoji: String","        var pushwoosh: PushwooshLiveActivityContentStateData?","    }","","    var orderNumber: String","    var pushwoosh: PushwooshLiveActivityAttributeData","}"]},{"text":"Step 5: Create Widget","level":2,"anchor":"Step-5-Create-Widget","type":"heading"},{"inlineContent":[{"text":"In your Widget Extension:","type":"text"}],"type":"paragraph"},{"code":["import WidgetKit","import SwiftUI","import ActivityKit","","@main","struct FoodDeliveryWidget: Widget {","    var body: some WidgetConfiguration {","        ActivityConfiguration(for: FoodDeliveryAttributes.self) { context in","            VStack(alignment: .leading, spacing: 8) {","                HStack {","                    Text(\"Order #\\(context.attributes.orderNumber)\")","                        .font(.headline)","                    Spacer()","                    Text(context.state.emoji)","                        .font(.title)","                }","","                Text(context.state.status)","                    .font(.subheadline)","","                HStack {","                    Image(systemName: \"clock\")","                    Text(context.state.estimatedTime)","                }","                .font(.caption)","            }","            .padding()","        } dynamicIsland: { context in","            DynamicIsland {","                DynamicIslandExpandedRegion(.leading) {","                    Text(context.state.emoji)","                        .font(.title)","                }","                DynamicIslandExpandedRegion(.trailing) {","                    Text(context.state.estimatedTime)","                        .font(.caption)","                }","                DynamicIslandExpandedRegion(.center) {","                    Text(context.state.status)","                        .font(.caption)","                }","            } compactLeading: {","                Text(context.state.emoji)","            } compactTrailing: {","                Text(context.state.estimatedTime)","                    .font(.caption2)","            } minimal: {","                Text(context.state.emoji)","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"Step 6: Initialize in AppDelegate","level":2,"anchor":"Step-6-Initialize-in-AppDelegate"},{"type":"codeListing","syntax":"swift","code":["import UIKit","import PushwooshFramework","import PushwooshLiveActivities","","@main","class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","","        if #available(iOS 16.1, *) {","            Pushwoosh.LiveActivities.setup(FoodDeliveryAttributes.self)","        }","","        return true","    }","}"]},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"setup()"},{"type":"text","text":" method handles the entire lifecycle of Live Activities:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Automatically listens for push-to-start token updates (iOS 17.2+)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Automatically listens for activity token updates"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Registers tokens with Pushwoosh server","type":"text"}]}]}]},{"type":"heading","text":"Step 7: Create Live Activity Manager","level":2,"anchor":"Step-7-Create-Live-Activity-Manager"},{"code":["import Foundation","import ActivityKit","import UIKit","import PushwooshFramework","import PushwooshLiveActivities","","class LiveActivityManager: NSObject, ObservableObject {","    public static let shared = LiveActivityManager()","    private var currentActivity: Activity<FoodDeliveryAttributes>?","","    func startActivity() {","        guard ActivityAuthorizationInfo().areActivitiesEnabled else {","            print(\"Live Activities are not enabled\")","            return","        }","","        do {","            let pushwooshData = PushwooshLiveActivityAttributeData(","                activityId: \"order_123\"","            )","","            let attribute = FoodDeliveryAttributes(","                orderNumber: \"1234567\",","                pushwoosh: pushwooshData","            )","","            let initialState = FoodDeliveryAttributes.ContentState(","                status: \"Preparing your meal\",","                estimatedTime: \"25 min\",","                emoji: \"👨‍🍳\",","                pushwoosh: nil","            )","","            let activity = try Activity<FoodDeliveryAttributes>.request(","                attributes: attribute,","                content: .init(state: initialState, staleDate: nil),","                pushType: .token","            )","","            self.currentActivity = activity","","            Task {","                for await pushToken in activity.pushTokenUpdates {","                    let pushTokenString = pushToken.reduce(\"\") {","                        $0 + String(format: \"%02x\", $1)","                    }","","                    print(\"Activity push token: \\(pushTokenString)\")","","                    Pushwoosh.LiveActivities.startLiveActivity(","                        token: pushTokenString,","                        activityId: \"order_123\"","                    )","                }","            }","        } catch {","            print(\"Start Activity Error: \\(error.localizedDescription)\")","        }","    }","","    func endActivity() async {","        guard let activity = currentActivity else { return }","","        await activity.end(nil, dismissalPolicy: .immediate)","","        Pushwoosh.LiveActivities.stopLiveActivity(activityId: \"order_123\")","    }","}"],"type":"codeListing","syntax":"swift"},{"text":"Step 8: Start Activity from UI","level":2,"type":"heading","anchor":"Step-8-Start-Activity-from-UI"},{"code":["import SwiftUI","","struct ContentView: View {","    var body: some View {","        VStack(spacing: 20) {","            Button(action: {","                LiveActivityManager.shared.startActivity()","            }) {","                Text(\"Start Live Activity\")","                    .foregroundColor(.white)","                    .padding()","                    .background(Color.blue)","                    .cornerRadius(10)","            }","","            Button(action: {","                Task {","                    await LiveActivityManager.shared.endActivity()","                }","            }) {","                Text(\"End Live Activity\")","                    .foregroundColor(.white)","                    .padding()","                    .background(Color.red)","                    .cornerRadius(10)","            }","        }","        .padding()","    }","}"],"type":"codeListing","syntax":"swift"},{"level":2,"text":"Step 9: Send Push Notifications via Pushwoosh API","anchor":"Step-9-Send-Push-Notifications-via-Pushwoosh-API","