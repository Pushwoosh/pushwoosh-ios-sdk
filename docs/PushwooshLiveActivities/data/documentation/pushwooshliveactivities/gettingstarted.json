":"doc:\/\/com.pushwoosh.PushwooshLiveActivities\/documentation\/PushwooshLiveActivities\/PushwooshLiveActivityAttributes","type":"reference","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["import WidgetKit","import SwiftUI","import ActivityKit","import PushwooshFramework","import PushwooshLiveActivities","","struct FoodDeliveryAttributes: PushwooshLiveActivityAttributes {","    public struct ContentState: PushwooshLiveActivityContentState {","        var status: String","        var estimatedTime: String","        var emoji: String","        var pushwoosh: PushwooshLiveActivityContentStateData?","    }","","    var orderNumber: String","    var pushwoosh: PushwooshLiveActivityAttributeData","}"]},{"anchor":"Step-5-Create-Widget","level":2,"text":"Step 5: Create Widget","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"In your Widget Extension:","type":"text"}]},{"syntax":"swift","code":["import WidgetKit","import SwiftUI","import ActivityKit","","@main","struct FoodDeliveryWidget: Widget {","    var body: some WidgetConfiguration {","        ActivityConfiguration(for: FoodDeliveryAttributes.self) { context in","            VStack(alignment: .leading, spacing: 8) {","                HStack {","                    Text(\"Order #\\(context.attributes.orderNumber)\")","                        .font(.headline)","                    Spacer()","                    Text(context.state.emoji)","                        .font(.title)","                }","","                Text(context.state.status)","                    .font(.subheadline)","","                HStack {","                    Image(systemName: \"clock\")","                    Text(context.state.estimatedTime)","                }","                .font(.caption)","            }","            .padding()","        } dynamicIsland: { context in","            DynamicIsland {","                DynamicIslandExpandedRegion(.leading) {","                    Text(context.state.emoji)","                        .font(.title)","                }","                DynamicIslandExpandedRegion(.trailing) {","                    Text(context.state.estimatedTime)","                        .font(.caption)","                }","                DynamicIslandExpandedRegion(.center) {","                    Text(context.state.status)","                        .font(.caption)","                }","            } compactLeading: {","                Text(context.state.emoji)","            } compactTrailing: {","                Text(context.state.estimatedTime)","                    .font(.caption2)","            } minimal: {","                Text(context.state.emoji)","            }","        }","    }","}"],"type":"codeListing"},{"anchor":"Step-6-Initialize-in-AppDelegate","text":"Step 6: Initialize in AppDelegate","type":"heading","level":2},{"code":["import UIKit","import PushwooshFramework","import PushwooshLiveActivities","","@main","class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","","        if #available(iOS 16.1, *) {","            Pushwoosh.LiveActivities.setup(FoodDeliveryAttributes.self)","        }","","        return true","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"setup()"},{"text":" method handles the entire lifecycle of Live Activities:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Automatically listens for push-to-start token updates (iOS 17.2+)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Automatically listens for activity token updates","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Registers tokens with Pushwoosh server","type":"text"}],"type":"paragraph"}]}]},{"anchor":"Step-7-Create-Live-Activity-Manager","text":"Step 7: Create Live Activity Manager","level":2,"type":"heading"},{"code":["import Foundation","import ActivityKit","import UIKit","import PushwooshFramework","import PushwooshLiveActivities","","class LiveActivityManager: NSObject, ObservableObject {","    public static let shared = LiveActivityManager()","    private var currentActivity: Activity<FoodDeliveryAttributes>?","","    func startActivity() {","        guard ActivityAuthorizationInfo().areActivitiesEnabled else {","            print(\"Live Activities are not enabled\")","            return","        }","","        do {","            let pushwooshData = PushwooshLiveActivityAttributeData(","                activityId: \"order_123\"","            )","","            let attribute = FoodDeliveryAttributes(","                orderNumber: \"1234567\",","                pushwoosh: pushwooshData","            )","","            let initialState = FoodDeliveryAttributes.ContentState(","                status: \"Preparing your meal\",","                estimatedTime: \"25 min\",","                emoji: \"👨‍🍳\",","                pushwoosh: nil","            )","","            let activity = try Activity<FoodDeliveryAttributes>.request(","                attributes: attribute,","                content: .init(state: initialState, staleDate: nil),","                pushType: .token","            )","","            self.currentActivity = activity","","            Task {","                for await pushToken in activity.pushTokenUpdates {","                    let pushTokenString = pushToken.reduce(\"\") {","                        $0 + String(format: \"%02x\", $1)","                    }","","                    print(\"Activity push token: \\(pushTokenString)\")","","                    Pushwoosh.LiveActivities.startLiveActivity(","                        token: pushTokenString,","                        activityId: \"order_123\"","                    )","                }","            }","        } catch {","            print(\"Start Activity Error: \\(error.localizedDescription)\")","        }","    }","","    func endActivity() async {","        guard let activity = currentActivity else { return }","","        await activity.end(nil, dismissalPolicy: .immediate)","","        Pushwoosh.LiveActivities.stopLiveActivity(activityId: \"order_123\")","    }","}"],"type":"codeListing","syntax":"swift"},{"level":2,"text":"Step 8: Start Activity from UI","type":"heading","anchor":"Step-8-Start-Activity-from-UI"},{"syntax":"swift","type":"codeListing","code":["import SwiftUI","","struct ContentView: View {","    var body: some View {","        VStack(spacing: 20) {","            Button(action: {","                LiveActivityManager.shared.startActivity()","            }) {","                Text(\"Start Live Activity\")","                    .foregroundColor(.white)","                    .padding()","                    .background(Color.blue)","                    .cornerRadius(10)","            }","","            Button(action: {","                Task {","                    await LiveActivityManager.shared.endActivity()","                }","            }) {","                Text(\"End Live Activity\")","                    .foregroundColor(.white)","                    .padding()","                    .background(Color.red)","                    .cornerRadius(10)","            }","        }","        .padding()","    }","}"]},{"level":2,"text":"Step 9: Send Push Notifications via Pushwoosh API","type":"heading","anchor":"Step-9-Send-Push-Notifications-via-Pushwoosh-API"},{"inlineContent":[{"text":"Use Pushwoosh REST API to send Live Activity updates from your server.","type":"text"}],"type":"paragraph"},{"anchor":"Start-Live-Activity-Push-to-Start-for-iOS-172+","type":"heading","text":"Start Live Activity (Push-to-Start for iOS 17.2+)","level":3},{"type":"paragraph","