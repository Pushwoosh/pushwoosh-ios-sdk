json\/1.3\/updateLiveActivity"}]},{"code":["{","  \"request\": {","    \"application\": \"YOUR-APP-CODE\",","    \"auth\": \"YOUR-API-TOKEN\",","    \"notifications\": [","      {","        \"live_activity\": {","          \"event\": \"update\",","          \"content-state\": {","            \"status\": \"On the way\",","            \"estimatedTime\": \"10 min\",","            \"emoji\": \"🚚\"","          },","          \"stale-date\": 1234567890","        },","        \"live_activity_id\": \"order_123\"","      }","    ]","  }","}"],"type":"codeListing","syntax":"json"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Optional Parameters:","type":"text"}]}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"stale-date"},{"type":"text","text":": Unix timestamp when content becomes stale"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"dismissal-date","type":"codeVoice"},{"text":": Unix timestamp when to dismiss (use with “end” event)","type":"text"}]}]}]},{"text":"End Live Activity","type":"heading","level":3,"anchor":"End-Live-Activity"},{"inlineContent":[{"code":"POST https:\/\/api.pushwoosh.com\/json\/1.3\/updateLiveActivity","type":"codeVoice"}],"type":"paragraph"},{"type":"codeListing","code":["{","  \"request\": {","    \"application\": \"YOUR-APP-CODE\",","    \"auth\": \"YOUR-API-TOKEN\",","    \"notifications\": [","      {","        \"live_activity\": {","          \"event\": \"end\",","          \"dismissal-date\": 1234567890","        },","        \"live_activity_id\": \"order_123\"","      }","    ]","  }","}"],"syntax":"json"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Note:","type":"text"}]},{"type":"text","text":" For push-to-start functionality (iOS 17.2+), the "},{"code":"setup()","type":"codeVoice"},{"text":" method automatically handles token registration. No additional code is needed in the app.","type":"text"}]},{"text":"Available SDK Methods","type":"heading","level":2,"anchor":"Available-SDK-Methods"},{"inlineContent":[{"type":"text","text":"The PushwooshLiveActivities module provides the following methods:"}],"type":"paragraph"},{"text":"Setup Methods","type":"heading","anchor":"Setup-Methods","level":3},{"code":["\/\/ Setup with custom attributes (iOS 16.1+)","static func setup<Attributes: PushwooshLiveActivityAttributes>(","    _ activityType: Attributes.Type",")","","\/\/ Setup with default attributes (iOS 16.1+)","static func defaultSetup()"],"type":"codeListing","syntax":"swift"},{"anchor":"Token-Management","level":3,"type":"heading","text":"Token Management"},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Important"}]},{"type":"text","text":": These methods are only needed if you are "},{"inlineContent":[{"type":"text","text":"NOT"}],"type":"strong"},{"text":" using ","type":"text"},{"type":"codeVoice","code":"setup()"},{"text":" or ","type":"text"},{"code":"defaultSetup()","type":"codeVoice"},{"type":"text","text":". The setup methods automatically manage all token registration and lifecycle. Use these methods only for manual token management scenarios."}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"},{"type":"codeListing","syntax":"swift","code":["\/\/ Send push-to-start token (iOS 17.2+)","static func sendPushToStartLiveActivity(token: String)","static func sendPushToStartLiveActivity(","    token: String,","    completion: @escaping (Error?) -> Void",")","","\/\/ Register activity token","static func startLiveActivity(token: String, activityId: String)","static func startLiveActivity(","    token: String,","    activityId: String,","    completion: @escaping (Error?) -> Void",")"]},{"anchor":"Activity-Lifecycle","text":"Activity Lifecycle","type":"heading","level":3},{"syntax":"swift","code":["\/\/ Stop all activities","static func stopLiveActivity()","static func stopLiveActivity(completion: