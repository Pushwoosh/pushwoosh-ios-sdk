 {","","    static func configure(delegate: PWMessagingDelegate) {","        \/\/ Set delegates","        Pushwoosh.configure.setDelegate(delegate)","","        \/\/ Configure foreground display","        Pushwoosh.configure.setShowPushnotificationAlert(true)","","        \/\/ Register for push","        Pushwoosh.configure.registerForPushNotifications()","    }","","    static func handleUserLogin(user: User) {","        \/\/ Set user identity","        Pushwoosh.configure.setUserId(user.id)","","        if let email = user.email {","            Pushwoosh.configure.setEmail(email)","        }","","        \/\/ Set user tags","        Pushwoosh.configure.setTags([","            \"logged_in\": true,","            \"user_type\": user.type.rawValue,","            \"signup_date\": user.createdAt","        ])","    }","","    static func handleUserLogout() {","        Pushwoosh.configure.unregisterForPushNotifications { _ in","            Pushwoosh.configure.setTags([","                \"logged_in\": false,","                \"user_id\": NSNull()","            ])","        }","    }","}"],"type":"codeListing"}],"kind":"content"}],"abstract":[{"type":"text","text":"Configuration interface for Pushwoosh SDK."}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore"]]},"relationshipsSections":[{"type":"inheritsFrom","kind":"relationships","identifiers":["doc:\/\/com.pushwoosh.PushwooshCore\/objc(cs)NSObject"],"title":"Inherits From"},{"kind":"relationships","identifiers":["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"],"type":"conformsTo","title":"Conforms To"}],"topicSections":[{"title":"Type Methods","identifiers":["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/configure","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/Pushwoos