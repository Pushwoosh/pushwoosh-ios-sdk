andleUserLogout() {","        Pushwoosh.configure.unregisterForPushNotifications { _ in","            Pushwoosh.configure.setTags([","                \"logged_in\": false,","                \"user_id\": NSNull()","            ])","        }","    }","}"]}],"kind":"content"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","kind":"symbol","title":"PWConfiguration","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","abstract":[],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","title":"PushwooshCore","role":"collection","url":"\/documentation\/pushwooshcore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PushwooshConfig/getAdditionalAuthorizationOptions":{"fragments":[{"kind":"text","text":"+ "},{"text":"getAdditionalAuthorizationOptions","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/pushwooshcore\/pushwooshconfig\/getadditionalauthorizationoptions","abstract":[{"type":"text","text":"Retrieves the current additional authorization options."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/getAdditionalAuthorizationOptions","type":"topic","role":"symbol","title":"getAdditionalAuthorizationOptions","navigatorTitle":[{"text":"getAdditionalAuthorizationOptions","kind":"identifier"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PushwooshConfig/setAdditionalAuthorizationOptions:":{"url":"\/documentation\/pushwooshcore\/pushwooshconfig\/setadditionalauthorizationoptions:","abstract":[{"type":"text","text":"Sets additional notificati