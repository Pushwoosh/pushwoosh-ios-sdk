_in\": false,","                \"user_id\": NSNull()","            ])","        }","    }","}"]}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore"]]},"abstract":[{"text":"Configuration interface for Pushwoosh SDK.","type":"text"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PushwooshConfig/addNotificationCenterDelegate:":{"url":"\/documentation\/pushwooshcore\/pushwooshconfig\/addnotificationcenterdelegate:","navigatorTitle":[{"kind":"identifier","text":"addNotificationCenterDelegate:"}],"role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"addNotificationCenterDelegate:","kind":"identifier"}],"title":"addNotificationCenterDelegate:","type":"topic","abstract":[{"type":"text","text":"Adds a custom "},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"text":" to the Pushwoosh notification center delegate proxy.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PushwooshConfig/configure":{"url":"\/documentation\/pushwooshcore\/pushwooshconfig\/configure","role":"symbol","title":"configure","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"configure"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"configure"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/configure","kind":"symbol","abstract":[{"type":"text","text":"Returns the configuration interface."}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"title":"PWConfiguration","type"