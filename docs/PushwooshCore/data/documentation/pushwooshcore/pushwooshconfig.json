andleUserLogout() {","        Pushwoosh.configure.unregisterForPushNotifications { _ in","            Pushwoosh.configure.setTags([","                \"logged_in\": false,","                \"user_id\": NSNull()","            ])","        }","    }","}"]}],"kind":"content"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PushwooshConfig/addNotificationCenterDelegate:":{"role":"symbol","url":"\/documentation\/pushwooshcore\/pushwooshconfig\/addnotificationcenterdelegate:","abstract":[{"type":"text","text":"Adds a custom "},{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"type":"text","text":" to the Pushwoosh notification center delegate proxy."}],"type":"topic","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:","fragments":[{"text":"+ ","kind":"text"},{"text":"addNotificationCenterDelegate:","kind":"identifier"}],"navigatorTitle":[{"text":"addNotificationCenterDelegate:","kind":"identifier"}],"title":"addNotificationCenterDelegate:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PushwooshConfig/setAdditionalAuthorizationOptions:":{"abstract":[{"type":"text","text":"Sets additional notification authorization options beyond the SDK defaults."}],"title":"setAdditionalAuthorizationOptions:","kind":"symbol","url":"\/documentation\/pushwooshcore\/pushwooshconfig\/setadditionalauthorizationoptions:","type":"topic","role":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"setAdditionalAuthorizationOptions:","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"setAdditionalAuthorizationOptions:"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/setAdditionalAuthorizationOptions:"},"doc://com.pushwoosh.PushwooshCore/objc(cs)NSObject":{"type":"unresolvable","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/objc(cs)NSObject","title":"NSObject"},"doc