woosh.configure.setShowPushnotificationAlert(true)","","        \/\/ Register for push","        Pushwoosh.configure.registerForPushNotifications()","    }","","    static func handleUserLogin(user: User) {","        \/\/ Set user identity","        Pushwoosh.configure.setUserId(user.id)","","        if let email = user.email {","            Pushwoosh.configure.setEmail(email)","        }","","        \/\/ Set user tags","        Pushwoosh.configure.setTags([","            \"logged_in\": true,","            \"user_type\": user.type.rawValue,","            \"signup_date\": user.createdAt","        ])","    }","","    static func handleUserLogout() {","        Pushwoosh.configure.unregisterForPushNotifications { _ in","            Pushwoosh.configure.setTags([","                \"logged_in\": false,","                \"user_id\": NSNull()","            ])","        }","    }","}"],"syntax":"swift"}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pushwooshconfig"]}],"topicSections":[{"identifiers":["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/configure","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/getAdditionalAuthorizationOptions","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/setAdditionalAuthorizationOptions:"],"title":"Type Methods"}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig","interfaceLanguage":"occ"},"sections":[],"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"relationshipsSections":[{"identifiers":["doc:\/\/com.pushwoosh.PushwooshCore\/objc(cs)NSObject"],"title":"Inherits From","kind":"relationships","type":"inheritsFrom"},{"kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/com.pushwoos