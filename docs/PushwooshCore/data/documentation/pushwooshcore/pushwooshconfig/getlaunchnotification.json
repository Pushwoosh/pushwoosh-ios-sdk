{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/getLaunchNotification","interfaceLanguage":"occ"},"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig"]]},"metadata":{"role":"symbol","externalID":"c:objc(cs)PushwooshConfig(cm)getLaunchNotification","modules":[{"name":"PushwooshCore"}],"fragments":[{"kind":"text","text":"+ "},{"text":"getLaunchNotification","kind":"identifier"}],"title":"getLaunchNotification","roleHeading":"Type Method","symbolKind":"method","navigatorTitle":[{"text":"getLaunchNotification","kind":"identifier"}]},"abstract":[{"type":"text","text":"Returns push notification payload if the app was started in response to a push notification, or "},{"type":"codeVoice","code":"nil"},{"text":" otherwise.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"text":"NSDictionary","preciseIdentifier":"c:objc(cs)NSDictionary","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"identifier","text":"getLaunchNotification"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"kind":"content","content":[{"type":"heading","text":"Return Value","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"text":"The push notification payload dictionary, or ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" if the app was not launched from a push notification."}]}]},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Use this method to retrieve the notification data that caused the app to launch from a terminated state."},{"type":"text","text":" "},{"type":"text","text":"This is useful for handling deep links or navigation based on the push content."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The value is set when the app is cold-started by tapping a push notification and remains available","type":"text"},{"type":"text","text":" "},{"text":"for the lifetime of the process. If the app was already running (foreground or background),","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the value is "},{"type":"codeVoice","code":"nil"},{"text":" — use ","type":"text"},{"type":"codeVoice","code":"PWMessagingDelegate"},{"text":" callbacks instead.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Must be called ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"after"}]},{"type":"text","text":" the SDK has finished initialization (e.g., in "},{"type":"codeVoice","code":"applicationDidBecomeActive:"},{"type":"text","text":" or later)."}]},{"text":"Example","type":"heading","level":2,"anchor":"Example"},{"syntax":"swift","type":"codeListing","code":["func applicationDidBecomeActive(_ application: UIApplication) {","    if let launchNotification = Pushwoosh.configure.getLaunchNotification() {","        print(\"App launched from push: \\(launchNotification)\")","    }","}"]},{"inlineContent":[{"type":"text","text":"Objective-C:"}],"type":"paragraph"},{"syntax":"objc","code":["- (void)applicationDidBecomeActive:(UIApplication *)application {","    NSDictionary *launchNotification = [Pushwoosh.configure getLaunchNotification];","    if (launchNotification) {","        NSLog(@\"App launched from push: %@\", launchNotification);","    }","}"],"type":"codeListing"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/getlaunchnotification"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","role":"collection","title":"PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","url":"\/documentation\/pushwooshcore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PushwooshConfig/getLaunchNotification":{"url":"\/documentation\/pushwooshcore\/pushwooshconfig\/getlaunchnotification","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/getLaunchNotification","type":"topic","fragments":[{"kind":"text","text":"+ "},{"text":"getLaunchNotification","kind":"identifier"}],"navigatorTitle":[{"text":"getLaunchNotification","kind":"identifier"}],"kind":"symbol","role":"symbol","title":"getLaunchNotification","abstract":[{"type":"text","text":"Returns push notification payload if the app was started in response to a push notification, or "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" otherwise."}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PushwooshConfig":{"type":"topic","kind":"symbol","role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig","fragments":[{"text":"PushwooshConfig","kind":"identifier"}],"abstract":[{"type":"text","text":"Configuration interface for Pushwoosh SDK."}],"title":"PushwooshConfig","url":"\/documentation\/pushwooshcore\/pushwooshconfig"}}}