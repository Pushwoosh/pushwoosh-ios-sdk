{"abstract":[{"type":"text","text":"Returns push notification payload if the app was started in response to a push notification, or "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" otherwise."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSDictionary","text":"NSDictionary"},{"kind":"text","text":" *) "},{"text":"getLaunchNotification","kind":"identifier"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}]},{"content":[{"level":2,"text":"Return Value","type":"heading","anchor":"return-value"},{"inlineContent":[{"type":"text","text":"The push notification payload dictionary, or "},{"code":"nil","type":"codeVoice"},{"text":" if the app was not launched from a push notification.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"Use this method to retrieve the notification data that caused the app to launch from a terminated state."},{"type":"text","text":" "},{"text":"This is useful for handling deep links or navigation based on the push content.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The value is set when the app is cold-started by tapping a push notification and remains available"},{"type":"text","text":" "},{"type":"text","text":"for the lifetime of the process. If the app was already running (foreground or background),"},{"type":"text","text":" "},{"type":"text","text":"the value is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" — use "},{"type":"codeVoice","code":"PWMessagingDelegate"},{"text":" callbacks instead.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Must be called "},{"inlineContent":[{"type":"text","text":"after"}],"type":"strong"},{"text":" the SDK has finished initialization (e.g., in ","type":"text"},{"type":"codeVoice","code":"applicationDidBecomeActive:"},{"type":"text","text":" or later)."}],"type":"paragraph"},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"type":"codeListing","syntax":"swift","code":["func applicationDidBecomeActive(_ application: UIApplication) {","    if let launchNotification = Pushwoosh.configure.getLaunchNotification() {","        print(\"App launched from push: \\(launchNotification)\")","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Objective-C:","type":"text"}]},{"type":"codeListing","code":["- (void)applicationDidBecomeActive:(UIApplication *)application {","    NSDictionary *launchNotification = [Pushwoosh.configure getLaunchNotification];","    if (launchNotification) {","        NSLog(@\"App launched from push: %@\", launchNotification);","    }","}"],"syntax":"objc"}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig"]]},"sections":[],"metadata":{"navigatorTitle":[{"kind":"identifier","text":"getLaunchNotification"}],"title":"getLaunchNotification","role":"symbol","externalID":"c:objc(cs)PushwooshConfig(cm)getLaunchNotification","modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","symbolKind":"method","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"getLaunchNotification"}]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/getlaunchnotification"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/getLaunchNotification"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshC