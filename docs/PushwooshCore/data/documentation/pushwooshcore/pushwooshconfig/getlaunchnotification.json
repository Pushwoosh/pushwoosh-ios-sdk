{"sections":[],"abstract":[{"text":"Returns push notification payload if the app was started in response to a push notification, or ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" otherwise."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSDictionary","text":"NSDictionary","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"identifier","text":"getLaunchNotification"},{"text":";","kind":"text"}]}]},{"content":[{"anchor":"return-value","text":"Return Value","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The push notification payload dictionary, or "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" if the app was not launched from a push notification."}],"type":"paragraph"}],"kind":"content"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Use this method to retrieve the notification data that caused the app to launch from a terminated state.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This is useful for handling deep links or navigation based on the push content."}]},{"inlineContent":[{"text":"The value is set when the app is cold-started by tapping a push notification and remains available","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for the lifetime of the process. If the app was already running (foreground or background),"},{"type":"text","text":" "},{"text":"the value is ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" — use ","type":"text"},{"type":"codeVoice","code":"PWMessagingDelegate"},{"type":"text","text":" callbacks instead."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Must be called ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"after"}]},{"text":" the SD