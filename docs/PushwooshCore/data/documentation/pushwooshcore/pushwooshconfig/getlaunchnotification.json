":"Example"},{"syntax":"swift","code":["func applicationDidBecomeActive(_ application: UIApplication) {","    if let launchNotification = Pushwoosh.configure.getLaunchNotification() {","        print(\"App launched from push: \\(launchNotification)\")","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"Objective-C:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"objc","code":["- (void)applicationDidBecomeActive:(UIApplication *)application {","    NSDictionary *launchNotification = [Pushwoosh.configure getLaunchNotification];","    if (launchNotification) {","        NSLog(@\"App launched from push: %@\", launchNotification);","    }","}"]}]}],"metadata":{"modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","externalID":"c:objc(cs)PushwooshConfig(cm)getLaunchNotification","symbolKind":"method","title":"getLaunchNotification","role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"getLaunchNotification","kind":"identifier"}],"navigatorTitle":[{"text":"getLaunchNotification","kind":"identifier"}]},"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/getLaunchNotification","interfaceLanguage":"occ"},"abstract":[{"text":"Returns push notification payload if the app was started in response to a push notification, or ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" otherwise."}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/getlaunchnotification"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PushwooshConfig":{"type":"topic","role":"symbol","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/d