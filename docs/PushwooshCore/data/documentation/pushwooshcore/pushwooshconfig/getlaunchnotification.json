,"text":" — use "},{"type":"codeVoice","code":"PWMessagingDelegate"},{"text":" callbacks instead.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Must be called ","type":"text"},{"inlineContent":[{"text":"after","type":"text"}],"type":"strong"},{"text":" the SDK has finished initialization (e.g., in ","type":"text"},{"type":"codeVoice","code":"applicationDidBecomeActive:"},{"text":" or later).","type":"text"}]},{"anchor":"Example","type":"heading","text":"Example","level":2},{"syntax":"swift","code":["func applicationDidBecomeActive(_ application: UIApplication) {","    if let launchNotification = Pushwoosh.configure.getLaunchNotification() {","        print(\"App launched from push: \\(launchNotification)\")","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Objective-C:"}]},{"syntax":"objc","code":["- (void)applicationDidBecomeActive:(UIApplication *)application {","    NSDictionary *launchNotification = [Pushwoosh.configure getLaunchNotification];","    if (launchNotification) {","        NSLog(@\"App launched from push: %@\", launchNotification);","    }","}"],"type":"codeListing"}],"kind":"content"}],"abstract":[{"type":"text","text":"Returns push notification payload if the app was started in response to a push notification, or "},{"code":"nil","type":"codeVoice"},{"text":" otherwise.","type":"text"}],"metadata":{"title":"getLaunchNotification","roleHeading":"Type Method","symbolKind":"method","navigatorTitle":[{"text":"getLaunchNotification","kind":"identifier"}],"fragments":[{"text":"+ ","kind":"text"},{"text":"getLaunchNotification","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"role":"symbol","externalID":"c:objc(cs)PushwooshConfig(cm)getLaunchNotification"},"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"to