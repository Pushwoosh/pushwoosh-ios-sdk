{"kind":"symbol","abstract":[{"type":"text","text":"Sets additional notification authorization options beyond the SDK defaults."}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setAdditionalAuthorizationOptions:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:@E@UNAuthorizationOptions","text":"UNAuthorizationOptions","kind":"typeIdentifier"},{"kind":"text","text":") "},{"kind":"internalParam","text":"options"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"parameters":[{"name":"options","content":[{"inlineContent":[{"text":"The additional ","type":"text"},{"code":"UNAuthorizationOptions","type":"codeVoice"},{"text":" to request.","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"When calling "},{"type":"codeVoice","code":"registerForPushNotifications"},{"type":"text","text":", the SDK requests these permissions by default:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionBadge"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionSound"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionAlert"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionCarPlay"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this method to request additional capabilities on top of the defaults."},{"text":" ","type":"text"},{"type":"text","text":"The options you set here are combined (bitwise OR) with the default options"},{"type":"text","text":" "},{"type":"text","text":"before being passed to "},{"code":"UNUserNotificationCenter.requestAuthorizationWithOptions:","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Must be called "},{"type":"strong","inlineContent":[{"text":"before","type":"text"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"registerForPushNotifications"},{"type":"text","text":"."}]},{"level":2,"anchor":"Available-Options","text":"Available Options","type":"heading"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionProvisional"},{"type":"text","text":" (iOS 12+) — Delivers notifications quietly to the Notification Center"},{"type":"text","text":" "},{"text":"without showing a permission dialog. The user sees notifications silently and can then choose to keep or disable them.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Use this for a “soft opt-in” strategy to avoid users declining the permission prompt upfront."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionCriticalAlert"},{"text":" (iOS 12+) — Allows notifications that bypass Do Not Disturb and the mute switch.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Requires a special entitlement from Apple (must be approved via Apple Developer portal)."},{"type":"text","text":" "},{"type":"text","text":"Intended for medical, health, safety, and public security apps."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionProvidesAppNotificationSettings","type":"codeVoice"},{"type":"text","text":" (iOS 12+) — Adds a “Configure in App” button"},{"text":" ","type":"text"},{"type":"text","text":"to the system notification settings for your app. When tapped, iOS calls"},{"type":"text","text":" "},{"code":"userNotificationCenter:openSettingsForNotification:","type":"codeVoice"},{"type":"text","text":" on your "},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:","isActive":true},{"text":" to register your delegate and handle this callback.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionAnnouncement"},{"type":"text","text":" (iOS 13+) — Allows Siri to automatically read out notifications"},{"text":" ","type":"text"},{"type":"text","text":"through AirPods and compatible headphones."}]}]}]},{"type":"heading","text":"Example — Provisional (Soft Opt-In)","anchor":"Example-Provisional-Soft-Opt-In","level":2},{"type":"codeListing","syntax":"swift","code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional])","    }","","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}"]},{"text":"Example — In-App Notification Settings Button","type":"heading","anchor":"Example-In-App-Notification-Settings-Button","level":2},{"code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.providesAppNotificationSettings])","    }","","    Pushwoosh.configure.addNotificationCenterDelegate(self)","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}","","\/\/ Called when user taps \"Configure in App\" in system notification settings","func userNotificationCenter(_ center: UNUserNotificationCenter,","                            openSettingsFor notification: UNNotification?) {","    \/\/ Navigate to your in-app notification settings screen","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Example-Combining-Multiple-Options","level":2,"type":"heading","text":"Example — Combining Multiple Options"},{"code":["if #available(iOS 12.0, *) {","    Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional, .providesAppNotificationSettings])","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Objective-C:"}],"type":"paragraph"},{"syntax":"objc","type":"codeListing","code":["if (@available(iOS 12.0, *)) {","    [Pushwoosh.configure setAdditionalAuthorizationOptions:UNAuthorizationOptionProvisional | UNAuthorizationOptionProvidesAppNotificationSettings];","}","","[Pushwoosh.configure registerForPushNotifications];"]}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/setAdditionalAuthorizationOptions:"},"sections":[],"metadata":{"roleHeading":"Type Method","fragments":[{"kind":"text","text":"+ "},{"text":"setAdditionalAuthorizationOptions:","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"setAdditionalAuthorizationOptions:"}],"title":"setAdditionalAuthorizationOptions:","symbolKind":"method","modules":[{"name":"PushwooshCore"}],"role":"symbol","externalID":"c:objc(cs)PushwooshConfig(cm)setAdditionalAuthorizationOptions:"},"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/setadditionalauthorizationoptions:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"role":"collection","url":"\/documentation