{"sections":[],"metadata":{"modules":[{"name":"PushwooshCore"}],"role":"symbol","title":"setAdditionalAuthorizationOptions:","navigatorTitle":[{"text":"setAdditionalAuthorizationOptions:","kind":"identifier"}],"symbolKind":"method","roleHeading":"Type Method","fragments":[{"kind":"text","text":"+ "},{"text":"setAdditionalAuthorizationOptions:","kind":"identifier"}],"externalID":"c:objc(cs)PushwooshConfig(cm)setAdditionalAuthorizationOptions:"},"abstract":[{"type":"text","text":"Sets additional notification authorization options beyond the SDK defaults."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"text":"setAdditionalAuthorizationOptions:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@E@UNAuthorizationOptions","text":"UNAuthorizationOptions"},{"kind":"text","text":") "},{"kind":"internalParam","text":"options"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"parameters":[{"name":"options","content":[{"inlineContent":[{"text":"The additional ","type":"text"},{"type":"codeVoice","code":"UNAuthorizationOptions"},{"text":" to request.","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"When calling "},{"type":"codeVoice","code":"registerForPushNotifications"},{"type":"text","text":", the SDK requests these permissions by default:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionBadge"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionSound"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionAlert","type":"