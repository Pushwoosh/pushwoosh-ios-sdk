th, safety, and public security apps."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionProvidesAppNotificationSettings"},{"type":"text","text":" (iOS 12+) — Adds a “Configure in App” button"},{"type":"text","text":" "},{"text":"to the system notification settings for your app. When tapped, iOS calls","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"userNotificationCenter:openSettingsForNotification:"},{"text":" on your ","type":"text"},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:","type":"reference"},{"text":" to register your delegate and handle this callback.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionAnnouncement"},{"text":" (iOS 13+) — Allows Siri to automatically read out notifications","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"through AirPods and compatible headphones."}]}]}]},{"level":2,"text":"Example — Provisional (Soft Opt-In)","anchor":"Example-Provisional-Soft-Opt-In","type":"heading"},{"type":"codeListing","syntax":"swift","code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional])","    }","","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}"]},{"text":"Example — In-App Notification Settings Button","type":"heading","anchor":"Example-In-App-Notification-Settings-Button","level":2},{"type":"codeListing","code":["func application(_ application: UIApplication,","       