{"metadata":{"symbolKind":"method","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"setAdditionalAuthorizationOptions:"}],"fragments":[{"text":"+ ","kind":"text"},{"text":"setAdditionalAuthorizationOptions:","kind":"identifier"}],"roleHeading":"Type Method","externalID":"c:objc(cs)PushwooshConfig(cm)setAdditionalAuthorizationOptions:","title":"setAdditionalAuthorizationOptions:","modules":[{"name":"PushwooshCore"}]},"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/setAdditionalAuthorizationOptions:"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":") ","kind":"text"},{"text":"setAdditionalAuthorizationOptions:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"UNAuthorizationOptions","kind":"typeIdentifier","preciseIdentifier":"c:@E@UNAuthorizationOptions"},{"kind":"text","text":") "},{"text":"options","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The additional ","type":"text"},{"code":"UNAuthorizationOptions","type":"codeVoice"},{"type":"text","text":" to request."}]}],"name":"options"}],"kind":"parameters"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When calling "},{"type":"codeVoice","code":"registerForPushNotifications"},{"text":", the SDK requests these permissions by default:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionBadge","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionSound","type":"codeVoice"}]}]},{"content