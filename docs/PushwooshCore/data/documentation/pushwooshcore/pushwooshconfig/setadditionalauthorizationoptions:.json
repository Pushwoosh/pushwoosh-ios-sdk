cial entitlement from Apple (must be approved via Apple Developer portal)."},{"type":"text","text":" "},{"type":"text","text":"Intended for medical, health, safety, and public security apps."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionProvidesAppNotificationSettings"},{"type":"text","text":" (iOS 12+) — Adds a “Configure in App” button"},{"type":"text","text":" "},{"type":"text","text":"to the system notification settings for your app. When tapped, iOS calls"},{"text":" ","type":"text"},{"type":"codeVoice","code":"userNotificationCenter:openSettingsForNotification:"},{"type":"text","text":" on your "},{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:"},{"type":"text","text":" to register your delegate and handle this callback."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionAnnouncement"},{"text":" (iOS 13+) — Allows Siri to automatically read out notifications","type":"text"},{"type":"text","text":" "},{"type":"text","text":"through AirPods and compatible headphones."}]}]}]},{"level":2,"text":"Example — Provisional (Soft Opt-In)","anchor":"Example-Provisional-Soft-Opt-In","type":"heading"},{"type":"codeListing","syntax":"swift","code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional])","    }","","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}"]},{"text":"Example — In-App Notification Settings Button","type":"heading","level":2,"anchor":