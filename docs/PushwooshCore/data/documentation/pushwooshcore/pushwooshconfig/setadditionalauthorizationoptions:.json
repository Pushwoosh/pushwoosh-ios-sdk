{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig"]]},"metadata":{"symbolKind":"method","title":"setAdditionalAuthorizationOptions:","role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"setAdditionalAuthorizationOptions:","kind":"identifier"}],"roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"kind":"identifier","text":"setAdditionalAuthorizationOptions:"}],"externalID":"c:objc(cs)PushwooshConfig(cm)setAdditionalAuthorizationOptions:"},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/setAdditionalAuthorizationOptions:","interfaceLanguage":"occ"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/setadditionalauthorizationoptions:"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"setAdditionalAuthorizationOptions:","kind":"identifier"},{"kind":"text","text":"("},{"text":"UNAuthorizationOptions","kind":"typeIdentifier","preciseIdentifier":"c:@E@UNAuthorizationOptions"},{"kind":"text","text":") "},{"text":"options","kind":"internalParam"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The additional "},{"type":"codeVoice","code":"UNAuthorizationOptions"},{"text":" to request.","type":"text"}],"type":"paragraph"}],"name":"options"}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"When calling "},{"code":"registerForPushNotifications","type":"codeVoice"},{"text":", the SDK requests these permissions by default:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionBadge"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionSound","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"code":"UNAuthorizationOptionAlert","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionCarPlay","type":"codeVoice"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Use this method to request additional capabilities on top of the defaults.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The options you set here are combined (bitwise OR) with the default options"},{"text":" ","type":"text"},{"text":"before being passed to ","type":"text"},{"type":"codeVoice","code":"UNUserNotificationCenter.requestAuthorizationWithOptions:"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Must be called "},{"inlineContent":[{"type":"text","text":"before"}],"type":"strong"},{"text":" ","type":"text"},{"code":"registerForPushNotifications","type":"codeVoice"},{"type":"text","text":"."}]},{"anchor":"Available-Options","type":"heading","text":"Available Options","level":2},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionProvisional"},{"type":"text","text":" (iOS 12+) — Delivers notifications quietly to the Notification Center"},{"text":" ","type":"text"},{"type":"text","text":"without showing a permission dialog. The user sees notifications silently and can then choose to keep or disable them."},{"text":" ","type":"text"},{"text":"Use this for a “soft opt-in” strategy to avoid users declining the permission prompt upfront.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionCriticalAlert"},{"type":"text","text":" (iOS 12+) — Allows notifications that bypass Do Not Disturb and the mute switch."},{"type":"text","text":" "},{"text":"Requires a special entitlement from Apple (must be approved via Apple Developer portal).","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Intended for medical, health, safety, and public security apps."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionProvidesAppNotificationSettings","type":"codeVoice"},{"type":"text","text":" (iOS 12+) — Adds a “Configure in App” button"},{"text":" ","type":"text"},{"text":"to the system notification settings for your app. When tapped, iOS calls","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"userNotificationCenter:openSettingsForNotification:"},{"type":"text","text":" on your "},{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:"},{"text":" to register your delegate and handle this callback.","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"UNAuthorizationOptionAnnouncement","type":"codeVoice"},{"type":"text","text":" (iOS 13+) — Allows Siri to automatically read out notifications"},{"text":" ","type":"text"},{"type":"text","text":"through AirPods and compatible headphones."}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"heading","level":2,"text":"Example — Provisional (Soft Opt-In)","anchor":"Example-Provisional-Soft-Opt-In"},{"type":"codeListing","code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional])","    }","","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}"],"syntax":"swift"},{"level":2,"type":"heading","anchor":"Example-In-App-Notification-Settings-Button","text":"Example — In-App Notification Settings Button"},{"syntax":"swift","code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.providesAppNotificationSettings])","    }","","    Pushwoosh.configure.addNotificationCenterDelegate(self)","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}","","\/\/ Called when user taps \"Configure in App\" in system notification settings","func userNotificationCenter(_ center: UNUserNotificationCenter,","                            openSettingsFor notification: UNNotification?) {","    \/\/ Navigate to your in-app notification settings screen","}"],"type":"codeListing"},{"type":"heading","level":2,"text":"Example — Combining Multiple Options","anchor":"Example-Combining-Multiple-Options"},{"code":["if #available(iOS 12.0, *) {","    Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional, .providesAppNotificationSettings])","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"Objective-C:","type":"text"}],"type":"paragraph"},{"code":["if (@available(iOS 12.0, *)) {","    [Pushwoosh.configure setAdditionalAuthorizationOptions:UNAuthorizationOptionProvisional | UNAuthorizationOptionProvidesAppNotificationSettings];","}","","[Pushwoosh.configure registerForPushNotifications];"],"type":"codeListing","syntax":"objc"}]}],"abstract":[{"text":"Sets additional notification authorization options beyond the SDK defaults.","type":"text"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PushwooshConfig/setAdditionalAuthorizationOp