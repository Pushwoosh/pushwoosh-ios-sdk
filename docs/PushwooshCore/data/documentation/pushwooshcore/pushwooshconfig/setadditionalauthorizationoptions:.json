{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/setAdditionalAuthorizationOptions:","interfaceLanguage":"occ"},"metadata":{"title":"setAdditionalAuthorizationOptions:","navigatorTitle":[{"kind":"identifier","text":"setAdditionalAuthorizationOptions:"}],"modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(cs)PushwooshConfig(cm)setAdditionalAuthorizationOptions:","roleHeading":"Type Method","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setAdditionalAuthorizationOptions:"}],"role":"symbol","symbolKind":"method"},"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"kind":"text","text":") "},{"kind":"identifier","text":"setAdditionalAuthorizationOptions:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:@E@UNAuthorizationOptions","text":"UNAuthorizationOptions","kind":"typeIdentifier"},{"kind":"text","text":") "},{"kind":"internalParam","text":"options"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"parameters":[{"name":"options","content":[{"inlineContent":[{"type":"text","text":"The additional "},{"type":"codeVoice","code":"UNAuthorizationOptions"},{"text":" to request.","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"When calling ","type":"text"},{"code":"registerForPushNotifications","type":"codeVoice"},{"type":"text","text":", the SDK requests these permissions by default:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionBadge"}]}]},{"content":[{"inlineContent":[{"code":"UNAuthorizationOptionSound","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionAlert"}]}]},{"content":[{"inlineContent":[{"code":"UNAuthorizationOptionCarPlay","type":"codeVoice"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"Use this method to request additional capabilities on top of the defaults."},{"type":"text","text":" "},{"type":"text","text":"The options you set here are combined (bitwise OR) with the default options"},{"text":" ","type":"text"},{"type":"text","text":"before being passed to "},{"code":"UNUserNotificationCenter.requestAuthorizationWithOptions:","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Must be called "},{"inlineContent":[{"text":"before","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"code":"registerForPushNotifications","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"Available Options","anchor":"Available-Options"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionProvisional"},{"text":" (iOS 12+) — Delivers notifications quietly to the Notification Center","type":"text"},{"type":"text","text":" "},{"type":"text","text":"without showing a permission dialog. The user sees notifications silently and can then choose to keep or disable them."},{"text":" ","type":"text"},{"text":"Use this for a “soft opt-in” strategy to avoid users declining the permission prompt upfront.","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"UNAuthorizationOptionCriticalAlert","type":"codeVoice"},{"text":" (iOS 12+) — Allows notifications that bypass Do Not Disturb and the mute switch.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Requires a special entitlement from Apple (must be approved via Apple Developer portal)."},{"type":"text","text":" "},{"type":"text","text":"Intended for medical, health, safety, and public security apps."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionProvidesAppNotificationSettings"},{"type":"text","text":" (iOS 12+) — Adds a “Configure in App” button"},{"type":"text","text":" "},{"text":"to the system notification settings for your app. When tapped, iOS calls","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"userNotificationCenter:openSettingsForNotification:"},{"text":" on your ","type":"text"},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:","isActive":true},{"text":" to register your delegate and handle this callback.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionAnnouncement"},{"type":"text","text":" (iOS 13+) — Allows Siri to automatically read out notifications"},{"type":"text","text":" "},{"type":"text","text":"through AirPods and compatible headphones."}]}]}],"type":"unorderedList"},{"type":"heading","anchor":"Example-Provisional-Soft-Opt-In","text":"Example — Provisional (Soft Opt-In)","level":2},{"code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional])","    }","","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Example-In-App-Notification-Settings-Button","type":"heading","text":"Example — In-App Notification Settings Button","level":2},{"syntax":"swift","code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.providesAppNotificationSettings])","    }","","    Pushwoosh.configure.addNotificationCenterDelegate(self)","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}","","\/\/ Called when user taps \"Configure in App\" in system notification settings","func userNotificationCenter(_ center: UNUserNotificationCenter,","                            openSettingsFor notification: UNNotification?) {","    \/\/ Navigate to your in-app notification settings screen","}"],"type":"codeListing"},{"anchor":"Example-Combining-Multiple-Options","type":"heading","level":2,"text":"Example — Combining Multiple Options"},{"type":"codeListing","code":["if #available(iOS 12.0, *) {","    Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional, .providesAppNotificationSettings])","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"Objective-C:"}],"type":"paragraph"},{"type":"codeListing","syntax":"objc","code":["if (@available(iOS 12.0, *)) {","    [Pushwoosh.configure setAdditionalAuthorizationOptions:UNAuthorizationOptionProvisional | UNAuthorizationOptionProvidesAppNotificationSettings];","}","","[Pushwoosh.configure registerForPushNotifications];"]}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig"]]},"kind":"symbol","abstract":[{"type":"text","text":"Sets additional notification authorization options beyond the SDK defaults."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/setadditionalauthorizationoptions:"]}],"sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PushwooshConfig/setAdditionalAuthorizationOp