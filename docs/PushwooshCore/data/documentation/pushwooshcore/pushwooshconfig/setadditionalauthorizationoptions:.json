{"abstract":[{"type":"text","text":"Sets additional notification authorization options beyond the SDK defaults."}],"kind":"symbol","metadata":{"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setAdditionalAuthorizationOptions:"}],"modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(cs)PushwooshConfig(cm)setAdditionalAuthorizationOptions:","navigatorTitle":[{"text":"setAdditionalAuthorizationOptions:","kind":"identifier"}],"symbolKind":"method","roleHeading":"Type Method","title":"setAdditionalAuthorizationOptions:","role":"symbol"},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/setAdditionalAuthorizationOptions:"},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"setAdditionalAuthorizationOptions:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"UNAuthorizationOptions","preciseIdentifier":"c:@E@UNAuthorizationOptions","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"options","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The additional "},{"type":"codeVoice","code":"UNAuthorizationOptions"},{"type":"text","text":" to request."}]}],"name":"options"}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When calling "},{"type":"codeVoice","code":"registerForPushNotifications"},{"text":", the SDK requests these permissions by default:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionBadge","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionSound"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"UNAuthorizationOptionAlert","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionCarPlay"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"Use this method to request additional capabilities on top of the defaults.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The options you set here are combined (bitwise OR) with the default options"},{"text":" ","type":"text"},{"text":"before being passed to ","type":"text"},{"type":"codeVoice","code":"UNUserNotificationCenter.requestAuthorizationWithOptions:"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Must be called "},{"type":"strong","inlineContent":[{"text":"before","type":"text"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"registerForPushNotifications"},{"type":"text","text":"."}]},{"type":"heading","text":"Available Options","anchor":"Available-Options","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"UNAuthorizationOptionProvisional","type":"codeVoice"},{"text":" (iOS 12+) — Delivers notifications quietly to the Notification Center","type":"text"},{"type":"text","text":" "},{"type":"text","text":"without showing a permission dialog. The user sees notifications silently and can then choose to keep or disable them."},{"text":" ","type":"text"},{"type":"text","text":"Use this for a “soft opt-in” strategy to avoid users declining the permission prompt upfront."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"UNAuthorizationOptionCriticalAlert","type":"codeVoice"},{"type":"text","text":" (iOS 12+) — Allows notifications that bypass Do Not Disturb and the mute switch."},{"text":" ","type":"text"},{"type":"text","text":"Requires a special entitlement from Apple (must be approved via Apple Developer portal)."},{"text":" ","type":"text"},{"type":"text","text":"Intended for medical, health, safety, and public security apps."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionProvidesAppNotificationSettings"},{"text":" (iOS 12+) — Adds a “Configure in App” button","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to the system notification settings for your app. When tapped, iOS calls"},{"type":"text","text":" "},{"type":"codeVoice","code":"userNotificationCenter:openSettingsForNotification:"},{"type":"text","text":" on your "},{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:"},{"type":"text","text":" to register your delegate and handle this callback."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionAnnouncement","type":"codeVoice"},{"type":"text","text":" (iOS 13+) — Allows Siri to automatically read out notifications"},{"type":"text","text":" "},{"type":"text","text":"through AirPods and compatible headphones."}]}]}]},{"type":"heading","level":2,"anchor":"Example-Provisional-Soft-Opt-In","text":"Example — Provisional (Soft Opt-In)"},{"code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional])","    }","","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}"],"type":"codeListing","syntax":"swift"},{"text":"Example — In-App Notification Settings Button","anchor":"Example-In-App-Notification-Settings-Button","type":"heading","level":2},{"syntax":"swift","code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.providesAppNotificationSettings])","    }","","    Pushwoosh.configure.addNotificationCenterDelegate(self)","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}","","\/\/ Called when user taps \"Configure in App\" in system notification settings","func userNotificationCenter(_ center: UNUserNotificationCenter,","                            openSettingsFor notification: UNNotification?) {","    \/\/ Navigate to your in-app notification settings screen","}"],"type":"codeListing"},{"anchor":"Example-Combining-Multiple-Options","text":"Example — Combining Multiple Options","type":"heading","level":2},{"code":["if #available(iOS 12.0, *) {","    Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional, .providesAppNotificationSettings])","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Objective-C:"}]},{"type":"codeListing","syntax":"objc","code":["if (@available(iOS 12.0, *)) {","    [Pushwoosh.configure setAdditionalAuthorizationOptions:UNAuthorizationOptionProvisional | UNAuthorizationOptionProvidesAppNotificationSettings];","}","","[Pushwoosh.configure registerForPushNotifications];"]}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/setadditionalauthorizationoptions:"]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig"]]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"abstract":[{"type":"text","text":"Core fo