these permissions by default:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionBadge","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionSound"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionAlert"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionCarPlay"}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"Use this method to request additional capabilities on top of the defaults.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The options you set here are combined (bitwise OR) with the default options"},{"text":" ","type":"text"},{"type":"text","text":"before being passed to "},{"type":"codeVoice","code":"UNUserNotificationCenter.requestAuthorizationWithOptions:"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Must be called ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"before"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"registerForPushNotifications"},{"text":".","type":"text"}]},{"text":"Available Options","anchor":"Available-Options","level":2,"type":"heading"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionProvisional"},{"type":"text","text":" (iOS 12+) — Delivers notifications quietly to the Notification Center"},{"text":" ","type":"text"},{"text":"without showing a permission dialog. The user sees notifications silently and can then choose to keep or disable them.","type":"text"},{"type":"text","text":" "},{"text":"Use this for a “soft opt-in” strategy to avoid users declining the permission prompt upfront.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionCriticalAlert"},{"type":"text","text":" (iOS 12+) — Allows notifications that bypass Do Not Disturb and the mute switch."},{"text":" ","type":"text"},{"type":"text","text":"Requires a special entitlement from Apple (must be approved via Apple Developer portal)."},{"text":" ","type":"text"},{"text":"Intended for medical, health, safety, and public security apps.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionProvidesAppNotificationSettings","type":"codeVoice"},{"text":" (iOS 12+) — Adds a “Configure in App” button","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to the system notification settings for your app. When tapped, iOS calls"},{"text":" ","type":"text"},{"code":"userNotificationCenter:openSettingsForNotification:","type":"codeVoice"},{"type":"text","text":" on your "},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:"},{"type":"text","text":" to register your delegate and handle this callback."}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionAnnouncement"},{"text":" (iOS 13+) — Allows Siri to automatically read out notifications","type":"text"},{"text":" ","type":"text"},{"text":"through AirPods and compatible headphones.","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","text":"Example — Provisional (Soft Opt-In)","level":2,"anchor":"Example-Provisional-Soft-Opt-In"},{"type":"codeListing","syntax":"swift","code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional])","    }","","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}"]},{"level":2,"text":"Example — In-App Notification Settings Button","type":"heading","anchor":"Example-In-App-Notification-Settings-Button"},{"syntax":"swift","type":"codeListing","code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.providesAppNotificationSettings])","    }","","    Pushwoosh.configure.addNotificationCenterDelegate(self)","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}","","\/\/ Called when user taps \"Configure in App\" in system notification settings","func userNotificationCenter(_ center: UNUserNotificationCenter,","                            openSettingsFor notification: UNNotification?) {","    \/\/ Navigate to your in-app notification settings screen","}"]},{"anchor":"Example-Combining-Multiple-Options","level":2,"text":"Example — Combining Multiple Options","type":"heading"},{"type":"codeListing","code":["if #available(iOS 12.0, *) {","    Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional, .providesAppNotificationSettings])","}"],"syntax":"swift"},{"inlineContent":[{"text":"Objective-C:","type":"text"}],"type":"paragraph"},{"code":["if (@available(iOS 12.0, *)) {","    [Pushwoosh.configure setAdditionalAuthorizationOptions:UNAuthorizationOptionProvisional | UNAuthorizationOptionProvidesAppNotificationSettings];","}","","[Pushwoosh.configure registerForPushNotifications];"],"type":"codeListing","syntax":"objc"}]}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/setadditionalauthorizationoptions:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PushwooshConfig/setAdditionalAuthorizationOp