{"kind":"symbol","abstract":[{"type":"text","text":"Sets additional notification authorization options beyond the SDK defaults."}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig"]]},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"setAdditionalAuthorizationOptions:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:@E@UNAuthorizationOptions","text":"UNAuthorizationOptions","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"options","kind":"internalParam"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The additional "},{"type":"codeVoice","code":"UNAuthorizationOptions"},{"text":" to request.","type":"text"}]}],"name":"options"}],"kind":"parameters"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"When calling ","type":"text"},{"code":"registerForPushNotifications","type":"codeVoice"},{"type":"text","text":", the SDK requests these permissions by default:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionBadge","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionSound","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionAlert"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionCarPlay","type":"codeVoice"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Use this method to request additional capabilities on top of the defaults.","type":"text"},{"type":"text","text":" "},{"text":"The options you set here are combined (bitwise OR) with the default options","type":"text"},{"type":"text","text":" "},{"type":"text","text":"before being passed to "},{"type":"codeVoice","code":"UNUserNotificationCenter.requestAuthorizationWithOptions:"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"Must be called "},{"type":"strong","inlineContent":[{"type":"text","text":"before"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"registerForPushNotifications"},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Available-Options","text":"Available Options","type":"heading","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionProvisional"},{"text":" (iOS 12+) — Delivers notifications quietly to the Notification Center","type":"text"},{"type":"text","text":" "},{"type":"text","text":"without showing a permission dialog. The user sees notifications silently and can then choose to keep or disable them."},{"text":" ","type":"text"},{"text":"Use this for a “soft opt-in” strategy to avoid users declining the permission prompt upfront.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionCriticalAlert","type":"codeVoice"},{"type":"text","text":" (iOS 12+) — Allows notifications that bypass Do Not Disturb and the mute switch."},{"type":"text","text":" "},{"type":"text","text":"Requires a special entitlement from Apple (must be approved via Apple Developer portal)."},{"type":"text","text":" "},{"type":"text","text":"Intended for medical, health, safety, and public security apps."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionProvidesAppNotificationSettings"},{"type":"text","text":" (iOS 12+) — Adds a “Configure in App” button"},{"type":"text","text":" "},{"text":"to the system notification settings for your app. When tapped, iOS calls","type":"text"},{"type":"text","text":" "},{"code":"userNotificationCenter:openSettingsForNotification:","type":"codeVoice"},{"type":"text","text":" on your "},{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:"},{"type":"text","text":" to register your delegate and handle this callback."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionAnnouncement"},{"type":"text","text":" (iOS 13+) — Allows Siri to automatically read out notifications"},{"text":" ","type":"text"},{"text":"through AirPods and compatible headphones.","type":"text"}]}]}]},{"level":2,"anchor":"Example-Provisional-Soft-Opt-In","type":"heading","text":"Example — Provisional (Soft Opt-In)"},{"type":"codeListing","syntax":"swift","code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional])","    }","","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}"]},{"type":"heading","level":2,"anchor":"Example-In-App-Notification-Settings-Button","text":"Example — In-App Notification Settings Button"},{"code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.providesAppNotificationSettings])","    }","","    Pushwoosh.configure.addNotificationCenterDelegate(self)","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}","","\/\/ Called when user taps \"Configure in App\" in system notification settings","func userNotificationCenter(_ center: UNUserNotificationCenter,","                            openSettingsFor notification: UNNotification?) {","    \/\/ Navigate to your in-app notification settings screen","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Example-Combining-Multiple-Options","text":"Example — Combining Multiple Options","level":2,"type":"heading"},{"syntax":"swift","type":"codeListing","code":["if #available(iOS 12.0, *) {","    Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional, .providesAppNotificationSettings])","}"]},{"type":"paragraph","inlineContent":[{"text":"Objective-C:","type":"text"}]},{"code":["if (@available(iOS 12.0, *)) {","    [Pushwoosh.configure setAdditionalAuthorizationOptions:UNAuthorizationOptionProvisional | UNAuthorizationOptionProvidesAppNotificationSettings];","}","","[Pushwoosh.configure registerForPushNotifications];"],"syntax":"objc","type":"codeListing"}],"kind":"content"}],"metadata":{"title":"setAdditionalAuthorizationOptions:","symbolKind":"method","modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(cs)PushwooshConfig(cm)setAdditionalAuthorizationOptions:","navigatorTitle":[{"kind":"identifier","text":"setAdditionalAuthorizationOptions:"}],"role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"setAdditionalAuthorizationOptions:","kind":"identifier"}],"roleHeading":"Type Method"},"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/setAdditionalAuthorizationOptions:"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/setadditionalauthorizationoptions:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PushwooshConfig":{"fragments":[{"text":"Push