{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig"]]},"metadata":{"title":"setAdditionalAuthorizationOptions:","navigatorTitle":[{"text":"setAdditionalAuthorizationOptions:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(cs)PushwooshConfig(cm)setAdditionalAuthorizationOptions:","symbolKind":"method","role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"setAdditionalAuthorizationOptions:","kind":"identifier"}],"roleHeading":"Type Method"},"variants":[{"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/setadditionalauthorizationoptions:"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"kind":"symbol","abstract":[{"type":"text","text":"Sets additional notification authorization options beyond the SDK defaults."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/setAdditionalAuthorizationOptions:"},"primaryContentSections":[{"declarations":[{"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setAdditionalAuthorizationOptions:"},{"text":"(","kind":"text"},{"text":"UNAuthorizationOptions","kind":"typeIdentifier","preciseIdentifier":"c:@E@UNAuthorizationOptions"},{"text":") ","kind":"text"},{"kind":"internalParam","text":"options"},{"text":";","kind":"text"}],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The additional "},{"code":"UNAuthorizationOptions","type":"codeVoice"},{"text":" to request.","type":"text"}],"type":"paragraph"}],"name":"options"}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"When calling "},{"type":"codeVoice","code":"registerForPushNotifications"},{"type":"text","text":", the SDK requests these permissions by default:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionBadge","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"code":"UNAuthorizationOptionSound","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"UNAuthorizationOptionAlert","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionCarPlay"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this method to request additional capabilities on top of the defaults."},{"type":"text","text":" "},{"type":"text","text":"The options you set here are combined (bitwise OR) with the default options"},{"type":"text","text":" "},{"type":"text","text":"before being passed to "},{"code":"UNUserNotificationCenter.requestAuthorizationWithOptions:","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Must be called "},{"inlineContent":[{"type":"text","text":"before"}],"type":"strong"},{"text":" ","type":"text"},{"code":"registerForPushNotifications","type":"codeVoice"},{"type":"text","text":"."}]},{"level":2,"anchor":"Available-Options","type":"heading","text":"Available Options"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionProvisional"},{"type":"text","text":" (iOS 12+) — Delivers notifications quietly to the Notification Center"},{"text":" ","type":"text"},{"text":"without showing a permission dialog. The user sees notifications silently and can then choose to keep or disable them.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Use this for a “soft opt-in” strategy to avoid users declining the permission prompt upfront."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionCriticalAlert"},{"type":"text","text":" (iOS 12+) — Allows notifications that bypass Do Not Disturb and the mute switch."},{"text":" ","type":"text"},{"type":"text","text":"Requires a special entitlement from Apple (must be approved via Apple Developer portal)."},{"type":"text","text":" "},{"type":"text","text":"Intended for medical, health, safety, and public security apps."}]}]},{"content":[{"inlineContent":[{"code":"UNAuthorizationOptionProvidesAppNotificationSettings","type":"codeVoice"},{"type":"text","text":" (iOS 12+) — Adds a “Configure in App” button"},{"text":" ","type":"text"},{"type":"text","text":"to the system notification settings for your app. When tapped, iOS calls"},{"type":"text","text":" "},{"type":"codeVoice","code":"userNotificationCenter:openSettingsForNotification:"},{"type":"text","text":" on your "},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:","isActive":true},{"type":"text","text":" to register your delegate and handle this callback."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionAnnouncement"},{"text":" (iOS 13+) — Allows Siri to automatically read out notifications","type":"text"},{"type":"text","text":" "},{"type":"text","text":"through AirPods and compatible headphones."}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Example-Provisional-Soft-Opt-In","level":2,"text":"Example — Provisional (Soft Opt-In)","type":"heading"},{"type":"codeListing","syntax":"swift","code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional])","    }","","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}"]},{"anchor":"Example-In-App-Notification-Settings-Button","level":2,"type":"heading","text":"Example — In-App Notification Settings Button"},{"code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.providesAppNotificationSettings])","    }","","    Pushwoosh.configure.addNotificationCenterDelegate(self)","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}","","\/\/ Called when user taps \"Configure in App\" in system notification settings","func userNotificationCenter(_ center: UNUserNotificationCenter,","                            openSettingsFor notification: UNNotification?) {","    \/\/ Navigate to your in-app notification settings screen","}"],"type":"codeListing","syntax":"swift"},{"text":"Example — Combining Multiple Options","level":2,"type":"heading","anchor":"Example-Combining-Multiple-Options"},{"syntax":"swift","code":["if #available(iOS 12.0, *) {","    Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional, .providesAppNotificationSettings])","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Objective-C:"}]},{"syntax":"objc","code":["if (@available(iOS 12.0, *)) {","    [Pushwoosh.configure setAdditionalAuthorizationOptions:UNAuthorizationOptionProvisional | UNAuthorizationOptionProvidesAppNotificationSettings];","}","","[Pushwoosh.configure registerForPushNotifications];"],"type":"codeListing"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PushwooshConfig/setAdditionalAuthorizationOp