"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Must be called ","type":"text"},{"inlineContent":[{"type":"text","text":"before"}],"type":"strong"},{"text":" ","type":"text"},{"type":"codeVoice","code":"registerForPushNotifications"},{"type":"text","text":"."}]},{"level":2,"text":"Available Options","type":"heading","anchor":"Available-Options"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"UNAuthorizationOptionProvisional","type":"codeVoice"},{"text":" (iOS 12+) — Delivers notifications quietly to the Notification Center","type":"text"},{"text":" ","type":"text"},{"text":"without showing a permission dialog. The user sees notifications silently and can then choose to keep or disable them.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Use this for a “soft opt-in” strategy to avoid users declining the permission prompt upfront."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionCriticalAlert","type":"codeVoice"},{"type":"text","text":" (iOS 12+) — Allows notifications that bypass Do Not Disturb and the mute switch."},{"type":"text","text":" "},{"type":"text","text":"Requires a special entitlement from Apple (must be approved via Apple Developer portal)."},{"type":"text","text":" "},{"text":"Intended for medical, health, safety, and public security apps.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionProvidesAppNotificationSettings"},{"text":" (iOS 12+) — Adds a “Configure in App” button","type":"text"},{"type":"text","text":" "},{"text":"to the system notification settings for your app. When tapped, iOS calls","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"userNotificationCenter:openSettingsForNotification:"},{"type":"text","text":" on your "},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"type":"text","text":"."},{"text":