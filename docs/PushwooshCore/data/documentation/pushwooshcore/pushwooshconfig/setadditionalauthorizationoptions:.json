{"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/setAdditionalAuthorizationOptions:"},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"kind":"text","text":") "},{"kind":"identifier","text":"setAdditionalAuthorizationOptions:"},{"text":"(","kind":"text"},{"text":"UNAuthorizationOptions","kind":"typeIdentifier","preciseIdentifier":"c:@E@UNAuthorizationOptions"},{"kind":"text","text":") "},{"text":"options","kind":"internalParam"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The additional "},{"type":"codeVoice","code":"UNAuthorizationOptions"},{"text":" to request.","type":"text"}]}],"name":"options"}],"kind":"parameters"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"When calling "},{"code":"registerForPushNotifications","type":"codeVoice"},{"type":"text","text":", the SDK requests these permissions by default:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionBadge"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionSound"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionAlert","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionCarPlay","type":"codeVoice"}]}]}]},{"inlineContent":[{"text":"Use this method to request additional capabilities on top of the defaults.","type":"text"},{"text":" ","type":"text"},{"text":"The options you set here are combined (bitwise OR) with the default options","type":"text"},{"type":"text","text":" "},{"type":"text","text":"before being passed to "},{"code":"UNUserNotificationCenter.requestAuthorizationWithOptions:","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Must be called ","type":"text"},{"inlineContent":[{"type":"text","text":"before"}],"type":"strong"},{"text":" ","type":"text"},{"type":"codeVoice","code":"registerForPushNotifications"},{"text":".","type":"text"}]},{"text":"Available Options","type":"heading","anchor":"Available-Options","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionProvisional"},{"text":" (iOS 12+) — Delivers notifications quietly to the Notification Center","type":"text"},{"type":"text","text":" "},{"type":"text","text":"without showing a permission dialog. The user sees notifications silently and can then choose to keep or disable them."},{"text":" ","type":"text"},{"type":"text","text":"Use this for a “soft opt-in” strategy to avoid users declining the permission prompt upfront."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionCriticalAlert","type":"codeVoice"},{"text":" (iOS 12+) — Allows notifications that bypass Do Not Disturb and the mute switch.","type":"text"},{"text":" ","type":"text"},{"text":"Requires a special entitlement from Apple (must be approved via Apple Developer portal).","type":"text"},{"type":"text","text":" "},{"text":"Intended for medical, health, safety, and public security apps.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionProvidesAppNotificationSettings"},{"text":" (iOS 12+) — Adds a “Configure in App” button","type":"text"},{"text":" ","type":"text"},{"text":"to the system notification settings for your app. When tapped, iOS calls","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"userNotificationCenter:openSettingsForNotification:"},{"text":" on your ","type":"text"},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:","isActive":true},{"text":" to register your delegate and handle this callback.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionAnnouncement"},{"text":" (iOS 13+) — Allows Siri to automatically read out notifications","type":"text"},{"type":"text","text":" "},{"type":"text","text":"through AirPods and compatible headphones."}],"type":"paragraph"}]}]},{"anchor":"Example-Provisional-Soft-Opt-In","type":"heading","level":2,"text":"Example — Provisional (Soft Opt-In)"},{"type":"codeListing","code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional])","    }","","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}"],"syntax":"swift"},{"level":2,"text":"Example — In-App Notification Settings Button","type":"heading","anchor":"Example-In-App-Notification-Settings-Button"},{"syntax":"swift","code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.providesAppNotificationSettings])","    }","","    Pushwoosh.configure.addNotificationCenterDelegate(self)","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}","","\/\/ Called when user taps \"Configure in App\" in system notification settings","func userNotificationCenter(_ center: UNUserNotificationCenter,","                            openSettingsFor notification: UNNotification?) {","    \/\/ Navigate to your in-app notification settings screen","}"],"type":"codeListing"},{"level":2,"type":"heading","anchor":"Example-Combining-Multiple-Options","text":"Example — Combining Multiple Options"},{"type":"codeListing","syntax":"swift","code":["if #available(iOS 12.0, *) {","    Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional, .providesAppNotificationSettings])","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Objective-C:"}]},{"syntax":"objc","code":["if (@available(iOS 12.0, *)) {","    [Pushwoosh.configure setAdditionalAuthorizationOptions:UNAuthorizationOptionProvisional | UNAuthorizationOptionProvidesAppNotificationSettings];","}","","[Pushwoosh.configure registerForPushNotifications];"],"type":"codeListing"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig"]]},"abstract":[{"type":"text","text":"Sets additional notification authorization options beyond the SDK defaults."}],"kind":"symbol","metadata":{"externalID":"c:objc(cs)PushwooshConfig(cm)setAdditionalAuthorizationOptions:","symbolKind":"method","navigatorTitle":[{"text":"setAdditionalAuthorizationOptions:","kind":"identifier"}],"title":"setAdditionalAuthorizationOptions:","modules":[{"name":"PushwooshCore"}],"fragments":[{"text":"+ ","kind":"text"},{"text":"setAdditionalAuthorizationOptions:","kind":"identifier"}],"roleHeading":"Type Method","role":"symbol"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/setadditionalauthorizationoptions:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","kind":"symbol","r