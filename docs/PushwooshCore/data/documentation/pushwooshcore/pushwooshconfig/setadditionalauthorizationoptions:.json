"},{"type":"paragraph","inlineContent":[{"text":"When calling ","type":"text"},{"type":"codeVoice","code":"registerForPushNotifications"},{"text":", the SDK requests these permissions by default:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionBadge","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionSound"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionAlert"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionCarPlay"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Use this method to request additional capabilities on top of the defaults."},{"text":" ","type":"text"},{"type":"text","text":"The options you set here are combined (bitwise OR) with the default options"},{"type":"text","text":" "},{"type":"text","text":"before being passed to "},{"code":"UNUserNotificationCenter.requestAuthorizationWithOptions:","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Must be called "},{"type":"strong","inlineContent":[{"text":"before","type":"text"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"registerForPushNotifications"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"heading","level":2,"text":"Available Options","anchor":"Available-Options"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionProvisional"},{"type":"text","text":" (iOS 12+) — Delivers notifications quietly to the Notification Center"},{"type":"text","text":" "},{"type":"text","text":"without showing a permission dialog. The user sees notifications silently and can then choose to keep or disable them."},{"type":"text","text":" "},{"type":"text","text":"Use this for a “soft opt-in” strategy to avoid users declining the permission prompt 