{"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/setadditionalauthorizationoptions:"]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig"]]},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setAdditionalAuthorizationOptions:"},{"text":"(","kind":"text"},{"text":"UNAuthorizationOptions","preciseIdentifier":"c:@E@UNAuthorizationOptions","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"options","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"The additional ","type":"text"},{"type":"codeVoice","code":"UNAuthorizationOptions"},{"type":"text","text":" to request."}],"type":"paragraph"}],"name":"options"}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"When calling "},{"type":"codeVoice","code":"registerForPushNotifications"},{"text":", the SDK requests these permissions by default:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionBadge","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionSound","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionAlert","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionCarPlay","type":"codeVoice"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this method to request additional capabilities on top of the defaults."},{"type":"text","text":" "},{"type":"text","text":"The options you set here are combined (bitwise OR) with the default options"},{"type":"text","text":" "},{"text":"before being passed to ","type":"text"},{"code":"UNUserNotificationCenter.requestAuthorizationWithOptions:","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"Must be called "},{"inlineContent":[{"type":"text","text":"before"}],"type":"strong"},{"text":" ","type":"text"},{"code":"registerForPushNotifications","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"anchor":"Available-Options","text":"Available Options","type":"heading","level":2},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionProvisional"},{"type":"text","text":" (iOS 12+) — Delivers notifications quietly to the Notification Center"},{"text":" ","type":"text"},{"type":"text","text":"without showing a permission dialog. The user sees notifications silently and can then choose to keep or disable them."},{"text":" ","type":"text"},{"text":"Use this for a “soft opt-in” strategy to avoid users declining the permission prompt upfront.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionCriticalAlert"},{"text":" (iOS 12+) — Allows notifications that bypass Do Not Disturb and the mute switch.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Requires a special entitlement from Apple (must be approved via Apple Developer portal)."},{"type":"text","text":" "},{"type":"text","text":"Intended for medical, health, safety, and public security apps."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionProvidesAppNotificationSettings"},{"type":"text","text":" (iOS 12+) — Adds a “Configure in App” button"},{"text":" ","type":"text"},{"type":"text","text":"to the system notification settings for your app. When tapped, iOS calls"},{"type":"text","text":" "},{"type":"codeVoice","code":"userNotificationCenter:openSettingsForNotification:"},{"type":"text","text":" on your "},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:","type":"reference","isActive":true},{"type":"text","text":" to register your delegate and handle this callback."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionAnnouncement","type":"codeVoice"},{"text":" (iOS 13+) — Allows Siri to automatically read out notifications","type":"text"},{"text":" ","type":"text"},{"text":"through AirPods and compatible headphones.","type":"text"}]}]}],"type":"unorderedList"},{"text":"Example — Provisional (Soft Opt-In)","type":"heading","level":2,"anchor":"Example-Provisional-Soft-Opt-In"},{"type":"codeListing","syntax":"swift","code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional])","    }","","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}"]},{"text":"Example — In-App Notification Settings Button","level":2,"type":"heading","anchor":"Example-In-App-Notification-Settings-Button"},{"type":"codeListing","code":["func application(_ application: UIApplication,","                didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","    if #available(iOS 12.0, *) {","        Pushwoosh.configure.setAdditionalAuthorizationOptions([.providesAppNotificationSettings])","    }","","    Pushwoosh.configure.addNotificationCenterDelegate(self)","    Pushwoosh.configure.registerForPushNotifications()","","    return true","}","","\/\/ Called when user taps \"Configure in App\" in system notification settings","func userNotificationCenter(_ center: UNUserNotificationCenter,","                            openSettingsFor notification: UNNotification?) {","    \/\/ Navigate to your in-app notification settings screen","}"],"syntax":"swift"},{"text":"Example — Combining Multiple Options","type":"heading","anchor":"Example-Combining-Multiple-Options","level":2},{"syntax":"swift","code":["if #available(iOS 12.0, *) {","    Pushwoosh.configure.setAdditionalAuthorizationOptions([.provisional, .providesAppNotificationSettings])","}"],"type":"codeListing"},{"inlineContent":[{"text":"Objective-C:","type":"text"}],"type":"paragraph"},{"syntax":"objc","code":["if (@available(iOS 12.0, *)) {","    [Pushwoosh.configure setAdditionalAuthorizationOptions:UNAuthorizationOptionProvisional | UNAuthorizationOptionProvidesAppNotificationSettings];","}","","[Pushwoosh.configure registerForPushNotifications];"],"type":"codeListing"}]}],"abstract":[{"type":"text","text":"Sets additional notification authorization options beyond the SDK defaults."}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/setAdditionalAuthorizationOptions:"},"metadata":{"symbolKind":"method","roleHeading":"Type Method","navigatorTitle":[{"text":"setAdditionalAuthorizationOptions:","kind":"identifier"}],"fragments":[{"text":"+ ","kind":"text"},{"text":"setAdditionalAuthorizationOptions:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(cs)PushwooshConfig(cm)setAdditionalAuthorizationOptions:","role":"symbol","title":"setAdditionalAuthorizationOptions:"},"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PushwooshConfig":{"type":"topic","identifier