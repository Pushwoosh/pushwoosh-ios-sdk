{"metadata":{"symbolKind":"method","modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(cs)PushwooshConfig(cm)setAdditionalAuthorizationOptions:","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setAdditionalAuthorizationOptions:"}],"navigatorTitle":[{"text":"setAdditionalAuthorizationOptions:","kind":"identifier"}],"roleHeading":"Type Method","title":"setAdditionalAuthorizationOptions:","role":"symbol"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/setAdditionalAuthorizationOptions:"},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"setAdditionalAuthorizationOptions:","kind":"identifier"},{"kind":"text","text":"("},{"text":"UNAuthorizationOptions","preciseIdentifier":"c:@E@UNAuthorizationOptions","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"options","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The additional "},{"code":"UNAuthorizationOptions","type":"codeVoice"},{"type":"text","text":" to request."}]}],"name":"options"}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"When calling "},{"type":"codeVoice","code":"registerForPushNotifications"},{"type":"text","text":", the SDK requests these permissions by default:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionBadge"}],"type":