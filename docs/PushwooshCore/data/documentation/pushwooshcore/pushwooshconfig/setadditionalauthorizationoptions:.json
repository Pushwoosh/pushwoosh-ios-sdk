oice"}]}]},{"content":[{"inlineContent":[{"code":"UNAuthorizationOptionSound","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionAlert","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"UNAuthorizationOptionCarPlay","type":"codeVoice"}]}]}]},{"inlineContent":[{"text":"Use this method to request additional capabilities on top of the defaults.","type":"text"},{"text":" ","type":"text"},{"text":"The options you set here are combined (bitwise OR) with the default options","type":"text"},{"type":"text","text":" "},{"type":"text","text":"before being passed to "},{"type":"codeVoice","code":"UNUserNotificationCenter.requestAuthorizationWithOptions:"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Must be called "},{"type":"strong","inlineContent":[{"text":"before","type":"text"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"registerForPushNotifications"},{"type":"text","text":"."}]},{"level":2,"text":"Available Options","type":"heading","anchor":"Available-Options"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNAuthorizationOptionProvisional"},{"text":" (iOS 12+) — Delivers notifications quietly to the Notification Center","type":"text"},{"type":"text","text":" "},{"text":"without showing a permission dialog. The user sees notifications silently and can then choose to keep or disable them.","type":"text"},{"type":"text","text":" "},{"text":"Use this for a “soft opt-in” strategy to avoid users declining the permission prompt upfront.","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"UNAuthorizationOptionCriticalAlert","type":"codeVoice"},{"type":"text","text":" (iOS 12+) — Allows notifications that bypass Do Not Disturb and the mute switch."},{"text":" ","type":"text"},{"text":"Requires a special entitlement from Apple (must be 