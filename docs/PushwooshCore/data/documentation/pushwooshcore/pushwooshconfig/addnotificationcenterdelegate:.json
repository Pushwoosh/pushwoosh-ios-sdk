fication handler:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["class NotificationHandler: NSObject, UNUserNotificationCenterDelegate {","","    func userNotificationCenter(_ center: UNUserNotificationCenter,","                                willPresent notification: UNNotification,","                                withCompletionHandler completionHandler: @escaping (UNNotificationPresentationOptions) -> Void) {","        if !PWMessage.isPushwooshMessage(notification.request.content.userInfo) {","            completionHandler([.banner, .sound])","        }","    }","","    func userNotificationCenter(_ center: UNUserNotificationCenter,","                                didReceive response: UNNotificationResponse,","                                withCompletionHandler completionHandler: @escaping () -> Void) {","        if !PWMessage.isPushwooshMessage(response.notification.request.content.userInfo) {","            \/\/ Handle your custom notification","            completionHandler()","        }","    }","}","","let handler = NotificationHandler()","Pushwoosh.configure.addNotificationCenterDelegate(handler)"]},{"inlineContent":[{"text":"Objective-C:","type":"text"}],"type":"paragraph"},{"syntax":"objc","type":"codeListing","code":["[Pushwoosh.configure addNotificationCenterDelegate:self];"]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWMessage\/isPushwooshMessage:","isActive":true},{"type":"text","text":" to distinguish Pushwoosh notifications from your own and handle only non-Pushwoosh notifications in your custom delegate."}]}],"style":"note","name":"Note","type":"aside"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PushwooshConfig/addNotificationCenterDelegate:":{"fragments":[{"text":"+ ","kind":"text"},{"text":"addNotificationCenterDelegate:","kind":"identifier"}],"type":