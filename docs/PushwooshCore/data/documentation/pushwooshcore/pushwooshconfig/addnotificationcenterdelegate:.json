{"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"kind":"identifier","text":"addNotificationCenterDelegate:"},{"text":"(","kind":"text"},{"text":"id<UNUserNotificationCenterDelegate>","preciseIdentifier":"c:Qoobjc(pl)UNUserNotificationCenterDelegate","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"delegate","kind":"internalParam"},{"text":";","kind":"text"}]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The delegate object that conforms to "},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"type":"text","text":" protocol. Must not be nil."}],"type":"paragraph"}],"name":"delegate"}]},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Use this method to register your own ","type":"text"},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"text":" alongside Pushwoosh’s built-in delegate.","type":"text"},{"text":" ","type":"text"},{"text":"Pushwoosh uses a delegate proxy to forward notification center callbacks to all registered delegates,","type":"text"},{"type":"text","text":" "},{"text":"enabling multiple components to respond to notification events without conflicts.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is the recommended way to handle notification center events when using Pushwoosh SDK 7.0+,"},{"type":"text","text":" "},{"type":"text","text":"as it avoids conflicts with Pushwoosh’s own notification handling."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Typical use cases:"}]},{"items":[{"content":[{"inlineContent":[{"text":"Integrating multiple push notification SDKs","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Adding custom notification handling logic (e.g., analytics, local notifications)"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Implementing custom notification actions"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"type":"heading","anchor":"Examples","text":"Examples"},{"type":"paragraph","inlineContent":[{"text":"Register AppDelegate as a notification delegate:","type":"text"}]},{"code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","    Pushwoosh.configure.addNotificationCenterDelegate(self)","    return true","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Register a dedicated notification handler:","type":"text"}]},{"syntax":"swift","code":["class NotificationHandler: NSObject, UNUserNotificationCenterDelegate {","","    func userNotificationCenter(_ center: UNUserNotificationCenter,","                                willPresent notification: UNNotification,","                                withCompletionHandler completionHandler: @escaping (UNNotificationPresentationOptions) -> Void) {","        if !PWMessage.isPushwooshMessage(notification.request.content.userInfo) {","            completionHandler([.banner, .sound])","        }","    }","","    func userNotificationCenter(_ center: UNUserNotificationCenter,","                                didReceive response: UNNotificationResponse,","                                withCompletionHandler completionHandler: @escaping () -> Void) {","        if !PWMessage.isPushwooshMessage(response.notification.request.content.userInfo) {","            \/\/ Handle your custom notification","            completionHandler()","        }","    }","}","","let handler = NotificationHandler()","Pushwoosh.configure.addNotificationCenterDelegate(handler)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Objective-C:"}]},{"syntax":"objc","code":["[Pushwoosh.configure addNotificationCenterDelegate:self];"],"type":"codeListing"},{"content":[{"inlineContent":[{"type":"text","text":"Use "},{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWMessage\/isPushwooshMessage:","type":"reference","isActive":true},{"type":"text","text":" to distinguish Pushwoosh notifications from your own and handle only non-Pushwoosh notifications in your custom delegate."}],"type":"paragraph"}],"name":"Note","style":"note","type":"aside"}],"kind":"content"}],"kind":"symbol","identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:","interfaceLanguage":"occ"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/addnotificationcenterdelegate:"]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig"]]},"abstract":[{"type":"text","text":"Adds a custom "},{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"type":"text","text":" to the Pushwoosh notification center delegate proxy."}],"sections":[],"metadata":{"role":"symbol","roleHeading":"Type Method","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"addNotificationCenterDelegate:"}],"title":"addNotificationCenterDelegate:","modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(cs)PushwooshConfig(cm)addNotificationCenterDelegate:","symbolKind":"method","navigatorTitle":[{"kind":"identifier","text":"addNotificationCenterDelegate:"}]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWMessage/isPushwooshMessage:":{"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWMessage\/isPushwooshMessage:"