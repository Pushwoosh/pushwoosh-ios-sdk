","            completionHandler()","        }","    }","}","","let handler = NotificationHandler()","Pushwoosh.configure.addNotificationCenterDelegate(handler)"]},{"type":"paragraph","inlineContent":[{"text":"Objective-C:","type":"text"}]},{"syntax":"objc","type":"codeListing","code":["[Pushwoosh.configure addNotificationCenterDelegate:self];"]},{"name":"Note","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWMessage\/isPushwooshMessage:","type":"reference","isActive":true},{"text":" to distinguish Pushwoosh notifications from your own and handle only non-Pushwoosh notifications in your custom delegate.","type":"text"}]}]}]}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/addnotificationcenterdelegate:"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"type":"text","text":"Adds a custom "},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"text":" to the Pushwoosh notification center delegate proxy.","type":"text"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:"},"metadata":{"externalID":"c:objc(cs)PushwooshConfig(cm)addNotificationCenterDelegate:","modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","role":"symbol","symbolKind":"method","title":"addNotificationCenterDelegate:","fragments":[{"text":"+ ","kind":"text"},{"text":"addNotificationCenterDelegate:","kind":"identifier"}],"navigatorTitle":[{"text":"addNotificationCenterDelegate:","kind":"identifier"}]},"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"role":"collection","title":"PushwooshCore","url":"\/documentation\/pushwooshc