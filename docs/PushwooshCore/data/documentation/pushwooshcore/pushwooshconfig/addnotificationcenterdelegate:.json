osh’s built-in delegate.","type":"text"},{"text":" ","type":"text"},{"text":"Pushwoosh uses a delegate proxy to forward notification center callbacks to all registered delegates,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"enabling multiple components to respond to notification events without conflicts."}]},{"type":"paragraph","inlineContent":[{"text":"This is the recommended way to handle notification center events when using Pushwoosh SDK 7.0+,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"as it avoids conflicts with Pushwoosh’s own notification handling."}]},{"inlineContent":[{"text":"Typical use cases:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Integrating multiple push notification SDKs"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Adding custom notification handling logic (e.g., analytics, local notifications)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Implementing custom notification actions"}]}]}]},{"level":2,"text":"Examples","anchor":"Examples","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Register AppDelegate as a notification delegate:","type":"text"}]},{"syntax":"swift","code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","    Pushwoosh.configure.addNotificationCenterDelegate(self)","    return true","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Register a dedicated notification handler:"}],"type":"paragraph"},{"code":["class NotificationHandler: NSObject, UNUserNotificationCenterDelegate {","","    func userNotificationCenter(_ center: UNUserNotificationCenter,","                                willPresent notification: UNNotification,","                                withCompletionHandler co