{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig"]]},"sections":[],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/addnotificationcenterdelegate:"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"addNotificationCenterDelegate:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:Qoobjc(pl)UNUserNotificationCenterDelegate","text":"id<UNUserNotificationCenterDelegate>","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"delegate","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"delegate","content":[{"inlineContent":[{"text":"The delegate object that conforms to ","type":"text"},{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"type":"text","text":" protocol. Must not be nil."}],"type":"paragraph"}]}]},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this method to register your own "},{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"text":" alongside Pushwoosh’s built-in delegate.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Pushwoosh uses a delegate proxy to forward notification center callbacks to all registered delegates,"},{"type":"text","text":" "},{"type":"text","text":"enabling multiple components to respond to notification events without conflicts."}]},{"inlineContent":[{"type":"text","text":"This is the recommended way to handle notification center events when using Pushwoosh SDK 7.0+,"},{"type":"text","text":" "},{"type":"text","text":"as it avoids conflicts with Pushwoosh’s own notification handling."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Typical use cases:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Integrating multiple push notification SDKs"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Adding custom notification handling logic (e.g., analytics, local notifications)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Implementing custom notification actions","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Examples","text":"Examples","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Register AppDelegate as a notification delegate:","type":"text"}]},{"code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","    Pushwoosh.configure.addNotificationCenterDelegate(self)","    return true","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register a dedicated notification handler:"}]},{"code":["class NotificationHandler: NSObject, UNUserNotificationCenterDelegate {","","    func userNotificationCenter(_ center: UNUserNotificationCenter,","                                willPresent notification: UNNotification,","                                withCompletionHandler completionHandler: @escaping (UNNotificationPresentationOptions) -> Void) {","        if !PWMessage.isPushwooshMessage(notification.request.content.userInfo) {","            completionHandler([.banner, .sound])","        }","    }","","    func userNotificationCenter(_ center: UNUserNotificationCenter,","                                didReceive response: UNNotificationResponse,","                                withCompletionHandler completionHandler: @escaping () -> Void) {","        if !PWMessage.isPushwooshMessage(response.notification.request.content.userInfo) {","            \/\/ Handle your custom notification","            completionHandler()","        }","    }","}","","let handler = NotificationHandler()","Pushwoosh.configure.addNotificationCenterDelegate(handler)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Objective-C:"}],"type":"paragraph"},{"type":"codeListing","syntax":"objc","code":["[Pushwoosh.configure addNotificationCenterDelegate:self];"]},{"type":"aside","name":"Note","style":"note","content":[{"inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWMessage\/isPushwooshMessage:"},{"type":"text","text":" to distinguish Pushwoosh notifications from your own and handle only non-Pushwoosh notifications in your custom delegate."}],"type":"paragraph"}]}],"kind":"content"}],"abstract":[{"text":"Adds a custom ","type":"text"},{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"text":" to the Pushwoosh notification center delegate proxy.","type":"text"}],"metadata":{"symbolKind":"method","role":"symbol","externalID":"c:objc(cs)PushwooshConfig(cm)addNotificationCenterDelegate:","fragments":[{"text":"+ ","kind":"text"},{"text":"addNotificationCenterDelegate:","kind":"identifier"}],"title":"addNotificationCenterDelegate:","modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","navigatorTitle":[{"kind":"identifier","text":"addNotificationCenterDelegate:"}]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWMessage/isPushwooshMessage:":{"role":"symbol","type":"topic","url":"\/documentation\/pushwooshcore\/pwmessage\/ispushwooshmessage:","kind":"symbol","title":"i