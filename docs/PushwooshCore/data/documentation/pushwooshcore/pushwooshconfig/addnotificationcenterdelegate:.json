ntent":[{"type":"text","text":"Objective-C:"}]},{"code":["[Pushwoosh.configure addNotificationCenterDelegate:self];"],"type":"codeListing","syntax":"objc"},{"name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWMessage\/isPushwooshMessage:","type":"reference","isActive":true},{"type":"text","text":" to distinguish Pushwoosh notifications from your own and handle only non-Pushwoosh notifications in your custom delegate."}]}],"style":"note"}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/addnotificationcenterdelegate:"]}],"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"roleHeading":"Type Method","role":"symbol","title":"addNotificationCenterDelegate:","symbolKind":"method","externalID":"c:objc(cs)PushwooshConfig(cm)addNotificationCenterDelegate:","modules":[{"name":"PushwooshCore"}],"fragments":[{"kind":"text","text":"+ "},{"text":"addNotificationCenterDelegate:","kind":"identifier"}],"navigatorTitle":[{"text":"addNotificationCenterDelegate:","kind":"identifier"}]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:","interfaceLanguage":"occ"},"abstract":[{"type":"text","text":"Adds a custom "},{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"type":"text","text":" to the Pushwoosh notification center delegate proxy."}],"sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","kind":"symbol","title":"PushwooshCore","type":"topic","abstract":[{"text":"Core foundation module for Pushwoosh SDK.",