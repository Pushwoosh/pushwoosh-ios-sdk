\/ Handle your custom notification","            completionHandler()","        }","    }","}","","let handler = NotificationHandler()","Pushwoosh.configure.addNotificationCenterDelegate(handler)"]},{"inlineContent":[{"text":"Objective-C:","type":"text"}],"type":"paragraph"},{"syntax":"objc","code":["[Pushwoosh.configure addNotificationCenterDelegate:self];"],"type":"codeListing"},{"content":[{"inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWMessage\/isPushwooshMessage:"},{"text":" to distinguish Pushwoosh notifications from your own and handle only non-Pushwoosh notifications in your custom delegate.","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Note","style":"note"}]}],"kind":"symbol","variants":[{"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/addnotificationcenterdelegate:"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"text":"Adds a custom ","type":"text"},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"text":" to the Pushwoosh notification center delegate proxy.","type":"text"}],"sections":[],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:"},"metadata":{"fragments":[{"kind":"text","text":"+ "},{"text":"addNotificationCenterDelegate:","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"text":"addNotificationCenterDelegate:","kind":"identifier"}],"externalID":"c:objc(cs)PushwooshConfig(cm)addNotificationCenterDelegate:","title":"addNotificationCenterDelegate:","modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","symbolKind":"method"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","kind":"symbol","role":"collection","title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/document