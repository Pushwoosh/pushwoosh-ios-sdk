{"kind":"symbol","abstract":[{"text":"Adds a custom ","type":"text"},{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"type":"text","text":" to the Pushwoosh notification center delegate proxy."}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"navigatorTitle":[{"text":"addNotificationCenterDelegate:","kind":"identifier"}],"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"addNotificationCenterDelegate:"}],"title":"addNotificationCenterDelegate:","symbolKind":"method","roleHeading":"Type Method","role":"symbol","externalID":"c:objc(cs)PushwooshConfig(cm)addNotificationCenterDelegate:","modules":[{"name":"PushwooshCore"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"addNotificationCenterDelegate:"},{"kind":"text","text":"("},{"text":"id<UNUserNotificationCenterDelegate>","kind":"typeIdentifier","preciseIdentifier":"c:Qoobjc(pl)UNUserNotificationCenterDelegate"},{"text":") ","kind":"text"},{"kind":"internalParam","text":"delegate"},{"text":";","kind":"text"}],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"name":"delegate","content":[{"inlineContent":[{"type":"text","text":"The delegate object that conforms to "},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"text":" protocol. Must not be nil.","type":"text"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"Use this method to register your own ","type":"text"},{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"text":" alongside Pushwoosh’s built-in delegate.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Pushwoosh uses a delegate proxy to forward notification center callbacks to all registered delegates,"},{"type":"text","text":" "},{"type":"text","text":"enabling multiple components to respond to notification events without conflicts."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This is the recommended way to handle notification center events when using Pushwoosh SDK 7.0+,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"as it avoids conflicts with Pushwoosh’s own notification handling."}]},{"type":"paragraph","inlineContent":[{"text":"Typical use cases:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Integrating multiple push notification SDKs"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Adding custom notification handling logic (e.g., analytics, local notifications)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Implementing custom notification actions","type":"text"}],"type":"paragraph"}]}]},{"text":"Examples","type":"heading","anchor":"Examples","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register AppDelegate as a notification delegate:"}]},{"code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","    Pushwoosh.configure.addNotificationCenterDelegate(self)","    return true","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Register a dedicated notification handler:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class NotificationHandler: NSObject, UNUserNotificationCenterDelegate {","","    func userNotificationCenter(_ center: UNUserNotificationCenter,","                                willPresent notification: UNNotification,","                                withCompletionHandler completionHandler: @escaping (UNNotificationPresentationOptions) -> Void) {","        if !PWMessage.isPushwooshMessage(notification.request.content.userInfo) {","            completionHandler([.banner, .sound])","        }","    }","","    func userNotificationCenter(_ center: UNUserNotificationCenter,","                                didReceive response: UNNotificationResponse,","                                withCompletionHandler completionHandler: @escaping () -> Void) {","        if !PWMessage.isPushwooshMessage(response.notification.request.content.userInfo) {","            \/\/ Handle your custom notification","            completionHandler()","        }","    }","}","","let handler = NotificationHandler()","Pushwoosh.configure.addNotificationCenterDelegate(handler)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Objective-C:"}]},{"syntax":"objc","code":["[Pushwoosh.configure addNotificationCenterDelegate:self];"],"type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWMessage\/isPushwooshMessage:","type":"reference"},{"type":"text","text":" to distinguish Pushwoosh notifications from your own and handle only non-Pushwoosh notifications in your custom delegate."}]}],"type":"aside","name":"Note","style":"note"}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/addnotificationcenterdelegate:"]}],"sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PushwooshConfig/addNotificationCenterDelegate:":{"fragments":[{"text":"+ ","kind":"text"},{"text":"addNotificationCenterDelegate:","kind":"identifier"}],"title"