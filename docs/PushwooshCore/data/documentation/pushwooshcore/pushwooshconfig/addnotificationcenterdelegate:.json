{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig"]]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:","interfaceLanguage":"occ"},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"kind":"identifier","text":"addNotificationCenterDelegate:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:Qoobjc(pl)UNUserNotificationCenterDelegate","text":"id<UNUserNotificationCenterDelegate>","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"delegate","kind":"internalParam"},{"text":";","kind":"text"}],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"name":"delegate","content":[{"inlineContent":[{"text":"The delegate object that conforms to ","type":"text"},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"text":" protocol. Must not be nil.","type":"text"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"text":"Use this method to register your own ","type":"text"},{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"type":"text","text":" alongside Pushwoosh’s built-in delegate."},{"type":"text","text":" "},{"type":"text","text":"Pushwoosh uses a delegate proxy to forward notification center callbacks to all registered delegates,"},{"text":" ","type":"text"},{"text":"enabling multiple components to respond to notification events without conflicts.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is the recommended way to handle notification center events when using Pushwoosh SDK 7.0+,"},{"type":"text","text":" "},{"type":"text","text":"as it avoids conflicts with Pushwoosh’s own notification handling."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Typical use cases:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Integrating multiple push notification SDKs"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Adding custom notification handling logic (e.g., analytics, local notifications)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Implementing custom notification actions","type":"text"}]}]}]},{"level":2,"text":"Examples","anchor":"Examples","type":"heading"},{"inlineContent":[{"type":"text","text":"Register AppDelegate as a notification delegate:"}],"type":"paragraph"},{"code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","    Pushwoosh.configure.addNotificationCenterDelegate(self)","    return true","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register a dedicated notification handler:"}]},{"code":["class NotificationHandler: NSObject, UNUserNotificationCenterDelegate {","","    func userNotificationCenter(_ center: UNUserNotificationCenter,","                                willPresent notification: UNNotification,","                                withCompletionHandler completionHandler: @escaping (UNNotificationPresentationOptions) -> Void) {","        if !PWMessage.isPushwooshMessage(notification.request.content.userInfo) {","            completionHandler([.banner, .sound])","        }","    }","","    func userNotificationCenter(_ center: UNUserNotificationCenter,","                                didReceive response: UNNotificationResponse,","                                withCompletionHandler completionHandler: @escaping () -> Void) {","        if !PWMessage.isPushwooshMessage(response.notification.request.content.userInfo) {","            \/\/ Handle your custom notification","            completionHandler()","        }","    }","}","","let handler = NotificationHandler()","Pushwoosh.configure.addNotificationCenterDelegate(handler)"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Objective-C:","type":"text"}]},{"code":["[Pushwoosh.configure addNotificationCenterDelegate:self];"],"type":"codeListing","syntax":"objc"},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWMessage\/isPushwooshMessage:"},{"type":"text","text":" to distinguish Pushwoosh notifications from your own and handle only non-Pushwoosh notifications in your custom delegate."}]}],"type":"aside"}]}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/addnotificationcenterdelegate:"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"abstract":[{"type":"text","text":"Adds a custom "},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"text":" to the Pushwoosh notification center delegate proxy.","type":"text"}],"metadata":{"role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"addNotificationCenterDelegate:","kind":"identifier"}],"externalID":"c:objc(cs)PushwooshConfig(cm)addNotificationCenterDelegate:","symbolKind":"method","roleHeading":"Type Method","navigatorTitle":[{"kind":"identifier","text":"addNotificationCenterDelegate:"}],"modules":[{"name":"PushwooshCore"}],"title":"addNotificationCenterDelegate:"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWMessage/isPushwooshMessage:":{"role":"symbol","abstract":[],"fragments":[{"kind":"text","text":"+ "},{"text":"isPushwooshMessage:","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWMessage\/isPushwooshMessage:","url":"\/documentation\/pushwooshcore\/pwmessage\/ispushwooshmessage:","type":"topic","navigatorTitle":[{"text":"isPushwooshMessage:","kind":"identifier"}],"title":"isPushwooshMessage:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PushwooshConfig/addNotificationCenterDelegate:":{"abstract":[{"type":"text","text":"Adds a custom "},{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"text":" to the Pushwoosh notification center delegate proxy.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"addNotificationCenterDelegate:"}],"type":"topic","title":"addNotificationCenterDelegate:","url":"\/documentation\/pushwooshcore\/pushwooshconfig\/addnotificationcenterdelegate:","role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"addNotificationCenterDelegate:","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","url":"\/documentation\/pushwooshcore","title":"PushwooshCore","type":"topic","kind":"symbol","role":"collection","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PushwooshConfig":{"abstract":[{"type":"text","text":"Configuration interface for Pushwoosh SDK."}],"type":"topic","title":"PushwooshConfig","url":"\/documentation\/pushwooshcore\/pushwooshconfig","role":"symbol","fragments":[{"kind":"identifier","text":"PushwooshConfig"}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig"}}}