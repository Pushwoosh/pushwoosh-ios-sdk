{"metadata":{"role":"symbol","externalID":"c:objc(cs)PushwooshConfig(cm)addNotificationCenterDelegate:","title":"addNotificationCenterDelegate:","navigatorTitle":[{"kind":"identifier","text":"addNotificationCenterDelegate:"}],"fragments":[{"text":"+ ","kind":"text"},{"text":"addNotificationCenterDelegate:","kind":"identifier"}],"symbolKind":"method","roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}]},"variants":[{"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/addnotificationcenterdelegate:"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"text":"Adds a custom ","type":"text"},{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"text":" to the Pushwoosh notification center delegate proxy.","type":"text"}],"kind":"symbol","sections":[],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"text":"addNotificationCenterDelegate:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:Qoobjc(pl)UNUserNotificationCenterDelegate","text":"id<UNUserNotificationCenterDelegate>","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"kind":"internalParam","text":"delegate"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The delegate object that conforms to "},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"text":" protocol. Must not be nil.","type":"text"}],"type":"paragraph"}],"name":"delegate"}],"kind":"parameters"},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"Use this method to register your own ","type":"text"},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"text":" alongside Pushwoosh’s built-in delegate.","type":"text"},{"text":" ","type":"text"},{"type":"text",