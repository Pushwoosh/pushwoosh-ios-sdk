mended way to handle notification center events when using Pushwoosh SDK 7.0+,"},{"text":" ","type":"text"},{"type":"text","text":"as it avoids conflicts with Pushwoosh’s own notification handling."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Typical use cases:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Integrating multiple push notification SDKs","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Adding custom notification handling logic (e.g., analytics, local notifications)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Implementing custom notification actions"}],"type":"paragraph"}]}]},{"text":"Examples","anchor":"Examples","level":2,"type":"heading"},{"inlineContent":[{"text":"Register AppDelegate as a notification delegate:","type":"text"}],"type":"paragraph"},{"code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","    Pushwoosh.configure.addNotificationCenterDelegate(self)","    return true","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Register a dedicated notification handler:"}],"type":"paragraph"},{"syntax":"swift","code":["class NotificationHandler: NSObject, UNUserNotificationCenterDelegate {","","    func userNotificationCenter(_ center: UNUserNotificationCenter,","                                willPresent notification: UNNotification,","                                withCompletionHandler completionHandler: @escaping (UNNotificationPresentationOptions) -> Void) {","        if !PWMessage.isPushwooshMessage(notification.request.content.userInfo) {","            completionHandler([.banner, .sound])","        }","    }","","    func userNotificationCenter(_ center: UNUserNotificationCenter,","                                didReceive response: UNNotificationResponse,","                                withCompletionHandler completionHandler: @escaping () -> Void) {","        if !PWMessage.isPushwooshMessage(response.notification.request.content.userInfo) {","            \/\/ Handle your custom notification","            completionHandler()","        }","    }","}","","let handler = NotificationHandler()","Pushwoosh.configure.addNotificationCenterDelegate(handler)"],"type":"codeListing"},{"inlineContent":[{"text":"Objective-C:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["[Pushwoosh.configure addNotificationCenterDelegate:self];"],"syntax":"objc"},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWMessage\/isPushwooshMessage:","isActive":true},{"type":"text","text":" to distinguish Pushwoosh notifications from your own and handle only non-Pushwoosh notifications in your custom delegate."}],"type":"paragraph"}]}]}],"abstract":[{"text":"Adds a custom ","type":"text"},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"type":"text","text":" to the Pushwoosh notification center delegate proxy."}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig"]]},"kind":"symbol","sections":[],"variants":[{"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/addnotificationcenterdelegate:"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PushwooshConfig/addNotificationCenterDelegate:":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificati