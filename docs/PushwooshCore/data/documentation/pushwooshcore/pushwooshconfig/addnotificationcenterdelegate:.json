{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig"]]},"sections":[],"abstract":[{"text":"Adds a custom ","type":"text"},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"text":" to the Pushwoosh notification center delegate proxy.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/addnotificationcenterdelegate:"]}],"metadata":{"title":"addNotificationCenterDelegate:","symbolKind":"method","navigatorTitle":[{"kind":"identifier","text":"addNotificationCenterDelegate:"}],"modules":[{"name":"PushwooshCore"}],"fragments":[{"kind":"text","text":"+ "},{"text":"addNotificationCenterDelegate:","kind":"identifier"}],"role":"symbol","externalID":"c:objc(cs)PushwooshConfig(cm)addNotificationCenterDelegate:","roleHeading":"Type Method"},"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PushwooshConfig\/addNotificationCenterDelegate:"},"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"kind":"text","text":") "},{"kind":"identifier","text":"addNotificationCenterDelegate:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:Qoobjc(pl)UNUserNotificationCenterDelegate","text":"id<UNUserNotificationCenterDelegate>","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"kind":"internalParam","text":"delegate"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"delegate","content":[{"inlineContent":[{"text":"The delegate object that conforms to ","type":"text"},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"text":" protocol. Must not be nil.","type":"text"}],"type":"paragraph"}]}]},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"Use this method to register your own ","type":"text"},{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"text":" alongside Pushwoosh’s built-in delegate.","type":"text"},{"type":"text","text":" "},{"text":"Pushwoosh uses a delegate proxy to forward notification center callbacks to all registered delegates,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"enabling multiple components to respond to notification events without conflicts."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is the recommended way to handle notification center events when using Pushwoosh SDK 7.0+,"},{"type":"text","text":" "},{"type":"text","text":"as it avoids conflicts with Pushwoosh’s own notification handling."}]},{"inlineContent":[{"type":"text","text":"Typical use cases:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Integrating multiple push notification SDKs","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Adding custom notification handling logic (e.g., analytics, local notifications)","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Implementing custom notification actions"}],"type":"paragraph"}]}]},{"level":2,"text":"Examples","anchor":"Examples","type":"heading"},{"inlineContent":[{"type":"text","text":"Register AppDelegate as a notification delegate:"}],"type":"paragraph"},{"code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","    Pushwoosh.configure.addNotificationCenterDelegate(self)","    return true","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register a dedicated notification handler:"}]},{"type":"codeListing","syntax":"swift","code":["class NotificationHandler: NSObject, UNUserNotificationCenterDelegate {","","    func userNotificationCenter(_ center: UNUserNotificationCenter,","                                willPresent notification: UNNotification,","                                withCompletionHandler completionHandler: @escaping (UNNotificationPresentationOptions) -> Void) {","        if !PWMessage.isPushwooshMessage(notification.request.content.userInfo) {","            completionHandler([.banner, .sound])","        }","    }","","    func userNotificationCenter(_ center: UNUserNotificationCenter,","                                didReceive response: UNNotificationResponse,","                                withCompletionHandler completionHandler: @escaping () -> Void) {","        if !PWMessage.isPushwooshMessage(response.notification.request.content.userInfo) {","            \/\/ Handle your custom notification","            completionHandler()","        }","    }","}","","let handler = NotificationHandler()","Pushwoosh.configure.addNotificationCenterDelegate(handler)"]},{"type":"paragraph","inlineContent":[{"text":"Objective-C:","type":"text"}]},{"type":"codeListing","syntax":"objc","code":["[Pushwoosh.configure addNotificationCenterDelegate:self];"]},{"content":[{"inlineContent":[{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWMessage\/isPushwooshMessage:","isActive":true},{"text":" to distinguish Pushwoosh notifications from your own and handle only non-Pushwoosh notifications in your custom delegate.","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"}],"kind":"content"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"ti