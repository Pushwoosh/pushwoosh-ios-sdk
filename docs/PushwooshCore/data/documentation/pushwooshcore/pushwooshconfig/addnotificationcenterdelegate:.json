name":"delegate"}]},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"text":"Use this method to register your own ","type":"text"},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"type":"text","text":" alongside Pushwoosh’s built-in delegate."},{"type":"text","text":" "},{"type":"text","text":"Pushwoosh uses a delegate proxy to forward notification center callbacks to all registered delegates,"},{"type":"text","text":" "},{"text":"enabling multiple components to respond to notification events without conflicts.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This is the recommended way to handle notification center events when using Pushwoosh SDK 7.0+,","type":"text"},{"type":"text","text":" "},{"text":"as it avoids conflicts with Pushwoosh’s own notification handling.","type":"text"}]},{"inlineContent":[{"text":"Typical use cases:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Integrating multiple push notification SDKs"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Adding custom notification handling logic (e.g., analytics, local notifications)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Implementing custom notification actions","type":"text"}],"type":"paragraph"}]}]},{"level":2,"type":"heading","anchor":"Examples","text":"Examples"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register AppDelegate as a notification delegate:"}]},{"type":"codeListing","code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","    Pushwoosh.configure.addNotificationCenterDelegate(self)","    return true","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Register a dedicated notification handler:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class NotificationHandler: NSObject, UNUserNotificationCenterDelegate {","","    func userNotificationCenter(_ center: UNUserNotificationCenter,","                                willPresent notification: UNNotification,","                                withCompletionHandler completionHandler: @escaping (UNNotificationPresentationOptions) -> Void) {","        if !PWMessage.isPushwooshMessage(notification.request.content.userInfo) {","            completionHandler([.banner, .sound])","        }","    }","","    func userNotificationCenter(_ center: UNUserNotificationCenter,","                                didReceive response: UNNotificationResponse,","                                withCompletionHandler completionHandler: @escaping () -> Void) {","        if !PWMessage.isPushwooshMessage(response.notification.request.content.userInfo) {","            \/\/ Handle your custom notification","            completionHandler()","        }","    }","}","","let handler = NotificationHandler()","Pushwoosh.configure.addNotificationCenterDelegate(handler)"]},{"inlineContent":[{"text":"Objective-C:","type":"text"}],"type":"paragraph"},{"code":["[Pushwoosh.configure addNotificationCenterDelegate:self];"],"syntax":"objc","type":"codeListing"},{"name":"Note","content":[{"inlineContent":[{"type":"text","text":"Use "},{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWMessage\/isPushwooshMessage:","isActive":true,"type":"reference"},{"type":"text","text":" to distinguish Pushwoosh notifications from your own and handle only non-Pushwoosh notifications in your custom delegate."}],"type":"paragraph"}],"style":"note","type":"aside"}],"kind":"content"}],"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWMessage/isPushwooshMessage:":{"type":"topic","abstract":[],"navigatorTitle":[{"text":"isPushwooshMessage:","kind":"identifier"}],"url":"\/documentation\/pushw