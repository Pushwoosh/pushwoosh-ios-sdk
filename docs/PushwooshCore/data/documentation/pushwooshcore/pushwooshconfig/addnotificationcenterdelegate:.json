:"text"},{"text":" ","type":"text"},{"text":"as it avoids conflicts with Pushwoosh’s own notification handling.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Typical use cases:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Integrating multiple push notification SDKs"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Adding custom notification handling logic (e.g., analytics, local notifications)"}]}]},{"content":[{"inlineContent":[{"text":"Implementing custom notification actions","type":"text"}],"type":"paragraph"}]}]},{"text":"Examples","anchor":"Examples","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Register AppDelegate as a notification delegate:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","    Pushwoosh.configure.addNotificationCenterDelegate(self)","    return true","}"]},{"type":"paragraph","inlineContent":[{"text":"Register a dedicated notification handler:","type":"text"}]},{"type":"codeListing","code":["class NotificationHandler: NSObject, UNUserNotificationCenterDelegate {","","    func userNotificationCenter(_ center: UNUserNotificationCenter,","                                willPresent notification: UNNotification,","                                withCompletionHandler completionHandler: @escaping (UNNotificationPresentationOptions) -> Void) {","        if !PWMessage.isPushwooshMessage(notification.request.content.userInfo) {","            completionHandler([.banner, .sound])","        }","    }","","    func userNotificationCenter(_ center: UNUserNotificationCenter,","                                didReceive response: UNNotificationResponse,","                                withCompletionHandler completionHandler: @escaping () -> Void) {","        if !PWMessage.isPushwooshMessage(response.notification.request.content.userInfo) {","            \/\/ Handle your custom notification","            completionHandler()","        }","    }","}","","let handler = NotificationHandler()","Pushwoosh.configure.addNotificationCenterDelegate(handler)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Objective-C:","type":"text"}]},{"code":["[Pushwoosh.configure addNotificationCenterDelegate:self];"],"syntax":"objc","type":"codeListing"},{"name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWMessage\/isPushwooshMessage:","type":"reference"},{"type":"text","text":" to distinguish Pushwoosh notifications from your own and handle only non-Pushwoosh notifications in your custom delegate."}]}],"style":"note"}],"kind":"content"}],"metadata":{"role":"symbol","modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","navigatorTitle":[{"kind":"identifier","text":"addNotificationCenterDelegate:"}],"fragments":[{"text":"+ ","kind":"text"},{"text":"addNotificationCenterDelegate:","kind":"identifier"}],"symbolKind":"method","title":"addNotificationCenterDelegate:","externalID":"c:objc(cs)PushwooshConfig(cm)addNotificationCenterDelegate:"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/addnotificationcenterdelegate:"]}],"abstract":[{"type":"text","text":"Adds a custom "},{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"type":"text","text":" to the Pushwoosh notification center delegate proxy."}],"sections":[],"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","title":"PushwooshCore"