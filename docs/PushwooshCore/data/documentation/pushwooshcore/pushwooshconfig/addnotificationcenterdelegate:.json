eContent":[{"type":"text","text":"Use this method to register your own "},{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"type":"text","text":" alongside Pushwoosh’s built-in delegate."},{"text":" ","type":"text"},{"type":"text","text":"Pushwoosh uses a delegate proxy to forward notification center callbacks to all registered delegates,"},{"type":"text","text":" "},{"type":"text","text":"enabling multiple components to respond to notification events without conflicts."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is the recommended way to handle notification center events when using Pushwoosh SDK 7.0+,"},{"type":"text","text":" "},{"text":"as it avoids conflicts with Pushwoosh’s own notification handling.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Typical use cases:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Integrating multiple push notification SDKs"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Adding custom notification handling logic (e.g., analytics, local notifications)"}]}]},{"content":[{"inlineContent":[{"text":"Implementing custom notification actions","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Examples","level":2,"text":"Examples"},{"inlineContent":[{"text":"Register AppDelegate as a notification delegate:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["func application(_ application: UIApplication,","                 didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","    Pushwoosh.configure.addNotificationCenterDelegate(self)","    return true","}"]},{"inlineContent":[{"text":"Register a dedicated notification handler:","type":"text"}],"type":"paragraph"},{"code":["class NotificationHandler: NSObject, UNUserNotificationCenterDelegate {","","    func userNotificationCenter(_ center: UNUserNotificationCenter,","                                willPresent notification: UNNotification,","                                withCompletionHandler completionHandler: @escaping (UNNotificationPresentationOptions) -> Void) {","        if !PWMessage.isPushwooshMessage(notification.request.content.userInfo) {","            completionHandler([.banner, .sound])","        }","    }","","    func userNotificationCenter(_ center: UNUserNotificationCenter,","                                didReceive response: UNNotificationResponse,","                                withCompletionHandler completionHandler: @escaping () -> Void) {","        if !PWMessage.isPushwooshMessage(response.notification.request.content.userInfo) {","            \/\/ Handle your custom notification","            completionHandler()","        }","    }","}","","let handler = NotificationHandler()","Pushwoosh.configure.addNotificationCenterDelegate(handler)"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Objective-C:"}]},{"syntax":"objc","type":"codeListing","code":["[Pushwoosh.configure addNotificationCenterDelegate:self];"]},{"type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWMessage\/isPushwooshMessage:","type":"reference"},{"text":" to distinguish Pushwoosh notifications from your own and handle only non-Pushwoosh notifications in your custom delegate.","type":"text"}]}],"style":"note"}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pushwooshconfig\/addnotificationcenterdelegate:"]}],"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","role":"collection","kind":"symbol","title":"PushwooshCore","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"id