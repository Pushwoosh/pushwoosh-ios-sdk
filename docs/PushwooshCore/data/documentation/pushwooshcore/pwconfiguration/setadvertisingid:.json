automatically."}]},{"inlineContent":[{"text":"Behavior:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Fire-and-forget: no completion handler. The SDK retries on transient failures.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Deduplicated: repeated calls with the same value do not produce additional","type":"text"},{"type":"text","text":" "},{"text":"network requests.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"The value is persisted locally only after a successful send and read back on","type":"text"},{"type":"text","text":" "},{"type":"text","text":"subsequent launches for the dedupe check."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default the IDFA is sent to "},{"code":"https:\/\/tracking.svc-nue.pushwoosh.com\/api\/v2\/device-api\/setMADID","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"You can override the tracking endpoint via the ","type":"text"},{"code":"Pushwoosh_TRACKING_URL","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"Info.plist key (useful for on-premise deployments and integration testing)."}]},{"text":"App Store submission requirement","anchor":"App-Store-submission-requirement","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Apple requires that any tracking domain be declared in the "},{"inlineContent":[{"text":"integrator’s","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"text":"app-level ","type":"text"},{"code":"PrivacyInfo.xcprivacy","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["<key>NSPrivacyTracking<\/key>","<true\/>","<key>NSPrivacyTrackingDomains<\/key>","<array>","    <string>tracking.svc-nue.pushwoosh.com<\/string>","<\/array>"],"type":"codeListing","syntax":"xml"},{"type":"paragraph","inlineContent":[{"text":"If you override ","type":"text"},{"code":"Pushwoosh_TRACKING_URL","type":"codeVoice"},{"text":", list ","type":"text"},{"inlineContent":[{"type":"text","text":"your"}],"type":"strong"},{"type":"text","text":" host instead. Apps that"},{"text":" ","type":"text"},{"text":"ship without this declaration will be blocked by iOS on non-authorized devices","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and may face App Store review issues."}]},{"inlineContent":[{"text":"You must also add ","type":"text"},{"code":"NSUserTrackingUsageDescription","type":"codeVoice"},{"text":" to ","type":"text"},{"code":"Info.plist","type":"codeVoice"},{"type":"text","text":" — it is the"},{"text":" ","type":"text"},{"text":"text displayed in the ATT consent prompt.","type":"text"}],"type":"paragraph"},{"anchor":"Example","text":"Example","level":2,"type":"heading"},{"type":"codeListing","code":["import AppTrackingTransparency","import AdSupport","","ATTrackingManager.requestTrackingAuthorization { status in","    if status == .authorized {","        let idfa = ASIdentifierManager.shared().advertisingIdentifier.uuidString","        Pushwoosh.configure.setAdvertisingId(idfa)","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"To clear:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.configure.setAdvertisingId(nil)"]}]}],"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)setAdvertisingId:","symbolKind":"method","fragments":[{"text":"+ ","kind":"text"},{"text":"setAdvertisingId:","kind":"identifier"}],"navigatorTitle":[{"text":"setAdvertisingId:","kind":"identifier"}],"role":"symbol","title":"setAdvertisingId:","roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}]},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"Sets the advertising identifier (IDFA) for the device.","type":"text"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.push