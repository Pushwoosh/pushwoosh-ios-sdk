{"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setadvertisingid:"]}],"abstract":[{"type":"text","text":"Sets the advertising identifier (IDFA) for the device."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"navigatorTitle":[{"kind":"identifier","text":"setAdvertisingId:"}],"roleHeading":"Type Method","symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)setAdvertisingId:","role":"symbol","title":"setAdvertisingId:","fragments":[{"text":"+ ","kind":"text"},{"text":"setAdvertisingId:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}]},"sections":[],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setAdvertisingId:"},"primaryContentSections":[{"declarations":[{"languages":["occ"],"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setAdvertisingId:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier","text":"NSString"},{"kind":"text","text":" *) "},{"text":"advertisingId","kind":"internalParam"},{"kind":"text","text":";"}],"platforms":["iOS"]}],"kind":"declarations"},{"parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The advertising identifier string, or "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" to clear it."}],"type":"paragraph"}],"name":"advertisingId"}],"kind":"parameters"},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The SDK does not collect IDFA automatically. The integrator is responsible for"},{"text":" ","type":"text"},{"type":"text","text":"requesting user consent via "},{"type":"codeVoice","code":"ATTrackingManager.requestTrackingAuthorization"},{"text":" and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"passing the resulting identifier to the SDK."}]},{"inlineContent":[{"type":"text","text":"Pass "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", an empty string, or the zero UUID"},{"type":"text","text":" "},{"type":"text","text":"("},{"code":"\"00000000-0000-0000-0000-000000000000\"","type":"codeVoice"},{"type":"text","text":") to clear the identifier on the backend."},{"text":" ","type":"text"},{"text":"The zero UUID is what ","type":"text"},{"code":"ASIdentifierManager.advertisingIdentifier","type":"codeVoice"},{"type":"text","text":" returns when"},{"type":"text","text":" "},{"type":"text","text":"tracking is denied or restricted — the SDK normalizes it to "},{"code":"nil","type":"codeVoice"},{"text":" automatically.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Behavior:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Fire-and-forget: no completion handler. The SDK retries on transient failures.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Deduplicated: repeated calls with the same value do not produce additional"},{"type":"text","text":" "},{"type":"text","text":"network requests."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The value is persisted locally only after a successful send and read back on"},{"text":" ","type":"text"},{"type":"text","text":"subsequent launches for the dedupe check."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"By default the IDFA is sent to "},{"type":"codeVoice","code":"https:\/\/tracking.svc-nue.pushwoosh.com\/api\/v2\/device-api\/setMADID"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"You can override the tracking endpoint via the "},{"type":"codeVoice","code":"Pushwoosh_TRACKING_URL"},{"type":"text","text":" "},{"type":"text","text":"Info.plist key (useful for on-premise deployments and integration testing)."}],"type":"paragraph"},{"type":"heading","text":"App Store submission requirement","anchor":"App-Store-submission-requirement","level":2},{"type":"paragraph","inlineContent":[{"text":"Apple requires that any tracking domain be declared in the ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"integrator’s"}]},{"type":"text","text":" "},{"type":"text","text":"app-level "},{"code":"PrivacyInfo.xcprivacy","type":"codeVoice"},{"type":"text","text":":"}]},{"syntax":"xml","code":["<key>NSPrivacyTracking<\/key>","<true\/>","<key>NSPrivacyTrackingDomains<\/key>","<array>","    <string>tracking.svc-nue.pushwoosh.com<\/string>","<\/array>"],"type":"codeListing"},{"inlineContent":[{"text":"If you override ","type":"text"},{"code":"Pushwoosh_TRACKING_URL","type":"codeVoice"},{"type":"text","text":", list "},{"inlineContent":[{"text":"your","type":"text"}],"type":"strong"},{"type":"text","text":" host instead. Apps that"},{"text":" ","type":"text"},{"text":"ship without this declaration will be blocked by iOS on non-authorized devices","type":"text"},{"text":" ","type":"text"},{"text":"and may face App Store review issues.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You must also add "},{"code":"NSUserTrackingUsageDescription","type":"codeVoice"},{"text":" to ","type":"text"},{"code":"Info.plist","type":"codeVoice"},{"type":"text","text":" — it is the"},{"type":"text","text":" "},{"type":"text","text":"text displayed in the ATT consent prompt."}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"code":["import AppTrackingTransparency","import AdSupport","","ATTrackingManager.requestTrackingAuthorization { status in","    if status == .authorized {","        let idfa = ASIdentifierManager.shared().advertisingIdentifier.uuidString","        Pushwoosh.configure.setAdvertisingId(idfa)","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To clear:"}]},{"type":"codeListing","syntax":"swift","code":["Pushwoosh.configure.setAdvertisingId(nil)"]}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setAdvertisingId:":{"navigatorTitle":[{"text":"setAdvertisingId:","kind":"identifier"}],"abstract":[{"type":"text","text":"Sets the advertising identifier (IDFA) for the device."}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setAdvertisingId:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setadvertisingid:","kind":"symbol","title":"setAdvertisingId:","role":"symbol","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setAdvertisingId:"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"title":"PWConfiguration","type":"topic","role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","kind":"symbol","role":"collection","title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}]}}}