{"text":" ","type":"text"},{"type":"text","text":"requesting user consent via "},{"code":"ATTrackingManager.requestTrackingAuthorization","type":"codeVoice"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"text":"passing the resulting identifier to the SDK.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Pass ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", an empty string, or the zero UUID"},{"type":"text","text":" "},{"type":"text","text":"("},{"code":"\"00000000-0000-0000-0000-000000000000\"","type":"codeVoice"},{"type":"text","text":") to clear the identifier on the backend."},{"text":" ","type":"text"},{"type":"text","text":"The zero UUID is what "},{"code":"ASIdentifierManager.advertisingIdentifier","type":"codeVoice"},{"text":" returns when","type":"text"},{"type":"text","text":" "},{"type":"text","text":"tracking is denied or restricted — the SDK normalizes it to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" automatically."}]},{"type":"paragraph","inlineContent":[{"text":"Behavior:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Fire-and-forget: no completion handler. The SDK retries on transient failures.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Deduplicated: repeated calls with the same value do not produce additional","type":"text"},{"type":"text","text":" "},{"type":"text","text":"network requests."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The value is persisted locally only after a successful send and read back on","type":"text"},{"type":"text","text":" "},{"type":"text","text":"subsequent launches for the dedupe check."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default the IDFA is sent to "},{"type":"codeVoice","code":"https:\/\/tracking.svc-nue.pushwoosh.com\/api\/v2\/device-api\/setMADID"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"You can override the tracking endpoint via the ","type":"text"},{"type":"codeVoice","code":"Pushwoosh_TRACKING_URL"},{"text":" ","type":"text"},{"text":"Info.plist key (useful for on-premise deployments and integration testing).","type":"text"}]},{"type":"heading","anchor":"App-Store-submission-requirement","text":"App Store submission requirement","level":2},{"inlineContent":[{"text":"Apple requires that any tracking domain be declared in the ","type":"text"},{"inlineContent":[{"text":"integrator’s","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"text":"app-level ","type":"text"},{"type":"codeVoice","code":"PrivacyInfo.xcprivacy"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["<key>NSPrivacyTracking<\/key>","<true\/>","<key>NSPrivacyTrackingDomains<\/key>","<array>","    <string>tracking.svc-nue.pushwoosh.com<\/string>","<\/array>"],"syntax":"xml","type":"codeListing"},{"inlineContent":[{"text":"If you override ","type":"text"},{"type":"codeVoice","code":"Pushwoosh_TRACKING_URL"},{"type":"text","text":", list "},{"type":"strong","inlineContent":[{"text":"your","type":"text"}]},{"text":" host instead. Apps that","type":"text"},{"text":" ","type":"text"},{"text":"ship without this declaration will be blocked by iOS on non-authorized devices","type":"text"},{"type":"text","text":" "},{"text":"and may face App Store review issues.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"You must also add ","type":"text"},{"code":"NSUserTrackingUsageDescription","type":"codeVoice"},{"text":" to ","type":"text"},{"code":"Info.plist","type":"codeVoice"},{"type":"text","text":" — it is the"},{"text":" ","type":"text"},{"type":"text","text":"text displayed in the ATT consent prompt."}]},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"code":["import AppTrackingTransparency","import AdSupport","","ATTrackingManager.requestTrackingAuthorization { status in","    if status == .authorized {","        let idfa = ASIdentifierManager.shared().advertisingIdentifier.uuidString","        Pushwoosh.configure.setAdvertisingId(idfa)","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To clear:"}]},{"syntax":"swift","code":["Pushwoosh.configure.setAdvertisingId(nil)"],"type":"codeListing"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","role":"collection","kind":"symbol","type":"topic","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"role":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","title":"PWConfiguration","kind":"symbol","type":"topic","abstract":[]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setAdvertisingId:":{"title":"setAdvertisingId:","kind":"symbol","abstract":[{"type":"text","text":"Sets the advertising identifier (IDFA) for the device."}],"fragments":[{"text":"+ ","kind":"text"},{"text":"setAdvertisingId:","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"setAdvertisingId:"}],"type":"topic","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setadvertisingid:","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setAdvertisingId:","role":"symbol"}}}