{"abstract":[{"type":"text","text":"Sets the advertising identifier (IDFA) for the device."}],"kind":"symbol","identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setAdvertisingId:","interfaceLanguage":"occ"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setAdvertisingId:"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString","text":"NSString"},{"text":" *) ","kind":"text"},{"text":"advertisingId","kind":"internalParam"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"name":"advertisingId","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The advertising identifier string, or "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to clear it."}]}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"The SDK does not collect IDFA automatically. The integrator is responsible for"},{"type":"text","text":" "},{"type":"text","text":"requesting user consent via "},{"type":"codeVoice","code":"ATTrackingManager.requestTrackingAuthorization"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"text":"passing the resulting identifier to the SDK.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Pass "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", an empty string, or the zero UUID"},{"type":"text","text":" "},{"text":"(","type":"text"},{"type":"codeVoice","code":"\"00000000-0000-0000-0000-000000000000\""},{"type":"text","text":") to clear the identifier on the backend."},{"text":" ","type":"text"},{"type":"text","text":"The zero UUID is what "},{"code":"ASIdentifierManager.advertisingIdentifier","type":"codeVoice"},{"type":"text","text":" returns when"},{"text":" ","type":"text"},{"type":"text","text":"tracking is denied or restricted — the SDK normalizes it to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" automatically."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Behavior:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"text":"Fire-and-forget: no completion handler. The SDK retries on transient failures.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Deduplicated: repeated calls with the same value do not produce additional"},{"text":" ","type":"text"},{"type":"text","text":"network requests."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The value is persisted locally only after a successful send and read back on"},{"type":"text","text":" "},{"type":"text","text":"subsequent launches for the dedupe check."}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default the IDFA is sent to "},{"code":"https:\/\/tracking.svc-nue.pushwoosh.com\/api\/v2\/device-api\/setMADID","type":"codeVoice"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"You can override the tracking endpoint via the ","type":"text"},{"code":"Pushwoosh_TRACKING_URL","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"Info.plist key (useful for on-premise deployments and integration testing)."}]},{"text":"App Store submission requirement","level":2,"anchor":"App-Store-submission-requirement","type":"heading"},{"inlineContent":[{"text":"Apple requires that any tracking domain be declared in the ","type":"text"},{"inlineContent":[{"text":"integrator’s","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"type":"text","text":"app-level "},{"type":"codeVoice","code":"PrivacyInfo.xcprivacy"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","syntax":"xml","code":["<key>NSPrivacyTracking<\/key>","<true\/>","<key>NSPrivacyTrackingDomains<\/key>","<array>","    <string>tracking.svc-nue.pushwoosh.com<\/string>","<\/array>"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you override "},{"code":"Pushwoosh_TRACKING_URL","type":"codeVoice"},{"text":", list ","type":"text"},{"type":"strong","inlineContent":[{"text":"your","type":"text"}]},{"text":" host instead. Apps that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"ship without this declaration will be blocked by iOS on non-authorized devices"},{"type":"text","text":" "},{"text":"and may face App Store review issues.","type":"text"}]},{"inlineContent":[{"text":"You must also add ","type":"text"},{"type":"codeVoice","code":"NSUserTrackingUsageDescription"},{"type":"text","text":" to "},{"type":"codeVoice","code":"Info.plist"},{"type":"text","text":" — it is the"},{"text":" ","type":"text"},{"text":"text displayed in the ATT consent prompt.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"Example","anchor":"Example"},{"type":"codeListing","syntax":"swift","code":["import AppTrackingTransparency","import AdSupport","","ATTrackingManager.requestTrackingAuthorization { status in","    if status == .authorized {","        let idfa = ASIdentifierManager.shared().advertisingIdentifier.uuidString","        Pushwoosh.configure.setAdvertisingId(idfa)","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To clear:"}]},{"syntax":"swift","type":"codeListing","code":["Pushwoosh.configure.setAdvertisingId(nil)"]}]}],"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)setAdvertisingId:","roleHeading":"Type Method","role":"symbol","symbolKind":"method","modules":[{"name":"PushwooshCore"}],"fragments":[{"text":"+ ","kind":"text"},{"text":"setAdvertisingId:","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"setAdvertisingId:"}],"title":"setAdvertisingId:"},"variants":[{"trait