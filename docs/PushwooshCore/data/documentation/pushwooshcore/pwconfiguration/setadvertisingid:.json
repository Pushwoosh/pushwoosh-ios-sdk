{"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setAdvertisingId:"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"NSString","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"text":"advertisingId","kind":"internalParam"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"parameters":[{"name":"advertisingId","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The advertising identifier string, or "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to clear it."}]}]}],"kind":"parameters"},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"The SDK does not collect IDFA automatically. The integrator is responsible for","type":"text"},{"text":" ","type":"text"},{"text":"requesting user consent via ","type":"text"},{"code":"ATTrackingManager.requestTrackingAuthorization","type":"codeVoice"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"text":"passing the resulting identifier to the SDK.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Pass "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", an empty string, or the zero UUID"},{"type":"text","text":" "},{"type":"text","text":"("},{"code":"\"00000000-0000-0000-0000-000000000000\"","type":"codeVoice"},{"type":"text","text":") to clear the identifier on the backend."},{"type":"text","text":" "},{"type":"text","text":"The zero UUID is what "},{"type":"codeVoice","code":"ASIdentifierManager.advertisingIdentifier"},{"type":"text","text":" returns when"},{"type":"text","text":" "},{"text":"tracking is denied or restricted — the SDK normalizes it to ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" automatically."}]},{"inlineContent":[{"text":"Behavior:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Fire-and-forget: no completion handler. The SDK retries on transient failures."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Deduplicated: repeated calls with the same value do not produce additional","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"network requests."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The value is persisted locally only after a successful send and read back on","type":"text"},{"type":"text","text":" "},{"text":"subsequent launches for the dedupe check.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"By default the IDFA is sent to ","type":"text"},{"type":"codeVoice","code":"https:\/\/tracking.svc-nue.pushwoosh.com\/api\/v2\/device-api\/setMADID"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"You can override the tracking endpoint via the ","type":"text"},{"type":"codeVoice","code":"Pushwoosh_TRACKING_URL"},{"type":"text","text":" "},{"type":"text","text":"Info.plist key (useful for on-premise deployments and integration testing)."}]},{"text":"App Store submission requirement","type":"heading","level":2,"anchor":"App-Store-submission-requirement"},{"inlineContent":[{"text":"Apple requires that any tracking domain be declared in the ","type":"text"},{"type":"strong","inlineContent":[{"text":"integrator’s","type":"text"}]},{"type":"text","text":" "},{"text":"app-level ","type":"text"},{"code":"PrivacyInfo.xcprivacy","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"xml","code":["<key>NSPrivacyTracking<\/key>","<true\/>","<key>NSPrivacyTrackingDomains<\/key>","<array>","    <string>tracking.svc-nue.pushwoosh.com<\/string>","<\/array>"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you override "},{"code":"Pushwoosh_TRACKING_URL","type":"codeVoice"},{"type":"text","text":", list "},{"inlineContent":[{"type":"text","text":"your"}],"type":"strong"},{"text":" host instead. Apps that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"ship without this declaration will be blocked by iOS on non-authorized devices"},{"text":" ","type":"text"},{"type":"text","text":"and may face App Store review issues."}]},{"type":"paragraph","inlineContent":[{"text":"You must also add ","type":"text"},{"code":"NSUserTrackingUsageDescription","type":"codeVoice"},{"type":"text","text":" to "},{"code":"Info.plist","type":"codeVoice"},{"type":"text","text":" — it is the"},{"text":" ","type":"text"},{"type":"text","text":"text displayed in the ATT consent prompt."}]},{"anchor":"Example","text":"Example","level":2,"type":"heading"},{"code":["import AppTrackingTransparency","import AdSupport","","ATTrackingManager.requestTrackingAuthorization { status in","    if status == .authorized {","        let idfa = ASIdentifierManager.shared().advertisingIdentifier.uuidString","        Pushwoosh.configure.setAdvertisingId(idfa)","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"To clear:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["Pushwoosh.configure.setAdvertisingId(nil)"]}],"kind":"content"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setAdvertisingId:"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setadvertisingid:"]}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"navigatorTitle":[{"text":"setAdvertisingId:","kind":"identifier"}],"roleHeading":"Type Met