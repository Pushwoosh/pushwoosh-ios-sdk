s that any tracking domain be declared in the ","type":"text"},{"inlineContent":[{"text":"integrator’s","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"text":"app-level ","type":"text"},{"type":"codeVoice","code":"PrivacyInfo.xcprivacy"},{"text":":","type":"text"}]},{"type":"codeListing","code":["<key>NSPrivacyTracking<\/key>","<true\/>","<key>NSPrivacyTrackingDomains<\/key>","<array>","    <string>tracking.svc-nue.pushwoosh.com<\/string>","<\/array>"],"syntax":"xml"},{"inlineContent":[{"text":"If you override ","type":"text"},{"type":"codeVoice","code":"Pushwoosh_TRACKING_URL"},{"text":", list ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"your"}]},{"text":" host instead. Apps that","type":"text"},{"type":"text","text":" "},{"text":"ship without this declaration will be blocked by iOS on non-authorized devices","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and may face App Store review issues."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You must also add "},{"type":"codeVoice","code":"NSUserTrackingUsageDescription"},{"text":" to ","type":"text"},{"code":"Info.plist","type":"codeVoice"},{"type":"text","text":" — it is the"},{"text":" ","type":"text"},{"type":"text","text":"text displayed in the ATT consent prompt."}]},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"syntax":"swift","type":"codeListing","code":["import AppTrackingTransparency","import AdSupport","","ATTrackingManager.requestTrackingAuthorization { status in","    if status == .authorized {","        let idfa = ASIdentifierManager.shared().advertisingIdentifier.uuidString","        Pushwoosh.configure.setAdvertisingId(idfa)","    }","}"]},{"inlineContent":[{"text":"To clear:","type":"text"}],"type":"paragraph"},{"code":["Pushwoosh.configure.setAdvertisingId(nil)"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfigu