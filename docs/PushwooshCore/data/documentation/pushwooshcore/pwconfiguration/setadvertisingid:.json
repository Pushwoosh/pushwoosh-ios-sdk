{"abstract":[{"text":"Sets the advertising identifier (IDFA) for the device.","type":"text"}],"kind":"symbol","identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setAdvertisingId:","interfaceLanguage":"occ"},"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"navigatorTitle":[{"text":"setAdvertisingId:","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)setAdvertisingId:","role":"symbol","title":"setAdvertisingId:","symbolKind":"method","roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}],"fragments":[{"kind":"text","text":"+ "},{"text":"setAdvertisingId:","kind":"identifier"}]},"sections":[],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"setAdvertisingId:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSString","text":"NSString","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"advertisingId"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"The advertising identifier string, or ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" to clear it.","type":"text"}],"type":"paragraph"}],"name":"advertisingId"}]},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The SDK does not collect IDFA automatically. The integrator is responsible for"},{"text":" ","type":"text"},{"text":"requesting user consent via ","type":"text"},{"code":"ATTrackingManager.requestTrackingAuthorization","type":"codeVoice"},{"text":" and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"passing the resulting identifier to the SDK."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Pass "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", an empty string, or the zero UUID"},{"type":"text","text":" "},{"text":"(","type":"text"},{"code":"\"00000000-0000-0000-0000-000000000000\"","type":"codeVoice"},{"text":") to clear the identifier on the backend.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The zero UUID is what "},{"type":"codeVoice","code":"ASIdentifierManager.advertisingIdentifier"},{"text":" returns when","type":"text"},{"type":"text","text":" "},{"text":"tracking is denied or restricted — the SDK normalizes it to ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" automatically."}]},{"type":"paragraph","inlineContent":[{"text":"Behavior:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Fire-and-forget: no completion handler. The SDK retries on transient failures."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Deduplicated: repeated calls with the same value do not produce additional"},{"type":"text","text":" "},{"type":"text","text":"network requests."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The value is persisted locally only after a successful send and read back on","type":"text"},{"type":"text","text":" "},{"type":"text","text":"subsequent launches for the dedupe check."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"By default the IDFA is sent to "},{"code":"https:\/\/tracking.svc-nue.pushwoosh.com\/api\/v2\/device-api\/setMADID","type":"codeVoice"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"You can override the tracking endpoint via the ","type":"text"},{"code":"Pushwoosh_TRACKING_URL","type":"codeVoice"},{"type":"text","text":" "},{"text":"Info.plist key (useful for on-premise deployments and integration testing).","type":"text"}],"type":"paragraph"},{"type":"heading","text":"App Store submission requirement","anchor":"App-Store-submission-requirement","level":2},{"inlineContent":[{"text":"Apple requires that any tracking domain be declared in the ","type":"text"},{"inlineContent":[{"text":"integrator’s","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"text":"app-level ","type":"text"},{"type":"codeVoice","code":"PrivacyInfo.xcprivacy"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","syntax":"xml","code":["<key>NSPrivacyTracking<\/key>","<true\/>","<key>NSPrivacyTrackingDomains<\/key>","<array>","    <string>tracking.svc-nue.pushwoosh.com<\/string>","<\/array>"]},{"inlineContent":[{"text":"If you override ","type":"text"},{"code":"Pushwoosh_TRACKING_URL","type":"codeVoice"},{"type":"text","text":", list "},{"inlineContent":[{"type":"text","text":"your"}],"type":"strong"},{"text":" host instead. Apps that","type":"text"},{"text":" ","type":"text"},{"text":"ship without this declaration will be blocked by iOS on non-authorized devices","type":"text"},{"text":" ","type":"text"},{"text":"and may face App Store review issues.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You must also add "},{"type":"codeVoice","code":"NSUserTrackingUsageDescription"},{"type":"text","text":" to "},{"type":"codeVoice","code":"Info.plist"},{"type":"text","text":" — it is the"},{"text":" ","type":"text"},{"type":"text","text":"text displayed in the ATT consent prompt."}],"type":"paragraph"},{"text":"Example","level":2,"anchor":"Example","type":"heading"},{"code":["import AppTrackingTransparency","import AdSupport","","ATTrackingManager.requestTrackingAuthorization { status in","    if status == .authorized {","        let idfa = ASIdentifierManager.shared().advertisingIdentifier.uuidString","        Pushwoosh.configure.setAdvertisingId(idfa)","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"To clear:","type":"text"}]},{"syntax":"swift","code":["Pushwoosh.configure.setAdvertisingId(nil)"],"type":"codeListing"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setadvertisingid:"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","url":"\/documentation\/pushwooshcore","role":"collection","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","title":"PushwooshCore","kind":"symbol","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"kind":"symbol","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setAdvertisingId:":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setAdvertisingId:","role":"symbol","abstract":[{"type":"text","text":"Sets the advertising identifier (IDFA) for the device."}],"title":"setAdvertisingId:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setadvertisingid:","kind":"symbol","navigatorTitle":[{"text":"setAdvertisingId:","kind":"identifier"}],"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setAdvertisingId:"}]}}}