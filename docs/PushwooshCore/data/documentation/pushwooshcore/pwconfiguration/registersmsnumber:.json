{"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registersmsnumber:"]}],"abstract":[{"type":"text","text":"Registers an SMS number for SMS messaging campaigns."}],"metadata":{"navigatorTitle":[{"text":"registerSmsNumber:","kind":"identifier"}],"title":"registerSmsNumber:","role":"symbol","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"registerSmsNumber:"}],"modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)registerSmsNumber:","symbolKind":"method","roleHeading":"Type Method"},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerSmsNumber:","interfaceLanguage":"occ"},"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"registerSmsNumber:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"NSString","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"text":"number","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"number","content":[{"type":"paragraph","inlineContent":[{"text":"The phone number in E.164 international format.","type":"text"}]}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Associates a phone number with the current device for SMS marketing campaigns.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This enables omnichannel messaging where users can receive communications via"},{"type":"text","text":" "},{"type":"text","text":"both push notifications and SMS."}]},{"inlineContent":[{"type":"text","text":"The phone number must be in E.164 international format:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Start with ‘+’ followed by country code","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"No spaces, dashes, or parentheses"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Examples: “+14155551234” (US), “+447911123456” (UK), “+491711234567” (Germany)"}]}]}]},{"anchor":"Example","text":"Example","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register SMS during phone verification flow:"}]},{"type":"codeListing","syntax":"swift","code":["class PhoneVerificationController {","","    func verifyPhoneNumber(_ phoneNumber: String, code: String,","                          completion: @escaping (Result<Void, Error>) -> Void) {","","        APIClient.shared.verifyCode(phone: phoneNumber, code: code) { [weak self] result in","            switch result {","            case .success:","                let normalizedNumber = self?.normalizeToE164(phoneNumber) ?? phoneNumber","                Pushwoosh.configure.registerSmsNumber(normalizedNumber)","","                Pushwoosh.configure.setTags([","                    \"phone_verified\": true,","                    \"sms_opted_in\": true,","                    \"phone_country\": self?.extractCountryCode(from: normalizedNumber) ?? \"\"","                ])","","                completion(.success(()))","","            case .failure(let error):","                completion(.failure(error))","            }","        }","    }","","    private func normalizeToE164(_ phone: String) -> String {","        let digits = phone.components(separatedBy: CharacterSet.decimalDigits.inverted).joined()","        return phone.hasPrefix(\"+\") ? \"+\\(digits)\" : \"+1\\(digits)\"","    }","","    private func extractCountryCode(from e164: String) -> String {","        \/\/ Extract country code from E.164 format","        guard e164.hasPrefix(\"+\") else { return \"\" }","        let countryCodeLength = e164.count > 12 ? 2 : (e164.count > 11 ? 1 : 1)","        return String(e164.dropFirst().prefix(countryCodeLength))","    }","}"]}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerSmsNumber:":{"navigatorTitle":[{"kind":"identifier","text":"registerSmsNumber:"}],"title":"registerSmsNumber:","role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/registersmsnumber:","kind":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"registerSmsNumber:","kind":"identifier"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerSmsNumber:","type":"topic","abstract":[{"type":"text","text":"Registers an SMS number for SMS messaging campaigns."}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"kind":"symbol","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","url":"\/documentation\/pushwooshcore","role":"collection","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","title":"PushwooshCore","kind":"symbol","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}]}}}