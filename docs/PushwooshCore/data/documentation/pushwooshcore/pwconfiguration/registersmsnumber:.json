{"sections":[],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerSmsNumber:","interfaceLanguage":"occ"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registersmsnumber:"]}],"metadata":{"roleHeading":"Type Method","navigatorTitle":[{"text":"registerSmsNumber:","kind":"identifier"}],"title":"registerSmsNumber:","symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)registerSmsNumber:","fragments":[{"text":"+ ","kind":"text"},{"text":"registerSmsNumber:","kind":"identifier"}],"role":"symbol","modules":[{"name":"PushwooshCore"}]},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"registerSmsNumber:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier","text":"NSString"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"number"},{"text":";","kind":"text"}]}]},{"parameters":[{"name":"number","content":[{"inlineContent":[{"text":"The phone number in E.164 international format.","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"Associates a phone number with the current device for SMS marketing campaigns.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This enables omnichannel messaging where users can receive communications via"},{"type":"text","text":" "},{"type":"text","text":"both push notifications and SMS."}],"type":"paragraph"},{"inlineContent":[{"text":"The phone number must be in E.164 international format:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Start with ‘+’ followed by country code"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"No spaces, dashes, or parentheses"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Examples: “+14155551234” (US), “+447911123456” (UK), “+491711234567” (Germany)"}]}]}]},{"level":2,"text":"Example","type":"heading","anchor":"Example"},{"inlineContent":[{"type":"text","text":"Register SMS during phone verification flow:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class PhoneVerificationController {","","    func verifyPhoneNumber(_ phoneNumber: String, code: String,","                          completion: @escaping (Result<Void, Error>) -> Void) {","","        APIClient.shared.verifyCode(phone: phoneNumber, code: code) { [weak self] result in","            switch result {","            case .success:","                let normalizedNumber = self?.normalizeToE164(phoneNumber) ?? phoneNumber","                Pushwoosh.configure.registerSmsNumber(normalizedNumber)","","                Pushwoosh.configure.setTags([","                    \"phone_verified\": true,","                    \"sms_opted_in\": true,","                    \"phone_country\": self?.extractCountryCode(from: normalizedNumber) ?? \"\"","                ])","","                completion(.success(()))","","            case .failure(let error):","                completion(.failure(error))","            }","        }","    }","","    private func normalizeToE164(_ phone: String) -> String {","        let digits = phone.components(separatedBy: CharacterSet.decimalDigits.inverted).joined()","        return phone.hasPrefix(\"+\") ? \"+\\(digits)\" : \"+1\\(digits)\"","    }","","    private func extractCountryCode(from e164: String) -> String {","        \/\/ Extract country code from E.164 format","        guard e164.hasPrefix(\"+\") else { return \"\" }","        let countryCodeLength = e164.count > 12 ? 2 : (e164.count > 11 ? 1 : 1)","        return String(e164.dropFirst().prefix(countryCodeLength))","    }","}"]}]}],"abstract":[{"text":"Registers an SMS number for SMS messaging campaigns.","type":"text"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerSmsNumber:":{"role":"symbol","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"registerSmsNumber:"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/registersmsnumber:","navigatorTitle":[{"kind":"identifier","text":"registerSmsNumber:"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerSmsNumber:","kind":"symbol","type":"topic","title":"registerSmsNumber:","abstract":[{"text":"Registers an SMS number for SMS messaging campaigns.","type":"text"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"role":"symbol","abstract":[],"kind":"symbol","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","url":"\/documentation\/pushwooshcore","role":"collection"}}}