{"kind":"symbol","sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"BOOL","kind":"typeIdentifier","preciseIdentifier":"c:@T@BOOL"},{"text":") ","kind":"text"},{"kind":"identifier","text":"isServerCommunicationAllowed"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"kind":"content","content":[{"text":"Return Value","level":2,"type":"heading","anchor":"return-value"},{"inlineContent":[{"text":"YES if server communication is allowed, NO otherwise","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Returns the current server communication status. When communication is disabled,"},{"text":" ","type":"text"},{"text":"the SDK will not send any data to Pushwoosh servers, including:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Device registration"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Tag updates","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Analytics events"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Push token updates"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"This is useful for GDPR compliance where users can opt out of data collection."}],"type":"paragraph"},{"text":"Example","level":2,"type":"heading","anchor":"Example"},{"inlineContent":[{"type":"text","text":"Check status before performing operations:"}],"type":"paragraph"},{"syntax":"swift","code":["class AnalyticsManager {","","    func trackEvent(_ event: String, properties: [String: Any]) {","        \/\/ Check if Pushwoosh communication is allowed","        guard Pushwoosh.configure.isServerCommunicationAllowed() else {","            Logger.debug(\"Pushwoosh communication disabled - skipping event tracking\")","            return","        }","","        \/\/ Track event with Pushwoosh","        Pushwoosh.configure.setTags([","            \"last_event\": event,","            \"last_event_date\": Date()","        ])","    }","}"],"type":"codeListing"}]}],"abstract":[{"type":"text","text":"Checks whether communication with Pushwoosh servers is currently allowed."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/isServerCommunicationAllowed","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)isServerCommunicationAllowed","title":"isServerCommunicationAllowed","roleHeading":"Type Method","role":"symbol","symbolKind":"method","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"isServerCommunicationAllowed"}],"navigatorTitle":[{"text":"isServerCommunicationAllowed","kind":"identifier"}]},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/isservercommunicationallowed"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/isServerCommunicationAllowed":{"fragments":[{"kind":"text","text":"+ "},{"text":"isServerCommunicationAllowed","kind":"identifier"}],"type":"topic","title":"isServerCommunicationAllowed","abstract":[{"text":"Checks whether communication with Pushwoosh servers is currently allowed.","type":"text"}],"navigatorTitle":[{"text":"isServerCommunicationAllowed","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/isServerCommunicationAllowed","url":"\/documentation\/pushwooshcore\/pwconfiguration