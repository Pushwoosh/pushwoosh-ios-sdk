{"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:@T@BOOL","text":"BOOL","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"isServerCommunicationAllowed","kind":"identifier"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Return Value","level":2,"type":"heading","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"YES if server communication is allowed, NO otherwise"}]}]},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Returns the current server communication status. When communication is disabled,"},{"type":"text","text":" "},{"text":"the SDK will not send any data to Pushwoosh servers, including:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Device registration"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Tag updates"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Analytics events","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Push token updates"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"This is useful for GDPR compliance where users can opt out of data collection.","type":"text"}]},{"anchor":"Example","type":"heading","text":"Example","level":2},{"type":"paragraph","inlineContent":[{"text":"Check status before performing operations:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class AnalyticsManager {","","    func trackEvent(_ event: String, properties: [String: Any]) {","        \/\/ Check if Pushwoosh communication is allowed","        guard Pushwoosh.configure.isServerCommunicationAllowed() else {","            Logger.debug(\"Pushwoosh communication disabled - skipping event tracking\")","            return","        }","","        \/\/ Track event with Pushwoosh","        Pushwoosh.configure.setTags([","            \"last_event\": event,","            \"last_event_date\": Date()","        ])","    }","}"]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/isservercommunicationallowed"]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/isServerCommunicationAllowed"},"kind":"symbol","sections":[],"metadata":{"symbolKind":"method","roleHeading":"Type Method","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"isServerCommunicationAllowed"}],"modules":[{"name":"PushwooshCore"}],"title":"isServerCommunicationAllowed","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"isServerCommunicationAllowed"}],"externalID":"c:objc(pl)PWConfiguration(cm)isServerCommunicationAllowed"},"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"abstract":[{"text":"Checks whether communication with Pushwoosh servers is currently allowed.","type":"text"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"title":"PWConfiguration","type":"topic","role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","kind":"symbol","role":"collection","title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","abstract":