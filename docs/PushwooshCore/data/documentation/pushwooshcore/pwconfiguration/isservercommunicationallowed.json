{"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"Checks whether communication with Pushwoosh servers is currently allowed.","type":"text"}],"sections":[],"metadata":{"navigatorTitle":[{"kind":"identifier","text":"isServerCommunicationAllowed"}],"title":"isServerCommunicationAllowed","externalID":"c:objc(pl)PWConfiguration(cm)isServerCommunicationAllowed","role":"symbol","symbolKind":"method","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"isServerCommunicationAllowed"}],"roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/isServerCommunicationAllowed","interfaceLanguage":"occ"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:@T@BOOL","kind":"typeIdentifier","text":"BOOL"},{"text":") ","kind":"text"},{"kind":"identifier","text":"isServerCommunicationAllowed"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"return-value","text":"Return Value","level":2},{"type":"paragraph","inlineContent":[{"text":"YES if server communication is allowed, NO otherwise","type":"text"}]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Returns the current server communication status. When communication is disabled,"},{"type":"text","text":" "},{"type":"text","text":"the SDK will not send any data to Pushwoosh servers, including:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Device registration"}]}]},{"content":[{"inlineContent":[{"text":"Tag updates","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Analytics events"}]}]},{"content":[{"type":"para