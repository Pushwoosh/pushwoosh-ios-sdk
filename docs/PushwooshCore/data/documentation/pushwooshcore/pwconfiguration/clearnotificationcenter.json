{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"kind":"text","text":") "},{"kind":"identifier","text":"clearNotificationCenter"},{"text":";","kind":"text"}]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Removes all notifications delivered by your app from the iOS Notification Center.","type":"text"},{"type":"text","text":" "},{"text":"This is commonly used when:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"User opens the app (clear notifications since they’re viewing content)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"User logs out (clear notifications for privacy)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Content is marked as read in-app"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Performing a “mark all as read” action"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Only removes notifications from your app; other apps’ notifications are unaffected.","type":"text"}],"type":"paragraph"},{"anchor":"Example","type":"heading","level":2,"text":"Example"},{"inlineContent":[{"type":"text","text":"Clear notifications on app activation and logout:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class NotificationManager {","","    func applicationDidBecomeActive() {","        \/\/ Clear notifications when user opens app","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Also reset badge","        UIApplication.shared.applicationIconBadgeNumber = 0","        Pushwoosh.configure.sendBadges(0)","    }","","    func handleUserLogout() {","        \/\/ Clear notifications for privacy","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Unregister from push","        Pushwoosh.configure.unregisterForPushNotifications { _ in }","","        \/\/ Clear user identity","        Pushwoosh.configure.setUserId(\"\")","    }","","    func markAllAsRead() {","        \/\/ Clear from notification center","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Update backend","        APIClient.shared.markAllNotificationsRead { _ in }","","        \/\/ Clear badge","        Pushwoosh.configure.sendBadges(0)","    }","}"]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"metadata":{"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"clearNotificationCenter"}],"modules":[{"name":"PushwooshCore"}],"role":"symbol","symbolKind":"method","title":"clearNotificationCenter","externalID":"c:objc(pl)PWConfiguration(cm)clearNotificationCenter","navigatorTitle":[{"text":"clearNotificationCenter","kind":"identifier"}],"roleHeading":"Type Method"},"abstract":[{"type":"text","text":"Clears all delivered notifications from the notification center."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/clearnotificationcenter"]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/clearNotificationCenter"},"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/clearNotificationCenter":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/clearNotificationCenter","role":"symbol","title":"clearNotificationCenter","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"clearNotificationCent