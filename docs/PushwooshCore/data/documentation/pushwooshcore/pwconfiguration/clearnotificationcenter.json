{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","sections":[],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/clearnotificationcenter"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"clearNotificationCenter","kind":"identifier"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Removes all notifications delivered by your app from the iOS Notification Center.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This is commonly used when:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"User opens the app (clear notifications since they’re viewing content)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"User logs out (clear notifications for privacy)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Content is marked as read in-app"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Performing a “mark all as read” action","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Only removes notifications from your app; other apps’ notifications are unaffected."}]},{"type":"heading","anchor":"Example","level":2,"text":"Example"},{"inlineContent":[{"text":"Clear notifications on app activation and logout:","type":"text"}],"type":"paragraph"},{"code":["class NotificationManager {","","    func applicationDidBecomeActive() {","        \/\/ Clear notifications when user opens app","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Also reset badge","        UIApplication.shared.applicationIconBadgeNumber = 0","        Pushwoosh.configure.sendBadges(0)","    }","","    func handleUserLogout() {","        \/\/ Clear notifications for privacy","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Unregister from push","        Pushwoosh.configure.unregisterForPushNotifications { _ in }","","        \/\/ Clear user identity","        Pushwoosh.configure.setUserId(\"\")","    }","","    func markAllAsRead() {","        \/\/ Clear from notification center","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Update backend","        APIClient.shared.markAllNotificationsRead { _ in }","","        \/\/ Clear badge","        Pushwoosh.configure.sendBadges(0)","    }","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"metadata":{"modules":[{"name":"PushwooshCore"}],"role":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"clearNotificationCenter","kind":"identifier"}],"symbolKind":"method","navigatorTitle":[{"text":"clearNotificationCenter","kind":"identifier"}],"title":"clearNotificationCenter","externalID":"c:objc(pl)PWConfiguration(cm)clearNotificationCenter","roleHeading":"Type Method"},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/clearNotificationCenter","interfaceLanguage":"occ"},"abstract":[{"text":"Clears all delivered notifications from the notification center.","type":"text"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"abstract":[],"role":"symbol","title":"PWConfiguration","type":"topic","url":"\/documentation\/pushwooshcore\/pwconfiguration"},