"paragraph","inlineContent":[{"type":"text","text":"Performing a “mark all as read” action"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Only removes notifications from your app; other apps’ notifications are unaffected."}]},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Clear notifications on app activation and logout:"}]},{"syntax":"swift","type":"codeListing","code":["class NotificationManager {","","    func applicationDidBecomeActive() {","        \/\/ Clear notifications when user opens app","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Also reset badge","        UIApplication.shared.applicationIconBadgeNumber = 0","        Pushwoosh.configure.sendBadges(0)","    }","","    func handleUserLogout() {","        \/\/ Clear notifications for privacy","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Unregister from push","        Pushwoosh.configure.unregisterForPushNotifications { _ in }","","        \/\/ Clear user identity","        Pushwoosh.configure.setUserId(\"\")","    }","","    func markAllAsRead() {","        \/\/ Clear from notification center","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Update backend","        APIClient.shared.markAllNotificationsRead { _ in }","","        \/\/ Clear badge","        Pushwoosh.configure.sendBadges(0)","    }","}"]}],"kind":"content"}],"abstract":[{"type":"text","text":"Clears all delivered notifications from the notification center."}],"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","role":"collection","kind":"symbol","type":"topic","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore"},"doc://com.pushwoosh.PushwooshCore/document