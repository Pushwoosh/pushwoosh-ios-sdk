{"kind":"symbol","sections":[],"abstract":[{"type":"text","text":"Clears all delivered notifications from the notification center."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"clearNotificationCenter","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"Removes all notifications delivered by your app from the iOS Notification Center."},{"type":"text","text":" "},{"type":"text","text":"This is commonly used when:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"User opens the app (clear notifications since they’re viewing content)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"User logs out (clear notifications for privacy)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Content is marked as read in-app"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Performing a “mark all as read” action","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Only removes notifications from your app; other apps’ notifications are unaffected."}],"type":"paragraph"},{"type":"heading","anchor":"Example","level":2,"text":"Example"},{"inlineContent":[{"type":"text","text":"Clear notifications on app activation and logout:"}],"type":"paragraph"},{"type":"codeListing","code":["class NotificationManager {","","    func applicationDidBecomeActive() {","        \/\/ Clear notifications when user opens app","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Also reset badge","        UIApplication.shared.applicationIconBadgeNumber = 0","        Pushwoosh.configure.sendBadges(0)","    }","","    func handleUserLogout() {","        \/\/ Clear notifications for privacy","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Unregister from push","        Pushwoosh.configure.unregisterForPushNotifications { _ in }","","        \/\/ Clear user identity","        Pushwoosh.configure.setUserId(\"\")","    }","","    func markAllAsRead() {","        \/\/ Clear from notification center","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Update backend","        APIClient.shared.markAllNotificationsRead { _ in }","","        \/\/ Clear badge","        Pushwoosh.configure.sendBadges(0)","    }","}"],"syntax":"swift"}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/clearNotificationCenter"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/clearnotificationcenter"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)clearNotificationCenter","roleHeading":"Type Method","navigatorTitle":[{"kind":"identifier","text":"clearNotificationCenter"}],"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"clearNotificationCenter"}],"modules":[{"name":"PushwooshCore"}],"title":"clearNotificationCenter","symbolKind":"method"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","title":"PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"role":"symbol","abstract":[]},