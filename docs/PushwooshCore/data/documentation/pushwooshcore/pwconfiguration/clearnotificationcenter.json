{"abstract":[{"type":"text","text":"Clears all delivered notifications from the notification center."}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/clearNotificationCenter"},"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"title":"clearNotificationCenter","roleHeading":"Type Method","fragments":[{"kind":"text","text":"+ "},{"text":"clearNotificationCenter","kind":"identifier"}],"navigatorTitle":[{"text":"clearNotificationCenter","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"role":"symbol","symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)clearNotificationCenter"},"kind":"symbol","sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"kind":"identifier","text":"clearNotificationCenter"},{"kind":"text","text":";"}],"platforms":["iOS"]}]},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Removes all notifications delivered by your app from the iOS Notification Center."},{"type":"text","text":" "},{"type":"text","text":"This is commonly used when:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"User opens the app (clear notifications since they’re viewing content)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"User logs out (clear notifications for privacy)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Content is marked as read in-app"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Performing a “mark all as read” action","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Only removes notifications from your app; other apps’ notifications are unaffected."}]},{"level":2,"type":"heading","anchor":"Example","text":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Clear notifications on app activation and logout:"}]},{"syntax":"swift","type":"codeListing","code":["class NotificationManager {","","    func applicationDidBecomeActive() {","        \/\/ Clear notifications when user opens app","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Also reset badge","        UIApplication.shared.applicationIconBadgeNumber = 0","        Pushwoosh.configure.sendBadges(0)","    }","","    func handleUserLogout() {","        \/\/ Clear notifications for privacy","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Unregister from push","        Pushwoosh.configure.unregisterForPushNotifications { _ in }","","        \/\/ Clear user identity","        Pushwoosh.configure.setUserId(\"\")","    }","","    func markAllAsRead() {","        \/\/ Clear from notification center","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Update backend","        APIClient.shared.markAllNotificationsRead { _ in }","","        \/\/ Clear badge","        Pushwoosh.configure.sendBadges(0)","    }","}"]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/clearnotificationcenter"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"abstract":[],"title":"PWConfiguration","role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration"},