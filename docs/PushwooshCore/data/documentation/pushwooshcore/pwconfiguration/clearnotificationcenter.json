{"sections":[],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/clearNotificationCenter"},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/clearnotificationcenter"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"clearNotificationCenter","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Removes all notifications delivered by your app from the iOS Notification Center."},{"text":" ","type":"text"},{"text":"This is commonly used when:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"User opens the app (clear notifications since they’re viewing content)"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"User logs out (clear notifications for privacy)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Content is marked as read in-app","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Performing a “mark all as read” action","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Only removes notifications from your app; other apps’ notifications are unaffected."}]},{"text":"Example","type":"heading","anchor":"Example","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Clear notifications on app activation and logout:"}]},{"type":"codeListing","syntax":"swift","code":["class NotificationManager {","","    func applicationDidBecomeActive() {","        \/\/ Clear notifications when user opens app","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Also reset badge","        UIApplication.shared.applicationIconBadgeNumber = 0","        Pushwoosh.configure.sendBadges(0)","    }","","    func handleUserLogout() {","        \/\/ Clear notifications for privacy","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Unregister from push","        Pushwoosh.configure.unregisterForPushNotifications { _ in }","","        \/\/ Clear user identity","        Pushwoosh.configure.setUserId(\"\")","    }","","    func markAllAsRead() {","        \/\/ Clear from notification center","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Update backend","        APIClient.shared.markAllNotificationsRead { _ in }","","        \/\/ Clear badge","        Pushwoosh.configure.sendBadges(0)","    }","}"]}],"kind":"content"}],"abstract":[{"type":"text","text":"Clears all delivered notifications from the notification center."}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","metadata":{"modules":[{"name":"PushwooshCore"}],"symbolKind":"method","navigatorTitle":[{"text":"clearNotificationCenter","kind":"identifier"}],"role":"symbol","roleHeading":"Type Method","externalID":"c:objc(pl)PWConfiguration(cm)clearNotificationCenter","fragments":[{"text":"+ ","kind":"text"},{"text":"clearNotificationCenter","kind":"identifier"}],"title":"clearNotificationCenter"},"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","abstract":[],"fragments":[{"kind":"identifier","text":"PWConfiguration"}],"title":"PWConfiguration","kind":"symbol","role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"},