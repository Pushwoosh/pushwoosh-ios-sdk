{"sections":[],"abstract":[{"type":"text","text":"Clears all delivered notifications from the notification center."}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/clearNotificationCenter","interfaceLanguage":"occ"},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"kind":"text","text":") "},{"kind":"identifier","text":"clearNotificationCenter"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"Removes all notifications delivered by your app from the iOS Notification Center.","type":"text"},{"type":"text","text":" "},{"text":"This is commonly used when:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"User opens the app (clear notifications since they’re viewing content)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"User logs out (clear notifications for privacy)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Content is marked as read in-app"}]}]},{"content":[{"inlineContent":[{"text":"Performing a “mark all as read” action","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"Only removes notifications from your app; other apps’ notifications are unaffected.","type":"text"}]},{"level":2,"type":"heading","text":"Example","anchor":"Example"},{"inlineContent":[{"text":"Clear notifications on app activation and logout:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["class NotificationManager {","","    func applicationDidBecomeActive() {","        \/\/ Clear notifications when user opens app","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Also reset badge","        UIApplication.shared.applicationIconBadgeNumber = 0","        Pushwoosh.configure.sendBadges(0)","    }","","    func handleUserLogout() {","        \/\/ Clear notifications for privacy","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Unregister from push","        Pushwoosh.configure.unregisterForPushNotifications { _ in }","","        \/\/ Clear user identity","        Pushwoosh.configure.setUserId(\"\")","    }","","    func markAllAsRead() {","        \/\/ Clear from notification center","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Update backend","        APIClient.shared.markAllNotificationsRead { _ in }","","        \/\/ Clear badge","        Pushwoosh.configure.sendBadges(0)","    }","}"],"syntax":"swift"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/clearnotificationcenter"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"role":"symbol","modules":[{"name":"PushwooshCore"}],"symbolKind":"method","navigatorTitle":[{"text":"clearNotificationCenter","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)clearNotificationCenter","roleHeading":"Type Method","fragments":[{"text":"+ ","kind":"text"},{"text":"clearNotificationCenter","kind":"identifier"}],"title":"clearNotificationCenter"},"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","kind":"symbol","title":"PWConfiguration","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","abstract":[],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"},