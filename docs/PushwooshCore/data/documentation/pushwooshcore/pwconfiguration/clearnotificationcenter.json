{"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/clearnotificationcenter"]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/clearNotificationCenter"},"abstract":[{"text":"Clears all delivered notifications from the notification center.","type":"text"}],"sections":[],"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)clearNotificationCenter","navigatorTitle":[{"text":"clearNotificationCenter","kind":"identifier"}],"roleHeading":"Type Method","symbolKind":"method","fragments":[{"kind":"text","text":"+ "},{"text":"clearNotificationCenter","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"role":"symbol","title":"clearNotificationCenter"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"clearNotificationCenter","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Removes all notifications delivered by your app from the iOS Notification Center."},{"text":" ","type":"text"},{"type":"text","text":"This is commonly used when:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"User opens the app (clear notifications since they’re viewing content)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"User logs out (clear notifications for privacy)","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Content is marked as read in-app","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Performing a “mark all as read” action"}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"Only removes notifications from your app; other apps’ notifications are unaffected.","type":"text"}],"type":"paragraph"},{"type":"heading","anchor":"Example","level":2,"text":"Example"},{"type":"paragraph","inlineContent":[{"text":"Clear notifications on app activation and logout:","type":"text"}]},{"type":"codeListing","code":["class NotificationManager {","","    func applicationDidBecomeActive() {","        \/\/ Clear notifications when user opens app","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Also reset badge","        UIApplication.shared.applicationIconBadgeNumber = 0","        Pushwoosh.configure.sendBadges(0)","    }","","    func handleUserLogout() {","        \/\/ Clear notifications for privacy","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Unregister from push","        Pushwoosh.configure.unregisterForPushNotifications { _ in }","","        \/\/ Clear user identity","        Pushwoosh.configure.setUserId(\"\")","    }","","    func markAllAsRead() {","        \/\/ Clear from notification center","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Update backend","        APIClient.shared.markAllNotificationsRead { _ in }","","        \/\/ Clear badge","        Pushwoosh.configure.sendBadges(0)","    }","}"],"syntax":"swift"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","url":"\/documentation\/pushwooshcore","kind":"symbol","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"role":"collection"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/clearNotificationCenter":{"title":"clearNotificationCenter","type":"topic","navigatorTitle":[{"text":"clearNotificationCenter","kind":"identifier"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/clearnotificationcenter","kind":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"clearNotificationCenter","kind":"identifier"}],"abstract":[{"type":"text","text":"Clears all delivered notifications from the notification center."}],"role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/clearNotificationCenter"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","type":"topic","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol"}}}