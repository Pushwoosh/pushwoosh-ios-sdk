{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":") ","kind":"text"},{"text":"clearNotificationCenter","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}]},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Removes all notifications delivered by your app from the iOS Notification Center."},{"type":"text","text":" "},{"text":"This is commonly used when:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"User opens the app (clear notifications since they’re viewing content)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"User logs out (clear notifications for privacy)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Content is marked as read in-app"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Performing a “mark all as read” action","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Only removes notifications from your app; other apps’ notifications are unaffected."}]},{"level":2,"type":"heading","anchor":"Example","text":"Example"},{"type":"paragraph","inlineContent":[{"text":"Clear notifications on app activation and logout:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["class NotificationManager {","","    func applicationDidBecomeActive() {","        \/\/ Clear notifications when user opens app","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Also reset badge","        UIApplication.shared.applicationIconBadgeNumber = 0","        Pushwoosh.configure.sendBadges(0)","    }","","    func handleUserLogout() {","        \/\/ Clear notifications for privacy","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Unregister from push","        Pushwoosh.configure.unregisterForPushNotifications { _ in }","","        \/\/ Clear user identity","        Pushwoosh.configure.setUserId(\"\")","    }","","    func markAllAsRead() {","        \/\/ Clear from notification center","        Pushwoosh.configure.clearNotificationCenter()","","        \/\/ Update backend","        APIClient.shared.markAllNotificationsRead { _ in }","","        \/\/ Clear badge","        Pushwoosh.configure.sendBadges(0)","    }","}"]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/clearnotificationcenter"]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"abstract":[{"type":"text","text":"Clears all delivered notifications from the notification center."}],"metadata":{"modules":[{"name":"PushwooshCore"}],"symbolKind":"method","title":"clearNotificationCenter","roleHeading":"Type Method","navigatorTitle":[{"text":"clearNotificationCenter","kind":"identifier"}],"role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)clearNotificationCenter","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"clearNotificationCenter"}]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/clearNotificationCenter","interfaceLanguage":"occ"},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/clearNotificationCenter":{"kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/clearnotificationcenter","abstract":[{"text":"Clears all delivered notifications from the notification center.","type":"text"}],"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"clearNoti