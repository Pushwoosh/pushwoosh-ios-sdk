{"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)setReverseProxy:headers:","roleHeading":"Type Method","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setReverseProxy:headers:"}],"title":"setReverseProxy:headers:","role":"symbol","modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"kind":"identifier","text":"setReverseProxy:headers:"}]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setReverseProxy:headers:","interfaceLanguage":"occ"},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setreverseproxy:headers:"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"setReverseProxy:"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"NSString","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"url"},{"text":" ","kind":"text"},{"kind":"identifier","text":"headers:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:Q$objc(cs)NSDictionary","text":"NSDictionary<NSString *,NSString *>","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"headers"},{"text":";","kind":"text"}],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The full URL of your reverse proxy endpoint (e.g., “https:\/\/proxy.company.com\/pushwoosh”). Must not be nil or empty.","type":"text"}]}],"name":"url"},{"content":[{"inlineContent":[{"text":"Optional dictionary of custom HTTP headers. Pass nil if no custom headers are needed.","type":"text"}],"type":"paragraph"}],"name":"headers"}]},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Routes all Pushwoosh SDK network requests through your own proxy server."},{"type":"text","text":" "},{"type":"text","text":"This is useful for:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Enterprise security","type":"text"}],"type":"strong"},{"text":": Route traffic through corporate proxies","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Regional compliance","type":"text"}],"type":"strong"},{"type":"text","text":": Ensure data flows through specific regions"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Network monitoring"}]},{"type":"text","text":": Inspect and log SDK traffic"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Firewall restrictions"}],"type":"strong"},{"type":"text","text":": Work around corporate firewall rules"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The proxy must forward requests to the appropriate Pushwoosh API endpoints"},{"type":"text","text":" "},{"text":"while preserving all headers and request body content.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Settings are not persisted and must be set on every app start."},{"text":" ","type":"text"},{"type":"text","text":"URL must start with https:\/\/ or http:\/\/."},{"type":"text","text":" "},{"text":"Custom headers are only applied when reverse proxy is active.","type":"text"}]},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"type":"paragraph","inlineContent":[{"text":"Configure proxy for enterprise deployment:","type":"text"}]},{"code":["class NetworkConfiguration {","","    func configureForEnterprise() {","        guard let proxyURL = Configuration.shared.pushwooshProxyURL else {","            return","        }","","        Pushwoosh.configure.setReverseProxy(proxyURL, headers: nil)","","        Logger.info(\"Pushwoosh configured to use proxy: \\(proxyURL)\")","    }","","    func configureForRegion(_ region: Region) {","        switch region {","        case .eu:","            Pushwoosh.configure.setReverseProxy(","                \"https:\/\/eu-proxy.company.com\/pushwoosh\",","                headers: [\"X-Auth-Token\": \"your-token\"]","            )","        case .asia:","            Pushwoosh.configure.setReverseProxy(","                \"https:\/\/asia-proxy.company.com\/pushwoosh\",","                headers: nil","            )","        case .us:","            break \/\/ No proxy needed","        }","    }","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"kind":"symbol","sections":[],"abstract":[{"text":"Sets a reverse proxy URL and optional custom HTTP headers for all SDK network requests.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setReverseProxy:headers:":{"type":"topic","abstract":[{"text":"Sets a reverse proxy URL and optional custom HTTP headers for all SDK network requests.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setReverseProxy:headers:","navigatorTitle":[{"text":"setReverseProxy:headers:","kind":"identifier"}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setReverseProxy:headers:"}],"title":"setReverseProxy:headers:","role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setreverseproxy:headers:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","url":"\/documentation\/pushwooshcore","role":"collection","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","title":"PushwooshCore","kind":"symbol","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"kind":"symbol","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","type":"topic"}}}