{"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setreverseproxy:headers:"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setReverseProxy:"},{"kind":"text","text":"("},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"url"},{"text":" ","kind":"text"},{"kind":"identifier","text":"headers:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:Q$objc(cs)NSDictionary","text":"NSDictionary<NSString *,NSString *>","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"headers"},{"text":";","kind":"text"}],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The full URL of your reverse proxy endpoint (e.g., “https:\/\/proxy.company.com\/pushwoosh”). Must not be nil or empty.","type":"text"}]}],"name":"url"},{"content":[{"inlineContent":[{"type":"text","text":"Optional dictionary of custom HTTP headers. Pass nil if no custom headers are needed."}],"type":"paragraph"}],"name":"headers"}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"text":"Routes all Pushwoosh SDK network requests through your own proxy server.","type":"text"},{"text":" ","type":"text"},{"text":"This is useful for:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Enterprise security"}]},{"type":"text","text":": Route traffic through corporate proxies"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Regional compliance"}],"type":"strong"},{"type":"text","text":": Ensure data flows through specific regions"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Network monitoring","type":"text"}],"type":"strong"},{"text":": Inspect and log SDK traffic","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Firewall restrictions"}]},{"type":"text","text":": Work around corporate firewall rules"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"The proxy must forward requests to the appropriate Pushwoosh API endpoints"},{"type":"text","text":" "},{"type":"text","text":"while preserving all headers and request body content."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Settings are not persisted and must be set on every app start."},{"text":" ","type":"text"},{"text":"URL must start with https:\/\/ or http:\/\/.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Custom headers are only applied when reverse proxy is active."}]},{"anchor":"Example","type":"heading","text":"Example","level":2},{"inlineContent":[{"type":"text","text":"Configure proxy for enterprise deployment:"}],"type":"paragraph"},{"code":["class NetworkConfiguration {","","    func configureForEnterprise() {","        guard let proxyURL = Configuration.shared.pushwooshProxyURL else {","            return","        }","","        Pushwoosh.configure.setReverseProxy(proxyURL, headers: nil)","","        Logger.info(\"Pushwoosh configured to use proxy: \\(proxyURL)\")","    }","","    func configureForRegion(_ region: Region) {","        switch region {","        case .eu:","            Pushwoosh.configure.setReverseProxy(","                \"https:\/\/eu-proxy.company.com\/pushwoosh\",","                headers: [\"X-Auth-Token\": \"your-token\"]","            )","        case .asia:","            Pushwoosh.configure.setReverseProxy(","                \"https:\/\/asia-proxy.company.com\/pushwoosh\",","                headers: nil","            )","        case .us:","            break \/\/ No proxy needed","        }","    }","}"],"syntax":"swift","type":"codeListing"}]}],"metadata":{"navigatorTitle":[{"text":"setReverseProxy:headers:","kind":"identifier"}],"symbolKind":"method","modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)setReverseProxy:headers:","title":"setReverseProxy:headers:","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setReverseProxy:headers:"}],"roleHeading":"Type Method","role":"symbol"},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setReverseProxy:headers:"},"abstract":[{"type":"text","text":"Sets a reverse proxy URL and optional custom HTTP headers for all SDK network requests."}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore","type":"topic","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","kind":"symbol","type":"topic","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"abstract":[],"role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setReverseProxy:headers:":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setReverseProxy:headers:","kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setreverseproxy:headers:","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setReverseProxy:headers:"}],"abstract":[{"type":"text","text":"Sets a reverse proxy URL and optional custom HTTP headers for all SDK network requests."}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"setReverseProxy:headers:"}],"title":"setReverseProxy:headers:"}}}