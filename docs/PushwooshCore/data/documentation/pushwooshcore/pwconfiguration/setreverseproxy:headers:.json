{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setReverseProxy:headers:","interfaceLanguage":"occ"},"abstract":[{"type":"text","text":"Sets a reverse proxy URL and optional custom HTTP headers for all SDK network requests."}],"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"text":"setReverseProxy:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier","text":"NSString"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"url"},{"kind":"text","text":" "},{"text":"headers:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSDictionary<NSString *,NSString *>","kind":"typeIdentifier","preciseIdentifier":"c:Q$objc(cs)NSDictionary"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"headers"},{"text":";","kind":"text"}],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"name":"url","content":[{"inlineContent":[{"text":"The full URL of your reverse proxy endpoint (e.g., “https:\/\/proxy.company.com\/pushwoosh”). Must not be nil or empty.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Optional dictionary of custom HTTP headers. Pass nil if no custom headers are needed."}]}],"name":"headers"}]},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Routes all Pushwoosh SDK network requests through your own proxy server.","type":"text"},{"text":" ","type":"text"},{"text":"This is useful for:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Enterprise security","type":"text"}],"type":"strong"},{"type":"text","text":": Route traffic through corporate proxies"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Regional compliance"}]},{"type":"text","text":": Ensure data flows through specific regions"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Network monitoring"}]},{"type":"text","text":": Inspect and log SDK traffic"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Firewall restrictions","type":"text"}],"type":"strong"},{"type":"text","text":": Work around corporate firewall rules"}]}]}]},{"inlineContent":[{"type":"text","text":"The proxy must forward requests to the appropriate Pushwoosh API endpoints"},{"type":"text","text":" "},{"type":"text","text":"while preserving all headers and request body content."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Settings are not persisted and must be set on every app start.","type":"text"},{"type":"text","text":" "},{"text":"URL must start with https:\/\/ or http:\/\/.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Custom headers are only applied when reverse proxy is active."}]},{"level":2,"anchor":"Example","text":"Example","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Configure proxy for enterprise deployment:"}]},{"code":["class NetworkConfiguration {","","    func configureForEnterprise() {","        guard let proxyURL = Configuration.shared.pushwooshProxyURL else {","            return","        }","","        Pushwoosh.configure.setReverseProxy(proxyURL, headers: nil)","","        Logger.info(\"Pushwoosh configured to use proxy: \\(proxyURL)\")","    }","","    func configureForRegion(_ region: Region) {","        switch region {","        case .eu:","            Pushwoosh.configure.setReverseProxy(","                \"https:\/\/eu-proxy.company.com\/pushwoosh\",","                headers: [\"X-Auth-Token\": \"your-token\"]","            )","        case .asia:","            Pushwoosh.configure.setReverseProxy(","                \"https:\/\/asia-proxy.company.com\/pushwoosh\",","                headers: nil","            )","        case .us:","            break \/\/ No proxy needed","        }","    }","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"roleHeading":"Type Method","symbolKind":"method","modules":[{"name":"PushwooshCore"}],"title":"setReverseProxy:headers:","externalID":"c:objc(pl)PWConfiguration(cm)setReverseProxy:headers:","role":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"setReverseProxy:headers:","kind":"identifier"}],"navigatorTitle":[{"text":"setReverseProxy:headers:","kind":"identifier"}]},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setreverseproxy:headers:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"fragments":[{"text":"PWConfiguration","kind":"identifier"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","role":"symbol","kind":"symbol","type":"topic","title":"PWConfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setReverseProxy:headers:":{"navigatorTitle":[{"kind":"identifier","text":"setReverseProxy:headers:"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setReverseProxy:headers:","abstract":[{"type":"text","text":"Sets a reverse proxy URL and optional custom HTTP headers for all SDK network requests."}],"kind":"symbol","url":"\/documenta