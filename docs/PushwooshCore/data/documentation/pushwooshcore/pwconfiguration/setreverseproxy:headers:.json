{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setReverseProxy:headers:","interfaceLanguage":"occ"},"kind":"symbol","metadata":{"fragments":[{"text":"+ ","kind":"text"},{"text":"setReverseProxy:headers:","kind":"identifier"}],"symbolKind":"method","roleHeading":"Type Method","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"setReverseProxy:headers:"}],"title":"setReverseProxy:headers:","modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)setReverseProxy:headers:"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setreverseproxy:headers:"]}],"abstract":[{"type":"text","text":"Sets a reverse proxy URL and optional custom HTTP headers for all SDK network requests."}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"text":"setReverseProxy:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString","text":"NSString"},{"text":" *) ","kind":"text"},{"text":"url","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"headers:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSDictionary<NSString *,NSString *>","preciseIdentifier":"c:Q$objc(cs)NSDictionary","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"headers"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"parameters":[{"name":"url","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The full URL of your reverse proxy endpoint (e.g., “https:\/\/proxy.company.com\/pushwoosh”). Must not be nil or empty."}]}]},{"name":"headers","content":[{"inlineContent":[{"type":"text","text":"Optional dictionary of custom HTTP headers. Pass nil if no custom headers are needed."}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Routes all Pushwoosh SDK network requests through your own proxy server.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This is useful for:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Enterprise security","type":"text"}]},{"text":": Route traffic through corporate proxies","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Regional compliance","type":"text"}]},{"text":": Ensure data flows through specific regions","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Network monitoring","type":"text"}],"type":"strong"},{"text":": Inspect and log SDK traffic","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Firewall restrictions","type":"text"}]},{"type":"text","text":": Work around corporate firewall rules"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"The proxy must forward requests to the appropriate Pushwoosh API endpoints","type":"text"},{"type":"text","text":" "},{"text":"while preserving all headers and request body content.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Settings are not persisted and must be set on every app start."},{"type":"text","text":" "},{"text":"URL must start with https:\/\/ or http:\/\/.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Custom headers are only applied when reverse proxy is active."}]},{"type":"heading","text":"Example","level":2,"anchor":"Example"},{"inlineContent":[{"type":"text","text":"Configure proxy for enterprise deployment:"}],"type":"paragraph"},{"code":["class NetworkConfiguration {","","    func configureForEnterprise() {","        guard let proxyURL = Configuration.shared.pushwooshProxyURL else {","            return","        }","","        Pushwoosh.configure.setReverseProxy(proxyURL, headers: nil)","","        Logger.info(\"Pushwoosh configured to use proxy: \\(proxyURL)\")","    }","","    func configureForRegion(_ region: Region) {","        switch region {","        case .eu:","            Pushwoosh.configure.setReverseProxy(","                \"https:\/\/eu-proxy.company.com\/pushwoosh\",","                headers: [\"X-Auth-Token\": \"your-token\"]","            )","        case .asia:","            Pushwoosh.configure.setReverseProxy(","                \"https:\/\/asia-proxy.company.com\/pushwoosh\",","                headers: nil","            )","        case .us:","            break \/\/ No proxy needed","        }","    }","}"],"syntax":"swift","type":"codeListing"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setReverseProxy:headers:":{"navigatorTitle":[{"text":"setReverseProxy:headers:","kind":"identifier"}],"type":"topic","role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setReverseProxy:headers:","title":"setReverseProxy:headers:","fragments":[{"text":"+ ","kind":"text"},{"text":"setReverseProxy:headers:","kind":"identifier"}],"abstract":[{"type":"text","text":"Sets a reverse proxy URL and optional custom HTTP headers for all SDK network requests."}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setreverseproxy:headers:","kind":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","role":"symbol","kind":"symbol","title":"PWConfiguration","type":"topic","fragments":[{"text":"PWConfiguration","kind":"identifier"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","title":"PushwooshCore","kind":"symbol","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","url":"\/documentation\/pushwooshcore","role":"collection"}}}