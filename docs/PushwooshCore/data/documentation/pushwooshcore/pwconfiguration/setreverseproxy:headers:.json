:"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Regional compliance"}]},{"text":": Ensure data flows through specific regions","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Network monitoring"}]},{"type":"text","text":": Inspect and log SDK traffic"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Firewall restrictions","type":"text"}]},{"type":"text","text":": Work around corporate firewall rules"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The proxy must forward requests to the appropriate Pushwoosh API endpoints"},{"text":" ","type":"text"},{"text":"while preserving all headers and request body content.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Settings are not persisted and must be set on every app start."},{"type":"text","text":" "},{"type":"text","text":"URL must start with https:\/\/ or http:\/\/."},{"text":" ","type":"text"},{"text":"Custom headers are only applied when reverse proxy is active.","type":"text"}]},{"type":"heading","text":"Example","level":2,"anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Configure proxy for enterprise deployment:"}]},{"syntax":"swift","type":"codeListing","code":["class NetworkConfiguration {","","    func configureForEnterprise() {","        guard let proxyURL = Configuration.shared.pushwooshProxyURL else {","            return","        }","","        Pushwoosh.configure.setReverseProxy(proxyURL, headers: nil)","","        Logger.info(\"Pushwoosh configured to use proxy: \\(proxyURL)\")","    }","","    func configureForRegion(_ region: Region) {","        switch region {","        case .eu:","            Pushwoosh.configure.setReverseProxy(","                \"https:\/\/eu-proxy.company.com\/pushwoosh\",","                headers: [\"X-Auth-Token\": \"your-token\"]","            )","        case .asia:","            Pushwoosh.configure.setReverseProxy(","                \"https:\/\/asia-proxy.company.com\/pushwoosh\",","                headers: nil","            )","        case .us:","            break \/\/ No proxy needed","        }","    }","}"]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setreverseproxy:headers:"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}],"symbolKind":"method","title":"setReverseProxy:headers:","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setReverseProxy:headers:"}],"externalID":"c:objc(pl)PWConfiguration(cm)setReverseProxy:headers:","navigatorTitle":[{"text":"setReverseProxy:headers:","kind":"identifier"}],"role":"symbol"},"sections":[],"abstract":[{"type":"text","text":"Sets a reverse proxy URL and optional custom HTTP headers for all SDK network requests."}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setReverseProxy:headers:","interfaceLanguage":"occ"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","kind":"symbol","title":"PushwooshCore","type":"topic","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","role":"collection"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"kind":"symbol","type":"topic","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"abstract":[],"role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","title":"PWConfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setReverseProxy:headers:":{"type":"topic","ti