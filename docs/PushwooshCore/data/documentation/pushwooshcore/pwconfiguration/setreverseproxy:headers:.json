{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setReverseProxy:headers:"},"sections":[],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setreverseproxy:headers:"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"title":"setReverseProxy:headers:","role":"symbol","modules":[{"name":"PushwooshCore"}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setReverseProxy:headers:"}],"roleHeading":"Type Method","navigatorTitle":[{"kind":"identifier","text":"setReverseProxy:headers:"}],"symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)setReverseProxy:headers:"},"abstract":[{"type":"text","text":"Sets a reverse proxy URL and optional custom HTTP headers for all SDK network requests."}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"text":") ","kind":"text"},{"text":"setReverseProxy:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"url"},{"text":" ","kind":"text"},{"kind":"identifier","text":"headers:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:Q$objc(cs)NSDictionary","text":"NSDictionary<NSString *,NSString *>"},{"kind":"text","text":" *) "},{"text":"headers","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"parameters":[{"name":"url","content":[{"type":"paragraph","inlineContent":[{"text":"The full URL of your reverse proxy endpoint (e.g., “https:\/\/proxy.company.com\/pushwoosh”). Must not be nil or empty.","type":"text"}]}]},{"name":"headers","content":[{"type":"paragraph","inlineContent":[{"text":"Optional dictionary of custom HTTP headers. Pass nil if no custom headers are needed.","type":"text"}]}]}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"Routes all Pushwoosh SDK network requests through your own proxy server."},{"type":"text","text":" "},{"text":"This is useful for:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Enterprise security"}]},{"type":"text","text":": Route traffic through corporate proxies"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Regional compliance","type":"text"}]},{"type":"text","text":": Ensure data flows through specific regions"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Network monitoring","type":"text"}]},{"type":"text","text":": Inspect and log SDK traffic"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Firewall restrictions","type":"text"}],"type":"strong"},{"text":": Work around corporate firewall rules","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The proxy must forward requests to the appropriate Pushwoosh API endpoints"},{"type":"text","text":" "},{"text":"while preserving all headers and request body content.","type":"text"}]},{"inlineContent":[{"text":"Settings are not persisted and must be set on every app start.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"URL must start with https:\/\/ or http:\/\/."},{"type":"text","text":" "},{"type":"text","text":"Custom headers are only applied when reverse proxy is active."}],"type":"paragraph"},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Configure proxy for enterprise deployment:"}]},{"type":"codeListing","syntax":"swift","code":["class NetworkConfiguration {","","    func configureForEnterprise() {","        guard let proxyURL = Configuration.shared.pushwooshProxyURL else {","            return","        }","","        Pushwoosh.configure.setReverseProxy(proxyURL, headers: nil)","","        Logger.info(\"Pushwoosh configured to use proxy: \\(proxyURL)\")","    }","","    func configureForRegion(_ region: Region) {","        switch region {","        case .eu:","            Pushwoosh.configure.setReverseProxy(","                \"https:\/\/eu-proxy.company.com\/pushwoosh\",","                headers: [\"X-Auth-Token\": \"your-token\"]","            )","        case .asia:","            Pushwoosh.configure.setReverseProxy(","                \"https:\/\/asia-proxy.company.com\/pushwoosh\",","                headers: nil","            )","        case .us:","            break \/\/ No proxy needed","        }","    }","}"]}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","title":"PushwooshCore","role":"collection","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"kind":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","abstract":[],"title":"PWConfiguration","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setReverseProxy:headers:":{"type":"topic","ur