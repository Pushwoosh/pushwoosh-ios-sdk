{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setReverseProxy:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSString","text":"NSString","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"url"},{"text":" ","kind":"text"},{"kind":"identifier","text":"headers:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:Q$objc(cs)NSDictionary","kind":"typeIdentifier","text":"NSDictionary<NSString *,NSString *>"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"headers"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"parameters":[{"name":"url","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The full URL of your reverse proxy endpoint (e.g., “https:\/\/proxy.company.com\/pushwoosh”). Must not be nil or empty."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Optional dictionary of custom HTTP headers. Pass nil if no custom headers are needed."}],"type":"paragraph"}],"name":"headers"}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Routes all Pushwoosh SDK network requests through your own proxy server."},{"type":"text","text":" "},{"text":"This is useful for:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Enterprise security","type":"text"}]},{"type":"text","text":": Route traffic through corporate proxies"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Regional compliance"}]},{"type":"text","text":": Ensure data flows through specific regions"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Network monitoring","type":"text"}]},{"type":"text","text":": Inspect and log SDK traffic"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Firewall restrictions","type":"text"}],"type":"strong"},{"type":"text","text":": Work around corporate firewall rules"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The proxy must forward requests to the appropriate Pushwoosh API endpoints"},{"type":"text","text":" "},{"type":"text","text":"while preserving all headers and request body content."}]},{"inlineContent":[{"text":"Settings are not persisted and must be set on every app start.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"URL must start with https:\/\/ or http:\/\/."},{"type":"text","text":" "},{"type":"text","text":"Custom headers are only applied when reverse proxy is active."}],"type":"paragraph"},{"anchor":"Example","text":"Example","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Configure proxy for enterprise deployment:"}],"type":"paragraph"},{"syntax":"swift","code":["class NetworkConfiguration {","","    func configureForEnterprise() {","        guard let proxyURL = Configuration.shared.pushwooshProxyURL else {","            return","        }","","        Pushwoosh.configure.setReverseProxy(proxyURL, headers: nil)","","        Logger.info(\"Pushwoosh configured to use proxy: \\(proxyURL)\")","    }","","    func configureForRegion(_ region: Region) {","        switch region {","        case .eu:","            Pushwoosh.configure.setReverseProxy(","                \"https:\/\/eu-proxy.company.com\/pushwoosh\",","                headers: [\"X-Auth-Token\": \"your-token\"]","            )","        case .asia:","            Pushwoosh.configure.setReverseProxy(","                \"https:\/\/asia-proxy.company.com\/pushwoosh\",","                headers: nil","            )","        case .us:","            break \/\/ No proxy needed","        }","    }","}"],"type":"codeListing"}]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setReverseProxy:headers:","interfaceLanguage":"occ"},"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"symbolKind":"method","modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"text":"setReverseProxy:headers:","kind":"identifier"}],"role":"symbol","roleHeading":"Type Method","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setReverseProxy:headers:"}],"title":"setReverseProxy:headers:","externalID":"c:objc(pl)PWConfiguration(cm)setReverseProxy:headers:"},"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"Sets a reverse proxy URL and optional custom HTTP headers for all SDK network requests."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setreverseproxy:headers:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"title":"PushwooshCore","kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setReverseProxy:headers:":{"abstract":[{"type":"text","text":"Sets a reverse proxy URL and optional custom HTTP headers for all SDK network requests."}],"fragments":[{"kind":"text","text":"+ "},{"text":"setReverseProxy:headers:","kind":"identifier"}],"kind":"symbol","title":"setReverseProxy:headers:","type":"topic","navigatorTitle":[{"text":"setReverseProxy:headers:","kind":"identifier"}],"role":"symbol","url":"\/documentatio