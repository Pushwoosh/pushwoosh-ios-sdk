{"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setreverseproxy:headers:"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setReverseProxy:headers:"},"abstract":[{"text":"Sets a reverse proxy URL and optional custom HTTP headers for all SDK network requests.","type":"text"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"setReverseProxy:","kind":"identifier"},{"kind":"text","text":"("},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"text":"url","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"headers:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSDictionary<NSString *,NSString *>","kind":"typeIdentifier","preciseIdentifier":"c:Q$objc(cs)NSDictionary"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"headers"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"url","content":[{"type":"paragraph","inlineContent":[{"text":"The full URL of your reverse proxy endpoint (e.g., “https:\/\/proxy.company.com\/pushwoosh”). Must not be nil or empty.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Optional dictionary of custom HTTP headers. Pass nil if no custom headers are needed."}]}],"name":"headers"}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Routes all Pushwoosh SDK network requests through your own proxy server."},{"text":" ","type":"text"},{"type":"text","text":"This is useful for:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Enterprise security"}]},{"text":": Route traffic through corporate proxies","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Regional compliance","type":"text"}],"type":"strong"},{"text":": Ensure data flows through specific regions","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Network monitoring"}],"type":"strong"},{"type":"text","text":": Inspect and log SDK traffic"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Firewall restrictions","type":"text"}],"type":"strong"},{"type":"text","text":": Work around corporate firewall rules"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"The proxy must forward requests to the appropriate Pushwoosh API endpoints","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"while preserving all headers and request body content."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Settings are not persisted and must be set on every app start."},{"text":" ","type":"text"},{"type":"text","text":"URL must start with https:\/\/ or http:\/\/."},{"type":"text","text":" "},{"text":"Custom headers are only applied when reverse proxy is active.","type":"text"}]},{"text":"Example","anchor":"Example","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Configure proxy for enterprise deployment:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class NetworkConfiguration {","","    func configureForEnterprise() {","        guard let proxyURL = Configuration.shared.pushwooshProxyURL else {","            return","        }","","        Pushwoosh.configure.setReverseProxy(proxyURL, headers: nil)","","        Logger.info(\"Pushwoosh configured to use proxy: \\(proxyURL)\")","    }","","    func configureForRegion(_ region: Region) {","        switch region {","        case .eu:","            Pushwoosh.configure.setReverseProxy(","                \"https:\/\/eu-proxy.company.com\/pushwoosh\",","                headers: [\"X-Auth-Token\": \"your-token\"]","            )","        case .asia:","            Pushwoosh.configure.setReverseProxy(","                \"https:\/\/asia-proxy.company.com\/pushwoosh\",","                headers: nil","            )","        case .us:","            break \/\/ No proxy needed","        }","    }","}"]}]}],"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)setReverseProxy:headers:","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setReverseProxy:headers:"}],"navigatorTitle":[{"kind":"identifier","text":"setReverseProxy:headers:"}],"roleHeading":"Type Method","title":"setReverseProxy:headers:","modules":[{"name":"PushwooshCore"}],"role":"symbol","symbolKind":"method"},"sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setReverseProxy:headers:":{"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setReverseProxy:headers:"}],"title":"setReverseProxy:headers:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setreverseproxy:headers:","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setReverseProxy:headers:","kind":"symbol","abstract":[{"text":"Sets a reverse proxy URL and optional custom HTTP headers for all SDK network requests.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"setReverseProxy:headers:"}],"role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","title":"PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","kind":"symbol","abstract":[],"role":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","type":"topic","kind":"symbol","url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","role":"collection","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}]}}}