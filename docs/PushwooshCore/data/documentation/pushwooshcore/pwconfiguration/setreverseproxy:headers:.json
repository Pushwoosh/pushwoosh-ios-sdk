{"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setreverseproxy:headers:"]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"setReverseProxy:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSString","text":"NSString","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"url"},{"text":" ","kind":"text"},{"kind":"identifier","text":"headers:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:Q$objc(cs)NSDictionary","text":"NSDictionary<NSString *,NSString *>","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"text":"headers","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"name":"url","content":[{"inlineContent":[{"type":"text","text":"The full URL of your reverse proxy endpoint (e.g., “https:\/\/proxy.company.com\/pushwoosh”). Must not be nil or empty."}],"type":"paragraph"}]},{"name":"headers","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Optional dictionary of custom HTTP headers. Pass nil if no custom headers are needed."}]}]}]},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Routes all Pushwoosh SDK network requests through your own proxy server."},{"type":"text","text":" "},{"text":"This is useful for:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Enterprise security"}]},{"text":": Route traffic through corporate proxies","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Regional compliance","type":"text"}]},{"type":"text","text":": Ensure data flows through specific regions"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Network monitoring","type":"text"}]},{"text":": Inspect and log SDK traffic","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Firewall restrictions"}]},{"type":"text","text":": Work around corporate firewall rules"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"The proxy must forward requests to the appropriate Pushwoosh API endpoints","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"while preserving all headers and request body content."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Settings are not persisted and must be set on every app start.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"URL must start with https:\/\/ or http:\/\/."},{"text":" ","type":"text"},{"text":"Custom headers are only applied when reverse proxy is active.","type":"text"}]},{"text":"Example","anchor":"Example","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Configure proxy for enterprise deployment:"}],"type":"paragraph"},{"type":"codeListing","code":["class NetworkConfiguration {","","    func configureForEnterprise() {","        guard let proxyURL = Configuration.shared.pushwooshProxyURL else {","            return","        }","","        Pushwoosh.configure.setReverseProxy(proxyURL, headers: nil)","","        Logger.info(\"Pushwoosh configured to use proxy: \\(proxyURL)\")","    }","","    func configureForRegion(_ region: Region) {","        switch region {","        case .eu:","            Pushwoosh.configure.setReverseProxy(","                \"https:\/\/eu-proxy.company.com\/pushwoosh\",","                headers: [\"X-Auth-Token\": \"your-token\"]","            )","        case .asia:","            Pushwoosh.configure.setReverseProxy(","                \"https:\/\/asia-proxy.company.com\/pushwoosh\",","                headers: nil","            )","        case .us:","            break \/\/ No proxy needed","        }","    }","}"],"syntax":"swift"}],"kind":"content"}],"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)setReverseProxy:headers:","navigatorTitle":[{"kind":"identifier","text":"setReverseProxy:headers:"}],"roleHeading":"Type Method","symbolKind":"method","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setReverseProxy:headers:"}],"modules":[{"name":"PushwooshCore"}],"role":"symbol","title":"setReverseProxy:headers:"},"kind":"symbol","abstract":[{"text":"Sets a reverse proxy URL and optional custom HTTP headers for all SDK network requests.","type":"text"}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setReverseProxy:headers:","interfaceLanguage":"occ"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setReverseProxy:headers:":{"title":"setReverseProxy:headers:","fragments":[{"text":"+ ","kind":"text"},{"text":"setReverseProxy:headers:","kind":"identifier"}],"role":"symbol","type":"topic","navigatorTitle":[{"text":"setReverseProxy:headers:","kind":"identifier"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setReverseProxy:headers:","abstract":[{"type":"text","text":"Sets a reverse proxy URL and optional custom HTTP headers for all SDK network requests."}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setreverseproxy:headers:","kind":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/