{"metadata":{"modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)setUserId:","title":"setUserId:","navigatorTitle":[{"text":"setUserId:","kind":"identifier"}],"role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setUserId:"}]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUserId:","interfaceLanguage":"occ"},"abstract":[{"text":"Sets a custom user identifier for the current device.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"kind":"text","text":") "},{"text":"setUserId:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"NSString","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"text":"userId","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The custom user identifier (e.g., database ID, UUID)","type":"text"}]}],"name":"userId"}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Associates a unique user ID with the device to:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Track users across multiple devices"}]}]},{"content":[{"inlineContent":[{"text":"Enable user-based targeting in campaigns","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Link push engagement to user accounts in your analytics"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Support user migration between devices"}]}]}]},{"anchor":"Example","level":2,"type":"heading","text":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Set user ID after successful login:"}]},{"type":"codeListing","syntax":"swift","code":["class AuthenticationService {","","    func handleSuccessfulLogin(user: User) {","        \/\/ Set user ID for cross-device tracking","        Pushwoosh.configure.setUserId(user.id)","","        \/\/ Set email if available","        if let email = user.email {","            Pushwoosh.configure.setEmail(email)","        }","","        \/\/ Update user profile tags","        Pushwoosh.configure.setTags([","            \"logged_in\": true,","            \"login_date\": Date(),","            \"login_count\": incrementLoginCount(),","            \"account_type\": user.accountType.rawValue,","            \"subscription_status\": user.subscription?.status.rawValue ?? \"none\"","        ])","","        \/\/ Sync with analytics platforms","        Analytics.identify(user.id, traits: [","            \"email\": user.email ?? \"\",","            \"pushwoosh_hwid\": Pushwoosh.configure.getHWID()","        ])","","        Logger.info(\"User logged in: \\(user.id)\")","    }","","    func handleAccountDeletion() {","        \/\/ Clear user identity","        Pushwoosh.configure.setUserId(\"\")","","        \/\/ Clear all user data tags","        Pushwoosh.configure.setTags([","            \"logged_in\": false,","            \"user_id\": NSNull(),","            \"email\": NSNull(),","            \"account_deleted\": true,","            \"deletion_date\": Date()","        ])","","        \/\/ Unregister from push","        Pushwoosh.configure.unregisterForPushNotifications { _ in }","    }","}"]}]}],"sections":[],"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setuserid:"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore",