{"sections":[],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUserId:"},"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","abstract":[{"text":"Sets a custom user identifier for the current device.","type":"text"}],"metadata":{"fragments":[{"kind":"text","text":"+ "},{"text":"setUserId:","kind":"identifier"}],"title":"setUserId:","symbolKind":"method","navigatorTitle":[{"text":"setUserId:","kind":"identifier"}],"role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)setUserId:","roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}]},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"text":"setUserId:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSString","preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"userId"},{"kind":"text","text":";"}],"languages":["occ"]}],"kind":"declarations"},{"parameters":[{"content":[{"inlineContent":[{"text":"The custom user identifier (e.g., database ID, UUID)","type":"text"}],"type":"paragraph"}],"name":"userId"}],"kind":"parameters"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"Associates a unique user ID with the device to:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Track users across multiple devices","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Enable user-based targeting in campaigns"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Link push engagement to user accounts in your analytics"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Support user migration between devices","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Example","level":2,"type":"heading","text":"Example"},{"inlineContent":[{"type":"text","text":"Set user ID after successful login:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class AuthenticationService {","","    func handleSuccessfulLogin(user: User) {","        \/\/ Set user ID for cross-device tracking","        Pushwoosh.configure.setUserId(user.id)","","        \/\/ Set email if available","        if let email = user.email {","            Pushwoosh.configure.setEmail(email)","        }","","        \/\/ Update user profile tags","        Pushwoosh.configure.setTags([","            \"logged_in\": true,","            \"login_date\": Date(),","            \"login_count\": incrementLoginCount(),","            \"account_type\": user.accountType.rawValue,","            \"subscription_status\": user.subscription?.status.rawValue ?? \"none\"","        ])","","        \/\/ Sync with analytics platforms","        Analytics.identify(user.id, traits: [","            \"email\": user.email ?? \"\",","            \"pushwoosh_hwid\": Pushwoosh.configure.getHWID()","        ])","","        Logger.info(\"User logged in: \\(user.id)\")","    }","","    func handleAccountDeletion() {","        \/\/ Clear user identity","        Pushwoosh.configure.setUserId(\"\")","","        \/\/ Clear all user data tags","        Pushwoosh.configure.setTags([","            \"logged_in\": false,","            \"user_id\": NSNull(),","            \"email\": NSNull(),","            \"account_deleted\": true,","            \"deletion_date\": Date()","        ])","","        \/\/ Unregister from push","        Pushwoosh.configure.unregisterForPushNotifications { _ in }","    }","}"]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setuserid:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setUserId:":{"type":"topic","abstract":[{"type":"text","text":"Sets a custom user identifier for the current device."}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setUserId:"}],"navigatorTitle":[{"kind":"identifier","text":"setUserId:"}],"title":"setUserId:","kind":"symbol","role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setuserid:","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUserId:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","abstract":[],"fragments":[{"kind":"identifier","text":"PWConfiguration"}],"title":"PWConfiguration","kind":"symbol","role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","url":"\/documentation\/pushwooshcore","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"role":"collection"}}}