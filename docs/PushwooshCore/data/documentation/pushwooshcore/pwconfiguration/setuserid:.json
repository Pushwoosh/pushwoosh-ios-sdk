{"abstract":[{"text":"Sets a custom user identifier for the current device.","type":"text"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"title":"setUserId:","role":"symbol","symbolKind":"method","modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","navigatorTitle":[{"kind":"identifier","text":"setUserId:"}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setUserId:"}],"externalID":"c:objc(pl)PWConfiguration(cm)setUserId:"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setuserid:"]}],"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setUserId:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier","text":"NSString"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"userId"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The custom user identifier (e.g., database ID, UUID)"}],"type":"paragraph"}],"name":"userId"}],"kind":"parameters"},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"Associates a unique user ID with the device to:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Track users across multiple devices"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Enable user-based targeting in campaigns"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Link push engagement to user accounts in your analytics"}]}]},{"content":[{"inlineContent":[{"text":"Support user migration between devices","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Example","type":"heading","anchor":"Example","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Set user ID after successful login:"}]},{"syntax":"swift","type":"codeListing","code":["class AuthenticationService {","","    func handleSuccessfulLogin(user: User) {","        \/\/ Set user ID for cross-device tracking","        Pushwoosh.configure.setUserId(user.id)","","        \/\/ Set email if available","        if let email = user.email {","            Pushwoosh.configure.setEmail(email)","        }","","        \/\/ Update user profile tags","        Pushwoosh.configure.setTags([","            \"logged_in\": true,","            \"login_date\": Date(),","            \"login_count\": incrementLoginCount(),","            \"account_type\": user.accountType.rawValue,","            \"subscription_status\": user.subscription?.status.rawValue ?? \"none\"","        ])","","        \/\/ Sync with analytics platforms","        Analytics.identify(user.id, traits: [","            \"email\": user.email ?? \"\",","            \"pushwoosh_hwid\": Pushwoosh.configure.getHWID()","        ])","","        Logger.info(\"User logged in: \\(user.id)\")","    }","","    func handleAccountDeletion() {","        \/\/ Clear user identity","        Pushwoosh.configure.setUserId(\"\")","","        \/\/ Clear all user data tags","        Pushwoosh.configure.setTags([","            \"logged_in\": false,","            \"user_id\": NSNull(),","            \"email\": NSNull(),","            \"account_deleted\": true,","            \"deletion_date\": Date()","        ])","","        \/\/ Unregister from push","        Pushwoosh.configure.unregisterForPushNotifications { _ in }","    }","}"]}],"kind":"content"}],"sections":[],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUserId:"},"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setUserId:":{"title":"setUserId:","role":"symbol","abstract":[{"type":"text","text":"Sets a custom user identifier for the current device."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUserId:","type":"topic","kind":"symbol","navigatorTitle":[{"text":"setUserId:","kind":"identifier"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setuserid:","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setUserId:"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","kind":"symbol","type":"topic","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"abstract":[],"role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore","type":"topic","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore"}}}