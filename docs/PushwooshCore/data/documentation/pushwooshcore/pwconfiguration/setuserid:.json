{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUserId:","interfaceLanguage":"occ"},"metadata":{"modules":[{"name":"PushwooshCore"}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setUserId:"}],"externalID":"c:objc(pl)PWConfiguration(cm)setUserId:","title":"setUserId:","role":"symbol","navigatorTitle":[{"text":"setUserId:","kind":"identifier"}],"roleHeading":"Type Method","symbolKind":"method"},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setuserid:"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setUserId:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString","text":"NSString"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"userId"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"parameters":[{"name":"userId","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The custom user identifier (e.g., database ID, UUID)"}]}]}],"kind":"parameters"},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Associates a unique user ID with the device to:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Track users across multiple devices"}]}]},{"content":[{"inlineContent":[{"text":"Enable user-based targeting in campaigns","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Link push engagement to user accounts in your analytics"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Support user migration between devices"}]}]}]},{"anchor":"Example","text":"Example","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Set user ID after successful login:"}],"type":"paragraph"},{"code":["class AuthenticationService {","","    func handleSuccessfulLogin(user: User) {","        \/\/ Set user ID for cross-device tracking","        Pushwoosh.configure.setUserId(user.id)","","        \/\/ Set email if available","        if let email = user.email {","            Pushwoosh.configure.setEmail(email)","        }","","        \/\/ Update user profile tags","        Pushwoosh.configure.setTags([","            \"logged_in\": true,","            \"login_date\": Date(),","            \"login_count\": incrementLoginCount(),","            \"account_type\": user.accountType.rawValue,","            \"subscription_status\": user.subscription?.status.rawValue ?? \"none\"","        ])","","        \/\/ Sync with analytics platforms","        Analytics.identify(user.id, traits: [","            \"email\": user.email ?? \"\",","            \"pushwoosh_hwid\": Pushwoosh.configure.getHWID()","        ])","","        Logger.info(\"User logged in: \\(user.id)\")","    }","","    func handleAccountDeletion() {","        \/\/ Clear user identity","        Pushwoosh.configure.setUserId(\"\")","","        \/\/ Clear all user data tags","        Pushwoosh.configure.setTags([","            \"logged_in\": false,","            \"user_id\": NSNull(),","            \"email\": NSNull(),","            \"account_deleted\": true,","            \"deletion_date\": Date()","        ])","","        \/\/ Unregister from push","        Pushwoosh.configure.unregisterForPushNotifications { _ in }","    }","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"sections":[],"kind":"symbol","abs