{"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setUserId:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSString","text":"NSString","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"userId"},{"kind":"text","text":";"}]}]},{"kind":"parameters","parameters":[{"name":"userId","content":[{"inlineContent":[{"type":"text","text":"The custom user identifier (e.g., database ID, UUID)"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"Associates a unique user ID with the device to:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Track users across multiple devices"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Enable user-based targeting in campaigns"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Link push engagement to user accounts in your analytics","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Support user migration between devices"}]}]}],"type":"unorderedList"},{"text":"Example","type":"heading","level":2,"anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Set user ID after successful login:"}]},{"type":"codeListing","syntax":"swift","code":["class AuthenticationService {","","    func handleSuccessfulLogin(user: User) {","        \/\/ Set user ID for cross-device tracking","        Pushwoosh.configure.setUserId(user.id)","","        \/\/ Set email if available","        if let email = user.email {","            Pushwoosh.configure.setEmail(email)","        }","","        \/\/ Update user profile tags","        Pushwoosh.configure.setTags([","            \"logged_in\": true,","            \"login_date\": Date(),","            \"login_count\": incrementLoginCount(),","            \"account_type\": user.accountType.rawValue,","            \"subscription_status\": user.subscription?.status.rawValue ?? \"none\"","        ])","","        \/\/ Sync with analytics platforms","        Analytics.identify(user.id, traits: [","            \"email\": user.email ?? \"\",","            \"pushwoosh_hwid\": Pushwoosh.configure.getHWID()","        ])","","        Logger.info(\"User logged in: \\(user.id)\")","    }","","    func handleAccountDeletion() {","        \/\/ Clear user identity","        Pushwoosh.configure.setUserId(\"\")","","        \/\/ Clear all user data tags","        Pushwoosh.configure.setTags([","            \"logged_in\": false,","            \"user_id\": NSNull(),","            \"email\": NSNull(),","            \"account_deleted\": true,","            \"deletion_date\": Date()","        ])","","        \/\/ Unregister from push","        Pushwoosh.configure.unregisterForPushNotifications { _ in }","    }","}"]}]}],"sections":[],"abstract":[{"type":"text","text":"Sets a custom user identifier for the current device."}],"kind":"symbol","variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setuserid:"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)setUserId:","modules":[{"name":"PushwooshCore"}],"title":"setUserId:","fragments":[{"kind":"text","text":"+ "},{"text":"setUserId:","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"text":"setUserId:","kind":"identifier"}],"symbolKind":"method","roleHeading":"Type Method"},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUserId:","interfaceLanguage":"occ"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setUserId:":{"title":"setUserId:","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUserId:","abstract":[{"text":"Sets a custom user identifier for the current device.","type":"text"}],"kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setuserid:","role":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"setUserId:","kind":"identifier"}],"type":"topic","navigatorTitle":[{"text":"setUserId:","kind":"identifier"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"role":"collection","title":"PushwooshCore","url":"\/documentation\/pushwooshcore","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","abstract":[],"kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"type":"topic"}}}