{"metadata":{"title":"setEmail:completion:","roleHeading":"Type Method","externalID":"c:objc(pl)PWConfiguration(cm)setEmail:completion:","symbolKind":"method","navigatorTitle":[{"kind":"identifier","text":"setEmail:completion:"}],"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setEmail:completion:"}],"role":"symbol","modules":[{"name":"PushwooshCore"}]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmail:completion:"},"abstract":[{"type":"text","text":"Associates an email address with the current device with completion confirmation."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemail:completion:"]}],"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"text":") ","kind":"text"},{"text":"setEmail:","kind":"identifier"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString","text":"NSString"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"email"},{"text":" ","kind":"text"},{"text":"completion:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"kind":"text","text":" (^"},{"kind":"text","text":")("},{"preciseIdentifier":"c:objc(cs)NSError","kind":"typeIdentifier","text":"NSError"},{"kind":"text","text":" * "},{"text":"error","kind":"internalParam"},{"text":")) ","kind":"text"},{"kind":"internalParam","text":"completion"},{"text":";","kind":"text"}]}]},{"kind":"parameters","parameters":[{"name":"email","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The user’s email address. Must be a valid email format."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Block called when the operation completes."},{"type":"text","text":" "},{"type":"text","text":"Receives nil on success, or an NSError on failure."}]}],"name":"completion"}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Same as "},{"type":"codeVoice","code":"setEmail:"},{"type":"text","text":" but provides callback when the server registration completes."},{"type":"text","text":" "},{"text":"Use this when you need to:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Verify email was registered before showing confirmation UI"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Chain operations that depend on email registration","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Implement error handling and retry logic","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Example","text":"Example","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Register email during account setup with verification:","type":"text"}]},{"syntax":"swift","code":["class AccountSetupController {","","    func submitEmail(_ email: String) {","        guard isValidEmail(email) else {","            showError(\"Please enter a valid email address\")","            return","        }","","        showLoadingState()","","        Pushwoosh.configure.setEmail(email) { [weak self] error in","            DispatchQueue.main.async {","                self?.hideLoadingState()","","                if let error = error {","                    Logger.error(\"Email registration failed: \\(error.localizedDescription)\")","                    self?.showRetryOption(for: email)","                    return","                }","","                \/\/ Email registered successfully - update tags","                let domain = email.components(separatedBy: \"@\").last ?? \"\"","                Pushwoosh.configure.setTags([","                    \"has_email\": true,","                    \"email_domain\": domain,","                    \"email_type\": self?.classifyEmailDomain(domain) ?? \"personal\"","                ])","","                self?.proceedToNextStep()","            }","        }","    }","","    private func classifyEmailDomain(_ domain: String) -> String {","        let businessDomains = [\"company.com\", \"enterprise.org\"]","        let educationDomains = [\"edu\", \"ac.uk\", \"edu.au\"]","","        if businessDomains.contains(domain) { return \"business\" }","        if educationDomains.contains(where: { domain.hasSuffix($0) }) { return \"education\" }","        return \"personal\"","    }","}"],"type":"codeListing"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmail:completion:":{"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemail:completion:","kind":"symbol","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmail:completion:","title":"setEmail:completion:","fragments":[{"text":"+ ","kind":"text"},{"text":"setEmail:completion:","kind":"identifier"}],"navigatorTitle":[{"text":"setEmail:completion:","kind":"identifier"}],"abstract":[{"type":"text","text":"Associates an email address with the current device with completion confirmation."}],"role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","title":"PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"role":"symbol","abstract":[]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","title":"PushwooshCore","role":"collection","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"kind":"symbol"}}}