{"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"text":") ","kind":"text"},{"text":"setEmail:","kind":"identifier"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"NSString","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"text":"email","kind":"internalParam"},{"kind":"text","text":" "},{"text":"completion:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"text":" (^","kind":"text"},{"kind":"text","text":")("},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSError","text":"NSError"},{"text":" * ","kind":"text"},{"text":"error","kind":"internalParam"},{"kind":"text","text":")) "},{"kind":"internalParam","text":"completion"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The user’s email address. Must be a valid email format."}],"type":"paragraph"}],"name":"email"},{"content":[{"inlineContent":[{"type":"text","text":"Block called when the operation completes."},{"type":"text","text":" "},{"text":"Receives nil on success, or an NSError on failure.","type":"text"}],"type":"paragraph"}],"name":"completion"}]},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Same as "},{"type":"codeVoice","code":"setEmail:"},{"type":"text","text":" but provides callback when the server registration completes."},{"text":" ","type":"text"},{"type":"text","text":"Use this when you need to:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Verify email was registered before showing confirmation UI","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Chain operations that depend on email registration"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Implement error handling and retry logic","type":"text"}]}]}],"type":"unorderedList"},{"text":"Example","anchor":"Example","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register email during account setup with verification:"}]},{"code":["class AccountSetupController {","","    func submitEmail(_ email: String) {","        guard isValidEmail(email) else {","            showError(\"Please enter a valid email address\")","            return","        }","","        showLoadingState()","","        Pushwoosh.configure.setEmail(email) { [weak self] error in","            DispatchQueue.main.async {","                self?.hideLoadingState()","","                if let error = error {","                    Logger.error(\"Email registration failed: \\(error.localizedDescription)\")","                    self?.showRetryOption(for: email)","                    return","                }","","                \/\/ Email registered successfully - update tags","                let domain = email.components(separatedBy: \"@\").last ?? \"\"","                Pushwoosh.configure.setTags([","                    \"has_email\": true,","                    \"email_domain\": domain,","                    \"email_type\": self?.classifyEmailDomain(domain) ?? \"personal\"","                ])","","                self?.proceedToNextStep()","            }","        }","    }","","    private func classifyEmailDomain(_ domain: String) -> String {","        let businessDomains = [\"company.com\", \"enterprise.org\"]","        let educationDomains = [\"edu\", \"ac.uk\", \"edu.au\"]","","        if businessDomains.contains(domain) { return \"business\" }","        if educationDomains.contains(where: { domain.hasSuffix($0) }) { return \"education\" }","        return \"personal\"","    }","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"metadata":{"symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)setEmail:completion:","roleHeading":"Type Method","fragments":[{"kind":"text","text":"+ "},{"text":"setEmail:completion:","kind":"identifier"}],"title":"setEmail:completion:","role":"symbol","modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"kind":"identifier","text":"setEmail:completion:"}]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmail:completion:"},"abstract":[{"text":"Associates an email address with the current device with completion confirmation.","type":"text"}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemail:completion:"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","url":"\/documentation\/pushwooshcore","role":"collection","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","title":"PushwooshCore","kind":"symbol","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmail:completion:":{"type":"topic","abstract":[{"type":"text","text":"Associates an email address with the current device with completion confirmation."}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmail:completion:","navigatorTitle":[{"kind":"identifier","text":"setEmail:completion:"}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setEmail:completion:"}],"title":"setEmail:completion:","role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\