{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setEmail:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString","text":"NSString"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"email"},{"text":" ","kind":"text"},{"kind":"identifier","text":"completion:"},{"kind":"text","text":"("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":" (^"},{"text":")(","kind":"text"},{"text":"NSError","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSError"},{"text":" * ","kind":"text"},{"text":"error","kind":"internalParam"},{"text":")) ","kind":"text"},{"text":"completion","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"email","content":[{"type":"paragraph","inlineContent":[{"text":"The user’s email address. Must be a valid email format.","type":"text"}]}]},{"name":"completion","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Block called when the operation completes."},{"text":" ","type":"text"},{"type":"text","text":"Receives nil on success, or an NSError on failure."}]}]}]},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Same as ","type":"text"},{"type":"codeVoice","code":"setEmail:"},{"text":" but provides callback when the server registration completes.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Use this when you need to:"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Verify email was registered before showing confirmation UI"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Chain operations that depend on email registration","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement error handling and retry logic"}]}]}],"type":"unorderedList"},{"anchor":"Example","type":"heading","level":2,"text":"Example"},{"inlineContent":[{"text":"Register email during account setup with verification:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["class AccountSetupController {","","    func submitEmail(_ email: String) {","        guard isValidEmail(email) else {","            showError(\"Please enter a valid email address\")","            return","        }","","        showLoadingState()","","        Pushwoosh.configure.setEmail(email) { [weak self] error in","            DispatchQueue.main.async {","                self?.hideLoadingState()","","                if let error = error {","                    Logger.error(\"Email registration failed: \\(error.localizedDescription)\")","                    self?.showRetryOption(for: email)","                    return","                }","","                \/\/ Email registered successfully - update tags","                let domain = email.components(separatedBy: \"@\").last ?? \"\"","                Pushwoosh.configure.setTags([","                    \"has_email\": true,","                    \"email_domain\": domain,","                    \"email_type\": self?.classifyEmailDomain(domain) ?? \"personal\"","                ])","","                self?.proceedToNextStep()","            }","        }","    }","","    private func classifyEmailDomain(_ domain: String) -> String {","        let businessDomains = [\"company.com\", \"enterprise.org\"]","        let educationDomains = [\"edu\", \"ac.uk\", \"edu.au\"]","","        if businessDomains.contains(domain) { return \"business\" }","        if educationDomains.contains(where: { domain.hasSuffix($0) }) { return \"education\" }","        return \"personal\"","    }","}"],"syntax":"swift"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemail:completion:"]}],"sections":[],"abstract":[{"type":"text","text":"Associates an email address with the current device with completion confirmation."}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmail:completion:","interfaceLanguage":"occ"},"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)setEmail:completion:","roleHeading":"Type Method","navigatorTitle":[{"text":"setEmail:completion:","kind":"identifier"}],"fragments":[{"text":"+ ","kind":"text"},{"text":"setEmail:completion:","kind":"identifier"}],"role":"symbol","modules":[{"name":"PushwooshCore"}],"symbolKind":"method","title":"setEmail:completion:"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","abstract":[],"fragments":[{"kind":"identifier","text":"PWConfiguration"}],"title":"PWConfiguration","kind":"symbol","role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","url":"\/documentation\/pushwooshcore","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"role":"collection"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmail:completion:":{"type":"topic","abstract":[{"type":"text","text":"Associates an email address with the current device with completion confirmation."}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setEmail:completion:"}],"navigatorTitle":[{"kind":"identifier","text":"setEmail:completion:"}],"title":"setEmail:completion:","kind":"symbol","role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemail:completion:","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmail:completion:"}}}