{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmail:completion:"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemail:completion:"]}],"abstract":[{"type":"text","text":"Associates an email address with the current device with completion confirmation."}],"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"setEmail:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"email"},{"text":" ","kind":"text"},{"kind":"identifier","text":"completion:"},{"text":"(","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":" (^","kind":"text"},{"kind":"text","text":")("},{"preciseIdentifier":"c:objc(cs)NSError","kind":"typeIdentifier","text":"NSError"},{"text":" * ","kind":"text"},{"text":"error","kind":"internalParam"},{"text":")) ","kind":"text"},{"kind":"internalParam","text":"completion"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The user’s email address. Must be a valid email format."}]}],"name":"email"},{"name":"completion","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Block called when the operation completes."},{"text":" ","type":"text"},{"text":"Receives nil on success, or an NSError on failure.","type":"text"}]}]}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"Same as ","type":"text"},{"code":"setEmail:","type":"codeVoice"},{"text":" but provides callback when the server registration completes.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Use this when you need to:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Verify email was registered before showing confirmation UI"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Chain operations that depend on email registration"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Implement error handling and retry logic","type":"text"}]}]}],"type":"unorderedList"},{"level":2,"text":"Example","type":"heading","anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register email during account setup with verification:"}]},{"code":["class AccountSetupController {","","    func submitEmail(_ email: String) {","        guard isValidEmail(email) else {","            showError(\"Please enter a valid email address\")","            return","        }","","        showLoadingState()","","        Pushwoosh.configure.setEmail(email) { [weak self] error in","            DispatchQueue.main.async {","                self?.hideLoadingState()","","                if let error = error {","                    Logger.error(\"Email registration failed: \\(error.localizedDescription)\")","                    self?.showRetryOption(for: email)","                    return","                }","","                \/\/ Email registered successfully - update tags","                let domain = email.components(separatedBy: \"@\").last ?? \"\"","                Pushwoosh.configure.setTags([","                    \"has_email\": true,","                    \"email_domain\": domain,","                    \"email_type\": self?.classifyEmailDomain(domain) ?? \"personal\"","                ])","","                self?.proceedToNextStep()","            }","        }","    }","","    private func classifyEmailDomain(_ domain: String) -> String {","        let businessDomains = [\"company.com\", \"enterprise.org\"]","        let educationDomains = [\"edu\", \"ac.uk\", \"edu.au\"]","","        if businessDomains.contains(domain) { return \"business\" }","        if educationDomains.contains(where: { domain.hasSuffix($0) }) { return \"education\" }","        return \"personal\"","    }","}"],"syntax":"swift","type":"codeListing"}]}],"metadata":{"roleHeading":"Type Method","navigatorTitle":[{"text":"setEmail:completion:","kind":"identifier"}],"symbolKind":"method","role":"symbol","title":"setEmail:completion:","fragments":[{"kind":"text","text":"+ "},{"text":"setEmail:completion:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)setEmail:completion:"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","role":"collection","title":"PushwooshCore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"abstract":[],"title":"PWConfiguration","role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmail:completion:":{"navigatorTitle":[{"kind":"identifier","text":"setEmail:completion:"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemail:completion:","kind":"symbol","type":"topic","abstract":[{"text":"Associates an email address with the current device with completion confirmation.","type":"text"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmail:completion:","title":"setEmail:completion:","role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setEmail:completion:"}]}}}