":"text","text":"Block called when the operation completes."},{"type":"text","text":" "},{"type":"text","text":"Receives nil on success, or an NSError on failure."}]}]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Same as "},{"code":"setEmail:","type":"codeVoice"},{"type":"text","text":" but provides callback when the server registration completes."},{"type":"text","text":" "},{"type":"text","text":"Use this when you need to:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Verify email was registered before showing confirmation UI"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Chain operations that depend on email registration"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement error handling and retry logic"}]}]}]},{"text":"Example","level":2,"type":"heading","anchor":"Example"},{"type":"paragraph","inlineContent":[{"text":"Register email during account setup with verification:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class AccountSetupController {","","    func submitEmail(_ email: String) {","        guard isValidEmail(email) else {","            showError(\"Please enter a valid email address\")","            return","        }","","        showLoadingState()","","        Pushwoosh.configure.setEmail(email) { [weak self] error in","            DispatchQueue.main.async {","                self?.hideLoadingState()","","                if let error = error {","                    Logger.error(\"Email registration failed: \\(error.localizedDescription)\")","                    self?.showRetryOption(for: email)","                    return","                }","","                \/\/ Email registered successfully - update tags","                let domain = email.components(separatedBy: \"@\").last ?? \"\"","                Pushwoosh.configure.setTags([","                    \"has_email\": true,","                    \"email_domain\": domain,","                    \"email_type\": self?.classifyEmailDomain(domain) ?? \"personal\"","                ])","","                self?.proceedToNextStep()","            }","        }","    }","","    private func classifyEmailDomain(_ domain: String) -> String {","        let businessDomains = [\"company.com\", \"enterprise.org\"]","        let educationDomains = [\"edu\", \"ac.uk\", \"edu.au\"]","","        if businessDomains.contains(domain) { return \"business\" }","        if educationDomains.contains(where: { domain.hasSuffix($0) }) { return \"education\" }","        return \"personal\"","    }","}"]}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmail:completion:":{"abstract":[{"text":"Associates an email address with the current device with completion confirmation.","type":"text"}],"type":"topic","navigatorTitle":[{"text":"setEmail:completion:","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmail:completion:","title":"setEmail:completion:","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setEmail:completion:"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemail:completion:","role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"role":"collection","title":"PushwooshCore","url":"\/documentation\/pushwooshcore","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/Pushwoo