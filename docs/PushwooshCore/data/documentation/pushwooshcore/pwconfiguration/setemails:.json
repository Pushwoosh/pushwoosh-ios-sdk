{"abstract":[{"text":"Registers multiple email addresses associated with the current user.","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"symbolKind":"method","modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","role":"symbol","title":"setEmails:","fragments":[{"kind":"text","text":"+ "},{"text":"setEmails:","kind":"identifier"}],"navigatorTitle":[{"text":"setEmails:","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)setEmails:"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemails:"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"kind":"identifier","text":"setEmails:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSArray","kind":"typeIdentifier","text":"NSArray"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"emails"},{"kind":"text","text":";"}]}]},{"parameters":[{"name":"emails","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Array of email address strings. Each must be a valid email format."}]}]}],"kind":"parameters"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Associates multiple email addresses with the current device for omnichannel"},{"text":" ","type":"text"},{"text":"email campaigns. This is useful when users have multiple email addresses","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(work, personal, etc.) and want to receive communications on all of them."}]},{"inlineContent":[{"text":"All provided emails will be linked to the same device and user ID,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"enabling unified targeting across all addresses."}],"type":"paragraph"},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register multiple emails from user profile:"}]},{"syntax":"swift","code":["class UserProfileManager {","","    func syncEmailsFromProfile(_ profile: UserProfile) {","        var emails: [String] = []","","        if let primary = profile.primaryEmail {","            emails.append(primary)","        }","        if let secondary = profile.secondaryEmail {","            emails.append(secondary)","        }","        if let work = profile.workEmail {","            emails.append(work)","        }","","        guard !emails.isEmpty else { return }","","        Pushwoosh.configure.setEmails(emails)","","        \/\/ Update tags with email count","        Pushwoosh.configure.setTags([","            \"email_count\": emails.count,","            \"has_work_email\": profile.workEmail != nil,","            \"has_multiple_emails\": emails.count > 1","        ])","    }","}"],"type":"codeListing"}],"kind":"content"}],"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmails:","interfaceLanguage":"occ"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"role":"symbol","abstract":[],"kind":"symbol","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmails:":{"abstract":[{"text":"Registers multiple email addresses associated with the current user.","type":"text"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemails:","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"setEmails:"}],"title":"setEmails:","kind":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"setEmails:","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmails:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","url":"\/documentation\/pushwooshcore","role":"collection"}}}