{"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmails:","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)setEmails:","title":"setEmails:","symbolKind":"method","navigatorTitle":[{"text":"setEmails:","kind":"identifier"}],"roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setEmails:"}],"role":"symbol"},"sections":[],"kind":"symbol","abstract":[{"type":"text","text":"Registers multiple email addresses associated with the current user."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"setEmails:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSArray","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSArray"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"emails"},{"text":";","kind":"text"}]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"Array of email address strings. Each must be a valid email format.","type":"text"}],"type":"paragraph"}],"name":"emails"}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Associates multiple email addresses with the current device for omnichannel"},{"text":" ","type":"text"},{"type":"text","text":"email campaigns. This is useful when users have multiple email addresses"},{"type":"text","text":" "},{"type":"text","text":"(work, personal, etc.) and want to receive communications on all of them."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"All provided emails will be linked to the same device and user ID,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"enabling unified targeting across all addresses."}]},{"level":2,"type":"heading","text":"Example","anchor":"Example"},{"inlineContent":[{"text":"Register multiple emails from user profile:","type":"text"}],"type":"paragraph"},{"code":["class UserProfileManager {","","    func syncEmailsFromProfile(_ profile: UserProfile) {","        var emails: [String] = []","","        if let primary = profile.primaryEmail {","            emails.append(primary)","        }","        if let secondary = profile.secondaryEmail {","            emails.append(secondary)","        }","        if let work = profile.workEmail {","            emails.append(work)","        }","","        guard !emails.isEmpty else { return }","","        Pushwoosh.configure.setEmails(emails)","","        \/\/ Update tags with email count","        Pushwoosh.configure.setTags([","            \"email_count\": emails.count,","            \"has_work_email\": profile.workEmail != nil,","            \"has_multiple_emails\": emails.count > 1","        ])","    }","}"],"type":"codeListing","syntax":"swift"}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemails:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","title":"PushwooshCore","kind":"symbol","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","url":"\/documentation\/pushwooshcore","role":"collection"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","role":"symbol","kind":"symbol","title":"PWConfiguration","type":"topic","fragments":[{"text":"PWConfiguration","kind":"identifier"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmails:":{"role":"symbol","kind":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"setEmails:","kind":"identifier"}],"type":"topic","title":"setEmails:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemails:","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmails:","abstract":[{"type":"text","text":"Registers multiple email addresses associated with the current user."}],"navigatorTitle":[{"text":"setEmails:","kind":"identifier"}]}}}