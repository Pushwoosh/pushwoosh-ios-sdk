{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"abstract":[{"text":"Registers multiple email addresses associated with the current user.","type":"text"}],"metadata":{"roleHeading":"Type Method","symbolKind":"method","modules":[{"name":"PushwooshCore"}],"title":"setEmails:","fragments":[{"kind":"text","text":"+ "},{"text":"setEmails:","kind":"identifier"}],"navigatorTitle":[{"text":"setEmails:","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)setEmails:","role":"symbol"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"text":"setEmails:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSArray","text":"NSArray"},{"text":" *) ","kind":"text"},{"text":"emails","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}]},{"parameters":[{"content":[{"inlineContent":[{"text":"Array of email address strings. Each must be a valid email format.","type":"text"}],"type":"paragraph"}],"name":"emails"}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Associates multiple email addresses with the current device for omnichannel","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"email campaigns. This is useful when users have multiple email addresses"},{"type":"text","text":" "},{"type":"text","text":"(work, personal, etc.) and want to receive communications on all of them."}]},{"inlineContent":[{"type":"text","text":"All provided emails will be linked to the same device and user ID,"},{"text":" ","type":"text"},{"type":"text","text":"enabling unified targeting across all addresses."}],"type":"paragraph"},{"type":"heading","anchor":"Example","text":"Example","level":2},{"type":"paragraph","inlineContent":[{"text":"Register multiple emails from user profile:","type":"text"}]},{"code":["class UserProfileManager {","","    func syncEmailsFromProfile(_ profile: UserProfile) {","        var emails: [String] = []","","        if let primary = profile.primaryEmail {","            emails.append(primary)","        }","        if let secondary = profile.secondaryEmail {","            emails.append(secondary)","        }","        if let work = profile.workEmail {","            emails.append(work)","        }","","        guard !emails.isEmpty else { return }","","        Pushwoosh.configure.setEmails(emails)","","        \/\/ Update tags with email count","        Pushwoosh.configure.setTags([","            \"email_count\": emails.count,","            \"has_work_email\": profile.workEmail != nil,","            \"has_multiple_emails\": emails.count > 1","        ])","    }","}"],"type":"codeListing","syntax":"swift"}]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmails:","interfaceLanguage":"occ"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemails:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore","type":"topic","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmails:":{"role":"symbol","title":"setEmails:","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmails:","kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemails:","navigatorTitle":[{"kind":"identifier","text":"setEmails:"}],"abstract":[{"type":"text","text":"Registers multiple email addresses associated with the current user."}],"fragments":[{"kind":"text","text":"+ "},{"text":"setEmails:","kind":"identifier"}],"type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","kind":"symbol","type":"topic","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"abstract":[],"role":"symbol"}}}