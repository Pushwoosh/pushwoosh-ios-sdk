{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemails:"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setEmails:"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSArray","text":"NSArray"},{"text":" *) ","kind":"text"},{"text":"emails","kind":"internalParam"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"parameters":[{"name":"emails","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Array of email address strings. Each must be a valid email format."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Associates multiple email addresses with the current device for omnichannel"},{"text":" ","type":"text"},{"type":"text","text":"email campaigns. This is useful when users have multiple email addresses"},{"text":" ","type":"text"},{"type":"text","text":"(work, personal, etc.) and want to receive communications on all of them."}]},{"inlineContent":[{"type":"text","text":"All provided emails will be linked to the same device and user ID,"},{"type":"text","text":" "},{"type":"text","text":"enabling unified targeting across all addresses."}],"type":"paragraph"},{"type":"heading","anchor":"Example","level":2,"text":"Example"},{"inlineContent":[{"text":"Register multiple emails from user profile:","type":"text"}],"type":"paragraph"},{"code":["class UserProfileManager {","","    func syncEmailsFromProfile(_ profile: UserProfile) {","        var emails: [String] = []","","        if let primary = profile.primaryEmail {","            emails.append(primary)","        }","        if let secondary = profile.secondaryEmail {","            emails.append(secondary)","        }","        if let work = profile.workEmail {","            emails.append(work)","        }","","        guard !emails.isEmpty else { return }","","        Pushwoosh.configure.setEmails(emails)","","        \/\/ Update tags with email count","        Pushwoosh.configure.setTags([","            \"email_count\": emails.count,","            \"has_work_email\": profile.workEmail != nil,","            \"has_multiple_emails\": emails.count > 1","        ])","    }","}"],"syntax":"swift","type":"codeListing"}]}],"metadata":{"title":"setEmails:","roleHeading":"Type Method","symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)setEmails:","fragments":[{"kind":"text","text":"+ "},{"text":"setEmails:","kind":"identifier"}],"navigatorTitle":[{"text":"setEmails:","kind":"identifier"}],"role":"symbol","modules":[{"name":"PushwooshCore"}]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmails:","interfaceLanguage":"occ"},"abstract":[{"text":"Registers multiple email addresses associated with the current user.","type":"text"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"abstract":[],"role":"symbol","title":"PWConfiguration","type":"topic","url":"\/documentation\/pushwooshcore\/pwconfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmails:":{"title":"setEmails:","fragments":[{"kind":"text","text":"+ "},{"text":"setEmails:","kind":"identifier"}],"type":"topic","role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemails:","kind":"symbol","abstract":[{"type":"text","text":"Registers multiple email addresses associated with the current user."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmails:","navigatorTitle":[{"kind":"identifier","text":"setEmails:"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"role":"collection","url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","title":"PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"type":"topic"}}}