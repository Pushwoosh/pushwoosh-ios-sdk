{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmails:"},"abstract":[{"text":"Registers multiple email addresses associated with the current user.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemails:"]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"title":"setEmails:","externalID":"c:objc(pl)PWConfiguration(cm)setEmails:","modules":[{"name":"PushwooshCore"}],"symbolKind":"method","navigatorTitle":[{"text":"setEmails:","kind":"identifier"}],"role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"setEmails:","kind":"identifier"}],"roleHeading":"Type Method"},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setEmails:"},{"text":"(","kind":"text"},{"text":"NSArray","preciseIdentifier":"c:objc(cs)NSArray","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"text":"emails","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"parameters":[{"name":"emails","content":[{"inlineContent":[{"text":"Array of email address strings. Each must be a valid email format.","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Associates multiple email addresses with the current device for omnichannel"},{"text":" ","type":"text"},{"type":"text","text":"email campaigns. This is useful when users have multiple email addresses"},{"text":" ","type":"text"},{"type":"text","text":"(work, personal, etc.) and want to receive communications on all of them."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All provided emails will be linked to the same device and user ID,"},{"type":"text","text":" "},{"type":"text","text":"enabling unified targeting across all addresses."}]},{"text":"Example","anchor":"Example","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Register multiple emails from user profile:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class UserProfileManager {","","    func syncEmailsFromProfile(_ profile: UserProfile) {","        var emails: [String] = []","","        if let primary = profile.primaryEmail {","            emails.append(primary)","        }","        if let secondary = profile.secondaryEmail {","            emails.append(secondary)","        }","        if let work = profile.workEmail {","            emails.append(work)","        }","","        guard !emails.isEmpty else { return }","","        Pushwoosh.configure.setEmails(emails)","","        \/\/ Update tags with email count","        Pushwoosh.configure.setTags([","            \"email_count\": emails.count,","            \"has_work_email\": profile.workEmail != nil,","            \"has_multiple_emails\": emails.count > 1","        ])","    }","}"]}]}],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","role":"collection","kind":"symbol","title":"PushwooshCore","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","url":"\/documentation\/pushwooshcore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmails:":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmails:","type":"topic","role":"symbol","title":"setEmails:","fragments":[{"kind":"text","text":"+ "},{"text":"setEmails:","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"setEmails:"}],"kind":"symbol","abstract":[{"text":"Registers multiple email addresses associated with the current user.","type":"text"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemails:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"fragments":[{"text":"PWConfiguration","kind":"identifier"}],"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","title":"PWConfiguration","kind":"symbol","type":"topic","role":"symbol"}}}