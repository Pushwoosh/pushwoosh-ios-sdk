{"abstract":[{"type":"text","text":"Registers multiple email addresses associated with the current user."}],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmails:","interfaceLanguage":"occ"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"setEmails:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"NSArray","preciseIdentifier":"c:objc(cs)NSArray"},{"kind":"text","text":" *) "},{"text":"emails","kind":"internalParam"},{"text":";","kind":"text"}]}]},{"kind":"parameters","parameters":[{"name":"emails","content":[{"type":"paragraph","inlineContent":[{"text":"Array of email address strings. Each must be a valid email format.","type":"text"}]}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Associates multiple email addresses with the current device for omnichannel"},{"type":"text","text":" "},{"text":"email campaigns. This is useful when users have multiple email addresses","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(work, personal, etc.) and want to receive communications on all of them."}],"type":"paragraph"},{"inlineContent":[{"text":"All provided emails will be linked to the same device and user ID,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"enabling unified targeting across all addresses."}],"type":"paragraph"},{"type":"heading","text":"Example","level":2,"anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register multiple emails from user profile:"}]},{"type":"codeListing","syntax":"swift","code":["class UserProfileManager {","","    func syncEmailsFromProfile(_ 