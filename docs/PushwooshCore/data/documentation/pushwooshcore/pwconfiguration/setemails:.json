{"sections":[],"metadata":{"navigatorTitle":[{"text":"setEmails:","kind":"identifier"}],"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setEmails:"}],"role":"symbol","symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)setEmails:","roleHeading":"Type Method","title":"setEmails:","modules":[{"name":"PushwooshCore"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":") ","kind":"text"},{"text":"setEmails:","kind":"identifier"},{"kind":"text","text":"("},{"text":"NSArray","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSArray"},{"text":" *) ","kind":"text"},{"text":"emails","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"name":"emails","content":[{"inlineContent":[{"type":"text","text":"Array of email address strings. Each must be a valid email format."}],"type":"paragraph"}]}]},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"text":"Associates multiple email addresses with the current device for omnichannel","type":"text"},{"type":"text","text":" "},{"type":"text","text":"email campaigns. This is useful when users have multiple email addresses"},{"type":"text","text":" "},{"text":"(work, personal, etc.) and want to receive communications on all of them.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All provided emails will be linked to the same device and user ID,"},{"text":" ","type":"text"},{"type":"text","text":"enabling unified targeting across all addresses."}]},{"anchor":"Example","text":"Example","type":"heading","level":2},{"inlineContent":[{"text":"Register multiple emails from user profile:","type":"text"}],"type":"paragraph"},{"code":["class UserProfileManager {","","    func syncEmailsFromProfile(_ profile: UserProfile) {","        var emails: [String] = []","","        if let primary = profile.primaryEmail {","            emails.append(primary)","        }","        if let secondary = profile.secondaryEmail {","            emails.append(secondary)","        }","        if let work = profile.workEmail {","            emails.append(work)","        }","","        guard !emails.isEmpty else { return }","","        Pushwoosh.configure.setEmails(emails)","","        \/\/ Update tags with email count","        Pushwoosh.configure.setTags([","            \"email_count\": emails.count,","            \"has_work_email\": profile.workEmail != nil,","            \"has_multiple_emails\": emails.count > 1","        ])","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmails:","interfaceLanguage":"occ"},"abstract":[{"text":"Registers multiple email addresses associated with the current user.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemails:"]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmails:":{"navigatorTitle":[{"text":"setEmails:","kind":"identifier"}],"type":"topic","abstract":[{"type":"text","text":"Registers multiple email addresses associated with the current user."}],"fragments":[{"text":"+ ","kind":"text"},{"text":"setEmails:","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmails:","role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemails:","title"