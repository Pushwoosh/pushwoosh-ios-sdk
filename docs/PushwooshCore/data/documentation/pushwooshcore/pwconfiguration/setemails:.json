{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmails:"},"metadata":{"roleHeading":"Type Method","symbolKind":"method","fragments":[{"text":"+ ","kind":"text"},{"text":"setEmails:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"role":"symbol","title":"setEmails:","externalID":"c:objc(pl)PWConfiguration(cm)setEmails:","navigatorTitle":[{"kind":"identifier","text":"setEmails:"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Registers multiple email addresses associated with the current user."}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"kind":"identifier","text":"setEmails:"},{"kind":"text","text":"("},{"text":"NSArray","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSArray"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"emails"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Array of email address strings. Each must be a valid email format."}]}],"name":"emails"}]},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Associates multiple email addresses with the current device for omnichannel","type":"text"},{"type":"text","text":" "},{"text":"email campaigns. This is useful when users have multiple email addresses","type":"text"},{"type":"text","text":" "},{"text":"(work, personal, etc.) and want to receive communications on all of them.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"All provided emails will be linked to the same device and user ID,"},{"type":"text","text":" "},{"type":"text","text":"enabling unified targeting across all addresses."}]},{"anchor":"Example","text":"Example","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Register multiple emails from user profile:"}],"type":"paragraph"},{"syntax":"swift","code":["class UserProfileManager {","","    func syncEmailsFromProfile(_ profile: UserProfile) {","        var emails: [String] = []","","        if let primary = profile.primaryEmail {","            emails.append(primary)","        }","        if let secondary = profile.secondaryEmail {","            emails.append(secondary)","        }","        if let work = profile.workEmail {","            emails.append(work)","        }","","        guard !emails.isEmpty else { return }","","        Pushwoosh.configure.setEmails(emails)","","        \/\/ Update tags with email count","        Pushwoosh.configure.setTags([","            \"email_count\": emails.count,","            \"has_work_email\": profile.workEmail != nil,","            \"has_multiple_emails\": emails.count > 1","        ])","    }","}"],"type":"codeListing"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemails:"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"type":"topic","role":"symbol","kind":"symbol","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmails:":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmails:","fragments":[{"kind":"text","text":"+ "},{"text":"setEmails:","kind":"identifier"}],"type":"topic","title":"setEmails:","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"setEmails:"}],"abstract":[{"text":"Registers multiple email addresses associated with the current user.","type":"text"}],"role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemails:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","role":"collection","url":"\/documentation\/pushwooshcore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"kind":"symbol"}}}