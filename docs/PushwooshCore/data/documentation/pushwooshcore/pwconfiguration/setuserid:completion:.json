{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUserId:completion:","interfaceLanguage":"occ"},"abstract":[{"type":"text","text":"Sets a custom user identifier with completion confirmation."}],"metadata":{"fragments":[{"text":"+ ","kind":"text"},{"text":"setUserId:completion:","kind":"identifier"}],"roleHeading":"Type Method","symbolKind":"method","role":"symbol","modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)setUserId:completion:","navigatorTitle":[{"kind":"identifier","text":"setUserId:completion:"}],"title":"setUserId:completion:"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"setUserId:","kind":"identifier"},{"kind":"text","text":"("},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"text":"userId","kind":"internalParam"},{"text":" ","kind":"text"},{"kind":"identifier","text":"completion:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"text":" (^","kind":"text"},{"kind":"text","text":")("},{"text":"NSError","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSError"},{"text":" * ","kind":"text"},{"text":"error","kind":"internalParam"},{"text":")) ","kind":"text"},{"text":"completion","kind":"internalParam"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"parameters":[{"name":"userId","content":[{"inlineContent":[{"text":"The custom user identifier (e.g., database ID, UUID, username).","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Block called when the operation completes."},{"text":" ","type":"text"},{"text":"Receives nil on success, or an NSError on failure.","type":"text"}]}],"name":"completion"}],"kind":"parameters"},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Same as ","type":"text"},{"type":"codeVoice","code":"setUserId:"},{"type":"text","text":" but provides callback when the server operation completes."},{"type":"text","text":" "},{"type":"text","text":"Use this when you need to ensure the user ID is set before performing"},{"text":" ","type":"text"},{"text":"dependent operations like merging user data or tracking critical events.","type":"text"}]},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"type":"paragraph","inlineContent":[{"text":"Handle login with guaranteed user ID synchronization:","type":"text"}]},{"code":["class LoginCoordinator {","","    func performLogin(credentials: Credentials,","                      completion: @escaping (Result<User, Error>) -> Void) {","","        APIClient.shared.login(credentials) { result in","            switch result {","            case .success(let user):","                \/\/ Set user ID with confirmation before proceeding","                Pushwoosh.configure.setUserId(user.id) { error in","                    if let error = error {","                        Logger.warning(\"User ID sync failed: \\(error.localizedDescription)\")","                        \/\/ Continue anyway - local state is still valid","                    }","","                    \/\/ Now safe to track login event with correct user attribution","                    Pushwoosh.configure.setTags([","                        \"logged_in\": true,","                        \"last_login\": ISO8601DateFormatter().string(from: Date()),","                        \"login_method\": credentials.method.rawValue","                    ])","","                    \/\/ Set email if available","                    if let email = user.email {","                        Pushwoosh.configure.setEmail(email)","                    }","","                    completion(.success(user))","                }","","            case .failure(let error):","                completion(.failure(error))","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setuserid:completion:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","url":"\/documentation\/pushwooshcore","role":"collection"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"role":"symbol","abstract":[],"kind":"symbol","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setUserId:completion:":{"title":"setUserId:completion:","navigatorTitle":[{"kind":"identifier","text":"setUserId:completion:"}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUserId:completion:","type":"topic","abstract":[{"type":"text","text":"Sets a custom user identifier with completion confirmation."}],"role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setuserid:completion:","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setUserId:compl