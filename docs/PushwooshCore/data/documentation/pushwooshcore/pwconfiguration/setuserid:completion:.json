rs":[{"name":"userId","content":[{"type":"paragraph","inlineContent":[{"text":"The custom user identifier (e.g., database ID, UUID, username).","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Block called when the operation completes."},{"text":" ","type":"text"},{"type":"text","text":"Receives nil on success, or an NSError on failure."}]}],"name":"completion"}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Same as ","type":"text"},{"type":"codeVoice","code":"setUserId:"},{"type":"text","text":" but provides callback when the server operation completes."},{"text":" ","type":"text"},{"type":"text","text":"Use this when you need to ensure the user ID is set before performing"},{"text":" ","type":"text"},{"type":"text","text":"dependent operations like merging user data or tracking critical events."}]},{"type":"heading","text":"Example","level":2,"anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle login with guaranteed user ID synchronization:"}]},{"type":"codeListing","syntax":"swift","code":["class LoginCoordinator {","","    func performLogin(credentials: Credentials,","                      completion: @escaping (Result<User, Error>) -> Void) {","","        APIClient.shared.login(credentials) { result in","            switch result {","            case .success(let user):","                \/\/ Set user ID with confirmation before proceeding","                Pushwoosh.configure.setUserId(user.id) { error in","                    if let error = error {","                        Logger.warning(\"User ID sync failed: \\(error.localizedDescription)\")","                        \/\/ Continue anyway - local state is still valid","                    }","","                    \/\/ Now safe to track login event with correct user attribution","                    Pushwoosh.configure.setTags([","                        \"logged_in\": true,","                        \"last_login\": ISO8601DateFormatter().string(from: Date()),","                        \"login_method\": credentials.method.rawValue","                    ])","","                    \/\/ Set email if available","                    if let email = user.email {","                        Pushwoosh.configure.setEmail(email)","                    }","","                    completion(.success(user))","                }","","            case .failure(let error):","                completion(.failure(error))","            }","        }","    }","}"]}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"title":"PushwooshCore","kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setUserId:completion:":{"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setuserid:completion:","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUserId:completion:","title":"setUserId:completion:","navigatorTitle":[{"text":"setUserId:completion:","kind":"identifier"}],"role":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"setUserId:completion:","kind":"identifier"}],"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Sets a custom user identifier with completion confirmation."}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","role":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"kind":"symbol","type":"topic","abs