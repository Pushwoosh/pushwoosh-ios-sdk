{"sections":[],"abstract":[{"type":"text","text":"Retrieves the current device’s tags from the Pushwoosh server."}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/loadtags:error:"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/loadTags:error:","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"symbolKind":"method","roleHeading":"Type Method","navigatorTitle":[{"text":"loadTags:error:","kind":"identifier"}],"role":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"loadTags:error:","kind":"identifier"}],"title":"loadTags:error:","externalID":"c:objc(pl)PWConfiguration(cm)loadTags:error:","modules":[{"name":"PushwooshCore"}]},"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"text":"loadTags:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":" (^","kind":"text"},{"kind":"text","text":")("},{"preciseIdentifier":"c:objc(cs)NSDictionary","text":"NSDictionary","kind":"typeIdentifier"},{"text":" * ","kind":"text"},{"kind":"internalParam","text":"tags"},{"text":")) ","kind":"text"},{"kind":"internalParam","text":"successBlock"},{"kind":"text","text":" "},{"text":"error:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"kind":"text","text":" (^"},{"kind":"text","text":")("},{"text":"NSError","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSError"},{"kind":"text","text":" * "},{"text":"error","kind":"internalParam"},{"kind":"text","text":")) "},{"kind":"internalParam","text":"errorBlock"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"parameters":[{"name":"successBlock","content":[{"inlineContent":[{"text":"Block called when tags are successfully retrieved.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Receives a dictionary containing all device tags."}],"type":"paragraph"}]},{"name":"errorBlock","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Block called if the request fails."},{"type":"text","text":" "},{"type":"text","text":"Receives an error describing the failure."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"text":"Fetches all tags currently set for this device. Tags are returned as a dictionary where keys","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are tag names and values are the corresponding tag values."}],"type":"paragraph"},{"inlineContent":[{"text":"Use this to sync local app state with server-side tags, or to verify tag values.","type":"text"}],"type":"paragraph"},{"text":"Example","type":"heading","level":2,"anchor":"Example"},{"inlineContent":[{"text":"Sync user preferences from Pushwoosh tags on app launch:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["class UserPreferencesSync {","","    func syncPreferencesFromServer(completion: @escaping (Result<UserPreferences, Error>) -> Void) {","        Pushwoosh.configure.loadTags({ [weak self] tags in","            guard let tags = tags else {","                completion(.success(UserPreferences.default))","                return","            }","","            let preferences = UserPreferences(","                isPremium: tags[\"is_premium\"] as? Bool ?? false,","                subscriptionTier: tags[\"subscription_tier\"] as? String,","                favoriteCategories: tags[\"favorite_categories\"] as? [String] ?? [],","                notificationPreferences: self?.parseNotificationPrefs(from: tags) ?? .default,","                lastSyncDate: Date()","            )","","            \/\/ Cache locally","            self?.cachePreferences(preferences)","","            completion(.success(preferences))","            Logger.info(\"User preferences synced from server\")","","        }, error: { error in","            Logger.error(\"Failed to load tags: \\(error?.localizedDescription ?? \"Unknown error\")\")","","            \/\/ Fall back to cached preferences","            if let cached = self.loadCachedPreferences() {","                completion(.success(cached))","            } else {","                completion(.failure(error ?? PushwooshError.unknown))","            }","        })","    }","","    private func parseNotificationPrefs(from tags: [AnyHashable: Any]) -> NotificationPreferences {","        return NotificationPreferences(","            marketingEnabled: tags[\"marketing_notifications\"] as? Bool ?? true,","            transactionalEnabled: tags[\"transactional_notifications\"] as? Bool ?? true,","            frequencyCap: tags[\"notification_frequency\"] as? String ?? \"normal\"","        )","    }","}"],"type":"codeListing"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"title":"PushwooshCore","type":"topic","role":"collection","url":"\/documentation\/pushwooshcore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/loadTags:error:":{"url":"\/documentation\/pushwooshcore\/pwconfiguration\/loadtags:error:","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/loadTags:error:","type":"topic","title":"loadTags:error:","kind":"symbol","abstract":[{"type":"text","text":"Retrieves the current device’s tags from the Pushwoosh server."}],"role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"loadTags:error:","kind":"identifier"}],"navigatorTitle":[{"text":"loadTags:error:","kind":"identifier"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","abstract":[],"role":"symbol","type":"topic"}}}