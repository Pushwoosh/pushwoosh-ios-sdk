{"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/loadTags:error:"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"declarations":[{"languages":["occ"],"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"loadTags:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"kind":"text","text":" (^"},{"text":")(","kind":"text"},{"kind":"typeIdentifier","text":"NSDictionary","preciseIdentifier":"c:objc(cs)NSDictionary"},{"text":" * ","kind":"text"},{"text":"tags","kind":"internalParam"},{"kind":"text","text":")) "},{"text":"successBlock","kind":"internalParam"},{"kind":"text","text":" "},{"kind":"identifier","text":"error:"},{"kind":"text","text":"("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":" (^"},{"text":")(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSError","text":"NSError","kind":"typeIdentifier"},{"text":" * ","kind":"text"},{"text":"error","kind":"internalParam"},{"kind":"text","text":")) "},{"text":"errorBlock","kind":"internalParam"},{"kind":"text","text":";"}],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Block called when tags are successfully retrieved.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Receives a dictionary containing all device tags."}]}],"name":"successBlock"},{"name":"errorBlock","content":[{"inlineContent":[{"text":"Block called if the request fails.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Receives an error describing the failure."}],"type":"paragraph"}]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"Fetches all tags currently set for this device. Tags are returned as a dictionary where keys","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are tag names and values are the corresponding tag values."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use this to sync local app state with server-side tags, or to verify tag values."}],"type":"paragraph"},{"text":"Example","level":2,"anchor":"Example","type":"heading"},{"inlineContent":[{"text":"Sync user preferences from Pushwoosh tags on app launch:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["class UserPreferencesSync {","","    func syncPreferencesFromServer(completion: @escaping (Result<UserPreferences, Error>) -> Void) {","        Pushwoosh.configure.loadTags({ [weak self] tags in","            guard let tags = tags else {","                completion(.success(UserPreferences.default))","                return","            }","","            let preferences = UserPreferences(","                isPremium: tags[\"is_premium\"] as? Bool ?? false,","                subscriptionTier: tags[\"subscription_tier\"] as? String,","                favoriteCategories: tags[\"favorite_categories\"] as? [String] ?? [],","                notificationPreferences: self?.parseNotificationPrefs(from: tags) ?? .default,","                lastSyncDate: Date()","            )","","            \/\/ Cache locally","            self?.cachePreferences(preferences)","","            completion(.success(preferences))","            Logger.info(\"User preferences synced from server\")","","        }, error: { error in","            Logger.error(\"Failed to load tags: \\(error?.localizedDescription ?? \"Unknown error\")\")","","            \/\/ Fall back to cached preferences","            if let cached = self.loadCachedPreferences() {","                completion(.success(cached))","            } else {","                completion(.failure(error ?? PushwooshError.unknown))","            }","        })","    }","","    private func parseNotificationPrefs(from tags: [AnyHashable: Any]) -> NotificationPreferences {","        return NotificationPreferences(","            marketingEnabled: tags[\"marketing_notifications\"] as? Bool ?? true,","            transactionalEnabled: tags[\"transactional_notifications\"] as? Bool ?? true,","            frequencyCap: tags[\"notification_frequency\"] as? String ?? \"normal\"","        )","    }","}"],"type":"codeListing"}]}],"abstract":[{"type":"text","text":"Retrieves the current device’s tags from the Pushwoosh server."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/loadtags:error:"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}],"fragments":[{"text":"+ ","kind":"text"},{"text":"loadTags:error:","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"text":"loadTags:error:","kind":"identifier"}],"title":"loadTags:error:","symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)loadTags:error:"},"sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/loadTags:error:":{"url":"\/documentation\/pushwooshcore\/pwconfiguration\/loadtags:error:","fragments":[{"text":"+ ","kind":"text"},{"text":"loadTags:error:","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"text":"loadTags:error:","kind":"identifier"}],"title":"loadTags:error:","abstract":[{"text":"Retrieves the current device’s tags from the Pushwoosh server.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/loadTags:error:","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","url":"\/documentation\/pushwooshcore","kind":"symbol","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"role":"collection"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","type":"topic","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol"}}}