{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setPurchaseDelegate:","interfaceLanguage":"occ"},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"symbolKind":"method","navigatorTitle":[{"kind":"identifier","text":"setPurchaseDelegate:"}],"title":"setPurchaseDelegate:","role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)setPurchaseDelegate:","fragments":[{"text":"+ ","kind":"text"},{"text":"setPurchaseDelegate:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method"},"kind":"symbol","sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"setPurchaseDelegate:","kind":"identifier"},{"kind":"text","text":"("},{"text":"id<PWPurchaseDelegate>","kind":"typeIdentifier","preciseIdentifier":"c:Qoobjc(pl)PWPurchaseDelegate"},{"text":") ","kind":"text"},{"text":"delegate","kind":"internalParam"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"name":"delegate","content":[{"type":"paragraph","inlineContent":[{"text":"Object implementing PWPurchaseDelegate protocol, or nil to remove the delegate","type":"text"}]}]}]},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The delegate will receive callbacks for in-app purchase events triggered from","type":"text"},{"type":"text","text":" "},{"text":"Pushwoosh rich media content (HTML pages, in-app messages).","type":"text"}]},{"inlineContent":[{"type":"text","text":"This enables:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Handling promoted purchases from the App Store","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Processing purchases initiated from rich media"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Tracking purchase completions and failures"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Restoring previous purchases"}]}]}]},{"text":"Example","level":2,"anchor":"Example","type":"heading"},{"inlineContent":[{"text":"Handle in-app purchases from rich media:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class PurchaseCoordinator: NSObject, PWPurchaseDelegate {","","    static let shared = PurchaseCoordinator()","","    func setup() {","        Pushwoosh.configure.setPurchaseDelegate(self)","    }","","    \/\/ MARK: - PWPurchaseDelegate","","    func onPW(inAppPurchaseHelperCallPromotedPurchase identifier: String) {","        Logger.info(\"Promoted purchase initiated: \\(identifier)\")","","        \/\/ Verify user is ready to purchase","        guard UserSession.shared.isLoggedIn else {","            \/\/ Save for later and prompt login","            PendingPurchaseManager.shared.save(identifier)","            NavigationCoordinator.shared.showLogin(reason: .purchase)","            return","        }","","        \/\/ Process the purchase","        IAPManager.shared.purchase(productIdentifier: identifier)","    }","","    func onPWInAppPurchaseHelperPaymentComplete(_ identifier: String) {","        Logger.info(\"Purchase completed: \\(identifier)\")","","        \/\/ Update user status","        Pushwoosh.configure.setTags([","            \"last_purchase\": identifier,","            \"last_purchase_date\": Date(),","            \"has_purchased\": true","        ])","","        \/\/ Unlock content","        ContentUnlocker.shared.unlock(identifier)","","        \/\/ Track in analytics","        Analytics.track(\"purchase_completed\", properties: [","            \"product_id\": identifier,","            \"source\": \"rich_media\"","        ])","    }","","    func onPWInAppPurchaseHelperPaymentFailedProductIdentifier(_ identifier: String, error: Error) {","        Logger.error(\"Purchase failed: \\(identifier) - \\(error.localizedDescription)\")","","        Analytics.track(\"purchase_failed\", properties: [","            \"product_id\": identifier,","            \"error\": error.localizedDescription","        ])","    }","}"]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setpurchasedelegate:"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"type":"text","text":"Sets the delegate for in-app purchase events from rich media."}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","role":"symbol","title":"PWConfiguration","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","abstract":[]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setPurchaseDelegate:":{"navigatorTitle":[{"kind":"identifier","text":"setPurchaseDelegate:"}],"type":"topic","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setpurchasedelegate:","title":"setPurchaseDelegate:","kind":"symbol","role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setPurchaseDelegate:"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setPurchaseDelegate:","abstract":[{"type":"text","text":"Sets the delegate for in-app purchase events from rich media."}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","url":"\/documentat