{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"metadata":{"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"mergeUserId:to:doMerge:completion:"}],"modules":[{"name":"PushwooshCore"}],"role":"symbol","symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)mergeUserId:to:doMerge:completion:","navigatorTitle":[{"kind":"identifier","text":"mergeUserId:to:doMerge:completion:"}],"roleHeading":"Type Method","title":"mergeUserId:to:doMerge:completion:"},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"Merges engagement data from one user to another.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/mergeuserid:to:domerge:completion:"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"mergeUserId:"},{"text":"(","kind":"text"},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"text":"oldUserId","kind":"internalParam"},{"text":" ","kind":"text"},{"kind":"identifier","text":"to:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSString","text":"NSString","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"newUserId","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"doMerge:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"BOOL","preciseIdentifier":"c:@T@BOOL"},{"kind":"text","text":") "},{"kind":"internalParam","text":"doMerge"},{"text":" ","kind":"text"},{"text":"completion:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"kind":"text","text":" (^"},{"text":")(","kind":"text"},{"text":"NSError","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSError"},{"text":" * ","kind":"text"},{"kind":"internalParam","text":"error"},{"kind":"text","text":")) "},{"text":"completion","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The source user identifier whose data will be transferred\/deleted."}]}],"name":"oldUserId"},{"name":"newUserId","content":[{"inlineContent":[{"type":"text","text":"The destination user identifier to receive the merged data."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"If YES, transfers all events to newUserId. If NO, deletes events for oldUserId."}],"type":"paragraph"}],"name":"doMerge"},{"name":"completion","content":[{"type":"paragraph","inlineContent":[{"text":"Block called when the operation completes.","type":"text"},{"text":" ","type":"text"},{"text":"Receives nil on success, or an NSError on failure.","type":"text"}]}]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"text":"Transfers or removes push engagement history when user identity changes.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Common scenarios include:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Anonymous to authenticated"}]},{"text":": Merge anonymous browsing data to logged-in user","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Account linking","type":"text"}]},{"type":"text","text":": Combine data when user links multiple accounts"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Account recovery"}]},{"type":"text","text":": Transfer data to recovered account"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Data cleanup"}],"type":"strong"},{"type":"text","text":": Remove data for deleted\/merged accounts"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"When ","type":"text"},{"code":"doMerge","type":"codeVoice"},{"type":"text","text":" is YES, all events (push opens, in-app interactions, etc.)"},{"type":"text","text":" "},{"text":"from ","type":"text"},{"type":"codeVoice","code":"oldUserId"},{"type":"text","text":" are moved to "},{"type":"codeVoice","code":"newUserId"},{"text":". When NO, events for ","type":"text"},{"type":"codeVoice","code":"oldUserId"},{"text":" ","type":"text"},{"type":"text","text":"are simply deleted."}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"Example","text":"Example"},{"type":"paragraph","inlineContent":[{"text":"Merge anonymous user data after sign-up:","type":"text"}]},{"syntax":"swift","code":["class UserIdentityManager {","","    private var anonymousUserId: String?","","    func startAnonymousSession() {","        \/\/ Generate anonymous ID for tracking before login","        anonymousUserId = \"anon_\\(UUID().uuidString)\"","        Pushwoosh.configure.setUserId(anonymousUserId!)","","        Pushwoosh.configure.setTags([","            \"is_anonymous\": true,","            \"session_start\": ISO8601DateFormatter().string(from: Date())","        ])","    }","","    func convertToAuthenticatedUser(_ authenticatedUser: User,","                                    completion: @escaping (Result<Void, Error>) -> Void) {","","        guard let anonId = anonymousUserId else {","            \/\/ No anonymous session to merge","            setupAuthenticatedUser(authenticatedUser, completion: completion)","            return","        }","","        \/\/ First set the new authenticated user ID","        Pushwoosh.configure.setUser(authenticatedUser.id, email: authenticatedUser.email) { [weak self] error in","            if let error = error {","                completion(.failure(error))","                return","            }","","            \/\/ Merge anonymous engagement data to authenticated user","            Pushwoosh.configure.mergeUserId(anonId, to: authenticatedUser.id, doMerge: true) { mergeError in","                if let mergeError = mergeError {","                    Logger.warning(\"Merge failed: \\(mergeError.localizedDescription)\")","                    \/\/ Continue anyway - user is authenticated","                }","","                \/\/ Update tags for authenticated state","                Pushwoosh.configure.setTags([","                    \"is_anonymous\": false,","                    \"conversion_date\": ISO8601DateFormatter().string(from: Date()),","                    \"had_anonymous_session\": true","                ])","","                self?.anonymousUserId = nil","                completion(.success(()))","            }","        }","    }","","    func handleAccountDeletion(userId: String, completion: @escaping (Result<Void, Error>) -> Void) {","        \/\/ Remove user data without merging (doMerge: false)","        Pushwoosh.configure.mergeUserId(userId, to: \"\", doMerge: false) { error in","            if let error = error {","                completion(.failure(error))","                return","            }","","            Pushwoosh.configure.setUserId(\"\")","            Pushwoosh.configure.stopServerCommunication()","            completion(.success(()))","        }","    }","}"],"type":"codeListing"}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/mergeUserId:to:doMerge:completion:"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"role":"symbol","abstract":[],"title":"PWConfiguration","kind":"symbol","fragments":[{"kind":"identifier","text":"PW