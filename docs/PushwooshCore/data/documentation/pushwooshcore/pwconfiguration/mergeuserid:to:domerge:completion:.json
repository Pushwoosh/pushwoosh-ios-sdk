{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/mergeUserId:to:doMerge:completion:"},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/mergeuserid:to:domerge:completion:"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":") ","kind":"text"},{"text":"mergeUserId:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier","text":"NSString"},{"text":" *) ","kind":"text"},{"text":"oldUserId","kind":"internalParam"},{"kind":"text","text":" "},{"text":"to:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier","text":"NSString"},{"kind":"text","text":" *) "},{"text":"newUserId","kind":"internalParam"},{"kind":"text","text":" "},{"kind":"identifier","text":"doMerge:"},{"kind":"text","text":"("},{"text":"BOOL","kind":"typeIdentifier","preciseIdentifier":"c:@T@BOOL"},{"kind":"text","text":") "},{"kind":"internalParam","text":"doMerge"},{"kind":"text","text":" "},{"text":"completion:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":" (^","kind":"text"},{"kind":"text","text":")("},{"kind":"typeIdentifier","text":"NSError","preciseIdentifier":"c:objc(cs)NSError"},{"text":" * ","kind":"text"},{"text":"error","kind":"internalParam"},{"text":")) ","kind":"text"},{"kind":"internalParam","text":"completion"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"name":"oldUserId","content":[{"type":"paragraph","inlineContent":[{"text":"The source user identifier whose data will be transferred\/deleted.","type":"text"}]}]},{"name":"newUserId","content":[{"inlineContent":[{"text":"The destination user identifier to receive the merged data.","type":"text"}],"type":"paragraph"}]},{"name":"doMerge","content":[{"inlineContent":[{"type":"text","text":"If YES, transfers all events to newUserId. If NO, deletes events for oldUserId."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Block called when the operation completes."},{"type":"text","text":" "},{"text":"Receives nil on success, or an NSError on failure.","type":"text"}]}],"name":"completion"}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Transfers or removes push engagement history when user identity changes.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Common scenarios include:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Anonymous to authenticated"}],"type":"strong"},{"text":": Merge anonymous browsing data to logged-in user","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Account linking","type":"text"}],"type":"strong"},{"text":": Combine data when user links multiple accounts","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Account recovery"}]},{"text":": Transfer data to recovered account","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Data cleanup","type":"text"}],"type":"strong"},{"text":": Remove data for deleted\/merged accounts","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"When "},{"code":"doMerge","type":"codeVoice"},{"type":"text","text":" is YES, all events (push opens, in-app interactions, etc.)"},{"text":" ","type":"text"},{"text":"from ","type":"text"},{"type":"codeVoice","code":"oldUserId"},{"text":" are moved to ","type":"text"},{"type":"codeVoice","code":"newUserId"},{"type":"text","text":". When NO, events for "},{"type":"codeVoice","code":"oldUserId"},{"type":"text","text":" "},{"text":"are simply deleted.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Example","anchor":"Example","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Merge anonymous user data after sign-up:"}]},{"syntax":"swift","code":["class UserIdentityManager {","","    private var anonymousUserId: String?","","    func startAnonymousSession() {","        \/\/ Generate anonymous ID for tracking before login","        anonymousUserId = \"anon_\\(UUID().uuidString)\"","        Pushwoosh.configure.setUserId(anonymousUserId!)","","        Pushwoosh.configure.setTags([","            \"is_anonymous\": true,","            \"session_start\": ISO8601DateFormatter().string(from: Date())","        ])","    }","","    func convertToAuthenticatedUser(_ authenticatedUser: User,","                                    completion: @escaping (Result<Void, Error>) -> Void) {","","        guard let anonId = anonymousUserId else {","            \/\/ No anonymous session to merge","            setupAuthenticatedUser(authenticatedUser, completion: completion)","            return","        }","","        \/\/ First set the new authenticated user ID","        Pushwoosh.configure.setUser(authenticatedUser.id, email: authenticatedUser.email) { [weak self] error in","            if let error = error {","                completion(.failure(error))","                return","            }","","            \/\/ Merge anonymous engagement data to authenticated user","            Pushwoosh.configure.mergeUserId(anonId, to: authenticatedUser.id, doMerge: true) { mergeError in","                if let mergeError = mergeError {","                    Logger.warning(\"Merge failed: \\(mergeError.localizedDescription)\")","                    \/\/ Continue anyway - user is authenticated","                }","","                \/\/ Update tags for authenticated state","                Pushwoosh.configure.setTags([","                    \"is_anonymous\": false,","                    \"conversion_date\": ISO8601DateFormatter().string(from: Date()),","                    \"had_anonymous_session\": true","                ])","","                self?.anonymousUserId = nil","                completion(.success(()))","            }","        }","    }","","    func handleAccountDeletion(userId: String, completion: @escaping (Result<Void, Error>) -> Void) {","        \/\/ Remove user data without merging (doMerge: false)","        Pushwoosh.configure.mergeUserId(userId, to: \"\", doMerge: false) { error in","            if let error = error {","                completion(.failure(error))","                return","            }","","            Pushwoosh.configure.setUserId(\"\")","            Pushwoosh.configure.stopServerCommunication()","            completion(.success(()))","        }","    }","}"],"type":"codeListing"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Merges engagement data from one user to another."}],"kind":"symbol","metadata":{"title":"mergeUserId:to:doMerge:completion:","externalID":"c:objc(pl)PWConfiguration(cm)mergeUserId:to:doMerge:completion:","roleHeading":"Type Method","navigatorTitle":[{"kind":"identifier","text":"mergeUserId:to:doMerge:completion:"}],"role":"symbol","symbolKind":"method","modules":[{"name":"PushwooshCore"}],"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"mergeUserId:to:doMerge:completion:"}]},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","abstract":[],"role":"symbol","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/mergeUserId:to:doMerge:completion:":{"title":"mergeUserId:to:doMerge:completion:","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"mergeUserId:to:doMerge:completion:"}],"type":"topic","abstract":[{"type":"text","text":"Merges engagement data from one user to another."}],"role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/mergeuserid:to:domerge:completion:","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"mergeUserId:to:doMerge:completion:"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/mergeUserId:to:doMerge:completion:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"title":"PushwooshCore","type":"topic","role":"collection","url":"\/documentation\/pushwooshcore"}}}