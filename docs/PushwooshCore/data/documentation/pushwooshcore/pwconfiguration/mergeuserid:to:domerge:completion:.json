{"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Merges engagement data from one user to another."}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"text":") ","kind":"text"},{"kind":"identifier","text":"mergeUserId:"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString","text":"NSString"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"oldUserId"},{"kind":"text","text":" "},{"kind":"identifier","text":"to:"},{"text":"(","kind":"text"},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"newUserId"},{"text":" ","kind":"text"},{"text":"doMerge:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:@T@BOOL","kind":"typeIdentifier","text":"BOOL"},{"text":") ","kind":"text"},{"kind":"internalParam","text":"doMerge"},{"text":" ","kind":"text"},{"text":"completion:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":" (^","kind":"text"},{"kind":"text","text":")("},{"preciseIdentifier":"c:objc(cs)NSError","text":"NSError","kind":"typeIdentifier"},{"text":" * ","kind":"text"},{"text":"error","kind":"internalParam"},{"kind":"text","text":")) "},{"text":"completion","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The source user identifier whose data will be transferred\/deleted.","type":"text"}]}],"name":"oldUserId"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The destination user identifier to receive the merged data.","type":"text"}]}],"name":"newUserId"},{"content":[{"inlineContent":[{"type":"text","text":"If YES, transfers all events to newUserId. If NO, deletes events for oldUserId."}],"type":"paragraph"}],"name":"doMerge"},{"name":"completion","content":[{"inlineContent":[{"type":"text","text":"Block called when the operation completes."},{"text":" ","type":"text"},{"type":"text","text":"Receives nil on success, or an NSError on failure."}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"Transfers or removes push engagement history when user identity changes."},{"type":"text","text":" "},{"type":"text","text":"Common scenarios include:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Anonymous to authenticated"}]},{"type":"text","text":": Merge anonymous browsing data to logged-in user"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Account linking","type":"text"}]},{"type":"text","text":": Combine data when user links multiple accounts"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Account recovery"}]},{"type":"text","text":": Transfer data to recovered account"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Data cleanup","type":"text"}]},{"type":"text","text":": Remove data for deleted\/merged accounts"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"code":"doMerge","type":"codeVoice"},{"type":"text","text":" is YES, all events (push opens, in-app interactions, etc.)"},{"text":" ","type":"text"},{"type":"text","text":"from "},{"type":"codeVoice","code":"oldUserId"},{"text":" are moved to ","type":"text"},{"code":"newUserId","type":"codeVoice"},{"text":". When NO, events for ","type":"text"},{"type":"codeVoice","code":"oldUserId"},{"type":"text","text":" "},{"type":"text","text":"are simply deleted."}]},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"inlineContent":[{"type":"text","text":"Merge anonymous user data after sign-up:"}],"type":"paragraph"},{"code":["class UserIdentityManager {","","    private var anonymousUserId: String?","","    func startAnonymousSession() {","        \/\/ Generate anonymous ID for tracking before login","        anonymousUserId = \"anon_\\(UUID().uuidString)\"","        Pushwoosh.configure.setUserId(anonymousUserId!)","","        Pushwoosh.configure.setTags([","            \"is_anonymous\": true,","            \"session_start\": ISO8601DateFormatter().string(from: Date())","        ])","    }","","    func convertToAuthenticatedUser(_ authenticatedUser: User,","                                    completion: @escaping (Result<Void, Error>) -> Void) {","","        guard let anonId = anonymousUserId else {","            \/\/ No anonymous session to merge","            setupAuthenticatedUser(authenticatedUser, completion: completion)","            return","        }","","        \/\/ First set the new authenticated user ID","        Pushwoosh.configure.setUser(authenticatedUser.id, email: authenticatedUser.email) { [weak self] error in","            if let error = error {","                completion(.failure(error))","                return","            }","","            \/\/ Merge anonymous engagement data to authenticated user","            Pushwoosh.configure.mergeUserId(anonId, to: authenticatedUser.id, doMerge: true) { mergeError in","                if let mergeError = mergeError {","                    Logger.warning(\"Merge failed: \\(mergeError.localizedDescription)\")","                    \/\/ Continue anyway - user is authenticated","                }","","                \/\/ Update tags for authenticated state","                Pushwoosh.configure.setTags([","                    \"is_anonymous\": false,","                    \"conversion_date\": ISO8601DateFormatter().string(from: Date()),","                    \"had_anonymous_session\": true","                ])","","                self?.anonymousUserId = nil","                completion(.success(()))","            }","        }","    }","","    func handleAccountDeletion(userId: String, completion: @escaping (Result<Void, Error>) -> Void) {","        \/\/ Remove user data without merging (doMerge: false)","        Pushwoosh.configure.mergeUserId(userId, to: \"\", doMerge: false) { error in","            if let error = error {","                completion(.failure(error))","                return","            }","","            Pushwoosh.configure.setUserId(\"\")","            Pushwoosh.configure.stopServerCommunication()","            completion(.success(()))","        }","    }","}"],"type":"codeListing","syntax":"swift"}]}],"sections":[],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/mergeuserid:to:domerge:completion:"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","metadata":{"modules":[{"name":"PushwooshCore"}],"symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)mergeUserId:to:doMerge:completion:","fragments":[{"text":"+ ","kind":"text"},{"text":"mergeUserId:to:doMerge:completion:","kind":"identifier"}],"navigatorTitle":[{"text":"mergeUserId:to:doMerge:completion:","kind":"identifier"}],"title":"mergeUserId:to:doMerge:completion:","roleHeading":"Type Method","role":"symbol"},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/mergeUserId:to:doMerge:completion:"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/mergeUserId:to:doMerge:completion:":{"abstract":[{"type":"text","text":"Merges engagement data from one user to another."}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"mergeUserId:to:doMerge:completion:"}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/mergeUserId:to:doMerge:completion:","title":"mergeUserId:to:doMerge:completion:","fragments":[{"text":"+ ","kind":"text"},{"text":"mergeUserId:to:doMerge:completion:","kind":"identifier"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/mergeuserid:to:domerge:completion:","role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","abstract":[],"kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"role":"collection","title":"PushwooshCore","url":"\/documentation\/pushwooshcore","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic"}}}