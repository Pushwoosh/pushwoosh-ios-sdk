{"metadata":{"roleHeading":"Type Method","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"mergeUserId:to:doMerge:completion:"}],"modules":[{"name":"PushwooshCore"}],"symbolKind":"method","title":"mergeUserId:to:doMerge:completion:","externalID":"c:objc(pl)PWConfiguration(cm)mergeUserId:to:doMerge:completion:","navigatorTitle":[{"text":"mergeUserId:to:doMerge:completion:","kind":"identifier"}],"role":"symbol"},"sections":[],"abstract":[{"type":"text","text":"Merges engagement data from one user to another."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"kind":"identifier","text":"mergeUserId:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString","text":"NSString"},{"kind":"text","text":" *) "},{"text":"oldUserId","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"to:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier","text":"NSString"},{"kind":"text","text":" *) "},{"text":"newUserId","kind":"internalParam"},{"kind":"text","text":" "},{"text":"doMerge:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:@T@BOOL","kind":"typeIdentifier","text":"BOOL"},{"kind":"text","text":") "},{"text":"doMerge","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"completion:","kind":"identifier"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"text":" (^","kind":"text"},{"kind":"text","text":")("},{"preciseIdentifier":"c:objc(cs)NSError","text":"NSError","kind":"typeIdentifier"},{"text":" * ","kind":"text"},{"kind":"internalParam","text":"error"},{"kind":"text","text":")) "},{"text":"completion","kind":"internalParam"},{"text":";","kind":"text"}]}]},{"kind":"parameters","parameters":[{"name":"oldUserId","content":[{"inlineContent":[{"type":"text","text":"The source user identifier whose data will be transferred\/deleted."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The destination user identifier to receive the merged data.","type":"text"}]}],"name":"newUserId"},{"name":"doMerge","content":[{"inlineContent":[{"text":"If YES, transfers all events to newUserId. If NO, deletes events for oldUserId.","type":"text"}],"type":"paragraph"}]},{"name":"completion","content":[{"type":"paragraph","inlineContent":[{"text":"Block called when the operation completes.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Receives nil on success, or an NSError on failure."}]}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Transfers or removes push engagement history when user identity changes.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Common scenarios include:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Anonymous to authenticated"}],"type":"strong"},{"type":"text","text":": Merge anonymous browsing data to logged-in user"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Account linking","type":"text"}],"type":"strong"},{"type":"text","text":": Combine data when user links multiple accounts"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Account recovery","type":"text"}]},{"text":": Transfer data to recovered account","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Data cleanup"}],"type":"strong"},{"type":"text","text":": Remove data for deleted\/merged accounts"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"code":"doMerge","type":"codeVoice"},{"text":" is YES, all events (push opens, in-app interactions, etc.)","type":"text"},{"text":" ","type":"text"},{"text":"from ","type":"text"},{"code":"oldUserId","type":"codeVoice"},{"text":" are moved to ","type":"text"},{"type":"codeVoice","code":"newUserId"},{"text":". When NO, events for ","type":"text"},{"type":"codeVoice","code":"oldUserId"},{"text":" ","type":"text"},{"text":"are simply deleted.","type":"text"}]},{"text":"Example","level":2,"anchor":"Example","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Merge anonymous user data after sign-up:","type":"text"}]},{"code":["class UserIdentityManager {","","    private var anonymousUserId: String?","","    func startAnonymousSession() {","        \/\/ Generate anonymous ID for tracking before login","        anonymousUserId = \"anon_\\(UUID().uuidString)\"","        Pushwoosh.configure.setUserId(anonymousUserId!)","","        Pushwoosh.configure.setTags([","            \"is_anonymous\": true,","            \"session_start\": ISO8601DateFormatter().string(from: Date())","        ])","    }","","    func convertToAuthenticatedUser(_ authenticatedUser: User,","                                    completion: @escaping (Result<Void, Error>) -> Void) {","","        guard let anonId = anonymousUserId else {","            \/\/ No anonymous session to merge","            setupAuthenticatedUser(authenticatedUser, completion: completion)","            return","        }","","        \/\/ First set the new authenticated user ID","        Pushwoosh.configure.setUser(authenticatedUser.id, email: authenticatedUser.email) { [weak self] error in","            if let error = error {","                completion(.failure(error))","                return","            }","","            \/\/ Merge anonymous engagement data to authenticated user","            Pushwoosh.configure.mergeUserId(anonId, to: authenticatedUser.id, doMerge: true) { mergeError in","                if let mergeError = mergeError {","                    Logger.warning(\"Merge failed: \\(mergeError.localizedDescription)\")","                    \/\/ Continue anyway - user is authenticated","                }","","                \/\/ Update tags for authenticated state","                Pushwoosh.configure.setTags([","                    \"is_anonymous\": false,","                    \"conversion_date\": ISO8601DateFormatter().string(from: Date()),","                    \"had_anonymous_session\": true","                ])","","                self?.anonymousUserId = nil","                completion(.success(()))","            }","        }","    }","","    func handleAccountDeletion(userId: String, completion: @escaping (Result<Void, Error>) -> Void) {","        \/\/ Remove user data without merging (doMerge: false)","        Pushwoosh.configure.mergeUserId(userId, to: \"\", doMerge: false) { error in","            if let error = error {","                completion(.failure(error))","                return","            }","","            Pushwoosh.configure.setUserId(\"\")","            Pushwoosh.configure.stopServerCommunication()","            completion(.success(()))","        }","    }","}"],"syntax":"swift","type":"codeListing"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/mergeuserid:to:domerge:completion:"]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/mergeUserId:to:doMerge:completion:","interfaceLanguage":"occ"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/mergeUserId:to:doMerge:completion:":{"role":"symbol","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"mergeUserId:to:doMerge:completion:"}],"title":"mergeUserId:to:doMerge:completion:","navigatorTitle":[{"kind":"identifier","text":"mergeUserId:to:doMerge:completion:"}],"abstract":[{"type":"text","text":"Merges engagement data from one user to another."}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/mergeuserid:to:domerge:completion:","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/mergeUserId:to:doMerge:completion:","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"role":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","title":"PWConfiguration","kind":"symbol","type":"topic","abstract":[]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","role":"collection","kind":"symbol","type":"topic","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore"}}}