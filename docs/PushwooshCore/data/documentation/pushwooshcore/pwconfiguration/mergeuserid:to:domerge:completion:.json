{"kind":"symbol","metadata":{"fragments":[{"kind":"text","text":"+ "},{"text":"mergeUserId:to:doMerge:completion:","kind":"identifier"}],"symbolKind":"method","navigatorTitle":[{"text":"mergeUserId:to:doMerge:completion:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"title":"mergeUserId:to:doMerge:completion:","role":"symbol","roleHeading":"Type Method","externalID":"c:objc(pl)PWConfiguration(cm)mergeUserId:to:doMerge:completion:"},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"Merges engagement data from one user to another.","type":"text"}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/mergeUserId:to:doMerge:completion:","interfaceLanguage":"occ"},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/mergeuserid:to:domerge:completion:"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"mergeUserId:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString","text":"NSString"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"oldUserId"},{"text":" ","kind":"text"},{"text":"to:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier","text":"NSString"},{"kind":"text","text":" *) "},{"text":"newUserId","kind":"internalParam"},{"text":" ","kind":"text"},{"kind":"identifier","text":"doMerge:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:@T@BOOL","text":"BOOL","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"doMerge","kind":"internalParam"},{"kind":"text","text":" "},{"kind":"identifier","text":"completion:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":" (^","kind":"text"},{"text":")(","kind":"text"},{"text":"NSError","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSError"},{"text":" * ","kind":"text"},{"kind":"internalParam","text":"error"},{"text":")) ","kind":"text"},{"text":"completion","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}]},{"parameters":[{"name":"oldUserId","content":[{"type":"paragraph","inlineContent":[{"text":"The source user identifier whose data will be transferred\/deleted.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The destination user identifier to receive the merged data."}]}],"name":"newUserId"},{"name":"doMerge","content":[{"type":"paragraph","inlineContent":[{"text":"If YES, transfers all events to newUserId. If NO, deletes events for oldUserId.","type":"text"}]}]},{"name":"completion","content":[{"type":"paragraph","inlineContent":[{"text":"Block called when the operation completes.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Receives nil on success, or an NSError on failure."}]}]}],"kind":"parameters"},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"Transfers or removes push engagement history when user identity changes."},{"text":" ","type":"text"},{"type":"text","text":"Common scenarios include:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Anonymous to authenticated","type":"text"}],"type":"strong"},{"type":"text","text":": Merge anonymous browsing data to logged-in user"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Account linking","type":"text"}],"type":"strong"},{"type":"text","text":": Combine data when user links multiple accounts"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Account recovery","type":"text"}],"type":"strong"},{"text":": Transfer data to recovered account","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Data cleanup"}]},{"type":"text","text":": Remove data for deleted\/merged accounts"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"code":"doMerge","type":"codeVoice"},{"text":" is YES, all events (push opens, in-app interactions, etc.)","type":"text"},{"text":" ","type":"text"},{"text":"from ","type":"text"},{"code":"oldUserId","type":"codeVoice"},{"text":" are moved to ","type":"text"},{"type":"codeVoice","code":"newUserId"},{"type":"text","text":". When NO, events for "},{"type":"codeVoice","code":"oldUserId"},{"text":" ","type":"text"},{"type":"text","text":"are simply deleted."}]},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Merge anonymous user data after sign-up:"}]},{"type":"codeListing","code":["class UserIdentityManager {","","    private var anonymousUserId: String?","","    func startAnonymousSession() {","        \/\/ Generate anonymous ID for tracking before login","        anonymousUserId = \"anon_\\(UUID().uuidString)\"","        Pushwoosh.configure.setUserId(anonymousUserId!)","","        Pushwoosh.configure.setTags([","            \"is_anonymous\": true,","            \"session_start\": ISO8601DateFormatter().string(from: Date())","        ])","    }","","    func convertToAuthenticatedUser(_ authenticatedUser: User,","                                    completion: @escaping (Result<Void, Error>) -> Void) {","","        guard let anonId = anonymousUserId else {","            \/\/ No anonymous session to merge","            setupAuthenticatedUser(authenticatedUser, completion: completion)","            return","        }","","        \/\/ First set the new authenticated user ID","        Pushwoosh.configure.setUser(authenticatedUser.id, email: authenticatedUser.email) { [weak self] error in","            if let error = error {","                completion(.failure(error))","                return","            }","","            \/\/ Merge anonymous engagement data to authenticated user","            Pushwoosh.configure.mergeUserId(anonId, to: authenticatedUser.id, doMerge: true) { mergeError in","                if let mergeError = mergeError {","                    Logger.warning(\"Merge failed: \\(mergeError.localizedDescription)\")","                    \/\/ Continue anyway - user is authenticated","                }","","                \/\/ Update tags for authenticated state","                Pushwoosh.configure.setTags([","                    \"is_anonymous\": false,","                    \"conversion_date\": ISO8601DateFormatter().string(from: Date()),","                    \"had_anonymous_session\": true","                ])","","                self?.anonymousUserId = nil","                completion(.success(()))","            }","        }","    }","","    func handleAccountDeletion(userId: String, completion: @escaping (Result<Void, Error>) -> Void) {","        \/\/ Remove user data without merging (doMerge: false)","        Pushwoosh.configure.mergeUserId(userId, to: \"\", doMerge: false) { error in","            if let error = error {","                completion(.failure(error))","                return","            }","","            Pushwoosh.configure.setUserId(\"\")","            Pushwoosh.configure.stopServerCommunication()","            completion(.success(()))","        }","    }","}"],"syntax":"swift"}],"kind":"content"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"kind":"symbol","type":"topic","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"abstract":[],"role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","title":"PWConfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","kind":"symbol","title":"PushwooshCore","type":"topic","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","role":"collection"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/mergeUserId:to:doMerge:completion:":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/mergeUserId:to:doMerge:completion:","title":"mergeUserId:to:doMerge:completion:","navigatorTitle":[{"text":"mergeUserId:to:doMerge:completion:","kind":"identifier"}],"role":"symbol","abstract":[{"type":"text","text":"Merges engagement data from one user to another."}],"fragments":[{"text":"+ ","kind":"text"},{"text":"mergeUserId:to:doMerge:completion:","kind":"identifier"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/mergeuserid:to:domerge:completion:","type":"topic","kind":"symbol"}}}