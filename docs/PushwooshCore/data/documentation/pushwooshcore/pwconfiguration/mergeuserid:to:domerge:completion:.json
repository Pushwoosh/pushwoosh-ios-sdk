{"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"abstract":[{"type":"text","text":"Merges engagement data from one user to another."}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/mergeUserId:to:doMerge:completion:","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"kind":"identifier","text":"mergeUserId:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString","text":"NSString"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"oldUserId"},{"text":" ","kind":"text"},{"text":"to:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"NSString","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"newUserId"},{"text":" ","kind":"text"},{"text":"doMerge:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"BOOL","preciseIdentifier":"c:@T@BOOL"},{"kind":"text","text":") "},{"text":"doMerge","kind":"internalParam"},{"kind":"text","text":" "},{"text":"completion:","kind":"identifier"},{"kind":"text","text":"("},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"kind":"text","text":" (^"},{"kind":"text","text":")("},{"text":"NSError","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSError"},{"text":" * ","kind":"text"},{"kind":"internalParam","text":"error"},{"text":")) ","kind":"text"},{"text":"completion","kind":"internalParam"},{"kind":"text","text":";"}]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The source user identifier whose data will be transferred\/deleted."}]}],"name":"oldUserId"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The destination user identifier to receive the merged data.","type":"text"}]}],"name":"newUserId"},{"content":[{"type":"paragraph","inlineContent":[{"text":"If YES, transfers all events to newUserId. If NO, deletes events for oldUserId.","type":"text"}]}],"name":"doMerge"},{"name":"completion","content":[{"type":"paragraph","inlineContent":[{"text":"Block called when the operation completes.","type":"text"},{"type":"text","text":" "},{"text":"Receives nil on success, or an NSError on failure.","type":"text"}]}]}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Transfers or removes push engagement history when user identity changes."},{"text":" ","type":"text"},{"type":"text","text":"Common scenarios include:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Anonymous to authenticated","type":"text"}],"type":"strong"},{"type":"text","text":": Merge anonymous browsing data to logged-in user"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Account linking","type":"text"}],"type":"strong"},{"type":"text","text":": Combine data when user links multiple accounts"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Account recovery"}]},{"text":": Transfer data to recovered account","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Data cleanup","type":"text"}]},{"text":": Remove data for deleted\/merged accounts","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"When ","type":"text"},{"type":"codeVoice","code":"doMerge"},{"type":"text","text":" is YES, all events (push opens, in-app interactions, etc.)"},{"type":"text","text":" "},{"text":"from ","type":"text"},{"code":"oldUserId","type":"codeVoice"},{"text":" are moved to ","type":"text"},{"type":"codeVoice","code":"newUserId"},{"type":"text","text":". When NO, events for "},{"code":"oldUserId","type":"codeVoice"},{"text":" ","type":"text"},{"text":"are simply deleted.","type":"text"}],"type":"paragraph"},{"type":"heading","anchor":"Example","text":"Example","level":2},{"inlineContent":[{"type":"text","text":"Merge anonymous user data after sign-up:"}],"type":"paragraph"},{"syntax":"swift","code":["class UserIdentityManager {","","    private var anonymousUserId: String?","","    func startAnonymousSession() {","        \/\/ Generate anonymous ID for tracking before login","        anonymousUserId = \"anon_\\(UUID().uuidString)\"","        Pushwoosh.configure.setUserId(anonymousUserId!)","","        Pushwoosh.configure.setTags([","            \"is_anonymous\": true,","            \"session_start\": ISO8601DateFormatter().string(from: Date())","        ])","    }","","    func convertToAuthenticatedUser(_ authenticatedUser: User,","                                    completion: @escaping (Result<Void, Error>) -> Void) {","","        guard let anonId = anonymousUserId else {","            \/\/ No anonymous session to merge","            setupAuthenticatedUser(authenticatedUser, completion: completion)","            return","        }","","        \/\/ First set the new authenticated user ID","        Pushwoosh.configure.setUser(authenticatedUser.id, email: authenticatedUser.email) { [weak self] error in","            if let error = error {","                completion(.failure(error))","                return","            }","","            \/\/ Merge anonymous engagement data to authenticated user","            Pushwoosh.configure.mergeUserId(anonId, to: authenticatedUser.id, doMerge: true) { mergeError in","                if let mergeError = mergeError {","                    Logger.warning(\"Merge failed: \\(mergeError.localizedDescription)\")","                    \/\/ Continue anyway - user is authenticated","                }","","                \/\/ Update tags for authenticated state","                Pushwoosh.configure.setTags([","                    \"is_anonymous\": false,","                    \"conversion_date\": ISO8601DateFormatter().string(from: Date()),","                    \"had_anonymous_session\": true","                ])","","                self?.anonymousUserId = nil","                completion(.success(()))","            }","        }","    }","","    func handleAccountDeletion(userId: String, completion: @escaping (Result<Void, Error>) -> Void) {","        \/\/ Remove user data without merging (doMerge: false)","        Pushwoosh.configure.mergeUserId(userId, to: \"\", doMerge: false) { error in","            if let error = error {","                completion(.failure(error))","                return","            }","","            Pushwoosh.configure.setUserId(\"\")","            Pushwoosh.configure.stopServerCommunication()","            completion(.success(()))","        }","    }","}"],"type":"codeListing"}]}],"kind":"symbol","metadata":{"modules":[{"name":"PushwooshCore"}],"title":"mergeUserId:to:doMerge:completion:","navigatorTitle":[{"text":"mergeUserId:to:doMerge:completion:","kind":"identifier"}],"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"mergeUserId:to:doMerge:completion:"}],"symbolKind":"method","role":"symbol","roleHeading":"Type Method","externalID":"c:objc(pl)PWConfiguration(cm)mergeUserId:to:doMerge:completion:"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/mergeuserid:to:domerge:completion:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/mergeUserId:to:doMerge:completion:":{"url":"\/documentation\/pushwooshcore\/pwconfiguration\/mergeuserid:to:domerge:completion:","role":"symbol","abstract":[{"type":"text","text":"Merges engagement data from one user to another."}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/mergeUserId:to:doMerge:completion:","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"mergeUserId:to:doMerge:completion:"}],"type":"topic","navigatorTitle":[{"text":"mergeUserId:to:doMerge:completion:","kind":"identifier"}],"title":"mergeUserId:to:doMerge:completion:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","kind":"symbol","title":"PWConfiguration","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","abstract":[],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","title":"PushwooshCore","role":"collection","url":"\/documentation\/pushwooshcore"}}}