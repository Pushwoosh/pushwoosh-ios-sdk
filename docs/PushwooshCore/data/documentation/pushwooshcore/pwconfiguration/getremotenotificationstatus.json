[{"type":"paragraph","inlineContent":[{"type":"text","text":"Key"}]}],[{"type":"paragraph","inlineContent":[{"text":"Type","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"enabled"}]}],[{"type":"paragraph","inlineContent":[{"text":"Bool","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Whether notifications are enabled"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"pushAlert"}]}],[{"type":"paragraph","inlineContent":[{"text":"Bool","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Whether alert banners are allowed"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"pushBadge","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bool"}]}],[{"inlineContent":[{"type":"text","text":"Whether badge updates are allowed"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"code":"pushSound","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bool"}]}],[{"type":"paragraph","inlineContent":[{"text":"Whether notification sounds are allowed","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"type"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Int"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Combined notification type bitmask"}]}]]]},{"level":2,"text":"Example","type":"heading","anchor":"Example"},{"type":"paragraph","inlineContent":[{"text":"Check notification status and prompt user if disabled:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class NotificationStatusManager {","","    func checkAndPromptForNotifications() {","        guard let status = Pushwoosh.configure.getRemoteNotificationStatus() else {","            Logger.warning(\"Could not retrieve notification status\")","            return","        }","","        let isEnabled = status[\"enabled\"] as? Bool ?? false","        let hasAlert = status[\"pushAlert\"] as? Bool ?? false","        let hasBadge = status[\"pushBadge\"] as? Bool ?? false","        let hasSound = status[\"pushSound\"] as? Bool ?? false","","        Logger.debug(\"\"\"","            Notification Status:","            - Enabled: \\(isEnabled)","            - Alert: \\(hasAlert)","            - Badge: \\(hasBadge)","            - Sound: \\(hasSound)","            \"\"\")","","        if !isEnabled {","            promptToEnableNotifications()","        } else if !hasAlert {","            promptToEnableAlerts()","        }","    }","","    private func promptToEnableNotifications() {","        let alert = UIAlertController(","            title: \"Enable Notifications\",","            message: \"You're missing out on important updates. Enable notifications in Settings.\",","            preferredStyle: .alert","        )","","        alert.addAction(UIAlertAction(title: \"Open Settings\", style: .default) { _ in","            if let settingsURL = URL(string: UIApplication.openSettingsURLString) {","                UIApplication.shared.open(settingsURL)","            }","        })","","        alert.addAction(UIAlertAction(title: \"Not Now\", style: .cancel))","","        UIApplication.topViewController()?.present(alert, animated: true)","    }","}"]},{"inlineContent":[{"type":"text","text":"for more detailed status information."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/getremotenotificationstatus"]}],"sections":[],"abstract":[{"text":"Returns dictionary with enabled remote notification types.","type":"text"}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getRemoteNotificationStatus","interfaceLanguage":"occ"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/Pushwoos