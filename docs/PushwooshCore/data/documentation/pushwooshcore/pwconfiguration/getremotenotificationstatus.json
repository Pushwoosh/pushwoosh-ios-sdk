   if !isEnabled {","            promptToEnableNotifications()","        } else if !hasAlert {","            promptToEnableAlerts()","        }","    }","","    private func promptToEnableNotifications() {","        let alert = UIAlertController(","            title: \"Enable Notifications\",","            message: \"You're missing out on important updates. Enable notifications in Settings.\",","            preferredStyle: .alert","        )","","        alert.addAction(UIAlertAction(title: \"Open Settings\", style: .default) { _ in","            if let settingsURL = URL(string: UIApplication.openSettingsURLString) {","                UIApplication.shared.open(settingsURL)","            }","        })","","        alert.addAction(UIAlertAction(title: \"Not Now\", style: .cancel))","","        UIApplication.topViewController()?.present(alert, animated: true)","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"for more detailed status information.","type":"text"}]}],"kind":"content"}],"abstract":[{"text":"Returns dictionary with enabled remote notification types.","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getRemoteNotificationStatus","interfaceLanguage":"occ"},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/getremotenotificationstatus"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"title":"getRemoteNotificationStatus","symbolKind":"method","modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)getRemoteNotificationStatus","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"getRemoteNotificationStatus"}],"navigatorTitle":[{"kind":"identifier","text":"getRemoteNotificationStatus"}],"role":"symbol","roleHeading":"Type Method"},"sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/Pushwoos