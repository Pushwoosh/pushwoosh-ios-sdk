t":"Whether notifications are enabled overall"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Which notification types are allowed (alert, badge, sound)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The authorization status"}]}]}]},{"type":"heading","level":2,"anchor":"Dictionary-Keys","text":"Dictionary Keys"},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Key","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Type","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"inlineContent":[{"type":"codeVoice","code":"enabled"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Bool"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Whether notifications are enabled"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"pushAlert"}]}],[{"type":"paragraph","inlineContent":[{"text":"Bool","type":"text"}]}],[{"inlineContent":[{"text":"Whether alert banners are allowed","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"pushBadge"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bool"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Whether badge updates are allowed"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"pushSound"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bool"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Whether notification sounds are allowed"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"type"}]}],[{"inlineContent":[{"type":"text","text":"Int"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Combined notification type bitmask"}]}]]]},{"text":"Example","type":"heading","anchor":"Example","level":2},{"inlineContent":[{"text":"Check notification status and prompt user if disabled:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class NotificationStatusManager {","","    func checkAndPromptForNotifications() {","        guard let status = Pushwoosh.configure.getRemoteNotificationStatus() else {","            Logger.warning(\"Could not retrieve notification status\")","            return","        }","","        let isEnabled = status[\"enabled\"] as? Bool ?? false","        let hasAlert = status[\"pushAlert\"] as? Bool ?? false","        let hasBadge = status[\"pushBadge\"] as? Bool ?? false","        let hasSound = status[\"pushSound\"] as? Bool ?? false","","        Logger.debug(\"\"\"","            Notification Status:","            - Enabled: \\(isEnabled)","            - Alert: \\(hasAlert)","            - Badge: \\(hasBadge)","            - Sound: \\(hasSound)","            \"\"\")","","        if !isEnabled {","            promptToEnableNotifications()","        } else if !hasAlert {","            promptToEnableAlerts()","        }","    }","","    private func promptToEnableNotifications() {","        let alert = UIAlertController(","            title: \"Enable Notifications\",","            message: \"You're missing out on important updates. Enable notifications in Settings.\",","            preferredStyle: .alert","        )","","        alert.addAction(UIAlertAction(title: \"Open Settings\", style: .default) { _ in","            if let settingsURL = URL(string: UIApplication.openSettingsURLString) {","                UIApplication.shared.open(settingsURL)","            }","        })","","        alert.addAction(UIAlertAction(title: \"Not Now\", style: .cancel))","","        UIApplication.topViewController()?.present(alert, animated: true)","    }","}"]},{"inlineContent":[{"text":"for more detailed status information.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/Pushwoos