aph","inlineContent":[{"type":"codeVoice","code":"pushAlert"}]}],[{"type":"paragraph","inlineContent":[{"text":"Bool","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"Whether alert banners are allowed"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"pushBadge"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bool"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Whether badge updates are allowed"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"pushSound","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Bool","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Whether notification sounds are allowed"}]}]],[[{"inlineContent":[{"code":"type","type":"codeVoice"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Int","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Combined notification type bitmask","type":"text"}]}]]]},{"type":"heading","anchor":"Example","text":"Example","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Check notification status and prompt user if disabled:"}]},{"type":"codeListing","code":["class NotificationStatusManager {","","    func checkAndPromptForNotifications() {","        guard let status = Pushwoosh.configure.getRemoteNotificationStatus() else {","            Logger.warning(\"Could not retrieve notification status\")","            return","        }","","        let isEnabled = status[\"enabled\"] as? Bool ?? false","        let hasAlert = status[\"pushAlert\"] as? Bool ?? false","        let hasBadge = status[\"pushBadge\"] as? Bool ?? false","        let hasSound = status[\"pushSound\"] as? Bool ?? false","","        Logger.debug(\"\"\"","            Notification Status:","            - Enabled: \\(isEnabled)","            - Alert: \\(hasAlert)","            - Badge: \\(hasBadge)","            - Sound: \\(hasSound)","            \"\"\")","","        if !isEnabled {","            promptToEnableNotifications()","        } else if !hasAlert {","            promptToEnableAlerts()","        }","    }","","    private func promptToEnableNotifications() {","        let alert = UIAlertController(","            title: \"Enable Notifications\",","            message: \"You're missing out on important updates. Enable notifications in Settings.\",","            preferredStyle: .alert","        )","","        alert.addAction(UIAlertAction(title: \"Open Settings\", style: .default) { _ in","            if let settingsURL = URL(string: UIApplication.openSettingsURLString) {","                UIApplication.shared.open(settingsURL)","            }","        })","","        alert.addAction(UIAlertAction(title: \"Not Now\", style: .cancel))","","        UIApplication.topViewController()?.present(alert, animated: true)","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"for more detailed status information.","type":"text"}]}],"kind":"content"}],"sections":[],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getRemoteNotificationStatus","interfaceLanguage":"occ"},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"Returns dictionary with enabled remote notification types."}],"metadata":{"symbolKind":"method","roleHeading":"Type Method","role":"symbol","title":"getRemoteNotificationStatus","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"getRemoteNotificationStatus"}],"modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)getRemoteNotificationStatus","navigatorTitle":[{"text":"getRemoteNotificationStatus","kind":"identifier"}]},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/Pushwoos