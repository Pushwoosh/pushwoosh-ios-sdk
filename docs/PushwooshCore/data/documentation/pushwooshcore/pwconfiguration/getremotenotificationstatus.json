type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Type","type":"text"}]}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"code":"enabled","type":"codeVoice"}]}],[{"inlineContent":[{"type":"text","text":"Bool"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Whether notifications are enabled"}]}]],[[{"inlineContent":[{"code":"pushAlert","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Bool"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Whether alert banners are allowed"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"pushBadge"}]}],[{"inlineContent":[{"type":"text","text":"Bool"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Whether badge updates are allowed"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"pushSound"}]}],[{"inlineContent":[{"type":"text","text":"Bool"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Whether notification sounds are allowed","type":"text"}]}]],[[{"inlineContent":[{"code":"type","type":"codeVoice"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Int","type":"text"}]}],[{"inlineContent":[{"text":"Combined notification type bitmask","type":"text"}],"type":"paragraph"}]]],"header":"row"},{"level":2,"anchor":"Example","text":"Example","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Check notification status and prompt user if disabled:"}]},{"code":["class NotificationStatusManager {","","    func checkAndPromptForNotifications() {","        guard let status = Pushwoosh.configure.getRemoteNotificationStatus() else {","            Logger.warning(\"Could not retrieve notification status\")","            return","        }","","        let isEnabled = status[\"enabled\"] as? Bool ?? false","        let hasAlert = status[\"pushAlert\"] as? Bool ?? false","        let hasBadge = status[\"pushBadge\"] as? Bool ?? false","        let hasSound = status[\"pushSound\"] as? Bool ?? false","","        Logger.debug(\"\"\"","            Notification Status:","            - Enabled: \\(isEnabled)","            - Alert: \\(hasAlert)","            - Badge: \\(hasBadge)","            - Sound: \\(hasSound)","            \"\"\")","","        if !isEnabled {","            promptToEnableNotifications()","        } else if !hasAlert {","            promptToEnableAlerts()","        }","    }","","    private func promptToEnableNotifications() {","        let alert = UIAlertController(","            title: \"Enable Notifications\",","            message: \"You're missing out on important updates. Enable notifications in Settings.\",","            preferredStyle: .alert","        )","","        alert.addAction(UIAlertAction(title: \"Open Settings\", style: .default) { _ in","            if let settingsURL = URL(string: UIApplication.openSettingsURLString) {","                UIApplication.shared.open(settingsURL)","            }","        })","","        alert.addAction(UIAlertAction(title: \"Not Now\", style: .cancel))","","        UIApplication.topViewController()?.present(alert, animated: true)","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"for more detailed status information.","type":"text"}]}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getRemoteNotificationStatus","interfaceLanguage":"occ"},"kind":"symbol","abstract":[{"type":"text","text":"Returns dictionary with enabled remote notification types."}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/Pushwoos