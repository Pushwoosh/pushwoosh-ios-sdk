{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getRemoteNotificationStatus"},"sections":[],"abstract":[{"type":"text","text":"Returns dictionary with enabled remote notification types."}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"role":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"getRemoteNotificationStatus","kind":"identifier"}],"roleHeading":"Type Method","navigatorTitle":[{"text":"getRemoteNotificationStatus","kind":"identifier"}],"title":"getRemoteNotificationStatus","externalID":"c:objc(pl)PWConfiguration(cm)getRemoteNotificationStatus","modules":[{"name":"PushwooshCore"}],"symbolKind":"method"},"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSDictionary","text":"NSDictionary"},{"text":" *) ","kind":"text"},{"kind":"identifier","text":"getRemoteNotificationStatus"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Return Value","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Dictionary containing notification status information, or nil if unavailable"}]}]},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Provides detailed information about the current notification settings for the app:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Whether notifications are enabled overall","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Which notification types are allowed (alert, badge, sound)","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The authorization status"}],"type":"paragraph"}]}]},{"text":"Dictionary Keys","level":2,"anchor":"Dictionary-Keys","type":"heading"},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Key"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Type"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"inlineContent":[{"type":"codeVoice","code":"enabled"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Bool"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Whether notifications are enabled","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"pushAlert","type":"codeVoice"}]}],[{"inlineContent":[{"type":"text","text":"Bool"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Whether alert banners are allowed"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"code":"pushBadge","type":"codeVoice"}]}],[{"inlineContent":[{"text":"Bool","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Whether badge updates are allowed"}]}]],[[{"inlineContent":[{"code":"pushSound","type":"codeVoice"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bool"}]}],[{"inlineContent":[{"text":"Whether notification sounds are allowed","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"code":"type","type":"codeVoice"}]}],[{"inlineContent":[{"type":"text","text":"Int"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Combined notification type bitmask"}]}]]]},{"type":"heading","text":"Example","level":2,"anchor":"Example"},{"inlineContent":[{"type":"text","text":"Check notification status and prompt user if disabled:"}],"type":"paragraph"},{"code":["class NotificationStatusManager {","","    func checkAndPromptForNotifications() {","        guard let status = Pushwoosh.configure.getRemoteNotificationStatus() else {","            Logger.warning(\"Could not retrieve notification status\")","            return","        }","","        let isEnabled = status[\"enabled\"] as? Bool ?? false","        let hasAlert = status[\"pushAlert\"] as? Bool ?? false","        let hasBadge = status[\"pushBadge\"] as? Bool ?? false","        let hasSound = status[\"pushSound\"] as? Bool ?? false","","        Logger.debug(\"\"\"","            Notification Status:","            - Enabled: \\(isEnabled)","            - Alert: \\(hasAlert)","            - Badge: \\(hasBadge)","            - Sound: \\(hasSound)","            \"\"\")","","        if !isEnabled {","            promptToEnableNotifications()","        } else if !hasAlert {","            promptToEnableAlerts()","        }","    }","","    private func promptToEnableNotifications() {","        let alert = UIAlertController(","            title: \"Enable Notifications\",","            message: \"You're missing out on important updates. Enable notifications in Settings.\",","            preferredStyle: .alert","        )","","        alert.addAction(UIAlertAction(title: \"Open Settings\", style: .default) { _ in","            if let settingsURL = URL(string: UIApplication.openSettingsURLString) {","                UIApplication.shared.open(settingsURL)","            }","        })","","        alert.addAction(UIAlertAction(title: \"Not Now\", style: .cancel))","","        UIApplication.topViewController()?.present(alert, animated: true)","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"for more detailed status information."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/getremotenotificationstatus"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/Pushwoos