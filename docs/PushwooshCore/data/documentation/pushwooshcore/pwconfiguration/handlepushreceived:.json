g","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"Call this method to process push notification payloads. The SDK will:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Parse the notification payload"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Track delivery statistics"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Trigger appropriate delegate callbacks"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Handle rich media and deep links","type":"text"}]}]}]},{"level":2,"text":"Example","anchor":"Example","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Handle notifications in various AppDelegate methods:","type":"text"}]},{"code":["class AppDelegate: UIResponder, UIApplicationDelegate {","","    \/\/ Legacy method for iOS < 10","    func application(_ application: UIApplication,","                    didReceiveRemoteNotification userInfo: [AnyHashable: Any]) {","        handleNotification(userInfo)","    }","","    \/\/ Modern method with background fetch","    func application(_ application: UIApplication,","                    didReceiveRemoteNotification userInfo: [AnyHashable: Any],","                    fetchCompletionHandler completionHandler: @escaping (UIBackgroundFetchResult) -> Void) {","","        let handled = handleNotification(userInfo)","","        \/\/ Perform background work if needed","        if let contentAvailable = userInfo[\"aps\"] as? [String: Any],","           contentAvailable[\"content-available\"] as? Int == 1 {","","            performBackgroundSync { newData in","                completionHandler(newData ? .newData : .noData)","            }","        } else {","            completionHandler(handled ? .newData : .noData)","        }","    }","","    private func handleNotification(_ userInfo: [AnyHashable: Any]) -> Bool {","        \/\/ Check if it's a Pushwoosh notification","        guard Pushwoosh.configure.handlePushReceived(userInfo) else {","            Logger.debug(\"Non-Pushwoosh notification received\")","            return false","        }","","        \/\/ Additional custom handling","        if let customData = userInfo[\"custom_data\"] as? [String: Any] {","            processCustomPayload(customData)","        }","","        return true","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","url":"\/documentation\/pushwooshcore","role":"collection","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","title":"PushwooshCore","kind":"symbol","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/handlePushReceived:":{"role":"symbol","abstract":[{"type":"text","text":"Handles a received push notification."}],"fragments":[{"text":"+ ","kind":"text"},{"text":"handlePushReceived:","kind":"identifier"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushReceived:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/handlepushreceived:","type":"topic","title":"handlePushReceived:","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"handlePushReceived:"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"kind":"symbol","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","type":"topic"}}}