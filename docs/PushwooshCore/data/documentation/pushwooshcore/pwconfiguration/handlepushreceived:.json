{"abstract":[{"type":"text","text":"Handles a received push notification."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/handlepushreceived:"]}],"metadata":{"roleHeading":"Type Method","navigatorTitle":[{"kind":"identifier","text":"handlePushReceived:"}],"fragments":[{"kind":"text","text":"+ "},{"text":"handlePushReceived:","kind":"identifier"}],"title":"handlePushReceived:","externalID":"c:objc(pl)PWConfiguration(cm)handlePushReceived:","modules":[{"name":"PushwooshCore"}],"role":"symbol","symbolKind":"method"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:@T@BOOL","text":"BOOL","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"kind":"identifier","text":"handlePushReceived:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSDictionary","text":"NSDictionary","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"userInfo","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"parameters":[{"content":[{"inlineContent":[{"text":"The notification payload dictionary received from APNs","type":"text"}],"type":"paragraph"}],"name":"userInfo"}],"kind":"parameters"},{"kind":"content","content":[{"text":"Return Value","level":2,"type":"heading","anchor":"return-value"},{"inlineContent":[{"type":"text","text":"YES if the notification was handled by Pushwoosh, NO if it’s not a Pushwoosh notification"}],"type":"paragraph"}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call this method to process push notification payloads. The SDK will:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Parse the notification payload","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Track delivery statistics","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Trigger appropriate delegate callbacks"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Handle rich media and deep links","type":"text"}]}]}]},{"level":2,"type":"heading","anchor":"Example","text":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle notifications in various AppDelegate methods:"}]},{"type":"codeListing","syntax":"swift","code":["class AppDelegate: UIResponder, UIApplicationDelegate {","","    \/\/ Legacy method for iOS < 10","    func application(_ application: UIApplication,","                    didReceiveRemoteNotification userInfo: [AnyHashable: Any]) {","        handleNotification(userInfo)","    }","","    \/\/ Modern method with background fetch","    func application(_ application: UIApplication,","                    didReceiveRemoteNotification userInfo: [AnyHashable: Any],","                    fetchCompletionHandler completionHandler: @escaping (UIBackgroundFetchResult) -> Void) {","","        let handled = handleNotification(userInfo)","","        \/\/ Perform background work if needed","        if let contentAvailable = userInfo[\"aps\"] as? [String: Any],","           contentAvailable[\"content-available\"] as? Int == 1 {","","            performBackgroundSync { newData in","                completionHandler(newData ? .newData : .noData)","            }","        } else {","            completionHandler(handled ? .newData : .noData)","        }","    }","","    private func handleNotification(_ userInfo: [AnyHashable: Any]) -> Bool {","        \/\/ Check if it's a Pushwoosh notification","        guard Pushwoosh.configure.handlePushReceived(userInfo) else {","            Logger.debug(\"Non-Pushwoosh notification received\")","            return false","        }","","        \/\/ Additional custom handling","        if let customData = userInfo[\"custom_data\"] as? [String: Any] {","            processCustomPayload(customData)","        }","","        return true","    }","}"]}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushReceived:"},"kind":"symbol","sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/handlePushReceived:":{"url":"\/documentation\/pushwooshcore\/pwconfiguration\/handlepushreceived:","title":"handlePushReceived:","abstract":[{"text":"Handles a received push notification.","type":"text"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"handlePushReceived:"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushReceived:","role":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"handlePushReceived:","kind":"identifier"}],"kind":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"title":"PushwooshCore","kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","role":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"kind":"symbol","type":"topic","abstract":[]}}}