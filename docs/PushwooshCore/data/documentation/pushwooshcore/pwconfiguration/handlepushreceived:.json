ta)","        }","","        return true","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"sections":[],"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)handlePushReceived:","navigatorTitle":[{"kind":"identifier","text":"handlePushReceived:"}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"handlePushReceived:"}],"symbolKind":"method","modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","title":"handlePushReceived:","role":"symbol"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/handlePushReceived:":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"handlePushReceived:"}],"fragments":[{"kind":"text","text":"+ "},{"text":"handlePushReceived:","kind":"identifier"}],"abstract":[{"type":"text","text":"Handles a received push notification."}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/handlepushreceived:","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushReceived:","kind":"symbol","title":"handlePushReceived:","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"abstract":[],"role":"symbol","title":"PWConfiguration","type":"topic","url":"\/documentation\/pushwooshcore\/pwconfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"role":"collection","url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","title":"PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"type":"topic"}}}