{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/handlepushreceived:"]}],"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@BOOL","text":"BOOL"},{"kind":"text","text":") "},{"text":"handlePushReceived:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSDictionary","text":"NSDictionary","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"userInfo","kind":"internalParam"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The notification payload dictionary received from APNs"}]}],"name":"userInfo"}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Return Value","anchor":"return-value"},{"inlineContent":[{"text":"YES if the notification was handled by Pushwoosh, NO if it’s not a Pushwoosh notification","type":"text"}],"type":"paragraph"}]},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Call this method to process push notification payloads. The SDK will:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Parse the notification payload"}]}]},{"content":[{"inlineContent":[{"text":"Track delivery statistics","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Trigger appropriate delegate callbacks"}]}]},{"content":[{"inlineContent":[{"text":"Handle rich media and deep links","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Example","level":2,"type":"heading","anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle notifications in various AppDelegate methods:"}]},{"type":"codeListing","syntax":"swift","code":["class AppDelegate: UIResponder, UIApplicationDelegate {","","    \/\/ Legacy method for iOS < 10","    func application(_ application: UIApplication,","                    didReceiveRemoteNotification userInfo: [AnyHashable: Any]) {","        handleNotification(userInfo)","    }","","    \/\/ Modern method with background fetch","    func application(_ application: UIApplication,","                    didReceiveRemoteNotification userInfo: [AnyHashable: Any],","                    fetchCompletionHandler completionHandler: @escaping (UIBackgroundFetchResult) -> Void) {","","        let handled = handleNotification(userInfo)","","        \/\/ Perform background work if needed","        if let contentAvailable = userInfo[\"aps\"] as? [String: Any],","           contentAvailable[\"content-available\"] as? Int == 1 {","","            performBackgroundSync { newData in","                completionHandler(newData ? .newData : .noData)","            }","        } else {","            completionHandler(handled ? .newData : .noData)","        }","    }","","    private func handleNotification(_ userInfo: [AnyHashable: Any]) -> Bool {","        \/\/ Check if it's a Pushwoosh notification","        guard Pushwoosh.configure.handlePushReceived(userInfo) else {","            Logger.debug(\"Non-Pushwoosh notification received\")","            return false","        }","","        \/\/ Additional custom handling","        if let customData = userInfo[\"custom_data\"] as? [String: Any] {","            processCustomPayload(customData)","        }","","        return true","    }","}"]}],"kind":"content"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","abstract":[{"text":"Handles a received push notification.","type":"text"}],"metadata":{"symbolKind":"method","navi