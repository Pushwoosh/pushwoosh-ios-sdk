:"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Call this method to process push notification payloads. The SDK will:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Parse the notification payload","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Track delivery statistics"}]}]},{"content":[{"inlineContent":[{"text":"Trigger appropriate delegate callbacks","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Handle rich media and deep links","type":"text"}]}]}]},{"level":2,"text":"Example","type":"heading","anchor":"Example"},{"inlineContent":[{"type":"text","text":"Handle notifications in various AppDelegate methods:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class AppDelegate: UIResponder, UIApplicationDelegate {","","    \/\/ Legacy method for iOS < 10","    func application(_ application: UIApplication,","                    didReceiveRemoteNotification userInfo: [AnyHashable: Any]) {","        handleNotification(userInfo)","    }","","    \/\/ Modern method with background fetch","    func application(_ application: UIApplication,","                    didReceiveRemoteNotification userInfo: [AnyHashable: Any],","                    fetchCompletionHandler completionHandler: @escaping (UIBackgroundFetchResult) -> Void) {","","        let handled = handleNotification(userInfo)","","        \/\/ Perform background work if needed","        if let contentAvailable = userInfo[\"aps\"] as? [String: Any],","           contentAvailable[\"content-available\"] as? Int == 1 {","","            performBackgroundSync { newData in","                completionHandler(newData ? .newData : .noData)","            }","        } else {","            completionHandler(handled ? .newData : .noData)","        }","    }","","    private func handleNotification(_ userInfo: [AnyHashable: Any]) -> Bool {","        \/\/ Check if it's a Pushwoosh notification","        guard Pushwoosh.configure.handlePushReceived(userInfo) else {","            Logger.debug(\"Non-Pushwoosh notification received\")","            return false","        }","","        \/\/ Additional custom handling","        if let customData = userInfo[\"custom_data\"] as? [String: Any] {","            processCustomPayload(customData)","        }","","        return true","    }","}"]}],"kind":"content"}],"sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/handlePushReceived:":{"type":"topic","abstract":[{"type":"text","text":"Handles a received push notification."}],"fragments":[{"kind":"text","text":"+ "},{"text":"handlePushReceived:","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"handlePushReceived:"}],"title":"handlePushReceived:","kind":"symbol","role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/handlepushreceived:","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushReceived:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","url":"\/documentation\/pushwooshcore","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"role":"collection"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","abstract":[],"fragments":[{"kind":"identifier","text":"PWConfiguration"}],"title":"PWConfiguration","kind":"symbol","role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"}}}