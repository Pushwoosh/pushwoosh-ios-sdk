{"abstract":[{"text":"Handles a received push notification.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:@T@BOOL","kind":"typeIdentifier","text":"BOOL"},{"kind":"text","text":") "},{"text":"handlePushReceived:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSDictionary","kind":"typeIdentifier","text":"NSDictionary"},{"kind":"text","text":" *) "},{"text":"userInfo","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"parameters":[{"content":[{"inlineContent":[{"text":"The notification payload dictionary received from APNs","type":"text"}],"type":"paragraph"}],"name":"userInfo"}],"kind":"parameters"},{"kind":"content","content":[{"text":"Return Value","level":2,"anchor":"return-value","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"YES if the notification was handled by Pushwoosh, NO if it’s not a Pushwoosh notification","type":"text"}]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Call this method to process push notification payloads. The SDK will:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Parse the notification payload"}]}]},{"content":[{"inlineContent":[{"text":"Track delivery statistics","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Trigger appropriate delegate callbacks"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Handle rich media and deep links"}],"type":"paragraph"}]}]},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"inlineContent":[{"type":"text","text":"Handle notifications in various AppDelegate methods:"}],"type":"paragraph"},{"syntax":"swift","code":["class AppDelegate: UIResponder, UIApplicationDelegate {","","    \/\/ Legacy method for iOS < 10","    func application(_ application: UIApplication,","                    didReceiveRemoteNotification userInfo: [AnyHashable: Any]) {","        handleNotification(userInfo)","    }","","    \/\/ Modern method with background fetch","    func application(_ application: UIApplication,","                    didReceiveRemoteNotification userInfo: [AnyHashable: Any],","                    fetchCompletionHandler completionHandler: @escaping (UIBackgroundFetchResult) -> Void) {","","        let handled = handleNotification(userInfo)","","        \/\/ Perform background work if needed","        if let contentAvailable = userInfo[\"aps\"] as? [String: Any],","           contentAvailable[\"content-available\"] as? Int == 1 {","","            performBackgroundSync { newData in","                completionHandler(newData ? .newData : .noData)","            }","        } else {","            completionHandler(handled ? .newData : .noData)","        }","    }","","    private func handleNotification(_ userInfo: [AnyHashable: Any]) -> Bool {","        \/\/ Check if it's a Pushwoosh notification","        guard Pushwoosh.configure.handlePushReceived(userInfo) else {","            Logger.debug(\"Non-Pushwoosh notification received\")","            return false","        }","","        \/\/ Additional custom handling","        if let customData = userInfo[\"custom_data\"] as? [String: Any] {","            processCustomPayload(customData)","        }","","        return true","    }","}"],"type":"codeListing"}]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushReceived:","interfaceLanguage":"occ"},"metadata":{"title":"handlePushReceived:","roleHeading":"Type Method","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"handlePushReceived:"}],"modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)handlePushReceived:",