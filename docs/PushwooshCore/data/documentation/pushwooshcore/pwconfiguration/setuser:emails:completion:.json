{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:emails:completion:","interfaceLanguage":"occ"},"metadata":{"symbolKind":"method","modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)setUser:emails:completion:","role":"symbol","roleHeading":"Type Method","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setUser:emails:completion:"}],"title":"setUser:emails:completion:","navigatorTitle":[{"text":"setUser:emails:completion:","kind":"identifier"}]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"kind":"identifier","text":"setUser:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"NSString","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"text":"userId","kind":"internalParam"},{"text":" ","kind":"text"},{"kind":"identifier","text":"emails:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSArray","text":"NSArray","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"emails","kind":"internalParam"},{"text":" ","kind":"text"},{"kind":"identifier","text":"completion:"},{"text":"(","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":" (^"},{"text":")(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSError","text":"NSError"},{"text":" * ","kind":"text"},{"kind":"internalParam","text":"error"},{"text":")) ","kind":"text"},{"kind":"internalParam","text":"completion"},{"kind":"text","text":";"}]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The custom user identifier."}]}],"name":"userId"},{"name":"emails","content":[{"inlineContent":[{"type":"text","text":"Array of email address strings."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Block called when the operation completes."},{"text":" ","type":"text"},{"text":"Receives nil on success, or an NSError on failure.","type":"text"}],"type":"paragraph"}],"name":"completion"}]},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Atomically associates a user ID with multiple email addresses and provides"},{"text":" ","type":"text"},{"type":"text","text":"confirmation when the operation completes. This is the recommended method"},{"type":"text","text":" "},{"type":"text","text":"for user identification during authentication flows."}],"type":"paragraph"},{"text":"Example","level":2,"anchor":"Example","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Handle OAuth login with full user setup:","type":"text"}]},{"syntax":"swift","code":["class OAuthLoginHandler {","","    func handleOAuthCallback(_ authResult: OAuthResult,","                            completion: @escaping (Result<Void, Error>) -> Void) {","","        \/\/ Extract user info from OAuth result","        let userId = authResult.userId","        var emails: [String] = []","","        if let primaryEmail = authResult.email {","            emails.append(primaryEmail)","        }","        if let verifiedEmails = authResult.verifiedEmails {","            emails.append(contentsOf: verifiedEmails.filter { $0 != authResult.email })","        }","","        \/\/ Set user and emails with confirmation","        Pushwoosh.configure.setUser(userId, emails: emails) { error in","            if let error = error {","                Logger.error(\"User setup failed: \\(error.localizedDescription)\")","                completion(.failure(error))","                return","            }","","            \/\/ User is now fully identified - set profile tags","            Pushwoosh.configure.setTags([","                \"oauth_provider\": authResult.provider.rawValue,","                \"has_profile_picture\": authResult.profilePictureURL != nil,","                \"locale\": authResult.locale ?? Locale.current.identifier,","                \"first_login\": !self.hasExistingSession(for: userId)","            ])","","            Analytics.track(\"oauth_login_complete\", properties: [","                \"provider\": authResult.provider.rawValue,","                \"email_count\": emails.count","            ])","","            completion(.success(()))","        }","    }","}"],"type":"codeListing"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"abstract":[{"type":"text","text":"Sets user identifier and emails with completion handler."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setuser:emails:completion:"]}],"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","title":"PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"role":"symbol","abstract":[]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setUser:emails:completion:":{"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setuser:emails:completion:","kind":"symbol","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:emails:completion:","title":"setUser:emails:completion:","fragments":[{"text":"+ ","kind":"text"},{"text":"setUser:emails:completion:","kind":"identifier"}],"navigatorTitle":[{"text":"setUser:emails:completion:","kind":"identifier"}],"abstract":[{"type":"text","text":"Sets user identifier and emails with completion handler."}],"role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","title":"PushwooshCore","role":"collection","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"kind":"symbol"}}}