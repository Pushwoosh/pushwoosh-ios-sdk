{"abstract":[{"text":"Sets user identifier and emails with completion handler.","type":"text"}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:emails:completion:","interfaceLanguage":"occ"},"sections":[],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"setUser:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier","text":"NSString"},{"text":" *) ","kind":"text"},{"text":"userId","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"emails:","kind":"identifier"},{"kind":"text","text":"("},{"text":"NSArray","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSArray"},{"text":" *) ","kind":"text"},{"text":"emails","kind":"internalParam"},{"kind":"text","text":" "},{"kind":"identifier","text":"completion:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":" (^","kind":"text"},{"kind":"text","text":")("},{"text":"NSError","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSError"},{"text":" * ","kind":"text"},{"kind":"internalParam","text":"error"},{"text":")) ","kind":"text"},{"kind":"internalParam","text":"completion"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The custom user identifier."}]}],"name":"userId"},{"name":"emails","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Array of email address strings."}]}]},{"name":"completion","content":[{"inlineContent":[{"type":"text","text":"Block called when the operation completes."},{"text":" ","type":"text"},{"type":"text","text":"Receives nil on success, or an NSError on failure."}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Atomically associates a user ID with multiple email addresses and provides","type":"text"},{"text":" ","type":"text"},{"text":"confirmation when the operation completes. This is the recommended method","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for user identification during authentication flows."}]},{"text":"Example","type":"heading","anchor":"Example","level":2},{"type":"paragraph","inlineContent":[{"text":"Handle OAuth login with full user setup:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class OAuthLoginHandler {","","    func handleOAuthCallback(_ authResult: OAuthResult,","                            completion: @escaping (Result<Void, Error>) -> Void) {","","        \/\/ Extract user info from OAuth result","        let userId = authResult.userId","        var emails: [String] = []","","        if let primaryEmail = authResult.email {","            emails.append(primaryEmail)","        }","        if let verifiedEmails = authResult.verifiedEmails {","            emails.append(contentsOf: verifiedEmails.filter { $0 != authResult.email })","        }","","        \/\/ Set user and emails with confirmation","        Pushwoosh.configure.setUser(userId, emails: emails) { error in","            if let error = error {","                Logger.error(\"User setup failed: \\(error.localizedDescription)\")","                completion(.failure(error))","                return","            }","","            \/\/ User is now fully identified - set profile tags","            Pushwoosh.configure.setTags([","                \"oauth_provider\": authResult.provider.rawValue,","                \"has_profile_picture\": authResult.profilePictureURL != nil,","                \"locale\": authResult.locale ?? Locale.current.identifier,","                \"first_login\": !self.hasExistingSession(for: userId)","            ])","","            Analytics.track(\"oauth_login_complete\", properties: [","                \"provider\": authResult.provider.rawValue,","                \"email_count\": emails.count","            ])","","            completion(.success(()))","        }","    }","}"]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"symbolKind":"method","title":"setUser:emails:completion:","navigatorTitle":[{"kind":"identifier","text":"setUser:emails:completion:"}],"role":"symbol","modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)setUser:emails:completion:","fragments":[{"text":"+ ","kind":"text"},{"text":"setUser:emails:completion:","kind":"identifier"}],"roleHeading":"Type Method"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setuser:emails:completion:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","url":"\/documentation\/pushwooshcore","title":"PushwooshCore","type":"topic","kind":"symbol","role":"collection","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","role":"symbol","title":"PWConfiguration","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","abstract":[]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setUser:emails:completion:":{"title":"setUser:emails:completion:","abstract":[{"type":"text","text":"Sets user identifier and emails with completion handler."}],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"setUser:emails:completion:","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"setUser:emails:completion:"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:emails:completion:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setuser:emails:completion:"}}}