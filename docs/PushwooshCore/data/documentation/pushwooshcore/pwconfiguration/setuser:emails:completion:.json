{"metadata":{"modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)setUser:emails:completion:","role":"symbol","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setUser:emails:completion:"}],"roleHeading":"Type Method","navigatorTitle":[{"text":"setUser:emails:completion:","kind":"identifier"}],"symbolKind":"method","title":"setUser:emails:completion:"},"kind":"symbol","sections":[],"abstract":[{"text":"Sets user identifier and emails with completion handler.","type":"text"}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setuser:emails:completion:"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:emails:completion:","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"kind":"identifier","text":"setUser:"},{"text":"(","kind":"text"},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"userId"},{"text":" ","kind":"text"},{"text":"emails:","kind":"identifier"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSArray","text":"NSArray"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"emails"},{"text":" ","kind":"text"},{"text":"completion:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"kind":"text","text":" (^"},{"kind":"text","text":")("},{"text":"NSError","preciseIdentifier":"c:objc(cs)NSError","kind":"typeIdentifier"},{"kind":"text","text":" * "},{"kind":"internalParam","text":"error"},{"kind":"text","text":")) "},{"text":"completion","kind":"internalParam"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"parameters":[{"name":"userId","content":[{"inlineContent":[{"text":"The custom user identifier.","type":"text"}],"type":"paragraph"}]},{"name":"emails","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Array of email address strings."}]}]},{"name":"completion","content":[{"inlineContent":[{"text":"Block called when the operation completes.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Receives nil on success, or an NSError on failure."}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"text":"Atomically associates a user ID with multiple email addresses and provides","type":"text"},{"type":"text","text":" "},{"type":"text","text":"confirmation when the operation completes. This is the recommended method"},{"text":" ","type":"text"},{"text":"for user identification during authentication flows.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Example","level":2,"anchor":"Example"},{"inlineContent":[{"text":"Handle OAuth login with full user setup:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["class OAuthLoginHandler {","","    func handleOAuthCallback(_ authResult: OAuthResult,","                            completion: @escaping (Result<Void, Error>) -> Void) {","","        \/\/ Extract user info from OAuth result","        let userId = authResult.userId","        var emails: [String] = []","","        if let primaryEmail = authResult.email {","            emails.append(primaryEmail)","        }","        if let verifiedEmails = authResult.verifiedEmails {","            emails.append(contentsOf: verifiedEmails.filter { $0 != authResult.email })","        }","","        \/\/ Set user and emails with confirmation","        Pushwoosh.configure.setUser(userId, emails: emails) { error in","            if let error = error {","                Logger.error(\"User setup failed: \\(error.localizedDescription)\")","                completion(.failure(error))","                return","            }","","            \/\/ User is now fully identified - set profile tags","            Pushwoosh.configure.setTags([","                \"oauth_provider\": authResult.provider.rawValue,","                \"has_profile_picture\": authResult.profilePictureURL != nil,","                \"locale\": authResult.locale ?? Locale.current.identifier,","                \"first_login\": !self.hasExistingSession(for: userId)","            ])","","            Analytics.track(\"oauth_login_complete\", properties: [","                \"provider\": authResult.provider.rawValue,","                \"email_count\": emails.count","            ])","","            completion(.success(()))","        }","    }","}"],"type":"codeListing"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setUser:emails:completion:":{"navigatorTitle":[{"text":"setUser:emails:completion:","kind":"identifier"}],"title":"setUser:emails:completion:","role":"symbol","kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setuser:emails:completion:","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:emails:completion:","abstract":[{"type":"text","text":"Sets user identifier and emails with completion handler."}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setUser:emails:completion:"}],"type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"role":"symbol","abstract":[],"kind":"symbol","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","url":"\/documentation\/pushwooshcore","role":"collection"}}}