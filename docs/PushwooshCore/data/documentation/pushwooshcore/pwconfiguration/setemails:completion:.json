"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Array of email address strings."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Block called when the operation completes."},{"type":"text","text":" "},{"text":"Receives nil on success, or an NSError on failure.","type":"text"}]}],"name":"completion"}],"kind":"parameters"},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Same as ","type":"text"},{"code":"setEmails:","type":"codeVoice"},{"text":" but provides callback when the server registration completes.","type":"text"},{"type":"text","text":" "},{"text":"Use this for confirmation UI or to chain dependent operations.","type":"text"}]},{"level":2,"text":"Example","anchor":"Example","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Import emails from third-party login with confirmation:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class SocialLoginHandler {","","    func handleGoogleSignIn(_ user: GIDGoogleUser) {","        var emails: [String] = []","","        \/\/ Primary email from Google","        if let email = user.profile?.email {","            emails.append(email)","        }","","        \/\/ Additional emails from Google profile if available","        if let additionalEmails = user.profile?.additionalEmails {","            emails.append(contentsOf: additionalEmails)","        }","","        Pushwoosh.configure.setEmails(emails) { error in","            if let error = error {","                Analytics.track(\"email_sync_failed\", properties: [","                    \"provider\": \"google\",","                    \"email_count\": emails.count,","                    \"error\": error.localizedDescription","                ])","                return","            }","","            Analytics.track(\"email_sync_success\", properties: [","                \"provider\": \"google\",","                \"email_count\": emails.count","            ])","","            \/\/ Set user ID from Google","            Pushwoosh.configure.setUserId(user.userID ?? \"\")","        }","    }","}"]}],"kind":"content"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","abstract":[],"role":"symbol","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmails:completion:":{"abstract":[{"text":"Registers multiple email addresses with completion handler.","type":"text"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmails:completion:","kind":"symbol","title":"setEmails:completion:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemails:completion:","role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"setEmails:completion:","kind":"identifier"}],"navigatorTitle":[{"text":"setEmails:completion:","kind":"identifier"}],"type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"title":"PushwooshCore","type":"topic","role":"collection","url":"\/documentation\/pushwooshcore"}}}