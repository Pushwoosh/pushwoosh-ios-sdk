{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmails:completion:","interfaceLanguage":"occ"},"kind":"symbol","abstract":[{"type":"text","text":"Registers multiple email addresses with completion handler."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemails:completion:"]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"title":"setEmails:completion:","roleHeading":"Type Method","role":"symbol","symbolKind":"method","modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)setEmails:completion:","fragments":[{"text":"+ ","kind":"text"},{"text":"setEmails:completion:","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"setEmails:completion:"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"setEmails:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSArray","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSArray"},{"text":" *) ","kind":"text"},{"text":"emails","kind":"internalParam"},{"text":" ","kind":"text"},{"kind":"identifier","text":"completion:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"text":" (^","kind":"text"},{"kind":"text","text":")("},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSError","text":"NSError"},{"text":" * ","kind":"text"},{"text":"error","kind":"internalParam"},{"kind":"text","text":")) "},{"kind":"internalParam","text":"completion"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"name":"emails","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Array of email address strings."}]}]},{"name":"completion","content":[{"inlineContent":[{"type":"text","text":"Block called when the operation completes."},{"type":"text","text":" "},{"text":"Receives nil on success, or an NSError on failure.","type":"text"}],"type":"paragraph"}]}]},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"Same as "},{"code":"setEmails:","type":"codeVoice"},{"type":"text","text":" but provides callback when the server registration completes."},{"text":" ","type":"text"},{"type":"text","text":"Use this for confirmation UI or to chain dependent operations."}],"type":"paragraph"},{"anchor":"Example","text":"Example","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Import emails from third-party login with confirmation:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class SocialLoginHandler {","","    func handleGoogleSignIn(_ user: GIDGoogleUser) {","        var emails: [String] = []","","        \/\/ Primary email from Google","        if let email = user.profile?.email {","            emails.append(email)","        }","","        \/\/ Additional emails from Google profile if available","        if let additionalEmails = user.profile?.additionalEmails {","            emails.append(contentsOf: additionalEmails)","        }","","        Pushwoosh.configure.setEmails(emails) { error in","            if let error = error {","                Analytics.track(\"email_sync_failed\", properties: [","                    \"provider\": \"google\",","                    \"email_count\": emails.count,","                    \"error\": error.localizedDescription","                ])","                return","            }","","            Analytics.track(\"email_sync_success\", properties: [","                \"provider\": \"google\",","                \"email_count\": emails.count","            ])","","            \/\/ Set user ID from Google","            Pushwoosh.configure.setUserId(user.userID ?? \"\")","        }","    }","}"]}],"kind":"content"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","abstract":[],"title":"PWConfiguration","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmails:completion:":{"title":"setEmails:completion:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemails:completion:","abstract":[{"type":"text","text":"Registers multiple email addresses with completion handler."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmails:completion:","role":"symbol","type":"topic","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setEmails:completion:"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"setEmails:completion:"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","title":"PushwooshCore","role":"collection","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"kind":"symbol"}}}