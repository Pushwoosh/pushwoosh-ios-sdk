{"text":"Import emails from third-party login with confirmation:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class SocialLoginHandler {","","    func handleGoogleSignIn(_ user: GIDGoogleUser) {","        var emails: [String] = []","","        \/\/ Primary email from Google","        if let email = user.profile?.email {","            emails.append(email)","        }","","        \/\/ Additional emails from Google profile if available","        if let additionalEmails = user.profile?.additionalEmails {","            emails.append(contentsOf: additionalEmails)","        }","","        Pushwoosh.configure.setEmails(emails) { error in","            if let error = error {","                Analytics.track(\"email_sync_failed\", properties: [","                    \"provider\": \"google\",","                    \"email_count\": emails.count,","                    \"error\": error.localizedDescription","                ])","                return","            }","","            Analytics.track(\"email_sync_success\", properties: [","                \"provider\": \"google\",","                \"email_count\": emails.count","            ])","","            \/\/ Set user ID from Google","            Pushwoosh.configure.setUserId(user.userID ?? \"\")","        }","    }","}"]}],"kind":"content"}],"metadata":{"roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}],"role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)setEmails:completion:","symbolKind":"method","title":"setEmails:completion:","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setEmails:completion:"}],"navigatorTitle":[{"kind":"identifier","text":"setEmails:completion:"}]},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"abstract":[{"text":"Registers multiple email addresses with completion handler.","type":"text"