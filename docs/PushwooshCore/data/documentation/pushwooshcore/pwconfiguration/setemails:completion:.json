{"abstract":[{"text":"Registers multiple email addresses with completion handler.","type":"text"}],"sections":[],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmails:completion:","interfaceLanguage":"occ"},"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)setEmails:completion:","title":"setEmails:completion:","symbolKind":"method","roleHeading":"Type Method","fragments":[{"text":"+ ","kind":"text"},{"text":"setEmails:completion:","kind":"identifier"}],"role":"symbol","modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"kind":"identifier","text":"setEmails:completion:"}]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemails:completion:"]}],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"text":"setEmails:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSArray","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSArray"},{"kind":"text","text":" *) "},{"text":"emails","kind":"internalParam"},{"text":" ","kind":"text"},{"kind":"identifier","text":"completion:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"kind":"text","text":" (^"},{"kind":"text","text":")("},{"text":"NSError","preciseIdentifier":"c:objc(cs)NSError","kind":"typeIdentifier"},{"kind":"text","text":" * "},{"text":"error","kind":"internalParam"},{"kind":"text","text":")) "},{"text":"completion","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"name":"emails","content":[{"inlineContent":[{"text":"Array of email address strings.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Block called when the operation completes.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Receives nil on success, or an NSError on failure."}],"type":"paragraph"}],"name":"completion"}]},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"text":"Same as ","type":"text"},{"type":"codeVoice","code":"setEmails:"},{"type":"text","text":" but provides callback when the server registration completes."},{"text":" ","type":"text"},{"text":"Use this for confirmation UI or to chain dependent operations.","type":"text"}],"type":"paragraph"},{"text":"Example","type":"heading","level":2,"anchor":"Example"},{"inlineContent":[{"text":"Import emails from third-party login with confirmation:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["class SocialLoginHandler {","","    func handleGoogleSignIn(_ user: GIDGoogleUser) {","        var emails: [String] = []","","        \/\/ Primary email from Google","        if let email = user.profile?.email {","            emails.append(email)","        }","","        \/\/ Additional emails from Google profile if available","        if let additionalEmails = user.profile?.additionalEmails {","            emails.append(contentsOf: additionalEmails)","        }","","        Pushwoosh.configure.setEmails(emails) { error in","            if let error = error {","                Analytics.track(\"email_sync_failed\", properties: [","                    \"provider\": \"google\",","                    \"email_count\": emails.count,","                    \"error\": error.localizedDescription","                ])","                return","            }","","            Analytics.track(\"email_sync_success\", properties: [","                \"provider\": \"google\",","                \"email_count\": emails.count","            ])","","            \/\/ Set user ID from Google","            Pushwoosh.configure.setUserId(user.userID ?? \"\")","        }","    }","}"],"syntax":"swift"}],"kind":"content"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore","type":"topic","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","kind":"symbol","type":"topic","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"abstract":[],"role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmails:completion:":{"type":"topic","kind":"symbol","title":"setEmails:completion:","abstract":[{"type":"text","text":"Registers multiple email addresses with completion handler."}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemails:completion:","fragments":[{"text":"+ ","kind":"text"},{"text":"setEmails:completion:","kind":"identifier"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmails:completion:","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"setEmails:completion:"}]}}}