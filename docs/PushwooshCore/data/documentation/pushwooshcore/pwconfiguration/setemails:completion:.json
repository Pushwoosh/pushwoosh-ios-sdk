{"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"text":") ","kind":"text"},{"text":"setEmails:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSArray","kind":"typeIdentifier","text":"NSArray"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"emails"},{"kind":"text","text":" "},{"kind":"identifier","text":"completion:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"text":" (^","kind":"text"},{"kind":"text","text":")("},{"preciseIdentifier":"c:objc(cs)NSError","text":"NSError","kind":"typeIdentifier"},{"text":" * ","kind":"text"},{"kind":"internalParam","text":"error"},{"kind":"text","text":")) "},{"kind":"internalParam","text":"completion"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"name":"emails","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Array of email address strings."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Block called when the operation completes."},{"text":" ","type":"text"},{"text":"Receives nil on success, or an NSError on failure.","type":"text"}]}],"name":"completion"}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"Same as "},{"code":"setEmails:","type":"codeVoice"},{"type":"text","text":" but provides callback when the server registration completes."},{"text":" ","type":"text"},{"type":"text","text":"Use this for confirmation UI or to chain dependent operations."}],"type":"paragraph"},{"anchor":"Example","text":"Example","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Import emails from third-party login with confirmation:","type":"text"}]},{"code":["class SocialLoginHandler {","","    func handleGoogleSignIn(_ user: GIDGoogleUser) {","        var emails: [String] = []","","        \/\/ Primary email from Google","        if let email = user.profile?.email {","            emails.append(email)","        }","","        \/\/ Additional emails from Google profile if available","        if let additionalEmails = user.profile?.additionalEmails {","            emails.append(contentsOf: additionalEmails)","        }","","        Pushwoosh.configure.setEmails(emails) { error in","            if let error = error {","                Analytics.track(\"email_sync_failed\", properties: [","                    \"provider\": \"google\",","                    \"email_count\": emails.count,","                    \"error\": error.localizedDescription","                ])","                return","            }","","            Analytics.track(\"email_sync_success\", properties: [","                \"provider\": \"google\",","                \"email_count\": emails.count","            ])","","            \/\/ Set user ID from Google","            Pushwoosh.configure.setUserId(user.userID ?? \"\")","        }","    }","}"],"type":"codeListing","syntax":"swift"}]}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemails:completion:"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"type":"text","text":"Registers multiple email addresses with completion handler."}],"metadata":{"symbolKind":"method","fragments":[{"kind":"text","text":"+ "},{"text":"setEmails:completion:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"text":"setEmails:completion:","kind":"identifier"}],"title":"setEmails:completion:","role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)setEmails:completion:","roleHeading":"Type Method"},"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\