{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Retrieves the current user identifier."}],"kind":"symbol","metadata":{"role":"symbol","navigatorTitle":[{"text":"getUserId","kind":"identifier"}],"roleHeading":"Type Method","title":"getUserId","modules":[{"name":"PushwooshCore"}],"symbolKind":"method","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"getUserId"}],"externalID":"c:objc(pl)PWConfiguration(cm)getUserId"},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getUserId","interfaceLanguage":"occ"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier","text":"NSString"},{"text":" *) ","kind":"text"},{"text":"getUserId","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}]},{"content":[{"anchor":"return-value","level":2,"text":"Return Value","type":"heading"},{"inlineContent":[{"text":"The current user identifier (custom user ID or HWID)","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Returns the user ID that was previously set via "},{"code":"setUserId:","type":"codeVoice"},{"type":"text","text":", or the HWID if no custom"},{"type":"text","text":" "},{"type":"text","text":"user ID has been set."}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"inlineContent":[{"text":"Sync user ID with analytics platforms:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["class AnalyticsCoordinator {","","    func syncIdentifiers() {","        let userId = Pushwoosh.configure.getUserId()","        let hwid = Pushwoosh.configure.getHWID()","","        \/\/ Sync with various analytics platforms","        Analytics.identify(userId)","        Crashlytics.setUserID(userId)","        MixpanelInstance.identify(distinctId: userId)","","        \/\/ Log device mapping for debugging","        Logger.debug(\"User identity: userId=\\(userId), hwid=\\(hwid)\")","    }","","    func trackEventWithUserContext(_ event: String, properties: [String: Any]) {","        var enrichedProperties = properties","        enrichedProperties[\"pushwoosh_user_id\"] = Pushwoosh.configure.getUserId()","        enrichedProperties[\"pushwoosh_hwid\"] = Pushwoosh.configure.getHWID()","","        Analytics.track(event, properties: enrichedProperties)","    }","}"],"type":"codeListing"}],"kind":"content"}],"sections":[],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/getuserid"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","url":"\/documentation\/pushwooshcore","role":"collection"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"role":"symbol","abstract":[],"kind":"symbol","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/getUserId":{"fragments":[{"kind":"text","text":"+ "},{"text":"getUserId","kind":"identifier"}],"type":"topic","abstract":[{"type":"text","text":"Retrieves the current user identifier."}],"role":"symbol","identifier":"