{"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","text":"NSString","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"text":"getUserId","kind":"identifier"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"content":[{"anchor":"return-value","text":"Return Value","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The current user identifier (custom user ID or HWID)","type":"text"}]}],"kind":"content"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Returns the user ID that was previously set via "},{"type":"codeVoice","code":"setUserId:"},{"type":"text","text":", or the HWID if no custom"},{"text":" ","type":"text"},{"text":"user ID has been set.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Example","anchor":"Example","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Sync user ID with analytics platforms:"}]},{"code":["class AnalyticsCoordinator {","","    func syncIdentifiers() {","        let userId = Pushwoosh.configure.getUserId()","        let hwid = Pushwoosh.configure.getHWID()","","        \/\/ Sync with various analytics platforms","        Analytics.identify(userId)","        Crashlytics.setUserID(userId)","        MixpanelInstance.identify(distinctId: userId)","","        \/\/ Log device mapping for debugging","        Logger.debug(\"User identity: userId=\\(userId), hwid=\\(hwid)\")","    }","","    func trackEventWithUserContext(_ event: String, properties: [String: Any]) {","        var enrichedProperties = properties","        enrichedProperties[\"pushwoosh_user_id\"] = Pushwoosh.configure.getUserId()","        enrichedProperties[\"pushwoosh_hwid\"] = Pushwoosh.configure.getHWID()","","        Analytics.track(event, properties: enrichedProperties)","    }","}"],"syntax":"swift","type":"codeListing"}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/getuserid"]}],"metadata":{"fragments":[{"text":"+ ","kind":"text"},{"text":"getUserId","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","externalID":"c:objc(pl)PWConfiguration(cm)getUserId","role":"symbol","symbolKind":"method","title":"getUserId","navigatorTitle":[{"text":"getUserId","kind":"identifier"}]},"abstract":[{"type":"text","text":"Retrieves the current user identifier."}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getUserId","interfaceLanguage":"occ"},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/getUserId":{"url":"\/documentation\/pushwooshcore\/pwconfiguration\/getuserid","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getUserId","title":"getUserId","navigatorTitle":[{"text":"getUserId","kind":"identifier"}],"role":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"getUserId","kind":"identifier"}],"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Retrieves the current user identifier."}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"title":"PushwooshCore","kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwcon