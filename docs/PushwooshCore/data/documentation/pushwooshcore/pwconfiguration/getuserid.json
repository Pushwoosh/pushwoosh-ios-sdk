{"abstract":[{"type":"text","text":"Retrieves the current user identifier."}],"metadata":{"roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}],"fragments":[{"kind":"text","text":"+ "},{"text":"getUserId","kind":"identifier"}],"title":"getUserId","externalID":"c:objc(pl)PWConfiguration(cm)getUserId","navigatorTitle":[{"text":"getUserId","kind":"identifier"}],"symbolKind":"method","role":"symbol"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getUserId","interfaceLanguage":"occ"},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSString","text":"NSString","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"identifier","text":"getUserId"},{"kind":"text","text":";"}],"languages":["occ"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Return Value","level":2,"anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The current user identifier (custom user ID or HWID)"}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Returns the user ID that was previously set via ","type":"text"},{"code":"setUserId:","type":"codeVoice"},{"text":", or the HWID if no custom","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"user ID has been set."}]},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Sync user ID with analytics platforms:"}]},{"type":"codeListing","code":["class AnalyticsCoordinator {","","    func syncIdentifiers() {","        let userId =