ing: Any]) {","        var enrichedProperties = properties","        enrichedProperties[\"pushwoosh_user_id\"] = Pushwoosh.configure.getUserId()","        enrichedProperties[\"pushwoosh_hwid\"] = Pushwoosh.configure.getHWID()","","        Analytics.track(event, properties: enrichedProperties)","    }","}"],"syntax":"swift","type":"codeListing"}]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getUserId","interfaceLanguage":"occ"},"abstract":[{"type":"text","text":"Retrieves the current user identifier."}],"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)getUserId","fragments":[{"kind":"text","text":"+ "},{"text":"getUserId","kind":"identifier"}],"role":"symbol","roleHeading":"Type Method","title":"getUserId","modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"text":"getUserId","kind":"identifier"}],"symbolKind":"method"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","kind":"symbol","title":"PushwooshCore","type":"topic","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","role":"collection"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/getUserId":{"kind":"symbol","abstract":[{"text":"Retrieves the current user identifier.","type":"text"}],"type":"topic","url":"\/documentation\/pushwooshcore\/pwconfiguration\/getuserid","role":"symbol","title":"getUserId","fragments":[{"kind":"text","text":"+ "},{"text":"getUserId","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"getUserId"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getUserId"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"kind":"symbol","type":"topic","fragments":[