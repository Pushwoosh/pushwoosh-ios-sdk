analytics platforms:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class AnalyticsCoordinator {","","    func syncIdentifiers() {","        let userId = Pushwoosh.configure.getUserId()","        let hwid = Pushwoosh.configure.getHWID()","","        \/\/ Sync with various analytics platforms","        Analytics.identify(userId)","        Crashlytics.setUserID(userId)","        MixpanelInstance.identify(distinctId: userId)","","        \/\/ Log device mapping for debugging","        Logger.debug(\"User identity: userId=\\(userId), hwid=\\(hwid)\")","    }","","    func trackEventWithUserContext(_ event: String, properties: [String: Any]) {","        var enrichedProperties = properties","        enrichedProperties[\"pushwoosh_user_id\"] = Pushwoosh.configure.getUserId()","        enrichedProperties[\"pushwoosh_hwid\"] = Pushwoosh.configure.getHWID()","","        Analytics.track(event, properties: enrichedProperties)","    }","}"]}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","title":"PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","kind":"symbol","abstract":[],"role":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","type":"topic","kind":"symbol","url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","role":"collection","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/getUserId":{"kind":"symbol","abstract":[{"type":"text","text":"Retrieves the current user identifier."}],"navigatorTitle":[{"text":"getUserId","kind":"identifier"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/d