perties)","    }","}"]}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"fragments":[{"kind":"text","text":"+ "},{"text":"getUserId","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"symbolKind":"method","title":"getUserId","role":"symbol","navigatorTitle":[{"text":"getUserId","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)getUserId","roleHeading":"Type Method"},"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getUserId"},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/getuserid"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"type":"text","text":"Retrieves the current user identifier."}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"title":"PWConfiguration","type":"topic","role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","kind":"symbol","role":"collection","title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/getUserId":{"fragments":[{"text":"+ ","kind":"text"},{"text":"getUserId","kind":"identifier"}],"title":"getUserId","kind":"symbol","type":"topic","url":"\/documentation\/pushwooshcore\/pwconfiguration\/getuserid","ide