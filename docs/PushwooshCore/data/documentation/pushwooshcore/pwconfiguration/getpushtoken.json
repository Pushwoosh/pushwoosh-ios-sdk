{"abstract":[{"text":"Retrieves the current device push token.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","text":"NSString","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"kind":"identifier","text":"getPushToken"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"content":[{"type":"heading","anchor":"return-value","level":2,"text":"Return Value"},{"inlineContent":[{"type":"text","text":"The device push token as a hexadecimal string, or nil if not yet registered"}],"type":"paragraph"}],"kind":"content"},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"text":"Returns the APNs device token as a hexadecimal string. The token is used by Apple’s","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Push Notification service to deliver notifications to this specific device."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The push token becomes available after:"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Calling "},{"type":"codeVoice","code":"registerForPushNotifications"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"User granting notification permission"}]}]},{"content":[{"inlineContent":[{"text":"Successful registration with APNs","type":"text"}],"type":"paragraph"}]}]},{"level":2,"type":"heading","anchor":"Example","text":"Example"},{"inlineContent":[{"type":"text","text":"Send push token to your backend for server-side notifications:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class PushTokenManager {","","    func syncPushTokenIfNeeded() {","        guard let pushToken = Pushwoosh.configure.getPushToken() else {","            Logger.debug(\"Push token not available yet\")","            return","        }","","        \/\/ Check if token has changed since last sync","        let lastSyncedToken = UserDefaults.standard.string(forKey: \"lastSyncedPushToken\")","        guard pushToken != lastSyncedToken else {","            return \/\/ Token unchanged, no need to sync","        }","","        let hwid = Pushwoosh.configure.getHWID()","","        APIClient.shared.post(\"\/api\/push-tokens\", body: [","            \"hwid\": hwid,","            \"pushToken\": pushToken,","            \"platform\": \"ios\"","        ]) { result in","            if case .success = result {","                UserDefaults.standard.set(pushToken, forKey: \"lastSyncedPushToken\")","                Logger.info(\"Push token synced successfully\")","            }","        }","    }","}"]}]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getPushToken","interfaceLanguage":"occ"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/getpushtoken"]}],"metadata":{"role":"symbol","modules":[{"name":"PushwooshCore"}],"fragments":[{"text":"+ ","kind":"text"},{"text":"getPushToken","kind":"identifier"}],"navigatorTitle":[{"text":"getPushToken","kind":"identifier"}],"roleHeading":"Type Method","title":"getPushToken","externalID":"c:objc(pl)PWConfiguration(cm)getPushToken","symbolKind":"method"},"kind":"symbol","sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"role":"symbol","abstract":[],"kind":"symbol","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","url":"\/documentation\/pushwooshcore","role":"collection"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/getPushToken":{"abstract":[{"type":"text","text":"Retrieves the current device push token."}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/getpushtoken","role":"symbol","navigatorTitle":[{"text":"getPushToken","kind":"identifier"}],"title":"getPushToken","kind":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"getPushToken","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getPushToken"}}}