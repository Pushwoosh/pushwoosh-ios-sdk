{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSString","text":"NSString","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"getPushToken","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}]},{"kind":"content","content":[{"text":"Return Value","anchor":"return-value","type":"heading","level":2},{"inlineContent":[{"text":"The device push token as a hexadecimal string, or nil if not yet registered","type":"text"}],"type":"paragraph"}]},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Returns the APNs device token as a hexadecimal string. The token is used by Apple’s"},{"type":"text","text":" "},{"text":"Push Notification service to deliver notifications to this specific device.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The push token becomes available after:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Calling ","type":"text"},{"type":"codeVoice","code":"registerForPushNotifications"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"User granting notification permission","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Successful registration with APNs","type":"text"}]}]}],"type":"orderedList"},{"level":2,"text":"Example","anchor":"Example","type":"heading"},{"inlineContent":[{"text":"Send push token to your backend for server-side notifications:","type":"text"}],"type":"paragraph"},{"code":["class PushTokenManager {","","    func syncPushTokenIfNeeded() {","        guard let pushToken = Pushwoosh.configure.getPushToken() else {","            Logger.debug(\"Push token not available yet\")","            return","        }","","        \/\/ Check if token has changed since last sync","        let lastSyncedToken = UserDefaults.standard.string(forKey: \"lastSyncedPushToken\")","        guard pushToken != lastSyncedToken else {","            return \/\/ Token unchanged, no need to sync","        }","","        let hwid = Pushwoosh.configure.getHWID()","","        APIClient.shared.post(\"\/api\/push-tokens\", body: [","            \"hwid\": hwid,","            \"pushToken\": pushToken,","            \"platform\": \"ios\"","        ]) { result in","            if case .success = result {","                UserDefaults.standard.set(pushToken, forKey: \"lastSyncedPushToken\")","                Logger.info(\"Push token synced successfully\")","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"sections":[],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getPushToken","interfaceLanguage":"occ"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"role":"symbol","symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)getPushToken","modules":[{"name":"PushwooshCore"}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"getPushToken"}],"navigatorTitle":[{"text":"getPushToken","kind":"identifier"}],"roleHeading":"Type Method","title":"getPushToken"},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/getpushtoken"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"text":"Retrieves the current device push token.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","title":"PushwooshCore","role":"collection","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"kind":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","abstract":[],"title":"PWConfiguration","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/getPushToken":{"type":"topic","role":"symbol","kind":"symbol","abstract":[{"text":"Retrieves the current device push token.","type":"text"}],"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"getPushToken"}],"navigatorTitle":[{"text":"getPushToken","kind":"identifier"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/getpushtoken","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getPushToken","title":"getPushToken"}}}