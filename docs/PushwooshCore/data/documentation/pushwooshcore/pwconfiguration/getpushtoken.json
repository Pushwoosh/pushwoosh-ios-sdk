{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getPushToken","interfaceLanguage":"occ"},"kind":"symbol","metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)getPushToken","symbolKind":"method","title":"getPushToken","roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}],"role":"symbol","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"getPushToken"}],"navigatorTitle":[{"kind":"identifier","text":"getPushToken"}]},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"abstract":[{"text":"Retrieves the current device push token.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/getpushtoken"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSString","text":"NSString","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"text":"getPushToken","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"kind":"content","content":[{"text":"Return Value","type":"heading","level":2,"anchor":"return-value"},{"inlineContent":[{"text":"The device push token as a hexadecimal string, or nil if not yet registered","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Returns the APNs device token as a hexadecimal string. The token is used by Apple’s"},{"text":" ","type":"text"},{"text":"Push Notification service to deliver notifications to this specific device.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The push token becomes available after:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Calling "},{"type":"codeVoice","code":"registerForPushNotifications"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"User granting notification permission"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Successful registration with APNs"}],"type":"paragraph"}]}],"type":"orderedList"},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"inlineContent":[{"text":"Send push token to your backend for server-side notifications:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class PushTokenManager {","","    func syncPushTokenIfNeeded() {","        guard let pushToken = Pushwoosh.configure.getPushToken() else {","            Logger.debug(\"Push token not available yet\")","            return","        }","","        \/\/ Check if token has changed since last sync","        let lastSyncedToken = UserDefaults.standard.string(forKey: \"lastSyncedPushToken\")","        guard pushToken != lastSyncedToken else {","            return \/\/ Token unchanged, no need to sync","        }","","        let hwid = Pushwoosh.configure.getHWID()","","        APIClient.shared.post(\"\/api\/push-tokens\", body: [","            \"hwid\": hwid,","            \"pushToken\": pushToken,","            \"platform\": \"ios\"","        ]) { result in","            if case .success = result {","                UserDefaults.standard.set(pushToken, forKey: \"lastSyncedPushToken\")","                Logger.info(\"Push token synced successfully\")","            }","        }","    }","}"]}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/getPushToken":{"abstract":[{"text":"Retrieves the current device push token.","type":"text"}],"type":"topic","navigatorTitle":[{"text":"getPushToken","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\