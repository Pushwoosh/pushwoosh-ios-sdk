{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getPushToken","interfaceLanguage":"occ"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier","text":"NSString"},{"text":" *) ","kind":"text"},{"kind":"identifier","text":"getPushToken"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}]},{"kind":"content","content":[{"text":"Return Value","level":2,"type":"heading","anchor":"return-value"},{"inlineContent":[{"type":"text","text":"The device push token as a hexadecimal string, or nil if not yet registered"}],"type":"paragraph"}]},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"text":"Returns the APNs device token as a hexadecimal string. The token is used by Apple’s","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Push Notification service to deliver notifications to this specific device."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The push token becomes available after:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Calling ","type":"text"},{"code":"registerForPushNotifications","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"User granting notification permission"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Successful registration with APNs"}],"type":"paragraph"}]}],"type":"orderedList"},{"level":2,"text":"Example","type":"heading","anchor":"Example"},{"inlineContent":[{"text":"Send push token to your backend for server-side notifications:","type":"text"}],"type":"paragraph"},{"code":["class PushTokenManager {","","    func syncPushTokenIfNeeded() {","        guard let pushToken = Pushwoosh.configure.getPushToken() else {","            Logger.debug(\"Push token not available yet\")","            return","        }","","        \/\/ Check if token has changed since last sync","        let lastSyncedToken = UserDefaults.standard.string(forKey: \"lastSyncedPushToken\")","        guard pushToken != lastSyncedToken else {","            return \/\/ Token unchanged, no need to sync","        }","","        let hwid = Pushwoosh.configure.getHWID()","","        APIClient.shared.post(\"\/api\/push-tokens\", body: [","            \"hwid\": hwid,","            \"pushToken\": pushToken,","            \"platform\": \"ios\"","        ]) { result in","            if case .success = result {","                UserDefaults.standard.set(pushToken, forKey: \"lastSyncedPushToken\")","                Logger.info(\"Push token synced successfully\")","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/getpushtoken"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"type":"text","text":"Retrieves the current device push token."}],"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"navigatorTitle":[{"kind":"identifier","text":"getPushToken"}],"role":"symbol","roleHeading":"Type Method","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"getPushToken"}],"title":"getPushToken","symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)getPushToken","modules":[{"name":"PushwooshCore"}]},"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/getPushToken":{"abstract":[{"type":"text","text":"Retrieves the current device push token."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getPushToken","fragments":[{"kind":"text","tex