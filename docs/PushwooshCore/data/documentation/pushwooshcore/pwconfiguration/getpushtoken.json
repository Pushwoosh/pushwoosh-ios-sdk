{"sections":[],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/getpushtoken"]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getPushToken","interfaceLanguage":"occ"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier","text":"NSString"},{"text":" *) ","kind":"text"},{"kind":"identifier","text":"getPushToken"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"content":[{"type":"heading","text":"Return Value","level":2,"anchor":"return-value"},{"inlineContent":[{"type":"text","text":"The device push token as a hexadecimal string, or nil if not yet registered"}],"type":"paragraph"}],"kind":"content"},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Returns the APNs device token as a hexadecimal string. The token is used by Apple’s"},{"text":" ","type":"text"},{"text":"Push Notification service to deliver notifications to this specific device.","type":"text"}]},{"inlineContent":[{"text":"The push token becomes available after:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Calling ","type":"text"},{"type":"codeVoice","code":"registerForPushNotifications"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"User granting notification permission","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Successful registration with APNs"}]}]}],"type":"orderedList"},{"anchor":"Example","type":"heading","text":"Example","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Send push token to your backend for server-side notifications:"}]},{"code":["class PushTokenManager {","","    func syncPushTokenIfNeeded() {","        guard let pushToken = Pushwoosh.configure.getPushToken() else {","            Logger.debug(\"Push token not available yet\")","            return","        }","","        \/\/ Check if token has changed since last sync","        let lastSyncedToken = UserDefaults.standard.string(forKey: \"lastSyncedPushToken\")","        guard pushToken != lastSyncedToken else {","            return \/\/ Token unchanged, no need to sync","        }","","        let hwid = Pushwoosh.configure.getHWID()","","        APIClient.shared.post(\"\/api\/push-tokens\", body: [","            \"hwid\": hwid,","            \"pushToken\": pushToken,","            \"platform\": \"ios\"","        ]) { result in","            if case .success = result {","                UserDefaults.standard.set(pushToken, forKey: \"lastSyncedPushToken\")","                Logger.info(\"Push token synced successfully\")","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"Retrieves the current device push token."}],"metadata":{"roleHeading":"Type Method","navigatorTitle":[{"text":"getPushToken","kind":"identifier"}],"symbolKind":"method","modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)getPushToken","role":"symbol","title":"getPushToken","fragments":[{"kind":"text","text":"+ "},{"text":"getPushToken","kind":"identifier"}]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","title":"PushwooshCore","kind":"symbol","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","url":"\/documentation\/pushwooshcore","role":"collection"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","role":"symbol","kind":"symbol","title":"PWConfiguration","type":"topic","fragments":[{"text":"PWConfiguration","kind":"identifier"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/getPushToken":{"role":"symbol","kind":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"getPushToken","kind":"identifier"}],"type":"topic","title":"getPushToken","url":"\/documentation\/pushwooshcore\/pwconfiguration\/getpushtoken","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getPushToken","abstract":[{"type":"text","text":"Retrieves the current device push token."}],"navigatorTitle":[{"text":"getPushToken","kind":"identifier"}]}}}