{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getPushToken"},"sections":[],"abstract":[{"text":"Retrieves the current device push token.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"text":"getPushToken","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"content":[{"anchor":"return-value","level":2,"text":"Return Value","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The device push token as a hexadecimal string, or nil if not yet registered"}]}],"kind":"content"},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Returns the APNs device token as a hexadecimal string. The token is used by Apple’s"},{"text":" ","type":"text"},{"type":"text","text":"Push Notification service to deliver notifications to this specific device."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The push token becomes available after:"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Calling ","type":"text"},{"type":"codeVoice","code":"registerForPushNotifications"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"User granting notification permission","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Successful registration with APNs","type":"text"}],"type":"paragraph"}]}]},{"level":2,"text":"Example","type":"heading","anchor":"Example"},{"type":"paragraph","inlineContent":[{"text":"Send push token to your backend for server-side notifications:","type":"text"}]},{"code":["class PushTokenManager {","","    func syncPushTokenIfNeeded() {","        guard let pushToken = Pushwoosh.configure.getPushToken() else {","            Logger.debug(\"Push token not available yet\")","            return","        }","","        \/\/ Check if token has changed since last sync","        let lastSyncedToken = UserDefaults.standard.string(forKey: \"lastSyncedPushToken\")","        guard pushToken != lastSyncedToken else {","            return \/\/ Token unchanged, no need to sync","        }","","        let hwid = Pushwoosh.configure.getHWID()","","        APIClient.shared.post(\"\/api\/push-tokens\", body: [","            \"hwid\": hwid,","            \"pushToken\": pushToken,","            \"platform\": \"ios\"","        ]) { result in","            if case .success = result {","                UserDefaults.standard.set(pushToken, forKey: \"lastSyncedPushToken\")","                Logger.info(\"Push token synced successfully\")","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"navigatorTitle":[{"kind":"identifier","text":"getPushToken"}],"symbolKind":"method","role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)getPushToken","modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","fragments":[{"text":"+ ","kind":"text"},{"text":"getPushToken","kind":"identifier"}],"title":"getPushToken"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/getpushtoken"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","url":"\/documentation\/pushwooshcore","role":"collection","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","title":"PushwooshCore","kind":"symbol","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/getPushToken":{"navigatorTitle":[{"kind":"identifier","text":"getPushToken"}],"abstract":[{"type":"text","text":"Retrieves the current device push token."}],"kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/getpushtoken","role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"getPushToken","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getPushToken","title":"getPushToken"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"kind":"symbol","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","type":"topic"}}}