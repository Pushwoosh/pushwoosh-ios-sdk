{"abstract":[{"type":"text","text":"Retrieves the current device push token."}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/getpushtoken"]}],"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)getPushToken","title":"getPushToken","fragments":[{"text":"+ ","kind":"text"},{"text":"getPushToken","kind":"identifier"}],"roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}],"role":"symbol","symbolKind":"method","navigatorTitle":[{"text":"getPushToken","kind":"identifier"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getPushToken"},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier","text":"NSString"},{"text":" *) ","kind":"text"},{"text":"getPushToken","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}]},{"kind":"content","content":[{"type":"heading","text":"Return Value","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The device push token as a hexadecimal string, or nil if not yet registered"}]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Returns the APNs device token as a hexadecimal string. The token is used by Apple’s","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Push Notification service to deliver notifications to this specific device."}]},{"type":"paragraph","inlineContent":[{"text":"The push token becomes available after:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"text":"Calling ","type":"text"},{"type":"codeVoice","code":"registerForPushNotifications"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"User granting notification permission"}]}]},{"content":[{"inlineContent":[{"text":"Successful registration with APNs","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"type":"heading","text":"Example","level":2,"anchor":"Example"},{"inlineContent":[{"text":"Send push token to your backend for server-side notifications:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class PushTokenManager {","","    func syncPushTokenIfNeeded() {","        guard let pushToken = Pushwoosh.configure.getPushToken() else {","            Logger.debug(\"Push token not available yet\")","            return","        }","","        \/\/ Check if token has changed since last sync","        let lastSyncedToken = UserDefaults.standard.string(forKey: \"lastSyncedPushToken\")","        guard pushToken != lastSyncedToken else {","            return \/\/ Token unchanged, no need to sync","        }","","        let hwid = Pushwoosh.configure.getHWID()","","        APIClient.shared.post(\"\/api\/push-tokens\", body: [","            \"hwid\": hwid,","            \"pushToken\": pushToken,","            \"platform\": \"ios\"","        ]) { result in","            if case .success = result {","                UserDefaults.standard.set(pushToken, forKey: \"lastSyncedPushToken\")","                Logger.info(\"Push token synced successfully\")","            }","        }","    }","}"]}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/getPushToken":{"title":"getPushToken","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"getPushToken"}],"kind":"symbol","role":"symbol","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/P