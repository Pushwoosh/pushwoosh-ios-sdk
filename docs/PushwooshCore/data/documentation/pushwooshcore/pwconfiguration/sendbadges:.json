{"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/sendbadges:"]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendBadges:","interfaceLanguage":"occ"},"metadata":{"modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","externalID":"c:objc(pl)PWConfiguration(cm)sendBadges:","title":"sendBadges:","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"sendBadges:"}],"navigatorTitle":[{"text":"sendBadges:","kind":"identifier"}],"role":"symbol","symbolKind":"method"},"sections":[],"abstract":[{"type":"text","text":"Synchronizes the application badge number with Pushwoosh servers."}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"text":"sendBadges:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:@T@NSInteger","text":"NSInteger","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"kind":"internalParam","text":"badge"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The current application badge number (0 to clear badge)."}]}],"name":"badge"}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Reports the current badge count to Pushwoosh for analytics and to enable"},{"type":"text","text":" "},{"text":"badge-based segmentation. This is useful for:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Analytics","type":"text"}]},{"type":"text","text":": Track user engagement through unread counts"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Segmentation"}],"type":"strong"},{"type":"text","text":": Target users with high\/low badge counts"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Badge management","type":"text"}]},{"type":"text","text":": Allow server-side badge manipulation"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call this method whenever you update the app badge to keep Pushwoosh in sync."}]},{"level":2,"text":"Example","type":"heading","anchor":"Example"},{"type":"paragraph","inlineContent":[{"text":"Sync badge with Pushwoosh when updating unread counts:","type":"text"}]},{"type":"codeListing","code":["class NotificationBadgeManager {","","    private(set) var unreadCount: Int = 0 {","        didSet {","            updateBadge()","        }","    }","","    func markAsRead(_ notificationIds: [String]) {","        unreadCount = max(0, unreadCount - notificationIds.count)","    }","","    func handleNewNotification() {","        unreadCount += 1","    }","","    func clearAll() {","        unreadCount = 0","    }","","    private func updateBadge() {","        \/\/ Update system badge","        if #available(iOS 16.0, *) {","            UNUserNotificationCenter.current().setBadgeCount(unreadCount)","        } else {","            UIApplication.shared.applicationIconBadgeNumber = unreadCount","        }","","        \/\/ Sync with Pushwoosh","        Pushwoosh.configure.sendBadges(unreadCount)","    }","}","","\/\/ Usage in AppDelegate","class AppDelegate: UIApplicationDelegate {","","    func applicationDidBecomeActive(_ application: UIApplication) {","        \/\/ Sync current badge state when app becomes active","        let currentBadge = application.applicationIconBadgeNumber","        Pushwoosh.configure.sendBadges(currentBadge)","    }","}"],"syntax":"swift"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","title":"PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"role":"symbol","abstract":[]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/sendBadges:":{"url":"\/documentation\/pushwooshcore\/pwconfiguration\/sendbadges:","kind":"symbol","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendBadges:","title":"sendBadges:","fragments":[{"text":"+ ","kind":"text"},{"text":"sendBadges:","kind":"identifier"}],"navigatorTitle":[{"text":"sendBadges:","kind":"identifier"}],"abstract":[{"type":"text","text":"Synchronizes the application badge number with Pushwoosh servers."}],"role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","title":"PushwooshCore","role":"collection","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"kind":"symbol"}}}