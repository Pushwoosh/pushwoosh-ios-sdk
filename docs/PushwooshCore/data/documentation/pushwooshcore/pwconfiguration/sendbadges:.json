{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendBadges:","interfaceLanguage":"occ"},"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"abstract":[{"type":"text","text":"Synchronizes the application badge number with Pushwoosh servers."}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/sendbadges:"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"modules":[{"name":"PushwooshCore"}],"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"sendBadges:"}],"navigatorTitle":[{"text":"sendBadges:","kind":"identifier"}],"symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)sendBadges:","role":"symbol","title":"sendBadges:","roleHeading":"Type Method"},"kind":"symbol","sections":[],"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"kind":"identifier","text":"sendBadges:"},{"kind":"text","text":"("},{"text":"NSInteger","kind":"typeIdentifier","preciseIdentifier":"c:@T@NSInteger"},{"kind":"text","text":") "},{"text":"badge","kind":"internalParam"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The current application badge number (0 to clear badge)."}]}],"name":"badge"}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"Reports the current badge count to Pushwoosh for analytics and to enable"},{"text":" ","type":"text"},{"text":"badge-based segmentation. This is useful for:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Analytics"}]},{"type":"text","text":": Track user engagement through unread counts"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Segmentation","type":"text"}],"type":"strong"},{"text":": Target users with high\/low badge counts","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Badge management","type":"text"}],"type":"strong"},{"type":"text","text":": Allow server-side badge manipulation"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"Call this method whenever you update the app badge to keep Pushwoosh in sync.","type":"text"}]},{"anchor":"Example","level":2,"type":"heading","text":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Sync badge with Pushwoosh when updating unread counts:"}]},{"type":"codeListing","syntax":"swift","code":["class NotificationBadgeManager {","","    private(set) var unreadCount: Int = 0 {","        didSet {","            updateBadge()","        }","    }","","    func markAsRead(_ notificationIds: [String]) {","        unreadCount = max(0, unreadCount - notificationIds.count)","    }","","    func handleNewNotification() {","        unreadCount += 1","    }","","    func clearAll() {","        unreadCount = 0","    }","","    private func updateBadge() {","        \/\/ Update system badge","        if #available(iOS 16.0, *) {","            UNUserNotificationCenter.current().setBadgeCount(unreadCount)","        } else {","            UIApplication.shared.applicationIconBadgeNumber = unreadCount","        }","","        \/\/ Sync with Pushwoosh","        Pushwoosh.configure.sendBadges(unreadCount)","    }","}","","\/\/ Usage in AppDelegate","class AppDelegate: UIApplicationDelegate {","","    func applicationDidBecomeActive(_ application: UIApplication) {","        \/\/ Sync current badge state when app becomes active","        let currentBadge = application.applicationIconBadgeNumber","        Pushwoosh.configure.sendBadges(currentBadge)","    }","}"]}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/sendBadges:":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendBadges:","abstract":[{"type":"text","text":"Synchronizes the application badge number with Pushwoosh servers."}],"type":"topic","url":"\/documentation\/pushwooshcore\/pwconfiguration\/sendbadges:","fragments":[{"kind":"text","text":"+ "},{"text":"sendBadges:","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"sendBadges:"}],"title":"sendBadges:","role":"symbol","kind":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","kind":"symbol","role":"collection","title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"title":"PWConfiguration","type":"topic","role":"symbol"}}}