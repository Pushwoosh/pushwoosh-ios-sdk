{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendBadges:","interfaceLanguage":"occ"},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"metadata":{"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"sendBadges:"}],"title":"sendBadges:","symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)sendBadges:","roleHeading":"Type Method","role":"symbol","navigatorTitle":[{"text":"sendBadges:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}]},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"sendBadges:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:@T@NSInteger","text":"NSInteger","kind":"typeIdentifier"},{"kind":"text","text":") "},{"kind":"internalParam","text":"badge"},{"kind":"text","text":";"}],"languages":["occ"]}],"kind":"declarations"},{"parameters":[{"name":"badge","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The current application badge number (0 to clear badge)."}]}]}],"kind":"parameters"},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"text":"Reports the current badge count to Pushwoosh for analytics and to enable","type":"text"},{"type":"text","text":" "},{"type":"text","text":"badge-based segmentation. This is useful for:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Analytics","type":"text"}]},{"type":"text","text":": Track user engagement through unread counts"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Segmentation","type":"text"}]},{"type":"text","text":": Target users with high\/low badge counts"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Badge management"}]},{"type":"text","text":": Allow server-side badge manipulation"}]}]}]},{"inlineContent":[{"type":"text","text":"Call this method whenever you update the app badge to keep Pushwoosh in sync."}],"type":"paragraph"},{"anchor":"Example","level":2,"type":"heading","text":"Example"},{"type":"paragraph","inlineContent":[{"text":"Sync badge with Pushwoosh when updating unread counts:","type":"text"}]},{"code":["class NotificationBadgeManager {","","    private(set) var unreadCount: Int = 0 {","        didSet {","            updateBadge()","        }","    }","","    func markAsRead(_ notificationIds: [String]) {","        unreadCount = max(0, unreadCount - notificationIds.count)","    }","","    func handleNewNotification() {","        unreadCount += 1","    }","","    func clearAll() {","        unreadCount = 0","    }","","    private func updateBadge() {","        \/\/ Update system badge","        if #available(iOS 16.0, *) {","            UNUserNotificationCenter.current().setBadgeCount(unreadCount)","        } else {","            UIApplication.shared.applicationIconBadgeNumber = unreadCount","        }","","        \/\/ Sync with Pushwoosh","        Pushwoosh.configure.sendBadges(unreadCount)","    }","}","","\/\/ Usage in AppDelegate","class AppDelegate: UIApplicationDelegate {","","    func applicationDidBecomeActive(_ application: UIApplication) {","        \/\/ Sync current badge state when app becomes active","        let currentBadge = application.applicationIconBadgeNumber","        Pushwoosh.configure.sendBadges(currentBadge)","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/sendbadges:"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"text":"Synchronizes the application badge number with Pushwoosh servers.","type":"text"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/sendBadges:":{"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"sendBadges:"}],"title":"sendBadges:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/sendbadges:","abstract":[{"text":"Synchronizes the application badge number with Pushwoosh servers.","type":"text"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendBadges:","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"sendBadges:"}],"kind":"symbol","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","role":"symbol","title":"PWConfiguration","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","abstract":[]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","url":"\/documentation\/pushwooshcore","title":"PushwooshCore","type":"topic","kind":"symbol","role":"collection","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}]}}}