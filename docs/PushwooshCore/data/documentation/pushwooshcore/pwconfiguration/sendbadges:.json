{"abstract":[{"type":"text","text":"Synchronizes the application badge number with Pushwoosh servers."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendBadges:","interfaceLanguage":"occ"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/sendbadges:"]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"kind":"identifier","text":"sendBadges:"},{"kind":"text","text":"("},{"text":"NSInteger","kind":"typeIdentifier","preciseIdentifier":"c:@T@NSInteger"},{"text":") ","kind":"text"},{"kind":"internalParam","text":"badge"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"parameters":[{"name":"badge","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The current application badge number (0 to clear badge)."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Reports the current badge count to Pushwoosh for analytics and to enable","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"badge-based segmentation. This is useful for:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Analytics","type":"text"}]},{"text":": Track user engagement through unread counts","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Segmentation"}],"type":"strong"},{"type":"text","text":": Target users with high\/low badge counts"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Badge management","type":"text"}],"type":"strong"},{"type":"text","text":": Allow server-side badge manipulation"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Call this method whenever you update the app badge to keep Pushwoosh in sync.","type":"text"}]},{"text":"Example","anchor":"Example","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Sync badge with Pushwoosh when updating unread counts:"}],"type":"paragraph"},{"syntax":"swift","code":["class NotificationBadgeManager {","","    private(set) var unreadCount: Int = 0 {","        didSet {","            updateBadge()","        }","    }","","    func markAsRead(_ notificationIds: [String]) {","        unreadCount = max(0, unreadCount - notificationIds.count)","    }","","    func handleNewNotification() {","        unreadCount += 1","    }","","    func clearAll() {","        unreadCount = 0","    }","","    private func updateBadge() {","        \/\/ Update system badge","        if #available(iOS 16.0, *) {","            UNUserNotificationCenter.current().setBadgeCount(unreadCount)","        } else {","            UIApplication.shared.applicationIconBadgeNumber = unreadCount","        }","","        \/\/ Sync with Pushwoosh","        Pushwoosh.configure.sendBadges(unreadCount)","    }","}","","\/\/ Usage in AppDelegate","class AppDelegate: UIApplicationDelegate {","","    func applicationDidBecomeActive(_ application: UIApplication) {","        \/\/ Sync current badge state when app becomes active","        let currentBadge = application.applicationIconBadgeNumber","        Pushwoosh.configure.sendBadges(currentBadge)","    }","}"],"type":"codeListing"}]}],"metadata":{"role":"symbol","symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)sendBadges:","modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"kind":"identifier","text":"sendBadges:"}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"sendBadges:"}],"title":"sendBadges:","roleHeading":"Type Method"},"kind":"symbol","sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","role":"collection","kind":"symbol","title":"PushwooshCore","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","url":"\/documentation\/pushwooshcore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/sendBadges:":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendBadges:","type":"topic","role":"symbol","title":"sendBadges:","fragments":[{"kind":"text","text":"+ "},{"text":"sendBadges:","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"sendBadges:"}],"kind":"symbol","abstract":[{"text":"Synchronizes the application badge number with Pushwoosh servers.","type":"text"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/sendbadges:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"fragments":[{"text":"PWConfiguration","kind":"identifier"}],"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","title":"PWConfiguration","kind":"symbol","type":"topic","role":"symbol"}}}