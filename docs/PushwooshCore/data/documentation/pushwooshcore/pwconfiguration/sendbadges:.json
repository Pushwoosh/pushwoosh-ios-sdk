{"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"Synchronizes the application badge number with Pushwoosh servers.","type":"text"}],"metadata":{"role":"symbol","symbolKind":"method","roleHeading":"Type Method","title":"sendBadges:","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"sendBadges:"}],"navigatorTitle":[{"text":"sendBadges:","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)sendBadges:","modules":[{"name":"PushwooshCore"}]},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/sendbadges:"]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendBadges:","interfaceLanguage":"occ"},"sections":[],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"sendBadges:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:@T@NSInteger","kind":"typeIdentifier","text":"NSInteger"},{"text":") ","kind":"text"},{"text":"badge","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"name":"badge","content":[{"type":"paragraph","inlineContent":[{"text":"The current application badge number (0 to clear badge).","type":"text"}]}]}]},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Reports the current badge count to Pushwoosh for analytics and to enable"},{"type":"text","text":" "},{"type":"text","text":"badge-based segmentation. This is useful for:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Analytics"}]},{"type":"text","text":": Track user engagement through unread counts"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Segmentation"}],"type":"strong"},{"text":": Target users with high\/low badge counts","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Badge management","type":"text"}]},{"type":"text","text":": Allow server-side badge manipulation"}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"Call this method whenever you update the app badge to keep Pushwoosh in sync.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Example","anchor":"Example","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Sync badge with Pushwoosh when updating unread counts:"}]},{"syntax":"swift","type":"codeListing","code":["class NotificationBadgeManager {","","    private(set) var unreadCount: Int = 0 {","        didSet {","            updateBadge()","        }","    }","","    func markAsRead(_ notificationIds: [String]) {","        unreadCount = max(0, unreadCount - notificationIds.count)","    }","","    func handleNewNotification() {","        unreadCount += 1","    }","","    func clearAll() {","        unreadCount = 0","    }","","    private func updateBadge() {","        \/\/ Update system badge","        if #available(iOS 16.0, *) {","            UNUserNotificationCenter.current().setBadgeCount(unreadCount)","        } else {","            UIApplication.shared.applicationIconBadgeNumber = unreadCount","        }","","        \/\/ Sync with Pushwoosh","        Pushwoosh.configure.sendBadges(unreadCount)","    }","}","","\/\/ Usage in AppDelegate","class AppDelegate: UIApplicationDelegate {","","    func applicationDidBecomeActive(_ application: UIApplication) {","        \/\/ Sync current badge state when app becomes active","        let currentBadge = application.applicationIconBadgeNumber","        Pushwoosh.configure.sendBadges(currentBadge)","    }","}"]}],"kind":"content"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/sendBadges:":{"abstract":[{"text":"Synchronizes the application badge number with Pushwoosh servers.","type":"text"}],"type":"topic","fragments":[{"text":"+ ","kind":"text"},{"text":"sendBadges:","kind":"identifier"}],"navigatorTitle":[{"text":"sendBadges:","kind":"identifier"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/sendbadges:","kind":"symbol","role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendBadges:","title":"sendBadges:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","type":"topic","url":"\/documentation\/pushwooshcore\/pwconfiguration","abstract":[],"role":"symbol","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"title":"PushwooshCore","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore"}}}