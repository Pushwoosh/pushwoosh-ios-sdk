{"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"navigatorTitle":[{"text":"sendBadges:","kind":"identifier"}],"role":"symbol","modules":[{"name":"PushwooshCore"}],"symbolKind":"method","roleHeading":"Type Method","fragments":[{"kind":"text","text":"+ "},{"text":"sendBadges:","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)sendBadges:","title":"sendBadges:"},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendBadges:"},"abstract":[{"text":"Synchronizes the application badge number with Pushwoosh servers.","type":"text"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/sendbadges:"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"kind":"identifier","text":"sendBadges:"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@NSInteger","text":"NSInteger"},{"text":") ","kind":"text"},{"text":"badge","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"parameters":[{"name":"badge","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The current application badge number (0 to clear badge)."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Reports the current badge count to Pushwoosh for analytics and to enable","type":"text"},{"type":"text","text":" "},{"type":"text","text":"badge-based segmentation. This is useful for:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Analytics"}]},{"type":"text","text":": Track user engagement through unread counts"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Segmentation","type":"text"}],"type":"strong"},{"type":"text","text":": Target users with high\/low badge counts"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Badge management"}]},{"type":"text","text":": Allow server-side badge manipulation"}]}]}]},{"inlineContent":[{"type":"text","text":"Call this method whenever you update the app badge to keep Pushwoosh in sync."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Example","anchor":"Example"},{"type":"paragraph","inlineContent":[{"text":"Sync badge with Pushwoosh when updating unread counts:","type":"text"}]},{"syntax":"swift","code":["class NotificationBadgeManager {","","    private(set) var unreadCount: Int = 0 {","        didSet {","            updateBadge()","        }","    }","","    func markAsRead(_ notificationIds: [String]) {","        unreadCount = max(0, unreadCount - notificationIds.count)","    }","","    func handleNewNotification() {","        unreadCount += 1","    }","","    func clearAll() {","        unreadCount = 0","    }","","    private func updateBadge() {","        \/\/ Update system badge","        if #available(iOS 16.0, *) {","            UNUserNotificationCenter.current().setBadgeCount(unreadCount)","        } else {","            UIApplication.shared.applicationIconBadgeNumber = unreadCount","        }","","        \/\/ Sync with Pushwoosh","        Pushwoosh.configure.sendBadges(unreadCount)","    }","}","","\/\/ Usage in AppDelegate","class AppDelegate: UIApplicationDelegate {","","    func applicationDidBecomeActive(_ application: UIApplication) {","        \/\/ Sync current badge state when app becomes active","        let currentBadge = application.applicationIconBadgeNumber","        Pushwoosh.configure.sendBadges(currentBadge)","    }","}"],"type":"codeListing"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","role":"collection","url":"\/documentation\/pushwooshcore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"kind":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/sendBadges:":{"role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/sendbadges:","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"sendBadges:"}],"type":"topic","abstract":[{"type":"text","text":"Synchronizes the application badge number with Pushwoosh servers."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendBadges:","kind":"symbol","navigatorTitle":[{"text":"sendBadges:","kind":"identifier"}],"title":"sendBadges:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"type":"topic","role":"symbol","kind":"symbol","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"}}}