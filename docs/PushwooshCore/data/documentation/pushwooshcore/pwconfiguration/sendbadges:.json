{"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/sendbadges:"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"Synchronizes the application badge number with Pushwoosh servers."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"kind":"identifier","text":"sendBadges:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:@T@NSInteger","kind":"typeIdentifier","text":"NSInteger"},{"kind":"text","text":") "},{"text":"badge","kind":"internalParam"},{"text":";","kind":"text"}]}]},{"parameters":[{"name":"badge","content":[{"inlineContent":[{"text":"The current application badge number (0 to clear badge).","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Reports the current badge count to Pushwoosh for analytics and to enable"},{"type":"text","text":" "},{"text":"badge-based segmentation. This is useful for:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Analytics","type":"text"}]},{"type":"text","text":": Track user engagement through unread counts"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Segmentation"}]},{"text":": Target users with high\/low badge counts","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Badge management"}],"type":"strong"},{"type":"text","text":": Allow server-side badge manipulation"}]}]}]},{"inlineContent":[{"type":"text","text":"Call this method whenever you update the app badge to keep Pushwoosh in sync."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Example","anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Sync badge with Pushwoosh when updating unread counts:"}]},{"syntax":"swift","type":"codeListing","code":["class NotificationBadgeManager {","","    private(set) var unreadCount: Int = 0 {","        didSet {","            updateBadge()","        }","    }","","    func markAsRead(_ notificationIds: [String]) {","        unreadCount = max(0, unreadCount - notificationIds.count)","    }","","    func handleNewNotification() {","        unreadCount += 1","    }","","    func clearAll() {","        unreadCount = 0","    }","","    private func updateBadge() {","        \/\/ Update system badge","        if #available(iOS 16.0, *) {","            UNUserNotificationCenter.current().setBadgeCount(unreadCount)","        } else {","            UIApplication.shared.applicationIconBadgeNumber = unreadCount","        }","","        \/\/ Sync with Pushwoosh","        Pushwoosh.configure.sendBadges(unreadCount)","    }","}","","\/\/ Usage in AppDelegate","class AppDelegate: UIApplicationDelegate {","","    func applicationDidBecomeActive(_ application: UIApplication) {","        \/\/ Sync current badge state when app becomes active","        let currentBadge = application.applicationIconBadgeNumber","        Pushwoosh.configure.sendBadges(currentBadge)","    }","}"]}],"kind":"content"}],"metadata":{"title":"sendBadges:","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"sendBadges:"}],"roleHeading":"Type Method","role":"symbol","modules":[{"name":"PushwooshCore"}],"symbolKind":"method","navigatorTitle":[{"kind":"identifier","text":"sendBadges:"}],"externalID":"c:objc(pl)PWConfiguration(cm)sendBadg