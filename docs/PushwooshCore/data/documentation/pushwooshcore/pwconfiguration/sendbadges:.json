{"abstract":[{"type":"text","text":"Synchronizes the application badge number with Pushwoosh servers."}],"sections":[],"metadata":{"role":"symbol","navigatorTitle":[{"text":"sendBadges:","kind":"identifier"}],"title":"sendBadges:","modules":[{"name":"PushwooshCore"}],"symbolKind":"method","fragments":[{"text":"+ ","kind":"text"},{"text":"sendBadges:","kind":"identifier"}],"roleHeading":"Type Method","externalID":"c:objc(pl)PWConfiguration(cm)sendBadges:"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"kind":"identifier","text":"sendBadges:"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@NSInteger","text":"NSInteger"},{"kind":"text","text":") "},{"text":"badge","kind":"internalParam"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"badge","content":[{"inlineContent":[{"type":"text","text":"The current application badge number (0 to clear badge)."}],"type":"paragraph"}]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Reports the current badge count to Pushwoosh for analytics and to enable"},{"type":"text","text":" "},{"text":"badge-based segmentation. This is useful for:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Analytics","type":"text"}],"type":"strong"},{"type":"text","text":": Track user engagement through unread counts"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Segmentation"}]},{"type":"text","text":": Target users with high\/low badge counts"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Badge management"}],"type":"strong"},{"type":"text","text":": Allow server-side badge manipulation"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call this method whenever you update the app badge to keep Pushwoosh in sync."}]},{"text":"Example","level":2,"anchor":"Example","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Sync badge with Pushwoosh when updating unread counts:","type":"text"}]},{"syntax":"swift","code":["class NotificationBadgeManager {","","    private(set) var unreadCount: Int = 0 {","        didSet {","            updateBadge()","        }","    }","","    func markAsRead(_ notificationIds: [String]) {","        unreadCount = max(0, unreadCount - notificationIds.count)","    }","","    func handleNewNotification() {","        unreadCount += 1","    }","","    func clearAll() {","        unreadCount = 0","    }","","    private func updateBadge() {","        \/\/ Update system badge","        if #available(iOS 16.0, *) {","            UNUserNotificationCenter.current().setBadgeCount(unreadCount)","        } else {","            UIApplication.shared.applicationIconBadgeNumber = unreadCount","        }","","        \/\/ Sync with Pushwoosh","        Pushwoosh.configure.sendBadges(unreadCount)","    }","}","","\/\/ Usage in AppDelegate","class AppDelegate: UIApplicationDelegate {","","    func applicationDidBecomeActive(_ application: UIApplication) {","        \/\/ Sync current badge state when app becomes active","        let currentBadge = application.applicationIconBadgeNumber","        Pushwoosh.configure.sendBadges(currentBadge)","    }","}"],"type":"codeListing"}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendBadges:","interfaceLanguage":"occ"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/sendbadges:"]}],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/sendBadges:":{"url":"\/documentation\/pushwooshcore\/pwconfiguration\/sendbadges:","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendBadges:","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"sendBadges:"}],"type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Synchronizes the application badge number with Pushwoosh servers."}],"title":"sendBadges:","fragments":[{"kind":"text","text":"+ "},{"text":"sendBadges:","kind":"identifier"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","title":"PushwooshCore","kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","abstract":[],"kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"title":"PWConfiguration"}}}