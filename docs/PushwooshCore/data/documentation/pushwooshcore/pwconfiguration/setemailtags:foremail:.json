{"abstract":[{"type":"text","text":"Sets tags for a specific email address in email campaigns."}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"kind":"identifier","text":"setEmailTags:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSDictionary","text":"NSDictionary","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"tags"},{"kind":"text","text":" "},{"kind":"identifier","text":"forEmail:"},{"text":"(","kind":"text"},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"email"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"parameters":[{"name":"tags","content":[{"inlineContent":[{"text":"Dictionary of tag names and values to associate with the email.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Supported value types: NSString, NSNumber, NSArray, NSNull (to delete)."}],"type":"paragraph"}]},{"name":"email","content":[{"inlineContent":[{"type":"text","text":"The email address to associate tags with. Must be a valid email format."}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"Associates tags with an email address independently of the current device.","type":"text"},{"text":" ","type":"text"},{"text":"This is used for email-specific segmentation in Pushwoosh Email campaigns.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Email tags are separate from device tags:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Device tags: Associated with push token, used for push segmentation"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Email tags: Associated with email address, used for email segmentation","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Use this for email-specific attributes like email preferences, engagement metrics,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"or email-only campaign targeting."}]},{"text":"Example","level":2,"type":"heading","anchor":"Example"},{"inlineContent":[{"text":"Update email campaign preferences:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["class EmailPreferencesManager {","","    func updateEmailPreferences(for email: String, preferences: EmailPreferences) {","        let tags: [String: Any] = [","            \"email_frequency\": preferences.frequency.rawValue,","            \"email_categories\": preferences.subscribedCategories.map { $0.rawValue },","            \"email_format\": preferences.preferHTML ? \"html\" : \"plain\",","            \"unsubscribed_categories\": preferences.unsubscribedCategories.map { $0.rawValue },","            \"last_preference_update\": ISO8601DateFormatter().string(from: Date())","        ]","","        Pushwoosh.configure.setEmailTags(tags, forEmail: email)","    }","","    func trackEmailEngagement(email: String, campaignId: String, action: EmailAction) {","        let engagementTags: [String: Any] = [","            \"last_email_open\": ISO8601DateFormatter().string(from: Date()),","            \"email_engagement_score\": calculateEngagementScore(for: email),","            \"last_clicked_campaign\": action == .clicked ? campaignId : NSNull()","        ]","","        Pushwoosh.configure.setEmailTags(engagementTags, forEmail: email)","    }","}"],"syntax":"swift"}]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:","interfaceLanguage":"occ"},"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)setEmailTags:forEmail:","role":"symbol","roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}],"title":"setEmailTags:forEmail:","fragments":[{"kind":"text","text":"+ "},{"text":"setEmailTags:forEmail:","kind":"identifier"}],"symbolKind":"method","navigatorTitle":[{"kind":"identifier","text":"setEmailTags:forEmail:"}]},"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmailTags:forEmail:":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:","navigatorTitle":[{"kind":"identifier","text":"setEmailTags:forEmail:"}],"kind":"symbol","type":"topic","role":"symbol","title":"setEmailTags:forEmail:","fragments":[{"kind":"text","text":"+ "},{"text":"setEmailTags:forEmail:","kind":"identifier"}],"abstract":[{"text":"Sets tags for a specific email address in email campaigns.","type":"text"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","url":"\/documentation\/pushwooshcore","role":"collection"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfigu