{"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"Sets tags for a specific email address in email campaigns."}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"metadata":{"modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"text":"setEmailTags:forEmail:","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)setEmailTags:forEmail:","symbolKind":"method","fragments":[{"text":"+ ","kind":"text"},{"text":"setEmailTags:forEmail:","kind":"identifier"}],"title":"setEmailTags:forEmail:","role":"symbol","roleHeading":"Type Method"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:"]}],"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"text":"setEmailTags:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"NSDictionary","preciseIdentifier":"c:objc(cs)NSDictionary"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"tags"},{"kind":"text","text":" "},{"text":"forEmail:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier","text":"NSString"},{"kind":"text","text":" *) "},{"text":"email","kind":"internalParam"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"Dictionary of tag names and values to associate with the email.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Supported value types: NSString, NSNumber, NSArray, NSNull (to delete)."}],"type":"paragraph"}],"name":"tags"},{"name":"email","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The email address to associate tags with. Must be a valid email format."}]}]}]},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Associates tags with an email address independently of the current device."},{"type":"text","text":" "},{"text":"This is used for email-specific segmentation in Pushwoosh Email campaigns.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Email tags are separate from device tags:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Device tags: Associated with push token, used for push segmentation"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Email tags: Associated with email address, used for email segmentation"}]}]}]},{"inlineContent":[{"type":"text","text":"Use this for email-specific attributes like email preferences, engagement metrics,"},{"type":"text","text":" "},{"type":"text","text":"or email-only campaign targeting."}],"type":"paragraph"},{"level":2,"text":"Example","anchor":"Example","type":"heading"},{"inlineContent":[{"type":"text","text":"Update email campaign preferences:"}],"type":"paragraph"},{"code":["class EmailPreferencesManager {","","    func updateEmailPreferences(for email: String, preferences: EmailPreferences) {","        let tags: [String: Any] = [","            \"email_frequency\": preferences.frequency.rawValue,","            \"email_categories\": preferences.subscribedCategories.map { $0.rawValue },","            \"email_format\": preferences.preferHTML ? \"html\" : \"plain\",","            \"unsubscribed_categories\": preferences.unsubscribedCategories.map { $0.rawValue },","            \"last_preference_update\": ISO8601DateFormatter().string(from: Date())","        ]","","        Pushwoosh.configure.setEmailTags(tags, forEmail: email)","    }","","    func trackEmailEngagement(email: String, campaignId: String, action: EmailAction) {","        let engagementTags: [String: Any] = [","            \"last_email_open\": ISO8601DateFormatter().string(from: Date()),","            \"email_engagement_score\": calculateEngagementScore(for: email),","            \"last_clicked_campaign\": action == .clicked ? campaignId : NSNull()","        ]","","        Pushwoosh.configure.setEmailTags(engagementTags, forEmail: email)","    }","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","type":"topic","url":"\/documentation\/pushwooshcore\/pwconfiguration","abstract":[],"role":"symbol","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"title":"PushwooshCore","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmailTags:forEmail:":{"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:","role":"symbol","navigatorTitle":[{"text":"setEmailTags:forEmail:","kind":"identifier"}],"kind":"symbol","abstract":[{"text":"Sets tags for a specific email address in email campaigns.","type":"text"}],"title":"setEmailTags:forEmail:","type":"topic","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setEmailTags:forEmail:"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/