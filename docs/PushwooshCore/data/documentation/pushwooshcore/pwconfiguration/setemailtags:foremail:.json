{"abstract":[{"text":"Sets tags for a specific email address in email campaigns.","type":"text"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:"]}],"kind":"symbol","identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:","interfaceLanguage":"occ"},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"setEmailTags:","kind":"identifier"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSDictionary","text":"NSDictionary"},{"kind":"text","text":" *) "},{"text":"tags","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"forEmail:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString","text":"NSString"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"email"},{"kind":"text","text":";"}],"platforms":["iOS"],"languages":["occ"]}]},{"parameters":[{"name":"tags","content":[{"inlineContent":[{"text":"Dictionary of tag names and values to associate with the email.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Supported value types: NSString, NSNumber, NSArray, NSNull (to delete)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The email address to associate tags with. Must be a valid email format.","type":"text"}],"type":"paragraph"}],"name":"email"}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Associates tags with an email address independently of the current device."},{"text":" ","type":"text"},{"type":"text","text":"This is used for email-specific segmentation in Pushwoosh Email campaigns."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Email tags are separate from device tags:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Device tags: Associated with push token, used for push segmentation"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Email tags: Associated with email address, used for email segmentation"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this for email-specific attributes like email preferences, engagement metrics,"},{"type":"text","text":" "},{"type":"text","text":"or email-only campaign targeting."}]},{"text":"Example","level":2,"type":"heading","anchor":"Example"},{"type":"paragraph","inlineContent":[{"text":"Update email campaign preferences:","type":"text"}]},{"code":["class EmailPreferencesManager {","","    func updateEmailPreferences(for email: String, preferences: EmailPreferences) {","        let tags: [String: Any] = [","            \"email_frequency\": preferences.frequency.rawValue,","            \"email_categories\": preferences.subscribedCategories.map { $0.rawValue },","            \"email_format\": preferences.preferHTML ? \"html\" : \"plain\",","            \"unsubscribed_categories\": preferences.unsubscribedCategories.map { $0.rawValue },","            \"last_preference_update\": ISO8601DateFormatter().string(from: Date())","        ]","","        Pushwoosh.configure.setEmailTags(tags, forEmail: email)","    }","","    func trackEmailEngagement(email: String, campaignId: String, action: EmailAction) {","        let engagementTags: [String: Any] = [","            \"last_email_open\": ISO8601DateFormatter().string(from: Date()),","            \"email_engagement_score\": calculateEngagementScore(for: email),","            \"last_clicked_campaign\": action == .clicked ? campaignId : NSNull()","        ]","","        Pushwoosh.configure.setEmailTags(engagementTags, forEmail: email)","    }","}"],"type":"codeListing","syntax":"swift"}]}],"metadata":{"modules":[{"name":"PushwooshCore"}],"title":"setEmailTags:forEmail:","role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)setEmailTags:forEmail:","fragments":[{"text":"+ ","kind":"text"},{"text":"setEmailTags:forEmail:","kind":"identifier"}],"roleHeading":"Type Method","symbolKind":"method","navigatorTitle":[{"text":"setEmailTags:forEmail:","kind":"identifier"}]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"role":"collection","title":"PushwooshCore","url":"\/documentation\/pushwooshcore","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmailTags:forEmail:":{"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:","navigatorTitle":[{"text":"setEmailTags:forEmail:","kind":"identifier"}],"abstract":[{"type":"text","text":"Sets tags for a specific email address in email campaigns."}],"title":"setEmailTags:forEmail:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:","role":"symbol","type":"topic","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setEmailTags:forEmail:"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","abstract":[],"kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"type":"topic"}}}