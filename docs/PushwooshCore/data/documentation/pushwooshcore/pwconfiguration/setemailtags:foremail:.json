{"abstract":[{"text":"Sets tags for a specific email address in email campaigns.","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:"},"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"text":"setEmailTags:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSDictionary","text":"NSDictionary","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"tags","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"forEmail:","kind":"identifier"},{"kind":"text","text":"("},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"text":"email","kind":"internalParam"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"tags","content":[{"inlineContent":[{"type":"text","text":"Dictionary of tag names and values to associate with the email."},{"text":" ","type":"text"},{"text":"Supported value types: NSString, NSNumber, NSArray, NSNull (to delete).","type":"text"}],"type":"paragraph"}]},{"name":"email","content":[{"inlineContent":[{"text":"The email address to associate tags with. Must be a valid email format.","type":"text"}],"type":"paragraph"}]}]},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"Associates tags with an email address independently of the current device.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This is used for email-specific segmentation in Pushwoosh Email campaigns."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Email tags are separate from device tags:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Device tags: Associated with push token, used for push segmentation"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Email tags: Associated with email address, used for email segmentation"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this for email-specific attributes like email preferences, engagement metrics,"},{"text":" ","type":"text"},{"type":"text","text":"or email-only campaign targeting."}]},{"level":2,"type":"heading","anchor":"Example","text":"Example"},{"inlineContent":[{"type":"text","text":"Update email campaign preferences:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class EmailPreferencesManager {","","    func updateEmailPreferences(for email: String, preferences: EmailPreferences) {","        let tags: [String: Any] = [","            \"email_frequency\": preferences.frequency.rawValue,","            \"email_categories\": preferences.subscribedCategories.map { $0.rawValue },","            \"email_format\": preferences.preferHTML ? \"html\" : \"plain\",","            \"unsubscribed_categories\": preferences.unsubscribedCategories.map { $0.rawValue },","            \"last_preference_update\": ISO8601DateFormatter().string(from: Date())","        ]","","        Pushwoosh.configure.setEmailTags(tags, forEmail: email)","    }","","    func trackEmailEngagement(email: String, campaignId: String, action: EmailAction) {","        let engagementTags: [String: Any] = [","            \"last_email_open\": ISO8601DateFormatter().string(from: Date()),","            \"email_engagement_score\": calculateEngagementScore(for: email),","            \"last_clicked_campaign\": action == .clicked ? campaignId : NSNull()","        ]","","        Pushwoosh.configure.setEmailTags(engagementTags, forEmail: email)","    }","}"]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"modules":[{"name":"PushwooshCore"}],"fragments":[{"text":"+ ","kind":"text"},{"text":"setEmailTags:forEmail:","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"setEmailTags:forEmail:"}],"role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)setEmailTags:forEmail:","symbolKind":"method","roleHeading":"Type Method","title":"setEmailTags:forEmail:"},"sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","title":"PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"role":"symbol","abstract":[]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","title":"PushwooshCore","role":"collection","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"kind":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmailTags:forEmail:":{"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:","type":"topic","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:","title":"setEmailTags:forEmail:","fragments":[{"text":"+ ","kind":"text"},{"text":"setEmailTags:forEmail:","kind":"identifier"}],"navigatorTitle":[{"text":"setEmailTags:forEmail:","kind":"identifier"}],"abstract":[{"type":"text","text":"Sets tags for a specific email address in email campaigns."}],"role":"symbol"}}}