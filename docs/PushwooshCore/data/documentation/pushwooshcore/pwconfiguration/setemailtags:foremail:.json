{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:","interfaceLanguage":"occ"},"abstract":[{"text":"Sets tags for a specific email address in email campaigns.","type":"text"}],"sections":[],"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)setEmailTags:forEmail:","symbolKind":"method","roleHeading":"Type Method","title":"setEmailTags:forEmail:","navigatorTitle":[{"kind":"identifier","text":"setEmailTags:forEmail:"}],"modules":[{"name":"PushwooshCore"}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setEmailTags:forEmail:"}],"role":"symbol"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setEmailTags:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSDictionary","kind":"typeIdentifier","text":"NSDictionary"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"tags"},{"kind":"text","text":" "},{"kind":"identifier","text":"forEmail:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSString","text":"NSString","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"text":"email","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"Dictionary of tag names and values to associate with the email."},{"type":"text","text":" "},{"text":"Supported value types: NSString, NSNumber, NSArray, NSNull (to delete).","type":"text"}],"type":"paragraph"}],"name":"tags"},{"content":[{"inlineContent":[{"type":"text","text":"The email address to associate tags with. Must be a valid email format."}],"type":"paragraph"}],"name":"email"}]},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Associates tags with an email address independently of the current device.","type":"text"},{"type":"text","text":" "},{"text":"This is used for email-specific segmentation in Pushwoosh Email campaigns.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Email tags are separate from device tags:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Device tags: Associated with push token, used for push segmentation"}]}]},{"content":[{"inlineContent":[{"text":"Email tags: Associated with email address, used for email segmentation","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Use this for email-specific attributes like email preferences, engagement metrics,"},{"type":"text","text":" "},{"type":"text","text":"or email-only campaign targeting."}],"type":"paragraph"},{"text":"Example","level":2,"type":"heading","anchor":"Example"},{"inlineContent":[{"text":"Update email campaign preferences:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class EmailPreferencesManager {","","    func updateEmailPreferences(for email: String, preferences: EmailPreferences) {","        let tags: [String: Any] = [","            \"email_frequency\": preferences.frequency.rawValue,","            \"email_categories\": preferences.subscribedCategories.map { $0.rawValue },","            \"email_format\": preferences.preferHTML ? \"html\" : \"plain\",","            \"unsubscribed_categories\": preferences.unsubscribedCategories.map { $0.rawValue },","            \"last_preference_update\": ISO8601DateFormatter().string(from: Date())","        ]","","        Pushwoosh.configure.setEmailTags(tags, forEmail: email)","    }","","    func trackEmailEngagement(email: String, campaignId: String, action: EmailAction) {","        let engagementTags: [String: Any] = [","            \"last_email_open\": ISO8601DateFormatter().string(from: Date()),","            \"email_engagement_score\": calculateEngagementScore(for: email),","            \"last_clicked_campaign\": action == .clicked ? campaignId : NSNull()","        ]","","        Pushwoosh.configure.setEmailTags(engagementTags, forEmail: email)","    }","}"]}],"kind":"content"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"title":"PWConfiguration","type":"topic","role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmailTags:forEmail:":{"abstract":[{"type":"text","text":"Sets tags for a specific email address in email campaigns."}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setEmailTags:forEmail:"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:","kind":"symbol","navigatorTitle":[{"text":"setEmailTags:forEmail:","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:","title":"setEmailTags:forEmail:","role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","kind":"symbol","role":"collection","title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","abstract