{"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"abstract":[{"text":"Sets tags for a specific email address in email campaigns.","type":"text"}],"metadata":{"roleHeading":"Type Method","navigatorTitle":[{"kind":"identifier","text":"setEmailTags:forEmail:"}],"title":"setEmailTags:forEmail:","externalID":"c:objc(pl)PWConfiguration(cm)setEmailTags:forEmail:","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setEmailTags:forEmail:"}],"symbolKind":"method","role":"symbol","modules":[{"name":"PushwooshCore"}]},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setEmailTags:"},{"kind":"text","text":"("},{"text":"NSDictionary","preciseIdentifier":"c:objc(cs)NSDictionary","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"tags","kind":"internalParam"},{"text":" ","kind":"text"},{"kind":"identifier","text":"forEmail:"},{"text":"(","kind":"text"},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"text":"email","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"tags","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Dictionary of tag names and values to associate with the email."},{"type":"text","text":" "},{"text":"Supported value types: NSString, NSNumber, NSArray, NSNull (to delete).","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The email address to associate tags with. Must be a valid email format."}],"type":"paragraph"}],"name":"email"}]},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Associates tags with an email address independently of the current device."},{"type":"text","text":" "},{"text":"This is used for email-specific segmentation in Pushwoosh Email campaigns.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Email tags are separate from device tags:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Device tags: Associated with push token, used for push segmentation","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Email tags: Associated with email address, used for email segmentation"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"Use this for email-specific attributes like email preferences, engagement metrics,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or email-only campaign targeting."}]},{"level":2,"type":"heading","text":"Example","anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Update email campaign preferences:"}]},{"type":"codeListing","syntax":"swift","code":["class EmailPreferencesManager {","","    func updateEmailPreferences(for email: String, preferences: EmailPreferences) {","        let tags: [String: Any] = [","            \"email_frequency\": preferences.frequency.rawValue,","            \"email_categories\": preferences.subscribedCategories.map { $0.rawValue },","            \"email_format\": preferences.preferHTML ? \"html\" : \"plain\",","            \"unsubscribed_categories\": preferences.unsubscribedCategories.map { $0.rawValue },","            \"last_preference_update\": ISO8601DateFormatter().string(from: Date())","        ]","","        Pushwoosh.configure.setEmailTags(tags, forEmail: email)","    }","","    func trackEmailEngagement(email: String, campaignId: String, action: EmailAction) {","        let engagementTags: [String: Any] = [","            \"last_email_open\": ISO8601DateFormatter().string(from: Date()),","            \"email_engagement_score\": calculateEngagementScore(for: email),","            \"last_clicked_campaign\": action == .clicked ? campaignId : NSNull()","        ]","","        Pushwoosh.configure.setEmailTags(engagementTags, forEmail: email)","    }","}"]}],"kind":"content"}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:","interfaceLanguage":"occ"},"kind":"symbol","variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","title":"PushwooshCore","role":"collection","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"role":"symbol","abstract":[],"title":"PWConfiguration","kind":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmailTags:forEmail:":{"title":"setEmailTags:forEmail:","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:","abstract":[{"text":"Sets tags for a specific email address in email campaigns.","type":"text"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"setEmailTags:forEmail:"}],"fragments":[{"text":"+ ","kind":"text"}