{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"kind":"identifier","text":"setEmailTags:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSDictionary","text":"NSDictionary","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"tags"},{"kind":"text","text":" "},{"kind":"identifier","text":"forEmail:"},{"text":"(","kind":"text"},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"email"},{"kind":"text","text":";"}]}]},{"kind":"parameters","parameters":[{"name":"tags","content":[{"inlineContent":[{"type":"text","text":"Dictionary of tag names and values to associate with the email."},{"type":"text","text":" "},{"text":"Supported value types: NSString, NSNumber, NSArray, NSNull (to delete).","type":"text"}],"type":"paragraph"}]},{"name":"email","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The email address to associate tags with. Must be a valid email format."}]}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Associates tags with an email address independently of the current device."},{"text":" ","type":"text"},{"type":"text","text":"This is used for email-specific segmentation in Pushwoosh Email campaigns."}]},{"type":"paragraph","inlineContent":[{"text":"Email tags are separate from device tags:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Device tags: Associated with push token, used for push segmentation","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Email tags: Associated with email address, used for email segmentation","type":"text"}]}]}]},{"inlineContent":[{"text":"Use this for email-specific attributes like email preferences, engagement metrics,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or email-only campaign targeting."}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"type":"paragraph","inlineContent":[{"text":"Update email campaign preferences:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class EmailPreferencesManager {","","    func updateEmailPreferences(for email: String, preferences: EmailPreferences) {","        let tags: [String: Any] = [","            \"email_frequency\": preferences.frequency.rawValue,","            \"email_categories\": preferences.subscribedCategories.map { $0.rawValue },","            \"email_format\": preferences.preferHTML ? \"html\" : \"plain\",","            \"unsubscribed_categories\": preferences.unsubscribedCategories.map { $0.rawValue },","            \"last_preference_update\": ISO8601DateFormatter().string(from: Date())","        ]","","        Pushwoosh.configure.setEmailTags(tags, forEmail: email)","    }","","    func trackEmailEngagement(email: String, campaignId: String, action: EmailAction) {","        let engagementTags: [String: Any] = [","            \"last_email_open\": ISO8601DateFormatter().string(from: Date()),","            \"email_engagement_score\": calculateEngagementScore(for: email),","            \"last_clicked_campaign\": action == .clicked ? campaignId : NSNull()","        ]","","        Pushwoosh.configure.setEmailTags(engagementTags, forEmail: email)","    }","}"]}]}],"metadata":{"modules":[{"name":"PushwooshCore"}],"title":"setEmailTags:forEmail:","role":"symbol","symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)setEmailTags:forEmail:","roleHeading":"Type Method","fragments":[{"text":"+ ","kind":"text"},{"text":"setEmailTags:forEmail:","kind":"identifier"}],"navigatorTitle":[{"text":"setEmailTags:forEmail:","kind":"identifier"}]},"abstract":[{"type":"text","text":"Sets tags for a specific email address in email campaigns."}],"sections":[],"kind":"symbol","variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmailTags:forEmail:":{"type":"topic","title":"setEmailTags:forEmail:","kind":"symbol","abstract":[{"text":"Sets tags for a specific email address in email campaigns.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"setEmailTags:forEmail:"}],"role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:","fragments":[{"text":"+ ","kind":"text"},{"text":"setEmailTags:forEmail:","kind":"identifier"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","url":"\/documentation\/pushwooshcore","kind":"symbol","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"role":"collection"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","type":"topic","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"abstract":[],"