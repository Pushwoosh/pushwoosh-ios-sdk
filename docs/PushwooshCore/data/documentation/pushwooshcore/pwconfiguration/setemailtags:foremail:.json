{"kind":"symbol","sections":[],"abstract":[{"text":"Sets tags for a specific email address in email campaigns.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"setEmailTags:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSDictionary","text":"NSDictionary","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"tags"},{"text":" ","kind":"text"},{"kind":"identifier","text":"forEmail:"},{"kind":"text","text":"("},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"email"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"name":"tags","content":[{"inlineContent":[{"text":"Dictionary of tag names and values to associate with the email.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Supported value types: NSString, NSNumber, NSArray, NSNull (to delete)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The email address to associate tags with. Must be a valid email format."}],"type":"paragraph"}],"name":"email"}]},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Associates tags with an email address independently of the current device."},{"text":" ","type":"text"},{"text":"This is used for email-specific segmentation in Pushwoosh Email campaigns.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Email tags are separate from device tags:","type":"text"}],"type":"paragra