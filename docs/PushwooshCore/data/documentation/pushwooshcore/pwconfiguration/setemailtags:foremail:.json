ngagement(email: String, campaignId: String, action: EmailAction) {","        let engagementTags: [String: Any] = [","            \"last_email_open\": ISO8601DateFormatter().string(from: Date()),","            \"email_engagement_score\": calculateEngagementScore(for: email),","            \"last_clicked_campaign\": action == .clicked ? campaignId : NSNull()","        ]","","        Pushwoosh.configure.setEmailTags(engagementTags, forEmail: email)","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:","interfaceLanguage":"occ"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"kind":"symbol","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmailTags:forEmail:":{"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:","type":"topic","role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:","navigatorTitle":[{"text":"setEmailTags:forEmail:","kind":"identifier"}],"title":"setEmailTags:forEmail:","abstract":[{"type":"text","text":"Sets tags for a specific email address in email campaigns."}],"kind":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"setEmailTags:forEmail:","kind":"identifier"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","url":"\/documentation\/pushwooshcore","role":"collection","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","title":"PushwooshCore","kind":"symbol","abstract