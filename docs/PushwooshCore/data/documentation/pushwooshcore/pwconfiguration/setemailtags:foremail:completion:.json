{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:completion:"},"metadata":{"symbolKind":"method","title":"setEmailTags:forEmail:completion:","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setEmailTags:forEmail:completion:"}],"roleHeading":"Type Method","role":"symbol","modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"kind":"identifier","text":"setEmailTags:forEmail:completion:"}],"externalID":"c:objc(pl)PWConfiguration(cm)setEmailTags:forEmail:completion:"},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"kind":"text","text":") "},{"kind":"identifier","text":"setEmailTags:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSDictionary","text":"NSDictionary"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"tags"},{"text":" ","kind":"text"},{"kind":"identifier","text":"forEmail:"},{"kind":"text","text":"("},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"email"},{"text":" ","kind":"text"},{"text":"completion:","kind":"identifier"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":" (^"},{"text":")(","kind":"text"},{"text":"NSError","preciseIdentifier":"c:objc(cs)NSError","kind":"typeIdentifier"},{"text":" * ","kind":"text"},{"text":"error","kind":"internalParam"},{"text":")) ","kind":"text"},{"kind":"internalParam","text":"completion"},{"kind":"text","text":";"}],"languages":["occ"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Dictionary of tag names and values to associate with the email.","type":"text"}]}],"name":"tags"},{"name":"email","content":[{"type":"paragraph","inlineContent":[{"text":"The email address to associate tags with.","type":"text"}]}]},{"name":"completion","content":[{"inlineContent":[{"type":"text","text":"Block called when the operation completes."},{"text":" ","type":"text"},{"type":"text","text":"Receives nil on success, or an NSError on failure."}],"type":"paragraph"}]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"Same as ","type":"text"},{"type":"codeVoice","code":"setEmailTags:forEmail:"},{"text":" but provides confirmation when the operation completes.","type":"text"},{"text":" ","type":"text"},{"text":"Use this when you need to verify tags were set before proceeding with other operations.","type":"text"}],"type":"paragraph"},{"type":"heading","anchor":"Example","level":2,"text":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Verify email and update tags with confirmation:"}]},{"type":"codeListing","syntax":"swift","code":["class EmailVerificationService {","","    func completeEmailVerification(email: String, verificationCode: String,","                                   completion: @escaping (Result<Void, Error>) -> Void) {","","        APIClient.shared.verifyEmail(email, code: verificationCode) { result in","            switch result {","            case .success:","                let verificationTags: [String: Any] = [","                    \"email_verified\": true,","                    \"verification_date\": ISO8601DateFormatter().string(from: Date()),","                    \"verification_method\": \"code\"","                ]","","                Pushwoosh.configure.setEmailTags(verificationTags, forEmail: email) { error in","                    if let error = error {","                        Logger.warning(\"Email tags update failed: \\(error.localizedDescription)\")","                        \/\/ Continue anyway - email is verified on backend","                    }","","                    \/\/ Also update device tags","                    Pushwoosh.configure.setTags([\"has_verified_email\": true])","","                    completion(.success(()))","                }","","            case .failure(let error):","                completion(.failure(error))","            }","        }","    }","}"]}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:completion:"]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"abstract":[{"type":"text","text":"Sets tags for a specific email address with a completion handler."}],"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","abstract":[],"title":"PWConfiguration","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmailTags:forEmail:completion:":{"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:completion:","title":"setEmailTags:forEmail:completion:","fragments":[{"text":"+ ","kind":"text"},{"text":"setEmailTags:forEmail:completion:","kind":"identifier"}],"abstract":[{"type":"text","text":"Sets tags for a specific email address with a completion handler."}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:completion:","type":"topic","role":"symbol","navigatorTitle":[{"text":"setEmailTags:forEmail:completion:","kind":"identifier"}]},"doc://com.