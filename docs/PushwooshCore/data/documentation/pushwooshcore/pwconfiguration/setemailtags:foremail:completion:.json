{"sections":[],"metadata":{"modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","externalID":"c:objc(pl)PWConfiguration(cm)setEmailTags:forEmail:completion:","symbolKind":"method","fragments":[{"text":"+ ","kind":"text"},{"text":"setEmailTags:forEmail:completion:","kind":"identifier"}],"navigatorTitle":[{"text":"setEmailTags:forEmail:completion:","kind":"identifier"}],"role":"symbol","title":"setEmailTags:forEmail:completion:"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:completion:"]}],"abstract":[{"text":"Sets tags for a specific email address with a completion handler.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"text":"setEmailTags:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSDictionary","kind":"typeIdentifier","text":"NSDictionary"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"tags"},{"kind":"text","text":" "},{"kind":"identifier","text":"forEmail:"},{"text":"(","kind":"text"},{"text":"NSString","preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"email"},{"kind":"text","text":" "},{"kind":"identifier","text":"completion:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":" (^","kind":"text"},{"kind":"text","text":")("},{"kind":"typeIdentifier","text":"NSError","preciseIdentifier":"c:objc(cs)NSError"},{"kind":"text","text":" * "},{"kind":"internalParam","text":"error"},{"kind":"text","text":")) "},{"kind":"internalParam","text":"completion"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"name":"tags","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Dictionary of tag names and values to associate with the email."}]}]},{"name":"email","content":[{"inlineContent":[{"text":"The email address to associate tags with.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Block called when the operation completes."},{"type":"text","text":" "},{"type":"text","text":"Receives nil on success, or an NSError on failure."}]}],"name":"completion"}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"Same as "},{"type":"codeVoice","code":"setEmailTags:forEmail:"},{"text":" but provides confirmation when the operation completes.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Use this when you need to verify tags were set before proceeding with other operations."}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"Example","text":"Example"},{"type":"paragraph","inlineContent":[{"text":"Verify email and update tags with confirmation:","type":"text"}]},{"code":["class EmailVerificationService {","","    func completeEmailVerification(email: String, verificationCode: String,","                                   completion: @escaping (Result<Void, Error>) -> Void) {","","        APIClient.shared.verifyEmail(email, code: verificationCode) { result in","            switch result {","            case .success:","                let verificationTags: [String: Any] = [","                    \"email_verified\": true,","                    \"verification_date\": ISO8601DateFormatter().string(from: Date()),","                    \"verification_method\": \"code\"","                ]","","                Pushwoosh.configure.setEmailTags(verificationTags, forEmail: email) { error in","                    if let error = error {","                        Logger.warning(\"Email tags update failed: \\(error.localizedDescription)\")","                        \/\/ Continue anyway - email is verified on backend","                    }","","                    \/\/ Also update device tags","                    Pushwoosh.configure.setTags([\"has_verified_email\": true])","","                    completion(.success(()))","                }","","            case .failure(let error):","                completion(.failure(error))","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"}]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:completion:","interfaceLanguage":"occ"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmailTags:forEmail:completion:":{"role":"symbol","abstract":[{"type":"text","text":"Sets tags for a specific email address with a completion handler."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:completion:","type":"topic","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:completion:","fragments":[{"kind":"text","text":"+ "},{"text":"setEmailTags:forEmail:completion:","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"setEmailTags:forEmail:completion:"}],"title":"setEmailTags:forEmail:completion:","kind":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"title":"PushwooshCore","type":"topic","role":"collection","url":"\/documentation\/pushwooshcore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","abstract":[],"role":"symbol","type":"topic"}}}