{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:completion:","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","abstract":[{"text":"Sets tags for a specific email address with a completion handler.","type":"text"}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"setEmailTags:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSDictionary","text":"NSDictionary"},{"text":" *) ","kind":"text"},{"text":"tags","kind":"internalParam"},{"kind":"text","text":" "},{"text":"forEmail:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSString","preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"email","kind":"internalParam"},{"text":" ","kind":"text"},{"kind":"identifier","text":"completion:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"text":" (^","kind":"text"},{"kind":"text","text":")("},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSError","text":"NSError"},{"text":" * ","kind":"text"},{"text":"error","kind":"internalParam"},{"kind":"text","text":")) "},{"kind":"internalParam","text":"completion"},{"kind":"text","text":";"}],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Dictionary of tag names and values to associate with the email."}]}],"name":"tags"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The email address to associate tags with.","type":"text"}]}],"name":"email"},{"content":[{"inlineContent":[{"type":"text","text":"Block called when the operation completes."},{"text":" ","type":"text"},{"type":"text","text":"Receives nil on success, or an NSError on failure."}],"type":"paragraph"}],"name":"completion"}]},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"Same as "},{"code":"setEmailTags:forEmail:","type":"codeVoice"},{"text":" but provides confirmation when the operation completes.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Use this when you need to verify tags were set before proceeding with other operations."}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"inlineContent":[{"type":"text","text":"Verify email and update tags with confirmation:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class EmailVerificationService {","","    func completeEmailVerification(email: String, verificationCode: String,","                                   completion: @escaping (Result<Void, Error>) -> Void) {","","        APIClient.shared.verifyEmail(email, code: verificationCode) { result in","            switch result {","            case .success:","                let verificationTags: [String: Any] = [","                    \"email_verified\": true,","                    \"verification_date\": ISO8601DateFormatter().string(from: Date()),","                    \"verification_method\": \"code\"","                ]","","                Pushwoosh.configure.setEmailTags(verificationTags, forEmail: email) { error in","                    if let error = error {","                        Logger.warning(\"Email tags update failed: \\(error.localizedDescription)\")","                        \/\/ Continue anyway - email is verified on backend","                    }","","                    \/\/ Also update device tags","                    Pushwoosh.configure.setTags([\"has_verified_email\": true])","","                    completion(.success(()))","                }","","            case .failure(let error):","                completion(.failure(error))","            }","        }","    }","}"]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:completion:"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)setEmailTags:forEmail:completion:","title":"setEmailTags:forEmail:completion:","role":"symbol","symbolKind":"method","modules":[{"name":"PushwooshCore"}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setEmailTags:forEmail:completion:"}],"navigatorTitle":[{"text":"setEmailTags:forEmail:completion:","kind":"identifier"}],"roleHeading":"Type Method"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","title":"PushwooshCore","kind":"symbol","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","url":"\/documentation\/pushwooshcore","role":"collection"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmailTags:forEmail:completion:":{"kind":"symbol","abstract":[{"type":"text","text":"Sets tags for a specific email address with a completion handler."}],"title":"setEmailTags:forEmail:completion:","role":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"setEmailTags:forEmail:completion:","kind":"identifier"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:completion:","type":"topic","navigatorTitle":[{"kind":"identifier","text":"setEmailTags:forEmail:completion:"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:completion:"},"doc://com.pushwoosh.PushwooshCore/documentation/Pushw