{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"roleHeading":"Type Method","symbolKind":"method","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setEmailTags:forEmail:completion:"}],"externalID":"c:objc(pl)PWConfiguration(cm)setEmailTags:forEmail:completion:","modules":[{"name":"PushwooshCore"}],"title":"setEmailTags:forEmail:completion:","navigatorTitle":[{"kind":"identifier","text":"setEmailTags:forEmail:completion:"}],"role":"symbol"},"sections":[],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:completion:","interfaceLanguage":"occ"},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"Sets tags for a specific email address with a completion handler.","type":"text"}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemailtags:foremail:completion:"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"kind":"identifier","text":"setEmailTags:"},{"kind":"text","text":"("},{"text":"NSDictionary","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSDictionary"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"tags"},{"text":" ","kind":"text"},{"text":"forEmail:","kind":"identifier"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"NSString","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"email"},{"kind":"text","text":" "},{"kind":"identifier","text":"completion:"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":" (^"},{"text":")(","kind":"text"},{"kind":"typeIdentifier","text":"NSError","preciseIdentifier":"c:objc(cs)NSError"},{"text":" * ","kind":"text"},{"kind":"internalParam","text":"error"},{"kind":"text","text":")) "},{"text":"completion","kind":"internalParam"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"tags","content":[{"inlineContent":[{"text":"Dictionary of tag names and values to associate with the email.","type":"text"}],"type":"paragraph"}]},{"name":"email","content":[{"type":"paragraph","inlineContent":[{"text":"The email address to associate tags with.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Block called when the operation completes.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Receives nil on success, or an NSError on failure."}],"type":"paragraph"}],"name":"completion"}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Same as "},{"type":"codeVoice","code":"setEmailTags:forEmail:"},{"text":" but provides confirmation when the operation completes.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Use this when you need to verify tags were set before proceeding with other operations."}]},{"anchor":"Example","type":"heading","text":"Example","level":2},{"inlineContent":[{"type":"text","text":"Verify email and update tags with confirmation:"}],"type":"paragraph"},{"type":"codeListing","code":["class EmailVerificationService {","","    func completeEmailVerification(email: String, verificationCode: String,","                                   completion: @escaping (Result<Void, Error>) -> Void) {","","        APIClient.shared.verifyEmail(email, code: verificationCode) { result in","            switch result {","            case .success:","                let verificationTags: [String: Any] = [","                    \"email_verified\": true,","                    \"verification_date\": ISO8601DateFormatter().string(from: Date()),","                    \"verification_method\": \"code\"","                ]","","                Pushwoosh.configure.setEmailTags(verificationTags, forEmail: email) { error in","                    if let error = error {","                        Logger.warning(\"Email tags update failed: \\(error.localizedDescription)\")","                        \/\/ Continue anyway - email is verified on backend","                    }","","                    \/\/ Also update device tags","                    Pushwoosh.configure.setTags([\"has_verified_email\": true])","","                    completion(.success(()))","                }","","            case .failure(let error):","                completion(.failure(error))","            }","        }","    }","}"],"syntax":"swift"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","role":"symbol","title":"PWConfiguration","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","abstract":[]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","url":"\/documentation\/pushwooshcore","title":"PushwooshCore","type":"topic","kind":"symbol","role":"collection","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmailTags:forEmail:completion:":{"abstract":[{"type":"text","text":"Sets tags for a specific email address with a completion handler."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:completion:","url":"\/documentation\/pushwooshcore\/pwcon