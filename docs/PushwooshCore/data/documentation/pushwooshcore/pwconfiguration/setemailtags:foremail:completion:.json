{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmailTags:forEmail:completion:"},"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"Sets tags for a specific email address with a completion handler."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"text":"setEmailTags:","kind":"identifier"},{"kind":"text","text":"("},{"text":"NSDictionary","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSDictionary"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"tags"},{"kind":"text","text":" "},{"text":"forEmail:","kind":"identifier"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"NSString","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"text":"email","kind":"internalParam"},{"text":" ","kind":"text"},{"kind":"identifier","text":"completion:"},{"text":"(","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":" (^"},{"kind":"text","text":")("},{"preciseIdentifier":"c:objc(cs)NSError","kind":"typeIdentifier","text":"NSError"},{"text":" * ","kind":"text"},{"text":"error","kind":"internalParam"},{"text":")) ","kind":"text"},{"text":"completion","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}]},{"parameters":[{"name":"tags","content":[{"type":"paragraph","inlineContent":[{"text":"Dictionary of tag names and values to associate with the email.","type":"text"}]}]},{"name":"email","content":[{"inlineContent":[{"type":"text","text":"The email address to associate tags with."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Block called when the operation completes.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Receives nil on success, or an NSError on failure."}],"type":"paragraph"}],"name":"completion"}],"kind":"parameters"},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Same as "},{"type":"codeVoice","code":"setEmailTags:forEmail:"},{"type":"text","text":" but provides confirmation when the operation completes."},{"text":" ","type":"text"},{"type":"text","text":"Use this when you need to verify tags were set before proceeding with other operations."}],"type":"paragraph"},{"type":"heading","anchor":"Example","level":2,"text":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Verify email and update tags with confirmation:"}]},{"code":["class EmailVerificationService {","","    func completeEmailVerification(email: String, verificationCode: String,","                                   completion: @escaping (Result<Void, Error>) -> Void) {","","        APIClient.shared.verifyEmail(email, code: verificationCode) { result in","            switch result {","            case .success:","                let verificationTags: [String: Any] = [","                    \"email_verified\": true,","                    \"verification_date\": ISO8601DateFormatter().string(from: Date()),","                    \"verification_method\": \"code\"","                ]","","                Pushwoosh.configure.setEmailTags(verificationTags, forEmail: email) { error in","                    if let error = error {","                        Logger.warning(\"Email tags update failed: \\(error.localizedDescription)\")","                        \/\/ Continue anyway - email is verified on backend","                    }","","                    \/\/ Also update device tags","                    Pushwoosh.configure.setTags([\"has_verified_email\": true])","","                    completion(.success(()))","                }","","            case .failure(let error):","                completion(.failure(error))","            }","     