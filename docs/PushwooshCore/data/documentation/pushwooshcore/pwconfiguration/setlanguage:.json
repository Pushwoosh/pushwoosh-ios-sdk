{"kind":"symbol","sections":[],"metadata":{"role":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"setLanguage:","kind":"identifier"}],"title":"setLanguage:","symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)setLanguage:","navigatorTitle":[{"kind":"identifier","text":"setLanguage:"}],"modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method"},"abstract":[{"type":"text","text":"Sets custom application language for localized notifications."}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setLanguage:","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"setLanguage:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"text":"language","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"parameters":[{"name":"language","content":[{"inlineContent":[{"text":"The language code (e.g., “en”, “de”, “fr”, “es”) or nil to reset to device language","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"Override the device language for Pushwoosh to enable:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Sending notifications in a specific language"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Language-based segmentation","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Supporting in-app language switching","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Must be a lowercase two-letter code according to ISO-639-1 standard.","type":"text"}]},{"text":"Example","anchor":"Example","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Support in-app language selection:"}]},{"type":"codeListing","code":["class LanguageManager {","","    static let shared = LanguageManager()","","    var currentLanguage: String {","        didSet {","            applyLanguageChange()","        }","    }","","    func applyLanguageChange() {","        \/\/ Update Pushwoosh language for targeted notifications","        Pushwoosh.configure.setLanguage(currentLanguage)","","        \/\/ Update user tags","        Pushwoosh.configure.setTags([","            \"language\": currentLanguage,","            \"language_changed_date\": Date()","        ])","","        \/\/ Update app UI","        Bundle.setLanguage(currentLanguage)","        NotificationCenter.default.post(name: .languageDidChange, object: nil)","","        Logger.info(\"App language changed to: \\(currentLanguage)\")","    }","","    func resetToDeviceLanguage() {","        Pushwoosh.configure.setLanguage(nil)","        currentLanguage = Locale.current.languageCode ?? \"en\"","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"“zh” (Chinese), “ja” (Japanese), “ko” (Korean), “ru” (Russian)","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setlanguage:"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","title":"PushwooshCore","kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setLanguage:":{"kind":"symbol","abstract":[{"type":"text","text":"Sets custom application language for localized notifications."}],"role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setLanguage:","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setLanguage:"}],"title":"setLanguage:","type":"topic","navigatorTitle":[{"text":"setLanguage:","kind":"identifier"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setlanguage:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","abstract":[],"kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"title":"PWConfiguration"}}}