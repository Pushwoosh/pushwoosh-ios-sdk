{"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setLanguage:"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"abstract":[{"text":"Sets custom application language for localized notifications.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"text":"setLanguage:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSString","text":"NSString","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"language"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"parameters":[{"name":"language","content":[{"inlineContent":[{"type":"text","text":"The language code (e.g., “en”, “de”, “fr”, “es”) or nil to reset to device language"}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Override the device language for Pushwoosh to enable:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Sending notifications in a specific language"}]}]},{"content":[{"inlineContent":[{"text":"Language-based segmentation","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Supporting in-app language switching","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Must be a lowercase two-letter code according to ISO-639-1 standard.","type":"text"}]},{"type":"heading","text":"Example","anchor":"Example","level":2},{"inlineContent":[{"text":"Support in-app language selection:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class LanguageManager {","","    static let shared = LanguageManager()","","    var currentLanguage: String {","        didSet {","            applyLanguageChange()","        }","    }","","    func applyLanguageChange() {","        \/\/ Update Pushwoosh language for targeted notifications","        Pushwoosh.configure.setLanguage(currentLanguage)","","        \/\/ Update user tags","        Pushwoosh.configure.setTags([","            \"language\": currentLanguage,","            \"language_changed_date\": Date()","        ])","","        \/\/ Update app UI","        Bundle.setLanguage(currentLanguage)","        NotificationCenter.default.post(name: .languageDidChange, object: nil)","","        Logger.info(\"App language changed to: \\(currentLanguage)\")","    }","","    func resetToDeviceLanguage() {","        Pushwoosh.configure.setLanguage(nil)","        currentLanguage = Locale.current.languageCode ?? \"en\"","    }","}"]},{"inlineContent":[{"type":"text","text":"“zh” (Chinese), “ja” (Japanese), “ko” (Korean), “ru” (Russian)"}],"type":"paragraph"}]}],"metadata":{"modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","role":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"setLanguage:","kind":"identifier"}],"title":"setLanguage:","externalID":"c:objc(pl)PWConfiguration(cm)setLanguage:","navigatorTitle":[{"text":"setLanguage:","kind":"identifier"}],"symbolKind":"method"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setlanguage:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","title":"PushwooshCore","role":"collection","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","abstract":[{"type":"text","text":"C