{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"abstract":[{"text":"Sets custom application language for localized notifications.","type":"text"}],"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)setLanguage:","fragments":[{"text":"+ ","kind":"text"},{"text":"setLanguage:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"role":"symbol","navigatorTitle":[{"text":"setLanguage:","kind":"identifier"}],"symbolKind":"method","title":"setLanguage:","roleHeading":"Type Method"},"kind":"symbol","variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setlanguage:"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":") ","kind":"text"},{"text":"setLanguage:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSString","text":"NSString","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"language","kind":"internalParam"},{"text":";","kind":"text"}],"platforms":["iOS"]}]},{"parameters":[{"name":"language","content":[{"inlineContent":[{"text":"The language code (e.g., “en”, “de”, “fr”, “es”) or nil to reset to device language","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Override the device language for Pushwoosh to enable:"}]},{"items":[{"content":[{"inlineContent":[{"text":"Sending notifications in a specific language","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Language-based segmentation","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Supporting in-app language switching"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Must be a lowercase two-letter code according to ISO-639-1 standard."}]},{"level":2,"anchor":"Example","type":"heading","text":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Support in-app language selection:"}]},{"code":["class LanguageManager {","","    static let shared = LanguageManager()","","    var currentLanguage: String {","        didSet {","            applyLanguageChange()","        }","    }","","    func applyLanguageChange() {","        \/\/ Update Pushwoosh language for targeted notifications","        Pushwoosh.configure.setLanguage(currentLanguage)","","        \/\/ Update user tags","        Pushwoosh.configure.setTags([","            \"language\": currentLanguage,","            \"language_changed_date\": Date()","        ])","","        \/\/ Update app UI","        Bundle.setLanguage(currentLanguage)","        NotificationCenter.default.post(name: .languageDidChange, object: nil)","","        Logger.info(\"App language changed to: \\(currentLanguage)\")","    }","","    func resetToDeviceLanguage() {","        Pushwoosh.configure.setLanguage(nil)","        currentLanguage = Locale.current.languageCode ?? \"en\"","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"“zh” (Chinese), “ja” (Japanese), “ko” (Korean), “ru” (Russian)"}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setLanguage:","interfaceLanguage":"occ"},"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setLanguage:":{"fragments":[{"text":"+ ","kind":"text"},{"text":"setLanguage:","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"text","text":"Sets custom application language for localized no