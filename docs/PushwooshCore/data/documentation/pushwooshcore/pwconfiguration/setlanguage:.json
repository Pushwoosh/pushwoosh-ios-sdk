{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"role":"symbol","symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)setLanguage:","navigatorTitle":[{"text":"setLanguage:","kind":"identifier"}],"roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}],"fragments":[{"text":"+ ","kind":"text"},{"text":"setLanguage:","kind":"identifier"}],"title":"setLanguage:"},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setlanguage:"]}],"abstract":[{"text":"Sets custom application language for localized notifications.","type":"text"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setLanguage:"},"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setLanguage:"},{"kind":"text","text":"("},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"language"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"parameters":[{"name":"language","content":[{"type":"paragraph","inlineContent":[{"text":"The language code (e.g., “en”, “de”, “fr”, “es”) or nil to reset to device language","type":"text"}]}]}],"kind":"parameters"},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Override the device language for Pushwoosh to enable:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Sending notifications in a specific language"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Language-based segmentation"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Supporting in-app language switching"}]}]}]},{"inlineContent":[{"type":"text","text":"Must be a lowercase two-letter code according to ISO-639-1 standard."}],"type":"paragraph"},{"text":"Example","level":2,"type":"heading","anchor":"Example"},{"inlineContent":[{"text":"Support in-app language selection:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class LanguageManager {","","    static let shared = LanguageManager()","","    var currentLanguage: String {","        didSet {","            applyLanguageChange()","        }","    }","","    func applyLanguageChange() {","        \/\/ Update Pushwoosh language for targeted notifications","        Pushwoosh.configure.setLanguage(currentLanguage)","","        \/\/ Update user tags","        Pushwoosh.configure.setTags([","            \"language\": currentLanguage,","            \"language_changed_date\": Date()","        ])","","        \/\/ Update app UI","        Bundle.setLanguage(currentLanguage)","        NotificationCenter.default.post(name: .languageDidChange, object: nil)","","        Logger.info(\"App language changed to: \\(currentLanguage)\")","    }","","    func resetToDeviceLanguage() {","        Pushwoosh.configure.setLanguage(nil)","        currentLanguage = Locale.current.languageCode ?? \"en\"","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"“zh” (Chinese), “ja” (Japanese), “ko” (Korean), “ru” (Russian)"}]}],"kind":"content"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setLanguage:":{"role":"symbol","navigatorTitle":[{"text":"setLanguage:","kind":"identifier"}],"title":"setLanguage:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setlanguage:","abstract":[{"