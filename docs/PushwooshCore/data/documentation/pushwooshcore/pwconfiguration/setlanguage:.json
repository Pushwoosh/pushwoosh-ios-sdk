{"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","metadata":{"symbolKind":"method","roleHeading":"Type Method","title":"setLanguage:","fragments":[{"kind":"text","text":"+ "},{"text":"setLanguage:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)setLanguage:","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"setLanguage:"}]},"abstract":[{"type":"text","text":"Sets custom application language for localized notifications."}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setlanguage:"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setLanguage:","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"kind":"text","text":") "},{"kind":"identifier","text":"setLanguage:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSString","text":"NSString","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"language"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The language code (e.g., “en”, “de”, “fr”, “es”) or nil to reset to device language"}],"type":"paragraph"}],"name":"language"}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Override the device language for Pushwoosh to enable:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Sending notifications in a specific language"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Language-based segmentation","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Supporting in-app language switching"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Must be a lowercase two-letter code according to ISO-639-1 standard."}],"type":"paragraph"},{"type":"heading","anchor":"Example","level":2,"text":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Support in-app language selection:"}]},{"type":"codeListing","syntax":"swift","code":["class LanguageManager {","","    static let shared = LanguageManager()","","    var currentLanguage: String {","        didSet {","            applyLanguageChange()","        }","    }","","    func applyLanguageChange() {","        \/\/ Update Pushwoosh language for targeted notifications","        Pushwoosh.configure.setLanguage(currentLanguage)","","        \/\/ Update user tags","        Pushwoosh.configure.setTags([","            \"language\": currentLanguage,","            \"language_changed_date\": Date()","        ])","","        \/\/ Update app UI","        Bundle.setLanguage(currentLanguage)","        NotificationCenter.default.post(name: .languageDidChange, object: nil)","","        Logger.info(\"App language changed to: \\(currentLanguage)\")","    }","","    func resetToDeviceLanguage() {","        Pushwoosh.configure.setLanguage(nil)","        currentLanguage = Locale.current.languageCode ?? \"en\"","    }","}"]},{"inlineContent":[{"type":"text","text":"“zh” (Chinese), “ja” (Japanese), “ko” (Korean), “ru” (Russian)"}],"type":"paragraph"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setLanguage:":{"navigatorTitle":[{"kind":"identifier","text":"setLanguage:"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setlanguage:","kind":"symbol","type":"topic","abstract":[{"text":"Sets custom application language for localized notifications.","type":"text"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setLanguage:","title":"setLanguage:","role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setLanguage:"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","role":"collection","title":"PushwooshCore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"abstract":[],"title":"PWConfiguration","role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration"}}}