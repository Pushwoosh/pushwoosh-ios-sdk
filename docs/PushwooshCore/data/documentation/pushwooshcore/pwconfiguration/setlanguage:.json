{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setLanguage:"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setLanguage:"},{"text":"(","kind":"text"},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"text":"language","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"name":"language","content":[{"inlineContent":[{"text":"The language code (e.g., “en”, “de”, “fr”, “es”) or nil to reset to device language","type":"text"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Override the device language for Pushwoosh to enable:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Sending notifications in a specific language","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Language-based segmentation","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Supporting in-app language switching","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"Must be a lowercase two-letter code according to ISO-639-1 standard."}],"type":"paragraph"},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"inlineContent":[{"type":"text","text":"Support in-app language selection:"}],"type":"paragraph"},{"code":["class LanguageManager {","","    static let shared = LanguageManager()","","    var currentLanguage: String {","        didSet {","            applyLanguageChange()","        }","    }","","    func applyLanguageChange() {","        \/\/ Update Pushwoosh language for targeted notifications","        Pushwoosh.configure.setLanguage(currentLanguage)","","        \/\/ Update user tags","        Pushwoosh.configure.setTags([","            \"language\": currentLanguage,","            \"language_changed_date\": Date()","        ])","","        \/\/ Update app UI","        Bundle.setLanguage(currentLanguage)","        NotificationCenter.default.post(name: .languageDidChange, object: nil)","","        Logger.info(\"App language changed to: \\(currentLanguage)\")","    }","","    func resetToDeviceLanguage() {","        Pushwoosh.configure.setLanguage(nil)","        currentLanguage = Locale.current.languageCode ?? \"en\"","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"“zh” (Chinese), “ja” (Japanese), “ko” (Korean), “ru” (Russian)","type":"text"}],"type":"paragraph"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Sets custom application language for localized notifications."}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setlanguage:"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","metadata":{"navigatorTitle":[{"text":"setLanguage:","kind":"identifier"}],"roleHeading":"Type Method","fragments":[{"text":"+ ","kind":"text"},{"text":"setLanguage:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)setLanguage:","title":"setLanguage:","role":"symbol","symbolKind":"method"},"sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","kind":"symbol","type":"topic","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"abstract":[],"role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore","type":"topic","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setLanguage:":{"type":"topic","title":"setLanguage:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setlanguage:","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"setLanguage:"}],"abstract":[{"text":"Sets custom application language for localized notifications.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setLanguage:","fragments":[{"kind":"text","text":"+ "},{"text":"setLanguage:","kind":"identifier"}]}}}