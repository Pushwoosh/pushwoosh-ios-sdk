ext":": Trigger automations based on purchases"}]}]}]},{"inlineContent":[{"type":"text","text":"Call this method from your "},{"code":"SKPaymentTransactionObserver","type":"codeVoice"},{"text":" for all","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"completed transactions."}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"type":"paragraph","inlineContent":[{"text":"Integrate with StoreKit payment observer:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["class StoreKitManager: NSObject, SKPaymentTransactionObserver {","","    func paymentQueue(_ queue: SKPaymentQueue,","                     updatedTransactions transactions: [SKPaymentTransaction]) {","","        let completedTransactions = transactions.filter {","            $0.transactionState == .purchased || $0.transactionState == .restored","        }","","        \/\/ Send completed transactions to Pushwoosh","        if !completedTransactions.isEmpty {","            Pushwoosh.configure.sendSKPaymentTransactions(completedTransactions)","        }","","        \/\/ Process each transaction","        for transaction in transactions {","            switch transaction.transactionState {","            case .purchased:","                handlePurchase(transaction)","                queue.finishTransaction(transaction)","","            case .restored:","                handleRestore(transaction)","                queue.finishTransaction(transaction)","","            case .failed:","                handleFailure(transaction)","                queue.finishTransaction(transaction)","","            case .deferred, .purchasing:","                break","","            @unknown default:","                break","            }","        }","    }","","    private func handlePurchase(_ transaction: SKPaymentTransaction) {","        let productId = transaction.payment.productIdentifier","","        \/\/ Update user tags for purchase segmentation","        Pushwoosh.configure.setTags([","            \"has_purchased\": true,","            \"last_purchase_date\": ISO8601DateFormatter().string(from: Date()),","            \"last_purchased_product\": productId","        ])","    }","}"]}]}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"abstract":[{"type":"text","text":"Sends StoreKit payment transactions to Pushwoosh for purchase tracking."}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/sendskpaymenttransactions:"]}],"metadata":{"role":"symbol","modules":[{"name":"PushwooshCore"}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"sendSKPaymentTransactions:"}],"navigatorTitle":[{"kind":"identifier","text":"sendSKPaymentTransactions:"}],"title":"sendSKPaymentTransactions:","symbolKind":"method","roleHeading":"Type Method","externalID":"c:objc(pl)PWConfiguration(cm)sendSKPaymentTransactions:"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","role":"collection","kind":"symbol","type":"topic","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"role":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","title":"PWConfiguration","kind":"symbol","type":"topic","abstract":[]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/sendSKPaymentTransactions:":{"rol