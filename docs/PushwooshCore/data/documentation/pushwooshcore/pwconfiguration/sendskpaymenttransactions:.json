{"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","metadata":{"symbolKind":"method","roleHeading":"Type Method","title":"sendSKPaymentTransactions:","fragments":[{"text":"+ ","kind":"text"},{"text":"sendSKPaymentTransactions:","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)sendSKPaymentTransactions:","modules":[{"name":"PushwooshCore"}],"role":"symbol","navigatorTitle":[{"text":"sendSKPaymentTransactions:","kind":"identifier"}]},"abstract":[{"type":"text","text":"Sends StoreKit payment transactions to Pushwoosh for purchase tracking."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/sendskpaymenttransactions:"]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendSKPaymentTransactions:"},"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"sendSKPaymentTransactions:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSArray","kind":"typeIdentifier","text":"NSArray"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"transactions"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"parameters":[{"name":"transactions","content":[{"inlineContent":[{"type":"text","text":"Array of "},{"code":"SKPaymentTransaction","type":"codeVoice"},{"type":"text","text":" objects from StoreKit."}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Automatically tracks in-app purchases from StoreKit transactions."},{"text":" ","type":"text"},{"type":"text","text":"This enables:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Revenue tracking","type":"text"}]},{"type":"text","text":": Monitor purchase revenue in Pushwoosh dashboard"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Purchase-based segmentation"}],"type":"strong"},{"text":": Target paying users, high-value customers","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"LTV analysis"}],"type":"strong"},{"type":"text","text":": Calculate customer lifetime value"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Purchase events","type":"text"}]},{"type":"text","text":": Trigger automations based on purchases"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Call this method from your "},{"type":"codeVoice","code":"SKPaymentTransactionObserver"},{"type":"text","text":" for all"},{"text":" ","type":"text"},{"type":"text","text":"completed transactions."}],"type":"paragraph"},{"anchor":"Example","type":"heading","text":"Example","level":2},{"inlineContent":[{"type":"text","text":"Integrate with StoreKit payment observer:"}],"type":"paragraph"},{"type":"codeListing","code":["class StoreKitManager: NSObject, SKPaymentTransactionObserver {","","    func paymentQueue(_ queue: SKPaymentQueue,","                     updatedTransactions transactions: [SKPaymentTransaction]) {","","        let completedTransactions = transactions.filter {","            $0.transactionState == .purchased || $0.transactionState == .restored","        }","","        \/\/ Send completed transactions to Pushwoosh","        if !completedTransactions.isEmpty {","            Pushwoosh.configure.sendSKPaymentTransactions(completedTransactions)","        }","","        \/\/ Process each transaction","        for transaction in transactions {","            switch transaction.transactionState {","            case .purchased:","                handlePurchase(transaction)","                queue.finishTransaction(transaction)","","            case .restored:","                handleRestore(transaction)","                queue.finishTransaction(transaction)","","            case .failed:","                handleFailure(transaction)","                queue.finishTransaction(transaction)","","            case .deferred, .purchasing:","                break","","            @unknown default:","                break","            }","        }","    }","","    private func handlePurchase(_ transaction: SKPaymentTransaction) {","        let productId = transaction.payment.productIdentifier","","        \/\/ Update user tags for purchase segmentation","        Pushwoosh.configure.setTags([","            \"has_purchased\": true,","            \"last_purchase_date\": ISO8601DateFormatter().string(from: Date()),","            \"last_purchased_product\": productId","        ])","    }","}"],"syntax":"swift"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","role":"collection","title":"PushwooshCore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/sendSKPaymentTransactions:":{"fragments":[{"kind":"text","text":"+ "},{"text":"sendSKPaymentTransactions:","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"sendSKPaymentTransactions:"}],"kind":"symbol","title":"sendSKPaymentTransactions:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/sendskpaymenttransactions:","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendSKPaymentTransactions:","abstract":[{"text":"Sends StoreKit payment transactions to Pushwoosh for purchase tracking.","type":"text"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"abstract":[],"title":"PWConfiguration","role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration"}}}