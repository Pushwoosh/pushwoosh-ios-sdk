{"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/sendskpaymenttransactions:"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"symbolKind":"method","title":"sendSKPaymentTransactions:","roleHeading":"Type Method","role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"sendSKPaymentTransactions:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)sendSKPaymentTransactions:","navigatorTitle":[{"kind":"identifier","text":"sendSKPaymentTransactions:"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"sendSKPaymentTransactions:","kind":"identifier"},{"kind":"text","text":"("},{"text":"NSArray","preciseIdentifier":"c:objc(cs)NSArray","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"text":"transactions","kind":"internalParam"},{"text":";","kind":"text"}]}]},{"kind":"parameters","parameters":[{"name":"transactions","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Array of "},{"code":"SKPaymentTransaction","type":"codeVoice"},{"type":"text","text":" objects from StoreKit."}]}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Automatically tracks in-app purchases from StoreKit transactions.","type":"text"},{"type":"text","text":" "},{"text":"This enables:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Revenue tracking","type":"text"}]},{"type":"text","text":": Monitor purchase revenue in Pushwoosh dashboard"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Purchase-based segmentation","type":"text"}],"type":"strong"},{"text":": Target paying users, high-value customers","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"LTV analysis","type":"text"}],"type":"strong"},{"text":": Calculate customer lifetime value","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Purchase events"}]},{"text":": Trigger automations based on purchases","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call this method from your "},{"type":"codeVoice","code":"SKPaymentTransactionObserver"},{"type":"text","text":" for all"},{"type":"text","text":" "},{"text":"completed transactions.","type":"text"}]},{"type":"heading","text":"Example","level":2,"anchor":"Example"},{"inlineContent":[{"text":"Integrate with StoreKit payment observer:","type":"text"}],"type":"paragraph"},{"code":["class StoreKitManager: NSObject, SKPaymentTransactionObserver {","","    func paymentQueue(_ queue: SKPaymentQueue,","                     updatedTransactions transactions: [SKPaymentTransaction]) {","","        let completedTransactions = transactions.filter {","            $0.transactionState == .purchased || $0.transactionState == .restored","        }","","        \/\/ Send completed transactions to Pushwoosh","        if !completedTransactions.isEmpty {","            Pushwoosh.configure.sendSKPaymentTransactions(completedTransactions)","        }","","        \/\/ Process each transaction","        for transaction in transactions {","            switch transaction.transactionState {","            case .purchased:","                handlePurchase(transaction)","                queue.finishTransaction(transaction)","","            case .restored:","                handleRestore(transaction)","                queue.finishTransaction(transaction)","","            case .failed:","                handleFailure(transaction)","                queue.finishTransaction(transaction)","","            case .deferred, .purchasing:","                break","","            @unknown default:","                break","            }","        }","    }","","    private func handlePurchase(_ transaction: SKPaymentTransaction) {","        let productId = transaction.payment.productIdentifier","","        \/\/ Update user tags for purchase segmentation","        Pushwoosh.configure.setTags([","            \"has_purchased\": true,","            \"last_purchase_date\": ISO8601DateFormatter().string(from: Date()),","            \"last_purchased_product\": productId","        ])","    }","}"],"syntax":"swift","type":"codeListing"}]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendSKPaymentTransactions:","interfaceLanguage":"occ"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"abstract":[{"type":"text","text":"Sends StoreKit payment transactions to Pushwoosh for purchase tracking."}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"title":"PushwooshCore","type":"topic","role":"collection","url":"\/documentation\/pushwooshcore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","abstract":[],"role":"symbol","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/sendSKPaymentTransactions:":{"type":"topic","title":"sendSKPaymentTransactions:","fragments":[{"text":"+ ","kind":"text"},{"text":"sendSKPaymentTransactions:","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendSKPaymentTransactions:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/sendskpaymenttransactions:","abstract":[{"text":"Sends StoreKit payment transactions to Pushwoosh for purchase tracking.","type":"text"}],"kind":"symbol","navigatorTitle":[{"text":"sendSKPaymentTransactions:","kind":"identifier"}]}}}