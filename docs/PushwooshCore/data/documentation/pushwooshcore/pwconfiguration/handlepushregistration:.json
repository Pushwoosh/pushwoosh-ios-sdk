{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Manually handles the device push token registration."}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","metadata":{"role":"symbol","title":"handlePushRegistration:","modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)handlePushRegistration:","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"handlePushRegistration:"}],"navigatorTitle":[{"text":"handlePushRegistration:","kind":"identifier"}],"roleHeading":"Type Method","symbolKind":"method"},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"kind":"identifier","text":"handlePushRegistration:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"NSData","preciseIdentifier":"c:objc(cs)NSData"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"deviceToken"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"deviceToken","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The device token Data received from APNs"}]}]}]},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Call this method from your AppDelegate’s ","type":"text"},{"type":"codeVoice","code":"application:didRegisterForRemoteNotificationsWithDeviceToken:"},{"text":" ","type":"text"},{"text":"to forward the device token to Pushwoosh.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The SDK normally handles this automatically via method swizzling, but you may need to call"},{"type":"text","text":" "},{"text":"this directly if:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"You’ve disabled swizzling","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You’re managing multiple push providers"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"You need custom token processing"}],"type":"paragraph"}]}]},{"level":2,"text":"Example","anchor":"Example","type":"heading"},{"inlineContent":[{"type":"text","text":"Manual token handling with multiple push providers:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(_ application: UIApplication,","                    didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","","        \/\/ Convert token to string for logging","        let tokenString = deviceToken.map { String(format: \"%02.2hhx\", $0) }.joined()","        Logger.info(\"Received APNs token: \\(tokenString.prefix(20))...\")","","        \/\/ Send to Pushwoosh","        Pushwoosh.configure.handlePushRegistration(deviceToken)","","        \/\/ Send to other push providers if needed","        FirebaseMessaging.messaging().apnsToken = deviceToken","","        \/\/ Sync with backend","        BackendAPI.shared.updatePushToken(tokenString)","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Only use this method if you need manual control."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/handlepushregistration:"]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushRegistration:","interfaceLanguage":"occ"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/handlePushRegistration:":{"navigatorTitle":[{"text":"handlePushRegistration:","kind":"identifier"}],