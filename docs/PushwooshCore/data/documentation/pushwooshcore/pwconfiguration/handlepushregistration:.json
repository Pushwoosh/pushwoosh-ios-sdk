{"sections":[],"abstract":[{"text":"Manually handles the device push token registration.","type":"text"}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/handlepushregistration:"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushRegistration:"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":") ","kind":"text"},{"text":"handlePushRegistration:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSData","text":"NSData","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"deviceToken"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"deviceToken","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The device token Data received from APNs"}]}]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call this method from your AppDelegate’s "},{"code":"application:didRegisterForRemoteNotificationsWithDeviceToken:","type":"codeVoice"},{"type":"text","text":" "},{"text":"to forward the device token to Pushwoosh.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The SDK normally handles this automatically via method swizzling, but you may need to call","type":"text"},{"type":"text","text":" "},{"text":"this directly if:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"You’ve disabled swizzling"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"You’re managing multiple push providers","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"You need custom token processing"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"inlineContent":[{"type":"text","text":"Manual token handling with multiple push providers:"}],"type":"paragraph"},{"syntax":"swift","code":["class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(_ application: UIApplication,","                    didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","","        \/\/ Convert token to string for logging","        let tokenString = deviceToken.map { String(format: \"%02.2hhx\", $0) }.joined()","        Logger.info(\"Received APNs token: \\(tokenString.prefix(20))...\")","","        \/\/ Send to Pushwoosh","        Pushwoosh.configure.handlePushRegistration(deviceToken)","","        \/\/ Send to other push providers if needed","        FirebaseMessaging.messaging().apnsToken = deviceToken","","        \/\/ Sync with backend","        BackendAPI.shared.updatePushToken(tokenString)","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Only use this method if you need manual control."}],"type":"paragraph"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","metadata":{"role":"symbol","symbolKind":"method","roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}],"title":"handlePushRegistration:","externalID":"c:objc(pl)PWConfiguration(cm)handlePushRegistration:","fragments":[{"text":"+ ","kind":"text"},{"text":"handlePushRegistration:","kind":"identifier"}],"navigatorTitle":[{"text":"handlePushRegistration:","kind":"identifier"}]},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/P