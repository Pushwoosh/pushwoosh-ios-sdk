{"abstract":[{"type":"text","text":"Manually handles the device push token registration."}],"sections":[],"metadata":{"roleHeading":"Type Method","title":"handlePushRegistration:","fragments":[{"text":"+ ","kind":"text"},{"text":"handlePushRegistration:","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"handlePushRegistration:"}],"symbolKind":"method","modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)handlePushRegistration:","role":"symbol"},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushRegistration:","interfaceLanguage":"occ"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/handlepushregistration:"]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"text":"handlePushRegistration:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSData","text":"NSData","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"deviceToken"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"deviceToken","content":[{"inlineContent":[{"text":"The device token Data received from APNs","type":"text"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"Call this method from your AppDelegate’s ","type":"text"},{"code":"application:didRegisterForRemoteNotificationsWithDeviceToken:","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"to forward the device token to Pushwoosh."}],"type":"paragraph"},{"inlineContent":[{"text":"The SDK normally handles this automatically via method swizzling, but you may need to call","type":"text"},{"text":" ","type":"text"},{"text":"this directly if:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"You’ve disabled swizzling"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You’re managing multiple push providers"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"You need custom token processing","type":"text"}]}]}],"type":"unorderedList"},{"level":2,"text":"Example","anchor":"Example","type":"heading"},{"inlineContent":[{"type":"text","text":"Manual token handling with multiple push providers:"}],"type":"paragraph"},{"type":"codeListing","code":["class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(_ application: UIApplication,","                    didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","","        \/\/ Convert token to string for logging","        let tokenString = deviceToken.map { String(format: \"%02.2hhx\", $0) }.joined()","        Logger.info(\"Received APNs token: \\(tokenString.prefix(20))...\")","","        \/\/ Send to Pushwoosh","        Pushwoosh.configure.handlePushRegistration(deviceToken)","","        \/\/ Send to other push providers if needed","        FirebaseMessaging.messaging().apnsToken = deviceToken","","        \/\/ Sync with backend","        BackendAPI.shared.updatePushToken(tokenString)","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Only use this method if you need manual control."}]}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/handlePushRegistration:":{"navigatorTitle":[{"kind":"identifier","text":"handlePushRegistration:"}],