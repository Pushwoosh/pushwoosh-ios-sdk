{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"text":"handlePushRegistration:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSData","text":"NSData","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"deviceToken"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}]},{"parameters":[{"name":"deviceToken","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The device token Data received from APNs"}]}]}],"kind":"parameters"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call this method from your AppDelegate’s "},{"code":"application:didRegisterForRemoteNotificationsWithDeviceToken:","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"to forward the device token to Pushwoosh."}]},{"inlineContent":[{"type":"text","text":"The SDK normally handles this automatically via method swizzling, but you may need to call"},{"text":" ","type":"text"},{"text":"this directly if:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You’ve disabled swizzling"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"You’re managing multiple push providers","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You need custom token processing"}]}]}]},{"level":2,"text":"Example","anchor":"Example","type":"heading"},{"inlineContent":[{"text":"Manual token handling with multiple push providers:","type":"text"}],"type":"paragraph"},{"code":["class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(_ application: UIApplication,","                    didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","","        \/\/ Convert token to string for logging","        let tokenString = deviceToken.map { String(format: \"%02.2hhx\", $0) }.joined()","        Logger.info(\"Received APNs token: \\(tokenString.prefix(20))...\")","","        \/\/ Send to Pushwoosh","        Pushwoosh.configure.handlePushRegistration(deviceToken)","","        \/\/ Send to other push providers if needed","        FirebaseMessaging.messaging().apnsToken = deviceToken","","        \/\/ Sync with backend","        BackendAPI.shared.updatePushToken(tokenString)","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Only use this method if you need manual control."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"Manually handles the device push token registration."}],"metadata":{"fragments":[{"kind":"text","text":"+ "},{"text":"handlePushRegistration:","kind":"identifier"}],"symbolKind":"method","navigatorTitle":[{"text":"handlePushRegistration:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"role":"symbol","roleHeading":"Type Method","title":"handlePushRegistration:","externalID":"c:objc(pl)PWConfiguration(cm)handlePushRegistration:"},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/handlepushregistration:"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushRegistration:","interfaceLanguage":"occ"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/Pushwoosh