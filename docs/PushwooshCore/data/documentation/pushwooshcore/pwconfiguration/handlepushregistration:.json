{"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushRegistration:","interfaceLanguage":"occ"},"abstract":[{"text":"Manually handles the device push token registration.","type":"text"}],"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)handlePushRegistration:","roleHeading":"Type Method","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"handlePushRegistration:"}],"role":"symbol","navigatorTitle":[{"text":"handlePushRegistration:","kind":"identifier"}],"title":"handlePushRegistration:","symbolKind":"method","modules":[{"name":"PushwooshCore"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"text":"handlePushRegistration:","kind":"identifier"},{"kind":"text","text":"("},{"text":"NSData","preciseIdentifier":"c:objc(cs)NSData","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"text":"deviceToken","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"parameters":[{"name":"deviceToken","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The device token Data received from APNs"}]}]}],"kind":"parameters"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"Call this method from your AppDelegate’s ","type":"text"},{"type":"codeVoice","code":"application:didRegisterForRemoteNotificationsWithDeviceToken:"},{"text":" ","type":"text"},{"text":"to forward the device token to Pushwoosh.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The SDK normally handles this automatically via method swizzling, but you may need to call"},{"text":" ","type":"text"},{"type":"text","text":"this directly if:"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"You’ve disabled swizzling"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"You’re managing multiple push providers","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You need custom token processing"}]}]}],"type":"unorderedList"},{"anchor":"Example","level":2,"type":"heading","text":"Example"},{"inlineContent":[{"type":"text","text":"Manual token handling with multiple push providers:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(_ application: UIApplication,","                    didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","","        \/\/ Convert token to string for logging","        let tokenString = deviceToken.map { String(format: \"%02.2hhx\", $0) }.joined()","        Logger.info(\"Received APNs token: \\(tokenString.prefix(20))...\")","","        \/\/ Send to Pushwoosh","        Pushwoosh.configure.handlePushRegistration(deviceToken)","","        \/\/ Send to other push providers if needed","        FirebaseMessaging.messaging().apnsToken = deviceToken","","        \/\/ Sync with backend","        BackendAPI.shared.updatePushToken(tokenString)","    }","}"]},{"inlineContent":[{"type":"text","text":"Only use this method if you need manual control."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/handlepushregistration:"]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/handlePushRegistration:":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/Pushwoos