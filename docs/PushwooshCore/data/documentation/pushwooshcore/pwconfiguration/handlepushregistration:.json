{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"abstract":[{"type":"text","text":"Manually handles the device push token registration."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"metadata":{"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"handlePushRegistration:"}],"roleHeading":"Type Method","navigatorTitle":[{"kind":"identifier","text":"handlePushRegistration:"}],"modules":[{"name":"PushwooshCore"}],"role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)handlePushRegistration:","title":"handlePushRegistration:","symbolKind":"method"},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushRegistration:","interfaceLanguage":"occ"},"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"handlePushRegistration:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSData","text":"NSData","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"text":"deviceToken","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"deviceToken","content":[{"type":"paragraph","inlineContent":[{"text":"The device token Data received from APNs","type":"text"}]}]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Call this method from your AppDelegate’s ","type":"text"},{"type":"codeVoice","code":"application:didRegisterForRemoteNotificationsWithDeviceToken:"},{"type":"text","text":" "},{"text":"to forward the device token to Pushwoosh.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The SDK normally handles this automatically via method swizzling, but you may need to call"},{"type":"text","text":" "},{"type":"text","text":"this directly if:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You’ve disabled swizzling"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"You’re managing multiple push providers"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"You need custom token processing","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Example","level":2,"text":"Example"},{"type":"paragraph","inlineContent":[{"text":"Manual token handling with multiple push providers:","type":"text"}]},{"type":"codeListing","code":["class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(_ application: UIApplication,","                    didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","","        \/\/ Convert token to string for logging","        let tokenString = deviceToken.map { String(format: \"%02.2hhx\", $0) }.joined()","        Logger.info(\"Received APNs token: \\(tokenString.prefix(20))...\")","","        \/\/ Send to Pushwoosh","        Pushwoosh.configure.handlePushRegistration(deviceToken)","","        \/\/ Send to other push providers if needed","        FirebaseMessaging.messaging().apnsToken = deviceToken","","        \/\/ Sync with backend","        BackendAPI.shared.updatePushToken(tokenString)","    }","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"Only use this method if you need manual control."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/handlepushregistration:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","title":"PushwooshCore","role":"collection","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"role":"symbol","abstract":[],"title":"PWConfiguration","kind":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/handlePushRegistration:":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushRegistration:","role":"symbol","abstract":[{"text":"Manually handles the device push token registration.","type":"text"}],"title":"handlePushRegistration:","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"handlePushRegistration:"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/handlepushregistration:","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"handlePushRegistration:"}]}}}