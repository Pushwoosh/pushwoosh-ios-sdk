{"abstract":[{"type":"text","text":"Manually handles the device push token registration."}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"text":"handlePushRegistration:","kind":"identifier"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSData","text":"NSData"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"deviceToken"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"deviceToken","content":[{"inlineContent":[{"text":"The device token Data received from APNs","type":"text"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"text":"Call this method from your AppDelegate’s ","type":"text"},{"type":"codeVoice","code":"application:didRegisterForRemoteNotificationsWithDeviceToken:"},{"type":"text","text":" "},{"type":"text","text":"to forward the device token to Pushwoosh."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The SDK normally handles this automatically via method swizzling, but you may need to call","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this directly if:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"You’ve disabled swizzling","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You’re managing multiple push providers"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"You need custom token processing","type":"text"}]}]}]},{"anchor":"Example","type":"heading","text":"Example","level":2},{"inlineContent":[{"type":"text","text":"Manual token handling with multiple push providers:"}],"type":"paragraph"},{"syntax":"swift","code":["class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(_ application: UIApplication,","                    didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","","        \/\/ Convert token to string for logging","        let tokenString = deviceToken.map { String(format: \"%02.2hhx\", $0) }.joined()","        Logger.info(\"Received APNs token: \\(tokenString.prefix(20))...\")","","        \/\/ Send to Pushwoosh","        Pushwoosh.configure.handlePushRegistration(deviceToken)","","        \/\/ Send to other push providers if needed","        FirebaseMessaging.messaging().apnsToken = deviceToken","","        \/\/ Sync with backend","        BackendAPI.shared.updatePushToken(tokenString)","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Only use this method if you need manual control.","type":"text"}]}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/handlepushregistration:"]}],"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)handlePushRegistration:","title":"handlePushRegistration:","fragments":[{"text":"+ ","kind":"text"},{"text":"handlePushRegistration:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"role":"symbol","symbolKind":"method","roleHeading":"Type Method","navigatorTitle":[{"kind":"identifier","text":"handlePushRegistration:"}]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushRegistration:","interfaceLanguage":"occ"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","role":"collection","kind":"symbol","type":"topic","abstract":[{"text":"Cor