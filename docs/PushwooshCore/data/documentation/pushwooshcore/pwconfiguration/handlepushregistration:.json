{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"kind":"symbol","identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushRegistration:","interfaceLanguage":"occ"},"metadata":{"symbolKind":"method","role":"symbol","modules":[{"name":"PushwooshCore"}],"fragments":[{"text":"+ ","kind":"text"},{"text":"handlePushRegistration:","kind":"identifier"}],"navigatorTitle":[{"text":"handlePushRegistration:","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)handlePushRegistration:","roleHeading":"Type Method","title":"handlePushRegistration:"},"abstract":[{"type":"text","text":"Manually handles the device push token registration."}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"kind":"identifier","text":"handlePushRegistration:"},{"kind":"text","text":"("},{"text":"NSData","preciseIdentifier":"c:objc(cs)NSData","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"text":"deviceToken","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"deviceToken","content":[{"inlineContent":[{"type":"text","text":"The device token Data received from APNs"}],"type":"paragraph"}]}]},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call this method from your AppDelegate’s "},{"type":"codeVoice","code":"application:didRegisterForRemoteNotificationsWithDeviceToken:"},{"type":"text","text":" "},{"text":"to forward the device token to Pushwoosh.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The SDK normally handles this automatically via method swizzling, but you may need to call","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this directly if:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You’ve disabled swizzling"}]}]},{"content":[{"inlineContent":[{"text":"You’re managing multiple push providers","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"You need custom token processing"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Example","type":"heading","level":2,"anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Manual token handling with multiple push providers:"}]},{"code":["class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(_ application: UIApplication,","                    didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","","        \/\/ Convert token to string for logging","        let tokenString = deviceToken.map { String(format: \"%02.2hhx\", $0) }.joined()","        Logger.info(\"Received APNs token: \\(tokenString.prefix(20))...\")","","        \/\/ Send to Pushwoosh","        Pushwoosh.configure.handlePushRegistration(deviceToken)","","        \/\/ Send to other push providers if needed","        FirebaseMessaging.messaging().apnsToken = deviceToken","","        \/\/ Sync with backend","        BackendAPI.shared.updatePushToken(tokenString)","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Only use this method if you need manual control."}]}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/handlepushregistration:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"role":"symbol","url":