{"abstract":[{"type":"text","text":"Manually handles the device push token registration."}],"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)handlePushRegistration:","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"handlePushRegistration:"}],"navigatorTitle":[{"text":"handlePushRegistration:","kind":"identifier"}],"roleHeading":"Type Method","title":"handlePushRegistration:","symbolKind":"method","role":"symbol","modules":[{"name":"PushwooshCore"}]},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"kind":"identifier","text":"handlePushRegistration:"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"NSData","preciseIdentifier":"c:objc(cs)NSData"},{"text":" *) ","kind":"text"},{"text":"deviceToken","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The device token Data received from APNs"}]}],"name":"deviceToken"}]},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Call this method from your AppDelegate’s ","type":"text"},{"type":"codeVoice","code":"application:didRegisterForRemoteNotificationsWithDeviceToken:"},{"type":"text","text":" "},{"text":"to forward the device token to Pushwoosh.","type":"text"}]},{"inlineContent":[{"text":"The SDK normally handles this automatically via method swizzling, but you may need to call","type":"text"},{"text":" ","type":"text"},{"text":"this directly if:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"You’ve disabled swizzling","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You’re managing multiple push providers"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You need custom token processing"}]}]}]},{"anchor":"Example","type":"heading","level":2,"text":"Example"},{"type":"paragraph","inlineContent":[{"text":"Manual token handling with multiple push providers:","type":"text"}]},{"code":["class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(_ application: UIApplication,","                    didRegisterForRemoteNotificationsWithDeviceToken deviceToken: Data) {","","        \/\/ Convert token to string for logging","        let tokenString = deviceToken.map { String(format: \"%02.2hhx\", $0) }.joined()","        Logger.info(\"Received APNs token: \\(tokenString.prefix(20))...\")","","        \/\/ Send to Pushwoosh","        Pushwoosh.configure.handlePushRegistration(deviceToken)","","        \/\/ Send to other push providers if needed","        FirebaseMessaging.messaging().apnsToken = deviceToken","","        \/\/ Sync with backend","        BackendAPI.shared.updatePushToken(tokenString)","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Only use this method if you need manual control."}],"type":"paragraph"}],"kind":"content"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushRegistration:"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/handlepushregistration:"]}],"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"type":"to