{"abstract":[{"type":"text","text":"Tracks an individual in-app purchase with custom price information."}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/sendpurchase:withprice:currencycode:anddate:"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"kind":"identifier","text":"sendPurchase:"},{"text":"(","kind":"text"},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"text":"productIdentifier","kind":"internalParam"},{"text":" ","kind":"text"},{"kind":"identifier","text":"withPrice:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSDecimalNumber","kind":"typeIdentifier","text":"NSDecimalNumber"},{"kind":"text","text":" *) "},{"text":"price","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"currencyCode:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSString","text":"NSString","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"currencyCode"},{"text":" ","kind":"text"},{"kind":"identifier","text":"andDate:"},{"text":"(","kind":"text"},{"text":"NSDate","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSDate"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"date"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The product identifier (SKU)."}],"type":"paragraph"}],"name":"productIdentifier"},{"content":[{"inlineContent":[{"text":"The purchase price as NSDecimalNumber for precision.","type":"text"}],"type":"paragraph"}],"name":"price"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"ISO 4217 currency code (e.g., “USD”, “EUR”, “GBP”)."}]}],"name":"currencyCode"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The date when the purchase occurred.","type":"text"}]}],"name":"date"}],"kind":"parameters"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Manually track a purchase when you need more control than automatic","type":"text"},{"type":"text","text":" "},{"text":"StoreKit tracking, or when processing purchases from other sources","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(web purchases, promotional codes, etc.)."}]},{"type":"paragraph","inlineContent":[{"text":"Use this for:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Non-StoreKit purchases (web, third-party payment processors)"}]}]},{"content":[{"inlineContent":[{"text":"Custom price tracking (discounts, promotions)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Server-verified purchases","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Cross-platform purchase sync"}],"type":"paragraph"}]}]},{"level":2,"type":"heading","text":"Example","anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Track purchases from different sources:"}]},{"code":["class PurchaseTracker {","","    func trackStoreKitPurchase(_ transaction: SKPaymentTransaction, product: SKProduct) {","        Pushwoosh.configure.sendPurchase(","            product.productIdentifier,","            withPrice: product.price,","            currencyCode: product.priceLocale.currencyCode ?? \"USD\",","            andDate: transaction.transactionDate ?? Date()","        )","","        updatePurchaseTags(productId: product.productIdentifier, price: product.price)","    }","","    func trackWebPurchase(_ purchase: WebPurchase) {","        \/\/ Track purchase made through web checkout","        Pushwoosh.configure.sendPurchase(","            purchase.productId,","            withPrice: NSDecimalNumber(value: purchase.amount),","            currencyCode: purchase.currency,","            andDate: purchase.timestamp","        )","","        updatePurchaseTags(productId: purchase.productId,","                          price: NSDecimalNumber(value: purchase.amount))","    }","","    func trackPromotionalPurchase(productId: String, originalPrice: Decimal, discountedPrice: Decimal) {","        \/\/ Track discounted purchase","        Pushwoosh.configure.sendPurchase(","            productId,","            withPrice: NSDecimalNumber(decimal: discountedPrice),","            currencyCode: Locale.current.currencyCode ?? \"USD\",","            andDate: Date()","        )","","        Pushwoosh.configure.setTags([","            \"used_promotion\": true,","            \"discount_amount\": NSDecimalNumber(decimal: originalPrice - discountedPrice)","        ])","    }","","    private func updatePurchaseTags(productId: String, price: NSDecimalNumber) {","        Pushwoosh.configure.setTags([","            \"total_purchases\": incrementPurchaseCount(),","            \"total_spent\": calculateTotalSpent(adding: price),","            \"customer_tier\": determineCustomerTier()","        ])","    }","}"],"type":"codeListing","syntax":"swift"}]}],"metadata":{"fragments":[{"text":"+ ","kind":"text"},{"text":"sendPurchase:withPrice:currencyCode:andDate:","kind":"identifier"}],"symbolKind":"method","navigatorTitle":[{"text":"sendPurchase:withPrice:currencyCode:andDate:","kind":"identifier"}],"title":"sendPurchase:withPrice:currencyCode:andDate:","roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}],"role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)sendPurchase:withPrice:currencyCode:andDate:"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendPurchase:withPrice:currencyCode:andDate:"},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/sendPurchase:withPrice:currencyCode:andDate:":{"url":"\/documentation\/pushwooshcore\/pwconfiguration\/sendpurchase:withprice:currencycode:anddate:","type":"topic","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendPurchase:withPrice:currencyCode:andDate:","title":"sendPurchase:withPrice:currencyCode:andDate:","fragments":[{"text":"+ ","kind":"text"},{"text":"sendPurchase:withPrice:currencyCode:andDate:","kind":"identifier"}],"navigatorTitle":[{"text":"sendPurchase:withPrice:currencyCode:andDate:","kind":"identifier"}],"abstract":[{"type":"text","text":"Tracks an individual in-app purchase with custom price information."}],"role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","title":"PushwooshCore","role":"collection","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"kind":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","title":"PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"role":"symbol","abstract":[]}}}