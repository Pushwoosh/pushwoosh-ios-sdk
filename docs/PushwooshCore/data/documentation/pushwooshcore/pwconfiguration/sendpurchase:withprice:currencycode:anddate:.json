{"sections":[],"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendPurchase:withPrice:currencyCode:andDate:","interfaceLanguage":"occ"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/sendpurchase:withprice:currencycode:anddate:"]}],"abstract":[{"text":"Tracks an individual in-app purchase with custom price information.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)sendPurchase:withPrice:currencyCode:andDate:","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"sendPurchase:withPrice:currencyCode:andDate:"}],"roleHeading":"Type Method","symbolKind":"method","role":"symbol","title":"sendPurchase:withPrice:currencyCode:andDate:","modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"text":"sendPurchase:withPrice:currencyCode:andDate:","kind":"identifier"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"sendPurchase:","kind":"identifier"},{"kind":"text","text":"("},{"text":"NSString","preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"productIdentifier"},{"text":" ","kind":"text"},{"text":"withPrice:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSDecimalNumber","kind":"typeIdentifier","text":"NSDecimalNumber"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"price"},{"text":" ","kind":"text"},{"kind":"identifier","text":"currencyCode:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString","text":"NSString"},{"text":" *) ","kind":"text"},{"text":"currencyCode","kind":"internalParam"},{"kind":"text","text":" "},{"text":"andDate:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSDate","text":"NSDate"},{"kind":"text","text":" *) "},{"text":"date","kind":"internalParam"},{"text":";","kind":"text"}]}]},{"parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The product identifier (SKU)."}],"type":"paragraph"}],"name":"productIdentifier"},{"content":[{"inlineContent":[{"text":"The purchase price as NSDecimalNumber for precision.","type":"text"}],"type":"paragraph"}],"name":"price"},{"name":"currencyCode","content":[{"type":"paragraph","inlineContent":[{"text":"ISO 4217 currency code (e.g., “USD”, “EUR”, “GBP”).","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The date when the purchase occurred."}]}],"name":"date"}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Manually track a purchase when you need more control than automatic"},{"type":"text","text":" "},{"type":"text","text":"StoreKit tracking, or when processing purchases from other sources"},{"text":" ","type":"text"},{"type":"text","text":"(web purchases, promotional codes, etc.)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use this for:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Non-StoreKit purchases (web, third-party payment processors)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Custom price tracking (discounts, promotions)"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Server-verified purchases"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Cross-platform purchase sync"}],"type":"paragraph"}]}]},{"level":2,"text":"Example","type":"heading","anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Track purchases from different sources:"}]},{"type":"codeListing","syntax":"swift","code":["class PurchaseTracker {","","    func trackStoreKitPurchase(_ transaction: SKPaymentTransaction, product: SKProduct) {","        Pushwoosh.configure.sendPurchase(","            product.productIdentifier,","            withPrice: product.price,","            currencyCode: product.priceLocale.currencyCode ?? \"USD\",","            andDate: transaction.transactionDate ?? Date()","        )","","        updatePurchaseTags(productId: product.productIdentifier, price: product.price)","    }","","    func trackWebPurchase(_ purchase: WebPurchase) {","        \/\/ Track purchase made through web checkout","        Pushwoosh.configure.sendPurchase(","            purchase.productId,","            withPrice: NSDecimalNumber(value: purchase.amount),","            currencyCode: purchase.currency,","            andDate: purchase.timestamp","        )","","        updatePurchaseTags(productId: purchase.productId,","                          price: NSDecimalNumber(value: purchase.amount))","    }","","    func trackPromotionalPurchase(productId: String, originalPrice: Decimal, discountedPrice: Decimal) {","        \/\/ Track discounted purchase","        Pushwoosh.configure.sendPurchase(","            productId,","            withPrice: NSDecimalNumber(decimal: discountedPrice),","            currencyCode: Locale.current.currencyCode ?? \"USD\",","            andDate: Date()","        )","","        Pushwoosh.configure.setTags([","            \"used_promotion\": true,","            \"discount_amount\": NSDecimalNumber(decimal: originalPrice - discountedPrice)","        ])","    }","","    private func updatePurchaseTags(productId: String, price: NSDecimalNumber) {","        Pushwoosh.configure.setTags([","            \"total_purchases\": incrementPurchaseCount(),","            \"total_spent\": calculateTotalSpent(adding: price),","            \"customer_tier\": determineCustomerTier()","        ])","    }","}"]}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","abstract":[],"fragments":[{"kind":"identifier","text":"PWConfiguration"}],"title":"PWConfiguration","kind":"symbol","role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/sendPurchase:withPrice:currencyCode:andDate:":{"abstract":[{"type":"text","text":"Tracks an individual in-app purchase with custom price information."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendPurchase:withPrice:currencyCode:andDate:","fragments":[{"kind":"text","text":"+ "},{"text":"sendPurchase:withPrice:currencyCode:andDate:","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"sendPurchase:withPrice:currencyCode:andDate:"}],"title":"sendPurchase:withPrice:currencyCode:andDate:","kind":"symbol","role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/sendpurchase:withprice:currencycode:anddate:","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","url":"\/documentation\/pushwooshcore","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"role":"collection"}}}