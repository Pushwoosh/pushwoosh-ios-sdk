{"metadata":{"navigatorTitle":[{"text":"sendPurchase:withPrice:currencyCode:andDate:","kind":"identifier"}],"role":"symbol","modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)sendPurchase:withPrice:currencyCode:andDate:","symbolKind":"method","title":"sendPurchase:withPrice:currencyCode:andDate:","fragments":[{"text":"+ ","kind":"text"},{"text":"sendPurchase:withPrice:currencyCode:andDate:","kind":"identifier"}],"roleHeading":"Type Method"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":") ","kind":"text"},{"text":"sendPurchase:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSString","text":"NSString","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"productIdentifier"},{"text":" ","kind":"text"},{"kind":"identifier","text":"withPrice:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"NSDecimalNumber","preciseIdentifier":"c:objc(cs)NSDecimalNumber"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"price"},{"text":" ","kind":"text"},{"text":"currencyCode:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"NSString","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"currencyCode"},{"kind":"text","text":" "},{"kind":"identifier","text":"andDate:"},{"kind":"text","text":"("},{"text":"NSDate","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSDate"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"date"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"name":"productIdentifier","content":[{"inlineContent":[{"text":"The product identifier (SKU).","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The purchase price as NSDecimalNumber for precision.","type":"text"}]}],"name":"price"},{"content":[{"type":"paragraph","inlineContent":[{"text":"ISO 4217 currency code (e.g., “USD”, “EUR”, “GBP”).","type":"text"}]}],"name":"currencyCode"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The date when the purchase occurred.","type":"text"}]}],"name":"date"}]},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Manually track a purchase when you need more control than automatic"},{"text":" ","type":"text"},{"text":"StoreKit tracking, or when processing purchases from other sources","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(web purchases, promotional codes, etc.)."}]},{"inlineContent":[{"type":"text","text":"Use this for:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Non-StoreKit purchases (web, third-party payment processors)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Custom price tracking (discounts, promotions)","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Server-verified purchases"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cross-platform purchase sync"}]}]}]},{"anchor":"Example","type":"heading","level":2,"text":"Example"},{"inlineContent":[{"text":"Track purchases from different sources:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class PurchaseTracker {","","    func trackStoreKitPurchase(_ transaction: SKPaymentTransaction, product: SKProduct) {","        Pushwoosh.configure.sendPurchase(","            product.productIdentifier,","            withPrice: product.price,","            currencyCode: product.priceLocale.currencyCode ?? \"USD\",","            andDate: transaction.transactionDate ?? Date()","        )","","        updatePurchaseTags(productId: product.productIdentifier, price: product.price)","    }","","    func trackWebPurchase(_ purchase: WebPurchase) {","        \/\/ Track purchase made through web checkout","        Pushwoosh.configure.sendPurchase(","            purchase.productId,","            withPrice: NSDecimalNumber(value: purchase.amount),","            currencyCode: purchase.currency,","            andDate: purchase.timestamp","        )","","        updatePurchaseTags(productId: purchase.productId,","                          price: NSDecimalNumber(value: purchase.amount))","    }","","    func trackPromotionalPurchase(productId: String, originalPrice: Decimal, discountedPrice: Decimal) {","        \/\/ Track discounted purchase","        Pushwoosh.configure.sendPurchase(","            productId,","            withPrice: NSDecimalNumber(decimal: discountedPrice),","            currencyCode: Locale.current.currencyCode ?? \"USD\",","            andDate: Date()","        )","","        Pushwoosh.configure.setTags([","            \"used_promotion\": true,","            \"discount_amount\": NSDecimalNumber(decimal: originalPrice - discountedPrice)","        ])","    }","","    private func updatePurchaseTags(productId: String, price: NSDecimalNumber) {","        Pushwoosh.configure.setTags([","            \"total_purchases\": incrementPurchaseCount(),","            \"total_spent\": calculateTotalSpent(adding: price),","            \"customer_tier\": determineCustomerTier()","        ])","    }","}"]}],"kind":"content"}],"kind":"symbol","variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/sendpurchase:withprice:currencycode:anddate:"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCor