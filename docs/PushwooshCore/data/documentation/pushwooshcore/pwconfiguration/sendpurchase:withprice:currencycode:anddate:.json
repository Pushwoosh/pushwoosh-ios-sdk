{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"sendPurchase:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString","text":"NSString"},{"kind":"text","text":" *) "},{"text":"productIdentifier","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"withPrice:","kind":"identifier"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"NSDecimalNumber","preciseIdentifier":"c:objc(cs)NSDecimalNumber"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"price"},{"kind":"text","text":" "},{"text":"currencyCode:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"text":"currencyCode","kind":"internalParam"},{"text":" ","kind":"text"},{"kind":"identifier","text":"andDate:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSDate","kind":"typeIdentifier","text":"NSDate"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"date"},{"text":";","kind":"text"}]}]},{"parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The product identifier (SKU)."}],"type":"paragraph"}],"name":"productIdentifier"},{"name":"price","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The purchase price as NSDecimalNumber for precision."}]}]},{"content":[{"inlineContent":[{"text":"ISO 4217 currency code (e.g., “USD”, “EUR”, “GBP”).","type":"text"}],"type":"paragraph"}],"name":"currencyCode"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The date when the purchase occurred."}]}],"name":"date"}],"kind":"parameters"},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Manually track a purchase when you need more control than automatic","type":"text"},{"type":"text","text":" "},{"text":"StoreKit tracking, or when processing purchases from other sources","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(web purchases, promotional codes, etc.)."}]},{"inlineContent":[{"type":"text","text":"Use this for:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Non-StoreKit purchases (web, third-party payment processors)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Custom price tracking (discounts, promotions)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Server-verified purchases","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Cross-platform purchase sync","type":"text"}]}]}],"type":"unorderedList"},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"inlineContent":[{"type":"text","text":"Track purchases from different sources:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class PurchaseTracker {","","    func trackStoreKitPurchase(_ transaction: SKPaymentTransaction, product: SKProduct) {","        Pushwoosh.configure.sendPurchase(","            product.productIdentifier,","            withPrice: product.price,","            currencyCode: product.priceLocale.currencyCode ?? \"USD\",","            andDate: transaction.transactionDate ?? Date()","        )","","        updatePurchaseTags(productId: product.productIdentifier, price: product.price)","    }","","    func trackWebPurchase(_ purchase: WebPurchase) {","        \/\/ Track purchase made through web checkout","        Pushwoosh.configure.sendPurchase(","            purchase.productId,","            withPrice: NSDecimalNumber(value: purchase.amount),","            currencyCode: purchase.currency,","            andDate: purchase.timestamp","        )","","        updatePurchaseTags(productId: purchase.productId,","                          price: NSDecimalNumber(value: purchase.amount))","    }","","    func trackPromotionalPurchase(productId: String, originalPrice: Decimal, discountedPrice: Decimal) {","        \/\/ Track discounted purchase","        Pushwoosh.configure.sendPurchase(","            productId,","            withPrice: NSDecimalNumber(decimal: discountedPrice),","            currencyCode: Locale.current.currencyCode ?? \"USD\",","            andDate: Date()","        )","","        Pushwoosh.configure.setTags([","            \"used_promotion\": true,","            \"discount_amount\": NSDecimalNumber(decimal: originalPrice - discountedPrice)","        ])","    }","","    private func updatePurchaseTags(productId: String, price: NSDecimalNumber) {","        Pushwoosh.configure.setTags([","            \"total_purchases\": incrementPurchaseCount(),","            \"total_spent\": calculateTotalSpent(adding: price),","            \"customer_tier\": determineCustomerTier()","        ])","    }","}"]}],"kind":"content"}],"kind":"symbol","variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/sendpurchase:withprice:currencycode:anddate:"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendPurchase:withPrice:currencyCode:andDate:"},"sections":[],"abstract":[{"type":"text","text":"Tracks an individual in-app purchase with custom price information."}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"roleHeading":"Type Method","externalID":"c:objc(pl)PWConfiguration(cm)sendPurchase:withPrice:currencyCode:andDate:","modules":[{"name":"PushwooshCore"}],"symbolKind":"method","title":"sendPurchase:withPrice:currencyCode:andDa