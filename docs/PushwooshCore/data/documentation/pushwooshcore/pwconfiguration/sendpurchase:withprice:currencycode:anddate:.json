{"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Tracks an individual in-app purchase with custom price information."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"sendPurchase:","kind":"identifier"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString","text":"NSString"},{"text":" *) ","kind":"text"},{"text":"productIdentifier","kind":"internalParam"},{"kind":"text","text":" "},{"kind":"identifier","text":"withPrice:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSDecimalNumber","text":"NSDecimalNumber","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"text":"price","kind":"internalParam"},{"text":" ","kind":"text"},{"kind":"identifier","text":"currencyCode:"},{"text":"(","kind":"text"},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"text":"currencyCode","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"andDate:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"NSDate","preciseIdentifier":"c:objc(cs)NSDate"},{"kind":"text","text":" *) "},{"text":"date","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The product identifier (SKU)."}]}],"name":"productIdentifier"},{"name":"price","content":[{"type":"paragraph","inlineContent":[{"text":"The purchase price as NSDecimalNumber for precision.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"ISO 4217 currency code (e.g., “USD”, “EUR”, “GBP”).","type":"text"}]}],"name":"currencyCode"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The date when the purchase occurred."}]}],"name":"date"}],"kind":"parameters"},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Manually track a purchase when you need more control than automatic","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"StoreKit tracking, or when processing purchases from other sources"},{"text":" ","type":"text"},{"text":"(web purchases, promotional codes, etc.).","type":"text"}]},{"inlineContent":[{"text":"Use this for:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Non-StoreKit purchases (web, third-party payment processors)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Custom price tracking (discounts, promotions)","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Server-verified purchases","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Cross-platform purchase sync"}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Example","level":2,"text":"Example"},{"type":"paragraph","inlineContent":[{"text":"Track purchases from different sources:","type":"text"}]},{"type":"codeListing","code":["class PurchaseTracker {","","    func trackStoreKitPurchase(_ transaction: SKPaymentTransaction, product: SKProduct) {","        Pushwoosh.configure.sendPurchase(","            product.productIdentifier,","            withPrice: product.price,","            currencyCode: product.priceLocale.currencyCode ?? \"USD\",","            andDate: transaction.transactionDate ?? Date()","        )","","        updatePurchaseTags(productId: product.productIdentifier, price: product.price)","    }","","    func trackWebPurchase(_ purchase: WebPurchase) {","        \/\/ Track purchase made through web checkout","        Pushwoosh.configure.sendPurchase(","            purchase.productId,","            withPrice: NSDecimalNumber(value: purchase.amount),","            currencyCode: purchase.currency,","            andDate: purchase.timestamp","        )","","        updatePurchaseTags(productId: purchase.productId,","                          price: NSDecimalNumber(value: purchase.amount))","    }","","    func trackPromotionalPurchase(productId: String, originalPrice: Decimal, discountedPrice: Decimal) {","        \/\/ Track discounted purchase","        Pushwoosh.configure.sendPurchase(","            productId,","            withPrice: NSDecimalNumber(decimal: discountedPrice),","            currencyCode: Locale.current.currencyCode ?? \"USD\",","            andDate: Date()","        )","","        Pushwoosh.configure.setTags([","            \"used_promotion\": true,","            \"discount_amount\": NSDecimalNumber(decimal: originalPrice - discountedPrice)","        ])","    }","","    private func updatePurchaseTags(productId: String, price: NSDecimalNumber) {","        Pushwoosh.configure.setTags([","            \"total_purchases\": incrementPurchaseCount(),","            \"total_spent\": calculateTotalSpent(adding: price),","            \"customer_tier\": determineCustomerTier()","        ])","    }","}"],"syntax":"swift"}]}],"sections":[],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/sendpurchase:withprice:currencycode:anddate:"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","metadata":{"modules":[{"name":"PushwooshCore"}],"role":"symbol","symbolKind":"method","fragments":[{"kind":"text","text":"+ "},{"text":"sendPurchase:withPrice:currencyCode:andDate:","kind":"identifier"}],"navigatorTitle":[{"text":"sendPurchase:withPrice:currencyCode:andDate:","kind":"identifier"}],"title":"sendPurchase:withPrice:currencyCode:andDate:","roleHeading":"Type Method","externalID":"c:objc(pl)PWConfiguration(cm)sendPurchase:withPrice:currencyCode:andDate:"},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendPurchase:withPrice:currencyCode:andDate:","interfaceLanguage":"occ"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/sendPurchase:withPrice:currencyCode:andDate:":{"abstract":[{"type":"text","text":"Tracks an individual in-app purchase with custom price information."}],"fragments":[{"text":"+ ","kind":"text"},{"text":"sendPurchase:withPrice:currencyCode:andDate:","kind":"identifier"}],"type":"topic","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/sendPurchase:withPrice:currencyCode:andDate:","title":"sendPurchase:withPrice:currencyCode:andDate:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/sendpurchase:withprice:currencycode:anddate:","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"sendPurchase:withPrice:currencyCode:andDate:"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","abstract":[],"kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"role":"collection","title":"PushwooshCore","url":"\/documentation\/pushwooshcore","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic"}}}