bled,","                \"categories_count\": preferences.categories.count","            ])","","            UserDefaults.standard.set(true, forKey: \"onboarding_completed\")","            completion(.success(()))","        }","    }","}"]}]}],"abstract":[{"type":"text","text":"Registers the device for push notifications with initial tags and a completion handler."}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswith:completion:"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"navigatorTitle":[{"kind":"identifier","text":"registerForPushNotificationsWith:completion:"}],"role":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"registerForPushNotificationsWith:completion:","kind":"identifier"}],"title":"registerForPushNotificationsWith:completion:","modules":[{"name":"PushwooshCore"}],"symbolKind":"method","roleHeading":"Type Method","externalID":"c:objc(pl)PWConfiguration(cm)registerForPushNotificationsWith:completion:"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerForPushNotificationsWith:completion:":{"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"registerForPushNotificationsWith:completion:"}],"role":"symbol","type":"topic","url":"\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswith:completion:","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"registerForPushNotificationsWith:completion:"}],"title":"registerForPushNotificationsWith:completion:","abstract":[{"text":"Registers the device for push notifications with initial tags and a completion handler.","type":"text"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotifica