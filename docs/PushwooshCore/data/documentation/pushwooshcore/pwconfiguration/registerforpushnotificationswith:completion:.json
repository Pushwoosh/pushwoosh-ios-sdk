{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)registerForPushNotificationsWith:completion:","role":"symbol","navigatorTitle":[{"text":"registerForPushNotificationsWith:completion:","kind":"identifier"}],"roleHeading":"Type Method","title":"registerForPushNotificationsWith:completion:","modules":[{"name":"PushwooshCore"}],"symbolKind":"method","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"registerForPushNotificationsWith:completion:"}]},"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"registerForPushNotificationsWith:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"NSDictionary","preciseIdentifier":"c:objc(cs)NSDictionary"},{"text":" *) ","kind":"text"},{"text":"tags","kind":"internalParam"},{"kind":"text","text":" "},{"kind":"identifier","text":"completion:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"void (^)(NSString *, NSError *)","preciseIdentifier":"c:BFv(#*$objc(cs)NSString#*$objc(cs)NSError)"},{"text":") ","kind":"text"},{"text":"completion","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"parameters":[{"name":"tags","content":[{"type":"paragraph","inlineContent":[{"text":"Dictionary of tag names and values to set during registration.","type":"text"},{"type":"text","text":" "},{"text":"Supported value types: NSString, NSNumber, NSArray (for list tags).","type":"text"}]}]},{"name":"completion","content":[{"inlineContent":[{"text":"Block called when registration completes.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Provides the push token on success, or an error on failure."}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The most comprehensive registration method that combines:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"System push permission request","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Pushwoosh server registration"}]}]},{"content":[{"inlineContent":[{"text":"Initial tag assignment","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Completion callback for status handling","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is ideal for onboarding flows where you need to track registration success"},{"text":" ","type":"text"},{"type":"text","text":"and have user data available to set as tags."}]},{"type":"heading","text":"Example","level":2,"anchor":"Example"},{"inlineContent":[{"type":"text","text":"Complete onboarding registration with error handling and analytics:"}],"type":"paragraph"},{"syntax":"swift","code":["class OnboardingManager {","","    func completeOnboarding(preferences: UserPreferences,","                           completion: @escaping (Result<Void, Error>) -> Void) {","","        let onboardingTags: [String: Any] = [","            \"onboarding_completed\": true,","            \"notification_preferences\": preferences.categories.map { $0.rawValue },","            \"preferred_time\": preferences.preferredNotificationTime,","            \"timezone\": TimeZone.current.identifier,","            \"device_language\": Locale.current.languageCode ?? \"en\"","        ]","","        Pushwoosh.configure.registerForPushNotifications(with: onboardingTags) { token, error in","            if let error = error {","                Analytics.track(\"onboarding_push_failed\", properties: [","                    \"error_code\": (error as NSError).code,","                    \"error_domain\": (error as NSError).domain","                ])","                completion(.failure(error))","                return","            }","","            let pushEnabled = token != nil","            Analytics.track(\"onboarding_completed\", properties: [","                \"push_enabled\": pushEnabled,","                \"categories_count\": preferences.categories.count","            ])","","            UserDefaults.standard.set(true, forKey: \"onboarding_completed\")","            completion(.success(()))","        }","    }","}"],"type":"codeListing"}]}],"sections":[],"abstract":[{"type":"text","text":"Registers the device for push notifications with initial tags and a completion handler."}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWith:completion:","interfaceLanguage":"occ"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswith:completion:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerForPushNotificationsWith:completion:":{"title":"registerForPushNotificationsWith:completion:","kind":"symbol","abstract":[{"type":"text","text":"Registers the device for push notifications with initial tags and a completion handler."}],"role":"symbol","navigatorTitle":[{"text":"registerForPushNotificationsWith:completion:","kind":"identifier"}],"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"registerForPushNotificationsWith:completion:"}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWith:completion:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotifica