dNotificationTime,","            \"timezone\": TimeZone.current.identifier,","            \"device_language\": Locale.current.languageCode ?? \"en\"","        ]","","        Pushwoosh.configure.registerForPushNotifications(with: onboardingTags) { token, error in","            if let error = error {","                Analytics.track(\"onboarding_push_failed\", properties: [","                    \"error_code\": (error as NSError).code,","                    \"error_domain\": (error as NSError).domain","                ])","                completion(.failure(error))","                return","            }","","            let pushEnabled = token != nil","            Analytics.track(\"onboarding_completed\", properties: [","                \"push_enabled\": pushEnabled,","                \"categories_count\": preferences.categories.count","            ])","","            UserDefaults.standard.set(true, forKey: \"onboarding_completed\")","            completion(.success(()))","        }","    }","}"],"type":"codeListing"}],"kind":"content"}],"sections":[],"abstract":[{"text":"Registers the device for push notifications with initial tags and a completion handler.","type":"text"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerForPushNotificationsWith:completion:":{"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"registerForPushNotificationsWith:completion:"}],"type":"topic","url":"\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswith:completion:","abstract":[{"text":"Registers the device for push notifications with initial tags and a completion handler.","type":"text"}],"role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWith:completion:","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"registerForPushNotificationsWith:completion:"}],"title":"registerForPushNotificationsWith:completion:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","title":"PushwooshCore","role":"collection","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"kind":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","title":"PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"role":"symbol","abstract":[]}}}