{"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"roleHeading":"Type Method","role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)registerForPushNotificationsWith:completion:","modules":[{"name":"PushwooshCore"}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"registerForPushNotificationsWith:completion:"}],"symbolKind":"method","title":"registerForPushNotificationsWith:completion:","navigatorTitle":[{"text":"registerForPushNotificationsWith:completion:","kind":"identifier"}]},"kind":"symbol","variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswith:completion:"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWith:completion:","interfaceLanguage":"occ"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"registerForPushNotificationsWith:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSDictionary","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSDictionary"},{"text":" *) ","kind":"text"},{"text":"tags","kind":"internalParam"},{"kind":"text","text":" "},{"kind":"identifier","text":"completion:"},{"text":"(","kind":"text"},{"text":"void (^)(NSString *, NSError *)","kind":"typeIdentifier","preciseIdentifier":"c:BFv(#*$objc(cs)NSString#*$objc(cs)NSError)"},{"text":") ","kind":"text"},{"kind":"internalParam","text":"completion"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"name":"tags","content":[{"inlineContent":[{"type":"text","text":"Dictionary of tag names and values to set during registration."},{"type":"text","text":" "},{"type":"text","text":"Supported value types: NSString, NSNumber, NSArray (for list tags)."}],"type":"paragraph"}]},{"name":"completion","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Block called when registration completes."},{"type":"text","text":" "},{"type":"text","text":"Provides the push token on success, or an error on failure."}]}]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"The most comprehensive registration method that combines:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"System push permission request"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Pushwoosh server registration"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Initial tag assignment","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Completion callback for status handling"}]}]}]},{"inlineContent":[{"text":"This is ideal for onboarding flows where you need to track registration success","type":"text"},{"text":" ","type":"text"},{"text":"and have user data available to set as tags.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Example","level":2,"anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Complete onboarding registration with error handling and analytics:"}]},{"code":["class OnboardingManager {","","    func completeOnboarding(preferences: UserPreferences,","                           completion: @escaping (Result<Void, Error>) -> Void) {","","        let onboardingTags: [String: Any] = [","            \"onboarding_completed\": true,","            \"notification_preferences\": preferences.categories.map { $0.rawValue },","            \"preferred_time\": preferences.preferredNotificationTime,","            \"timezone\": TimeZone.current.identifier,","            \"device_language\": Locale.current.languageCode ?? \"en\"","        ]","","        Pushwoosh.configure.registerForPushNotifications(with: onboardingTags) { token, error in","            if let error = error {","                Analytics.track(\"onboarding_push_failed\", properties: [","                    \"error_code\": (error as NSError).code,","                    \"error_domain\": (error as NSError).domain","                ])","                completion(.failure(error))","                return","            }","","            let pushEnabled = token != nil","            Analytics.track(\"onboarding_completed\", properties: [","                \"push_enabled\": pushEnabled,","                \"categories_count\": preferences.categories.count","            ])","","            UserDefaults.standard.set(true, forKey: \"onboarding_completed\")","            completion(.success(()))","        }","    }","}"],"syntax":"swift","type":"codeListing"}]}],"abstract":[{"type":"text","text":"Registers the device for push notifications with initial tags and a completion handler."}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","url":"\/documentation\/pushwooshcore","kind":"symbol","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"role":"collection"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","type":"topic","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerForPushNotificationsWith:completion:":{"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"registerForPushNotificationsWith:completion:"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWith:completion:","navigatorTitle":[{"kind":"identifier","text":"registerForPushNotificationsWith:completion:"}],"type":"topic","url":"\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswith:completion:","title":"registerForPushNotificationsWith:completion:","kind":"symbol","role":"symbol","abstract":[{"text":"Registers the device for push notifications with initial tags and a completion handler.","type":"text"}]}}}