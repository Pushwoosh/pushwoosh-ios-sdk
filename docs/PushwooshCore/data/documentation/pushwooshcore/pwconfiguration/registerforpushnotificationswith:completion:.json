"            \"timezone\": TimeZone.current.identifier,","            \"device_language\": Locale.current.languageCode ?? \"en\"","        ]","","        Pushwoosh.configure.registerForPushNotifications(with: onboardingTags) { token, error in","            if let error = error {","                Analytics.track(\"onboarding_push_failed\", properties: [","                    \"error_code\": (error as NSError).code,","                    \"error_domain\": (error as NSError).domain","                ])","                completion(.failure(error))","                return","            }","","            let pushEnabled = token != nil","            Analytics.track(\"onboarding_completed\", properties: [","                \"push_enabled\": pushEnabled,","                \"categories_count\": preferences.categories.count","            ])","","            UserDefaults.standard.set(true, forKey: \"onboarding_completed\")","            completion(.success(()))","        }","    }","}"],"syntax":"swift","type":"codeListing"}]}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswith:completion:"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerForPushNotificationsWith:completion:":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWith:completion:","abstract":[{"text":"Registers the device for push notifications with initial tags and a completion handler.","type":"text"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswith:completion:","fragments":[{"kind":"text","text":"+ "},{"text":"registerForPushNotificationsWith:completion:","kind":"identifier"}],"navigatorTitle":[{"text":"registerForPushNotificationsWith:completion:","kind":"identifier"}],"title":"registerForPushNotificationsWith:compl