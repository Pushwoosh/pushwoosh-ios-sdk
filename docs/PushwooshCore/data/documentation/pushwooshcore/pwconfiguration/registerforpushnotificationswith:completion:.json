{"abstract":[{"type":"text","text":"Registers the device for push notifications with initial tags and a completion handler."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"text":"registerForPushNotificationsWith:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSDictionary","preciseIdentifier":"c:objc(cs)NSDictionary","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"tags"},{"kind":"text","text":" "},{"text":"completion:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:BFv(#*$objc(cs)NSString#*$objc(cs)NSError)","kind":"typeIdentifier","text":"void (^)(NSString *, NSError *)"},{"text":") ","kind":"text"},{"kind":"internalParam","text":"completion"},{"kind":"text","text":";"}],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"name":"tags","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Dictionary of tag names and values to set during registration."},{"text":" ","type":"text"},{"text":"Supported value types: NSString, NSNumber, NSArray (for list tags).","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Block called when registration completes."},{"text":" ","type":"text"},{"text":"Provides the push token on success, or an error on failure.","type":"text"}],"type":"paragraph"}],"name":"completion"}]},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"The most comprehensive registration method that combines:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"System push permission request"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Pushwoosh server registration"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Initial tag assignment"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Completion callback for status handling"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"This is ideal for onboarding flows where you need to track registration success","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and have user data available to set as tags."}]},{"anchor":"Example","text":"Example","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Complete onboarding registration with error handling and analytics:"}]},{"code":["class OnboardingManager {","","    func completeOnboarding(preferences: UserPreferences,","                           completion: @escaping (Result<Void, Error>) -> Void) {","","        let onboardingTags: [String: Any] = [","            \"onboarding_completed\": true,","            \"notification_preferences\": preferences.categories.map { $0.rawValue },","            \"preferred_time\": preferences.preferredNotificationTime,","            \"timezone\": TimeZone.current.identifier,","            \"device_language\": Locale.current.languageCode ?? \"en\"","        ]","","        Pushwoosh.configure.registerForPushNotifications(with: onboardingTags) { token, error in","            if let error = error {","                Analytics.track(\"onboarding_push_failed\", properties: [","                    \"error_code\": (error as NSError).code,","                    \"error_domain\": (error as NSError).domain","                ])","                completion(.failure(error))","                return","            }","","            let pushEnabled = token != nil","            Analytics.track(\"onboarding_completed\", properties: [","                \"push_enabled\": pushEnabled,","                \"categories_count\": preferences.categories.count","            ])","","            UserDefaults.standard.set(true, forKey: \"onboarding_completed\")","            completion(.success(()))","        }","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)registerForPushNotificationsWith:completion:","title":"registerForPushNotificationsWith:completion:","role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"registerForPushNotificationsWith:completion:","kind":"identifier"}],"symbolKind":"method","roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"text":"registerForPushNotificationsWith:completion:","kind":"identifier"}]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWith:completion:","interfaceLanguage":"occ"},"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswith:completion:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerForPushNotificationsWith:completion:":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWith:completion:","abstract":[{"type":"text","text":"Registers the device for push notifications with initial tags and a completion handler."}],"title":"registerForPushNotificationsWith:completion:","role":"symbol","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"registerForPushNotificationsWith:completion:"}],"kind":"symbol","type":"topic","url":"\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswith:completion:","navigatorTitle":[{"text":"registerForPushNotificationsWith:completion:"