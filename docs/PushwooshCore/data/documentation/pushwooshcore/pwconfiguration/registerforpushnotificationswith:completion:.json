{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"Registers the device for push notifications with initial tags and a completion handler.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":") ","kind":"text"},{"text":"registerForPushNotificationsWith:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSDictionary","preciseIdentifier":"c:objc(cs)NSDictionary","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"tags","kind":"internalParam"},{"kind":"text","text":" "},{"text":"completion:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"void (^)(NSString *, NSError *)","kind":"typeIdentifier","preciseIdentifier":"c:BFv(#*$objc(cs)NSString#*$objc(cs)NSError)"},{"kind":"text","text":") "},{"text":"completion","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"]}],"kind":"declarations"},{"parameters":[{"name":"tags","content":[{"type":"paragraph","inlineContent":[{"text":"Dictionary of tag names and values to set during registration.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Supported value types: NSString, NSNumber, NSArray (for list tags)."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Block called when registration completes."},{"type":"text","text":" "},{"text":"Provides the push token on success, or an error on failure.","type":"text"}]}],"name":"completion"}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"text":"The most comprehensive registration method that combines:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"System push permission request"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Pushwoosh server registration","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Initial tag assignment"}]}]},{"content":[{"inlineContent":[{"text":"Completion callback for status handling","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"This is ideal for onboarding flows where you need to track registration success","type":"text"},{"text":" ","type":"text"},{"text":"and have user data available to set as tags.","type":"text"}]},{"level":2,"type":"heading","text":"Example","anchor":"Example"},{"inlineContent":[{"type":"text","text":"Complete onboarding registration with error handling and analytics:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class OnboardingManager {","","    func completeOnboarding(preferences: UserPreferences,","                           completion: @escaping (Result<Void, Error>) -> Void) {","","        let onboardingTags: [String: Any] = [","            \"onboarding_completed\": true,","            \"notification_preferences\": preferences.categories.map { $0.rawValue },","            \"preferred_time\": preferences.preferredNotificationTime,","            \"timezone\": TimeZone.current.identifier,","            \"device_language\": Locale.current.languageCode ?? \"en\"","        ]","","        Pushwoosh.configure.registerForPushNotifications(with: onboardingTags) { token, error in","            if let error = error {","                Analytics.track(\"onboarding_push_failed\", properties: [","                    \"error_code\": (error as NSError).code,","                    \"error_domain\": (error as NSError).domain","                ])","                completion(.failure(error))","                return","            }","","            let pushEnabled = token != nil","            Analytics.track(\"onboarding_completed\", properties: [","                \"push_enabled\": pushEnabled,","                \"categories_count\": preferences.categories.count","            ])","","            UserDefaults.standard.set(true, forKey: \"onboarding_completed\")","            completion(.success(()))","        }","    }","}"]}]}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswith:completion:"]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWith:completion:"},"metadata":{"roleHeading":"Type Method","role":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"registerForPushNotificationsWith:completion:","kind":"identifier"}],"symbolKind":"method","navigatorTitle":[{"kind":"identifier","text":"registerForPushNotificationsWith:completion:"}],"externalID":"c:objc(pl)PWConfiguration(cm)registerForPushNotificationsWith:completion:","title":"registerForPushNotificationsWith:completion:","modules":[{"name":"PushwooshCore"}]},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore","type":"topic","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","kind":"symbol","type":"topic","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"abstract":[],"role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PW