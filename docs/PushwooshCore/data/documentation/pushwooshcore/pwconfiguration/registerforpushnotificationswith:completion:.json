ng_completed\", properties: [","                \"push_enabled\": pushEnabled,","                \"categories_count\": preferences.categories.count","            ])","","            UserDefaults.standard.set(true, forKey: \"onboarding_completed\")","            completion(.success(()))","        }","    }","}"],"type":"codeListing","syntax":"swift"}]}],"kind":"symbol","variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswith:completion:"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"registerForPushNotificationsWith:completion:"}],"navigatorTitle":[{"text":"registerForPushNotificationsWith:completion:","kind":"identifier"}],"symbolKind":"method","roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}],"role":"symbol","title":"registerForPushNotificationsWith:completion:","externalID":"c:objc(pl)PWConfiguration(cm)registerForPushNotificationsWith:completion:"},"sections":[],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWith:completion:"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerForPushNotificationsWith:completion:":{"type":"topic","navigatorTitle":[{"text":"registerForPushNotificationsWith:completion:","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWith:completion:","abstract":[{"type":"text","text":"Registers the device for push notifications with initial tags and a completion handler."}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswith:completion:","title":"registerForPushNotificationsWith:completion:","role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"registerForPushNotificati