"type":"text"},{"type":"text","text":" "},{"type":"text","text":"Supported value types: NSString, NSNumber, NSArray (for list tags)."}]}]},{"name":"completion","content":[{"type":"paragraph","inlineContent":[{"text":"Block called when registration completes.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Provides the push token on success, or an error on failure."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"The most comprehensive registration method that combines:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"System push permission request","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Pushwoosh server registration","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Initial tag assignment","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Completion callback for status handling"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"This is ideal for onboarding flows where you need to track registration success","type":"text"},{"text":" ","type":"text"},{"text":"and have user data available to set as tags.","type":"text"}]},{"text":"Example","anchor":"Example","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Complete onboarding registration with error handling and analytics:"}]},{"type":"codeListing","syntax":"swift","code":["class OnboardingManager {","","    func completeOnboarding(preferences: UserPreferences,","                           completion: @escaping (Result<Void, Error>) -> Void) {","","        let onboardingTags: [String: Any] = [","            \"onboarding_completed\": true,","            \"notification_preferences\": preferences.categories.map { $0.rawValue },","            \"preferred_time\": preferences.preferredNotificationTime,","            \"timezone\": TimeZone.current.identifier,","            \"device_language\": Locale.current.languageCode ?? \"en\"","        ]","","        Pushwoosh.configure.registerForPushNotifications(with: onboardingTags) { token, error in","            if let error = error {","                Analytics.track(\"onboarding_push_failed\", properties: [","                    \"error_code\": (error as NSError).code,","                    \"error_domain\": (error as NSError).domain","                ])","                completion(.failure(error))","                return","            }","","            let pushEnabled = token != nil","            Analytics.track(\"onboarding_completed\", properties: [","                \"push_enabled\": pushEnabled,","                \"categories_count\": preferences.categories.count","            ])","","            UserDefaults.standard.set(true, forKey: \"onboarding_completed\")","            completion(.success(()))","        }","    }","}"]}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"Registers the device for push notifications with initial tags and a completion handler."}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerForPushNotificationsWith:completion:":{"kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswith:completion:","abstract":[{"type":"text","text":"Registers the device for push notifications with initial tags and a completion handler."}],"fragments":[{"kind":"text","text":"+ "},{"text":"registerForPushNotificationsWith:completion:","kind":"identifier"}],"role":"symbol","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWith:completion:","navigatorTitle":[{"kind":"identifier","text":"registerForPushNotificationsWith:completion:"}],"title":"registerForPushNotifica