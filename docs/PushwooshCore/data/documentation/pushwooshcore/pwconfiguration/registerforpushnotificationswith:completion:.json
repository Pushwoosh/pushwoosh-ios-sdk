t"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Block called when registration completes."},{"text":" ","type":"text"},{"text":"Provides the push token on success, or an error on failure.","type":"text"}]}],"name":"completion"}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The most comprehensive registration method that combines:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"System push permission request"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Pushwoosh server registration","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Initial tag assignment"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Completion callback for status handling"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is ideal for onboarding flows where you need to track registration success"},{"text":" ","type":"text"},{"type":"text","text":"and have user data available to set as tags."}]},{"text":"Example","type":"heading","anchor":"Example","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Complete onboarding registration with error handling and analytics:"}]},{"code":["class OnboardingManager {","","    func completeOnboarding(preferences: UserPreferences,","                           completion: @escaping (Result<Void, Error>) -> Void) {","","        let onboardingTags: [String: Any] = [","            \"onboarding_completed\": true,","            \"notification_preferences\": preferences.categories.map { $0.rawValue },","            \"preferred_time\": preferences.preferredNotificationTime,","            \"timezone\": TimeZone.current.identifier,","            \"device_language\": Locale.current.languageCode ?? \"en\"","        ]","","        Pushwoosh.configure.registerForPushNotifications(with: onboardingTags) { token, error in","            if let error = error {","                Analytics.track(\"onboarding_push_failed\", properties: [","                    \"error_code\": (error as NSError).code,","                    \"error_domain\": (error as NSError).domain","                ])","                completion(.failure(error))","                return","            }","","            let pushEnabled = token != nil","            Analytics.track(\"onboarding_completed\", properties: [","                \"push_enabled\": pushEnabled,","                \"categories_count\": preferences.categories.count","            ])","","            UserDefaults.standard.set(true, forKey: \"onboarding_completed\")","            completion(.success(()))","        }","    }","}"],"type":"codeListing","syntax":"swift"}]}],"abstract":[{"type":"text","text":"Registers the device for push notifications with initial tags and a completion handler."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswith:completion:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"title":"PWConfiguration","type":"topic","role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","kind":"symbol","role":"collection","title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerForPushNotificationsWith:completion:":{"title":"registerForPushNotificationsWith:completion:","kind":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"registerForPushNotificationsWith:completion:","kind":"identifier"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWith:completion:","role":"symbol","type":"topic","abstract":[{"type":"text","text":"Registers the device for push notifications with initial tags and a completion handler."}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswith:completion:","navigatorTitle":[{"kind":"identifier","text":"registerForPushNotificationsWith:completion:"}]}}}