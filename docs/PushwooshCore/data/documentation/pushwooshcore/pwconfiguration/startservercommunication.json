{"sections":[],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/startServerCommunication"},"abstract":[{"text":"Enables communication with Pushwoosh servers.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"startServerCommunication","kind":"identifier"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"Starts or resumes communication with Pushwoosh servers. This allows the SDK to send and receive","type":"text"},{"type":"text","text":" "},{"type":"text","text":"data including device registration, tags, push tokens, and analytics."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Call this method after the user has consented to data collection, or to re-enable","type":"text"},{"type":"text","text":" "},{"type":"text","text":"communication after it was previously stopped."}]},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"inlineContent":[{"type":"text","text":"Enable communication after GDPR consent:"}],"type":"paragraph"},{"type":"codeListing","code":["class ConsentManager {","","    func handleUserConsent(accepted: Bool) {","        if accepted {","            \/\/ User accepted data collection","            Pushwoosh.configure.startServerCommunication()","","            \/\/ Register for push after consent","            Pushwoosh.configure.registerForPushNotifications()","","            \/\/ Sync any pending user data","            syncPendingUserData()","","            Logger.info(\"User consented - Pushwoosh communication enabled\")","        } else {","            \/\/ User declined - disable communication","            Pushwoosh.configure.st