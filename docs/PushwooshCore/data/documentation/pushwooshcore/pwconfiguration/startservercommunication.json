epted {","            \/\/ User accepted data collection","            Pushwoosh.configure.startServerCommunication()","","            \/\/ Register for push after consent","            Pushwoosh.configure.registerForPushNotifications()","","            \/\/ Sync any pending user data","            syncPendingUserData()","","            Logger.info(\"User consented - Pushwoosh communication enabled\")","        } else {","            \/\/ User declined - disable communication","            Pushwoosh.configure.stopServerCommunication()","            Logger.info(\"User declined - Pushwoosh communication disabled\")","        }","","        UserDefaults.standard.set(accepted, forKey: \"gdprConsent\")","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"called "},{"code":"stopServerCommunication","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}],"abstract":[{"type":"text","text":"Enables communication with Pushwoosh servers."}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/startservercommunication"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/startServerCommunication":{"title":"startServerCommunication","type":"topic","navigatorTitle":[{"text":"startServerCommunication","kind":"identifier"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/startservercommunication","kind":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"startServerCommunication","kind":"identifier"}],"abstract":[{"text":"Enables communication with Pushwoosh servers.","type":"text"}],"role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/startServerCommunication"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/