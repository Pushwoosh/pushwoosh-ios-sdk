sh after consent","            Pushwoosh.configure.registerForPushNotifications()","","            \/\/ Sync any pending user data","            syncPendingUserData()","","            Logger.info(\"User consented - Pushwoosh communication enabled\")","        } else {","            \/\/ User declined - disable communication","            Pushwoosh.configure.stopServerCommunication()","            Logger.info(\"User declined - Pushwoosh communication disabled\")","        }","","        UserDefaults.standard.set(accepted, forKey: \"gdprConsent\")","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"called "},{"type":"codeVoice","code":"stopServerCommunication"},{"type":"text","text":"."}]}],"kind":"content"}],"metadata":{"roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"kind":"identifier","text":"startServerCommunication"}],"title":"startServerCommunication","role":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"startServerCommunication","kind":"identifier"}],"symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)startServerCommunication"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/startServerCommunication":{"type":"topic","abstract":[{"type":"text","text":"Enables communication with Pushwoosh servers."}],"fragments":[{"kind":"text","text":"+ "},{"text":"startServerCommunication","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"startServerCommunication"}],"title":"startServerCommunication","kind":"symbol","role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/startservercommunication","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/startServerCommunication"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","abstract":[],"fragments":[{"kind":"identifier","text":"PWConfigura