{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":") ","kind":"text"},{"kind":"identifier","text":"startServerCommunication"},{"text":";","kind":"text"}]}]},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Starts or resumes communication with Pushwoosh servers. This allows the SDK to send and receive"},{"type":"text","text":" "},{"type":"text","text":"data including device registration, tags, push tokens, and analytics."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call this method after the user has consented to data collection, or to re-enable"},{"type":"text","text":" "},{"type":"text","text":"communication after it was previously stopped."}]},{"anchor":"Example","level":2,"text":"Example","type":"heading"},{"inlineContent":[{"type":"text","text":"Enable communication after GDPR consent:"}],"type":"paragraph"},{"code":["class ConsentManager {","","    func handleUserConsent(accepted: Bool) {","        if accepted {","            \/\/ User accepted data collection","            Pushwoosh.configure.startServerCommunication()","","            \/\/ Register for push after consent","            Pushwoosh.configure.registerForPushNotifications()","","            \/\/ Sync any pending user data","            syncPendingUserData()","","            Logger.info(\"User consented - Pushwoosh communication enabled\")","        } else {","            \/\/ User declined - disable communication","            Pushwoosh.configure.stopServerCommunication()","            Logger.info(\"User declined - Pushwoosh communication disabled\")","        }","","        UserDefaults.standard.set(accepted, forKey: \"gdprConsent\")","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"called "},{"code":"stopServerCommunication","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"title":"startServerCommunication","externalID":"c:objc(pl)PWConfiguration(cm)startServerCommunication","roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}],"role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"startServerCommunication"}],"symbolKind":"method","navigatorTitle":[{"kind":"identifier","text":"startServerCommunication"}]},"abstract":[{"type":"text","text":"Enables communication with Pushwoosh servers."}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/startServerCommunication"},"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/startservercommunication"]}],"sections":[],"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/startServerCommunication":{"url":"\/documentation\/pushwooshcore\/pwconfiguration\/startservercommunication","title":"startServerCommunication","abstract":[{"text":"Enables communication with Pushwoosh servers.","type":"text"}],"role":"symbol","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"startServerCommunication"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/startServerCommunication","kind":"symbol","type":"topic","navigatorTitle":[{"text":"startServerCommunication","kind":"identifier"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","kind":"symbol","role":"collection","title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"title":"PWConfiguration","type":"topic","role":"symbol"}}}