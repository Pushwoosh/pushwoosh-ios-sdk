{"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"startServerCommunication","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Starts or resumes communication with Pushwoosh servers. This allows the SDK to send and receive","type":"text"},{"type":"text","text":" "},{"type":"text","text":"data including device registration, tags, push tokens, and analytics."}]},{"inlineContent":[{"text":"Call this method after the user has consented to data collection, or to re-enable","type":"text"},{"type":"text","text":" "},{"type":"text","text":"communication after it was previously stopped."}],"type":"paragraph"},{"text":"Example","type":"heading","level":2,"anchor":"Example"},{"inlineContent":[{"type":"text","text":"Enable communication after GDPR consent:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class ConsentManager {","","    func handleUserConsent(accepted: Bool) {","        if accepted {","            \/\/ User accepted data collection","            Pushwoosh.configure.startServerCommunication()","","            \/\/ Register for push after consent","            Pushwoosh.configure.registerForPushNotifications()","","            \/\/ Sync any pending user data","            syncPendingUserData()","","            Logger.info(\"User consented - Pushwoosh communication enabled\")","        } else {","            \/\/ User declined - disable communication","            Pushwoosh.configure.stopServerCommunication()","            Logger.info(\"User declined - Pushwoosh communication disabled\")","        }","","        UserDefaults.standard.set(accepted, forKey: \"gdprConsent\")","    }","}"]},{"inlineContent":[{"text":"called ","type":"text"},{"type":"codeVoice","code":"stopServerCommunication"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"abstract":[{"type":"text","text":"Enables communication with Pushwoosh servers."}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/startservercommunication"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"symbol","metadata":{"modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"text":"startServerCommunication","kind":"identifier"}],"roleHeading":"Type Method","symbolKind":"method","role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)startServerCommunication","title":"startServerCommunication","fragments":[{"text":"+ ","kind":"text"},{"text":"startServerCommunication","kind":"identifier"}]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/startServerCommunication","interfaceLanguage":"occ"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","type":"topic","url":"\/documentation\/pushwooshcore\/pwconfiguration","abstract":[],"role":"symbol","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"title":"PushwooshCore","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/startServer