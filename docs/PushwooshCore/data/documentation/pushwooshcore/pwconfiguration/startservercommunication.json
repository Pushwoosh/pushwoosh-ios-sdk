{"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Enables communication with Pushwoosh servers."}],"sections":[],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/startservercommunication"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/startServerCommunication","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","metadata":{"roleHeading":"Type Method","navigatorTitle":[{"kind":"identifier","text":"startServerCommunication"}],"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"startServerCommunication"}],"externalID":"c:objc(pl)PWConfiguration(cm)startServerCommunication","modules":[{"name":"PushwooshCore"}],"role":"symbol","title":"startServerCommunication","symbolKind":"method"},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"startServerCommunication","kind":"identifier"},{"kind":"text","text":";"}],"languages":["occ"]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Starts or resumes communication with Pushwoosh servers. This allows the SDK to send and receive"},{"type":"text","text":" "},{"type":"text","text":"data including device registration, tags, push tokens, and analytics."}]},{"inlineContent":[{"text":"Call this method after the user has consented to data collection, or to re-enable","type":"text"},{"type":"text","text":" "},{"text":"communication after it was previously stopped.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Example","type":"heading","text":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Enable communication after GDPR consent:"}]},{"code":["class ConsentManager {","","    func handleUserConsent(accepted: Bool) {","        if accepted {","            \/\/ User accepted data collection","            Pushwoosh.configure.startServerCommunication()","","            \/\/ Register for push after consent","            Pushwoosh.configure.registerForPushNotifications()","","            \/\/ Sync any pending user data","            syncPendingUserData()","","            Logger.info(\"User consented - Pushwoosh communication enabled\")","        } else {","            \/\/ User declined - disable communication","            Pushwoosh.configure.stopServerCommunication()","            Logger.info(\"User declined - Pushwoosh communication disabled\")","        }","","        UserDefaults.standard.set(accepted, forKey: \"gdprConsent\")","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"called "},{"code":"stopServerCommunication","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/startServerCommunication":{"navigatorTitle":[{"text":"startServerCommunication","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/startServerCommunication","title":"startServerCommunication","abstract":[{"text":"Enables communication with Pushwoosh servers.","type":"text"}],"kind":"symbol","role":"symbol","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"startServerCommunication"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/startservercommunication"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","title":"PushwooshCore","kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","abstract":[],"kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"title":"PWConfiguration"}}}