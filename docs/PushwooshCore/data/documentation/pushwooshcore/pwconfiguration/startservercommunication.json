{"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"abstract":[{"text":"Enables communication with Pushwoosh servers.","type":"text"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/startServerCommunication"},"metadata":{"title":"startServerCommunication","externalID":"c:objc(pl)PWConfiguration(cm)startServerCommunication","fragments":[{"text":"+ ","kind":"text"},{"text":"startServerCommunication","kind":"identifier"}],"roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}],"role":"symbol","navigatorTitle":[{"text":"startServerCommunication","kind":"identifier"}],"symbolKind":"method"},"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"kind":"text","text":") "},{"text":"startServerCommunication","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Starts or resumes communication with Pushwoosh servers. This allows the SDK to send and receive"},{"type":"text","text":" "},{"type":"text","text":"data including device registration, tags, push tokens, and analytics."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call this method after the user has consented to data collection, or to re-enable"},{"text":" ","type":"text"},{"type":"text","text":"communication after it was previously stopped."}]},{"type":"heading","anchor":"Example","text":"Example","level":2},{"type":"paragraph","inlineContent":[{"text":"Enable communication after GDPR consent:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["class ConsentManager {","","    func handleUserConsent(accepted: Bool) {","        if accepted {","            \/\/ User accepted data collection","            Pushwoosh.configure.startServerCommunication()","","            \/\/ Register for push after consent","            Pushwoosh.configure.registerForPushNotifications()","","            \/\/ Sync any pending user data","            syncPendingUserData()","","            Logger.info(\"User consented - Pushwoosh communication enabled\")","        } else {","            \/\/ User declined - disable communication","            Pushwoosh.configure.stopServerCommunication()","            Logger.info(\"User declined - Pushwoosh communication disabled\")","        }","","        UserDefaults.standard.set(accepted, forKey: \"gdprConsent\")","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"called "},{"type":"codeVoice","code":"stopServerCommunication"},{"type":"text","text":"."}]}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/startservercommunication"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"kind":"symbol","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/startServerCommunication":{"kind":"symbol","role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/startservercommunication","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/startServerCommunication","abstract":[{"text":"Enables communication with Pushwoosh servers.","type":"text"}],"fr