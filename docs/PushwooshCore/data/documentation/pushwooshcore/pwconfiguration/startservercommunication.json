{"abstract":[{"type":"text","text":"Enables communication with Pushwoosh servers."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/startservercommunication"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"startServerCommunication","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}]},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Starts or resumes communication with Pushwoosh servers. This allows the SDK to send and receive"},{"type":"text","text":" "},{"type":"text","text":"data including device registration, tags, push tokens, and analytics."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call this method after the user has consented to data collection, or to re-enable"},{"type":"text","text":" "},{"type":"text","text":"communication after it was previously stopped."}]},{"anchor":"Example","type":"heading","level":2,"text":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Enable communication after GDPR consent:"}]},{"code":["class ConsentManager {","","    func handleUserConsent(accepted: Bool) {","        if accepted {","            \/\/ User accepted data collection","            Pushwoosh.configure.startServerCommunication()","","            \/\/ Register for push after consent","            Pushwoosh.configure.registerForPushNotifications()","","            \/\/ Sync any pending user data","            syncPendingUserData()","","            Logger.info(\"User consented - Pushwoosh communication enabled\")","        } else {","            \/\/ User declined - disable communication","            Pushwoosh.configure.stopServerCommunication()","            Logger.info(\"User declined - Pushwoosh communication disabled\")","        }","","        UserDefaults.standard.set(accepted, forKey: \"gdprConsent\")","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"called "},{"type":"codeVoice","code":"stopServerCommunication"},{"type":"text","text":"."}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/startServerCommunication","interfaceLanguage":"occ"},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"startServerCommunication"}],"symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)startServerCommunication","role":"symbol","modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"kind":"identifier","text":"startServerCommunication"}],"title":"startServerCommunication","roleHeading":"Type Method"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","title":"PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","kind":"symbol","abstract":[],"role":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","type":"topic","kind":"symbol","url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","role":"collection","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/startServer