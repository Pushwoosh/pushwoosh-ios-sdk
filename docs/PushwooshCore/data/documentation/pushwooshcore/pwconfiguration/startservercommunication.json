r data","            syncPendingUserData()","","            Logger.info(\"User consented - Pushwoosh communication enabled\")","        } else {","            \/\/ User declined - disable communication","            Pushwoosh.configure.stopServerCommunication()","            Logger.info(\"User declined - Pushwoosh communication disabled\")","        }","","        UserDefaults.standard.set(accepted, forKey: \"gdprConsent\")","    }","}"]},{"inlineContent":[{"type":"text","text":"called "},{"code":"stopServerCommunication","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]}],"metadata":{"navigatorTitle":[{"text":"startServerCommunication","kind":"identifier"}],"symbolKind":"method","role":"symbol","title":"startServerCommunication","externalID":"c:objc(pl)PWConfiguration(cm)startServerCommunication","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"startServerCommunication"}],"modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"role":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","title":"PWConfiguration","kind":"symbol","type":"topic","abstract":[]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/startServerCommunication":{"navigatorTitle":[{"text":"startServerCommunication","kind":"identifier"}],"role":"symbol","type":"topic","url":"\/documentation\/pushwooshcore\/pwconfiguration\/startservercommunication","abstract":[{"type":"text","text":"Enables communication with Pushwoosh servers."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/do