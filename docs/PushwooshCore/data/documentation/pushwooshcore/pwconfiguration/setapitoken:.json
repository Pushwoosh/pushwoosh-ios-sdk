ations or perform"},{"text":" ","type":"text"},{"text":"other API operations on behalf of the app.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"be decompiled or intercepted.","type":"text"}]},{"type":"heading","text":"Example","level":2,"anchor":"Example"},{"inlineContent":[{"type":"text","text":"Configure API token for server-side operations:"}],"type":"paragraph"},{"code":["class ServerIntegration {","","    func configureForServerSidePush(apiToken: String) {","        \/\/ Set API token for server communication","        Pushwoosh.configure.setApiToken(apiToken)","","        \/\/ Now the app can make authenticated API calls","        sendTestNotification()","    }","","    private func sendTestNotification() {","        \/\/ Server-side push sending using the API token","        let hwid = Pushwoosh.configure.getHWID()","        PushwooshAPI.sendPush(to: hwid, message: \"Test notification\")","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"your app, while the API Token authenticates API requests.","type":"text"}]}],"kind":"content"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setApiToken:":{"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setapitoken:","role":"symbol","abstract":[{"type":"text","text":"Sets the Pushwoosh API Token for server-to-server communication."}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setApiToken:","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setApiToken:"}],"type":"topic","navigatorTitle":[{"text":"setApiToken:","kind":"identifier"}],"title":"setApiToken:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","title":