{"kind":"symbol","abstract":[{"type":"text","text":"Registers a WhatsApp number for WhatsApp Business messaging."}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerWhatsappNumber:","interfaceLanguage":"occ"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"kind":"text","text":") "},{"kind":"identifier","text":"registerWhatsappNumber:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"NSString","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"text":"number","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}]},{"parameters":[{"name":"number","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The phone number in E.164 international format."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Associates a WhatsApp number with the current device for WhatsApp Business API","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"messaging campaigns. This enables rich messaging with images, documents, and"},{"type":"text","text":" "},{"type":"text","text":"interactive buttons through WhatsApp."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The phone number must be in E.164 international format:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Start with ‘+’ followed by country code"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"No spaces, dashes, or parentheses"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Must be a valid WhatsApp-enabled number"}],"type":"paragraph"}]}]},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"inlineContent":[{"type":"text","text":"Register WhatsApp during communication preferences setup:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class CommunicationPreferencesManager {","","    struct Preferences {","        var pushEnabled: Bool","        var smsEnabled: Bool","        var whatsappEnabled: Bool","        var whatsappNumber: String?","    }","","    func savePreferences(_ preferences: Preferences) {","        \/\/ Register WhatsApp if user opted in and provided number","        if preferences.whatsappEnabled, let number = preferences.whatsappNumber {","            let normalizedNumber = normalizePhoneNumber(number)","            Pushwoosh.configure.registerWhatsappNumber(normalizedNumber)","        }","","        \/\/ Update channel preferences tags","        Pushwoosh.configure.setTags([","            \"channel_push\": preferences.pushEnabled,","            \"channel_sms\": preferences.smsEnabled,","            \"channel_whatsapp\": preferences.whatsappEnabled","        ])","    }","","    private func normalizePhoneNumber(_ phone: String) -> String {","        let digits = phone.filter { $0.isNumber }","        return phone.hasPrefix(\"+\") ? \"+\\(digits)\" : \"+\\(digits)\"","    }","}"]}]}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerwhatsappnumber:"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"title":"registerWhatsappNumber:","modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)registerWhatsappNumber:","fragments":[{"kind":"text","text":"+ "},{"text":"registerWhatsappNumber:","kind":"identifier"}],"role":"symbol","symbolKind":"method","navigatorTitle":[{"text":"registerWhatsappNumber:","kind":"identifier"}],"roleHeading":"Type Method"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerWhatsappNumber:":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerWhatsappNumber:","role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"registerWhatsappNumber:","kind":"identifier"}],"type":"topic","abstract":[{"text":"Registers a WhatsApp number for WhatsApp Business messaging.","type":"text"}],"kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/registerwhatsappnumber:","navigatorTitle":[{"kind":"identifier","text":"registerWhatsappNumber:"}],"title":"registerWhatsappNumber:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","title":"PushwooshCore","role":"collection","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"kind":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","title":"PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"role":"symbol","abstract":[]}}}