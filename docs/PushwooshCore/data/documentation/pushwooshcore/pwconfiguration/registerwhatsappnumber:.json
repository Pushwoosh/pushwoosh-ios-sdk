{"metadata":{"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"registerWhatsappNumber:"}],"modules":[{"name":"PushwooshCore"}],"role":"symbol","symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)registerWhatsappNumber:","navigatorTitle":[{"text":"registerWhatsappNumber:","kind":"identifier"}],"roleHeading":"Type Method","title":"registerWhatsappNumber:"},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerwhatsappnumber:"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"kind":"identifier","text":"registerWhatsappNumber:"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"NSString","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"text":"number","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"name":"number","content":[{"inlineContent":[{"type":"text","text":"The phone number in E.164 international format."}],"type":"paragraph"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Associates a WhatsApp number with the current device for WhatsApp Business API"},{"text":" ","type":"text"},{"type":"text","text":"messaging campaigns. This enables rich messaging with images, documents, and"},{"text":" ","type":"text"},{"type":"text","text":"interactive buttons through WhatsApp."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The phone number must be in E.164 international format:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Start with ‘+’ followed by country code","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"No spaces, dashes, or parentheses","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Must be a valid WhatsApp-enabled number","type":"text"}]}]}],"type":"unorderedList"},{"text":"Example","level":2,"type":"heading","anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register WhatsApp during communication preferences setup:"}]},{"type":"codeListing","syntax":"swift","code":["class CommunicationPreferencesManager {","","    struct Preferences {","        var pushEnabled: Bool","        var smsEnabled: Bool","        var whatsappEnabled: Bool","        var whatsappNumber: String?","    }","","    func savePreferences(_ preferences: Preferences) {","        \/\/ Register WhatsApp if user opted in and provided number","        if preferences.whatsappEnabled, let number = preferences.whatsappNumber {","            let normalizedNumber = normalizePhoneNumber(number)","            Pushwoosh.configure.registerWhatsappNumber(normalizedNumber)","        }","","        \/\/ Update channel preferences tags","        Pushwoosh.configure.setTags([","            \"channel_push\": preferences.pushEnabled,","            \"channel_sms\": preferences.smsEnabled,","            \"channel_whatsapp\": preferences.whatsappEnabled","        ])","    }","","    private func normalizePhoneNumber(_ phone: String) -> String {","        let digits = phone.filter { $0.isNumber }","        return phone.hasPrefix(\"+\") ? \"+\\(digits)\" : \"+\\(digits)\"","    }","}"]}]}],"abstract":[{"text":"Registers a WhatsApp number for WhatsApp Business messaging.","type":"text"}],"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerWh