{"metadata":{"role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)registerWhatsappNumber:","symbolKind":"method","modules":[{"name":"PushwooshCore"}],"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"registerWhatsappNumber:"}],"navigatorTitle":[{"text":"registerWhatsappNumber:","kind":"identifier"}],"roleHeading":"Type Method","title":"registerWhatsappNumber:"},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerWhatsappNumber:","interfaceLanguage":"occ"},"sections":[],"abstract":[{"text":"Registers a WhatsApp number for WhatsApp Business messaging.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerwhatsappnumber:"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"kind":"identifier","text":"registerWhatsappNumber:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier","text":"NSString"},{"kind":"text","text":" *) "},{"text":"number","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"parameters":[{"content":[{"inlineContent":[{"text":"The phone number in E.164 international format.","type":"text"}],"type":"paragraph"}],"name":"number"}],"kind":"parameters"},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Associates a WhatsApp number with the current device for WhatsApp Business API"},{"type":"text","text":" "},{"text":"messaging campaigns. This enables rich messaging with images, documents, and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"interactive buttons through WhatsApp."}]},{"type":"paragraph","inlineContent":[{"text":"The phone number must be in E.164 international format:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Start with ‘+’ followed by country code"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"No spaces, dashes, or parentheses","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Must be a valid WhatsApp-enabled number","type":"text"}],"type":"paragraph"}]}]},{"anchor":"Example","type":"heading","level":2,"text":"Example"},{"inlineContent":[{"text":"Register WhatsApp during communication preferences setup:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["class CommunicationPreferencesManager {","","    struct Preferences {","        var pushEnabled: Bool","        var smsEnabled: Bool","        var whatsappEnabled: Bool","        var whatsappNumber: String?","    }","","    func savePreferences(_ preferences: Preferences) {","        \/\/ Register WhatsApp if user opted in and provided number","        if preferences.whatsappEnabled, let number = preferences.whatsappNumber {","            let normalizedNumber = normalizePhoneNumber(number)","            Pushwoosh.configure.registerWhatsappNumber(normalizedNumber)","        }","","        \/\/ Update channel preferences tags","        Pushwoosh.configure.setTags([","            \"channel_push\": preferences.pushEnabled,","            \"channel_sms\": preferences.smsEnabled,","            \"channel_whatsapp\": preferences.whatsappEnabled","        ])","    }","","    private func normalizePhoneNumber(_ phone: String) -> String {","        let digits = phone.filter { $0.isNumber }","        return phone.hasPrefix(\"+\") ? \"+\\(digits)\" : \"+\\(digits)\"","    }","}"],"type":"c