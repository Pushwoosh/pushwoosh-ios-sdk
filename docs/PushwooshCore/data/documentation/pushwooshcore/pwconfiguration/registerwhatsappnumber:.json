{"abstract":[{"text":"Registers a WhatsApp number for WhatsApp Business messaging.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerwhatsappnumber:"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"text":"registerWhatsappNumber:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSString","text":"NSString","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"text":"number","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"number","content":[{"inlineContent":[{"text":"The phone number in E.164 international format.","type":"text"}],"type":"paragraph"}]}]},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Associates a WhatsApp number with the current device for WhatsApp Business API","type":"text"},{"text":" ","type":"text"},{"text":"messaging campaigns. This enables rich messaging with images, documents, and","type":"text"},{"type":"text","text":" "},{"text":"interactive buttons through WhatsApp.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The phone number must be in E.164 international format:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Start with ‘+’ followed by country code","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"No spaces, dashes, or parentheses","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Must be a valid WhatsApp-enabled number"}]}]}],"type":"unorderedList"},{"text":"Example","type":"heading","level":2,"anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register WhatsApp during communication preferences setup:"}]},{"type":"codeListing","code":["class CommunicationPreferencesManager {","","    struct Preferences {","        var pushEnabled: Bool","        var smsEnabled: Bool","        var whatsappEnabled: Bool","        var whatsappNumber: String?","    }","","    func savePreferences(_ preferences: Preferences) {","        \/\/ Register WhatsApp if user opted in and provided number","        if preferences.whatsappEnabled, let number = preferences.whatsappNumber {","            let normalizedNumber = normalizePhoneNumber(number)","            Pushwoosh.configure.registerWhatsappNumber(normalizedNumber)","        }","","        \/\/ Update channel preferences tags","        Pushwoosh.configure.setTags([","            \"channel_push\": preferences.pushEnabled,","            \"channel_sms\": preferences.smsEnabled,","            \"channel_whatsapp\": preferences.whatsappEnabled","        ])","    }","","    private func normalizePhoneNumber(_ phone: String) -> String {","        let digits = phone.filter { $0.isNumber }","        return phone.hasPrefix(\"+\") ? \"+\\(digits)\" : \"+\\(digits)\"","    }","}"],"syntax":"swift"}],"kind":"content"}],"sections":[],"metadata":{"symbolKind":"method","roleHeading":"Type Method","role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)registerWhatsappNumber:","modules":[{"name":"PushwooshCore"}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"registerWhatsappNumber:"}],"navigatorTitle":[{"text":"registerWhatsappNumber:","kind":"identifier"}],"title":"registerWhatsappNumber:"},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerWhatsappNumber:"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"fragments":[{"text":"PWConfiguration","kind":"identifier"}],"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","title":"PWConfiguration","kind":"symbol","type":"topic","role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","role":"collection","kind":"symbol","title":"PushwooshCore","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","url":"\/documentation\/pushwooshcore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerWhatsappNumber:":{"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"registerWhatsappNumber:"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerWhatsappNumber:","abstract":[{"text":"Registers a WhatsApp number for WhatsApp Business messaging.","type":"text"}],"role":"symbol","title":"registerWhatsappNumber:","navigatorTitle":[{"text":"registerWhatsappNumber:","kind":"identifier"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/registerwhatsappnumber:","type":"topic","kind":"symbol"}}}