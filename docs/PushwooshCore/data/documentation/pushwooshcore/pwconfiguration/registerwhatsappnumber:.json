{"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"registerWhatsappNumber:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSString","preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"text":"number","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"parameters":[{"content":[{"inlineContent":[{"text":"The phone number in E.164 international format.","type":"text"}],"type":"paragraph"}],"name":"number"}],"kind":"parameters"},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Associates a WhatsApp number with the current device for WhatsApp Business API"},{"text":" ","type":"text"},{"type":"text","text":"messaging campaigns. This enables rich messaging with images, documents, and"},{"type":"text","text":" "},{"text":"interactive buttons through WhatsApp.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The phone number must be in E.164 international format:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Start with ‘+’ followed by country code","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"No spaces, dashes, or parentheses"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Must be a valid WhatsApp-enabled number"}],"type":"paragraph"}]}]},{"text":"Example","level":2,"anchor":"Example","type":"heading"},{"inlineContent":[{"type":"text","text":"Register WhatsApp during communication preferences setup:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class CommunicationPreferencesManager {","","    struct Preferences {","        var pushEnabled: Bool","        var smsEnabled: Bool","        var whatsappEnabled: Bool","        var whatsappNumber: String?","    }","","    func savePreferences(_ preferences: Preferences) {","        \/\/ Register WhatsApp if user opted in and provided number","        if preferences.whatsappEnabled, let number = preferences.whatsappNumber {","            let normalizedNumber = normalizePhoneNumber(number)","            Pushwoosh.configure.registerWhatsappNumber(normalizedNumber)","        }","","        \/\/ Update channel preferences tags","        Pushwoosh.configure.setTags([","            \"channel_push\": preferences.pushEnabled,","            \"channel_sms\": preferences.smsEnabled,","            \"channel_whatsapp\": preferences.whatsappEnabled","        ])","    }","","    private func normalizePhoneNumber(_ phone: String) -> String {","        let digits = phone.filter { $0.isNumber }","        return phone.hasPrefix(\"+\") ? \"+\\(digits)\" : \"+\\(digits)\"","    }","}"]}],"kind":"content"}],"kind":"symbol","abstract":[{"text":"Registers a WhatsApp number for WhatsApp Business messaging.","type":"text"}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerwhatsappnumber:"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"metadata":{"title":"registerWhatsappNumber:","role":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"registerWhatsappNumber:","kind":"identifier"}],"navigatorTitle":[{"text":"registerWhatsappNumber:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"symbolKind":"method","roleHeading":"Type Method","externalID":"c:objc(pl)PWConfiguration(cm)registerWhatsappNumber:"},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerWhatsappNumber:","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","role":"collection","title":"PushwooshCore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"abstract":[],"title":"PWConfiguration","role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerWhatsappNumber:":{"fragments":[{"kind":"text","text":"+ "},{"text":"registerWhatsappNumber:","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"registerWhatsappNumber:"}],"kind":"symbol","title":"registerWhatsappNumber:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/registerwhatsappnumber:","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerWhatsappNumber:","abstract":[{"text":"Registers a WhatsApp number for WhatsApp Business messaging.","type":"text"}]}}}