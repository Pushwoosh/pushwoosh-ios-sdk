{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerWhatsappNumber:","interfaceLanguage":"occ"},"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"text":"registerWhatsappNumber:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier","text":"NSString"},{"text":" *) ","kind":"text"},{"text":"number","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"name":"number","content":[{"type":"paragraph","inlineContent":[{"text":"The phone number in E.164 international format.","type":"text"}]}]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"text":"Associates a WhatsApp number with the current device for WhatsApp Business API","type":"text"},{"type":"text","text":" "},{"type":"text","text":"messaging campaigns. This enables rich messaging with images, documents, and"},{"type":"text","text":" "},{"text":"interactive buttons through WhatsApp.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The phone number must be in E.164 international format:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Start with ‘+’ followed by country code"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"No spaces, dashes, or parentheses"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Must be a valid WhatsApp-enabled number"}]}]}]},{"level":2,"text":"Example","type":"heading","anchor":"Example"},{"inlineContent":[{"text":"Register WhatsApp during communication preferences setup:","type":"text"}],"type":"paragraph"},{"code":["class CommunicationPreferencesManager {","","    struct Preferences {","        var pushEnabled: Bool","        var smsEnabled: Bool","        var whatsappEnabled: Bool","        var whatsappNumber: String?","    }","","    func savePreferences(_ preferences: Preferences) {","        \/\/ Register WhatsApp if user opted in and provided number","        if preferences.whatsappEnabled, let number = preferences.whatsappNumber {","            let normalizedNumber = normalizePhoneNumber(number)","            Pushwoosh.configure.registerWhatsappNumber(normalizedNumber)","        }","","        \/\/ Update channel preferences tags","        Pushwoosh.configure.setTags([","            \"channel_push\": preferences.pushEnabled,","            \"channel_sms\": preferences.smsEnabled,","            \"channel_whatsapp\": preferences.whatsappEnabled","        ])","    }","","    private func normalizePhoneNumber(_ phone: String) -> String {","        let digits = phone.filter { $0.isNumber }","        return phone.hasPrefix(\"+\") ? \"+\\(digits)\" : \"+\\(digits)\"","    }","}"],"syntax":"swift","type":"codeListing"}]}],"abstract":[{"text":"Registers a WhatsApp number for WhatsApp Business messaging.","type":"text"}],"sections":[],"metadata":{"roleHeading":"Type Method","fragments":[{"text":"+ ","kind":"text"},{"text":"registerWhatsappNumber:","kind":"identifier"}],"navigatorTitle":[{"text":"registerWhatsappNumber:","kind":"identifier"}],"symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)registerWhatsappNumber:","modules":[{"name":"PushwooshCore"}],"title":"registerWhatsappNumber:","role":"symbol"},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerwhatsappnumber:"],"traits":[{"interfaceLang