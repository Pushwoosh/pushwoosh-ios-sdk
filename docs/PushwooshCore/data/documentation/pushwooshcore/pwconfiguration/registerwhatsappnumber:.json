{"abstract":[{"text":"Registers a WhatsApp number for WhatsApp Business messaging.","type":"text"}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerWhatsappNumber:","interfaceLanguage":"occ"},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerwhatsappnumber:"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"registerWhatsappNumber:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"text":"number","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"The phone number in E.164 international format.","type":"text"}],"type":"paragraph"}],"name":"number"}]},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Associates a WhatsApp number with the current device for WhatsApp Business API"},{"text":" ","type":"text"},{"type":"text","text":"messaging campaigns. This enables rich messaging with images, documents, and"},{"text":" ","type":"text"},{"type":"text","text":"interactive buttons through WhatsApp."}],"type":"paragraph"},{"inlineContent":[{"text":"The phone number must be in E.164 international format:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Start with ‘+’ followed by country code"}]}]},{"content":[{"inlineContent":[{"text":"No spaces, dashes, or parentheses","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Must be a valid WhatsApp-enabled number","type":"text"}]}]}]},{"type":"heading","text":"Example","anchor":"Example","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register WhatsApp during communication preferences setup:"}]},{"code":["class CommunicationPreferencesManager {","","    struct Preferences {","        var pushEnabled: Bool","        var smsEnabled: Bool","        var whatsappEnabled: Bool","        var whatsappNumber: String?","    }","","    func savePreferences(_ preferences: Preferences) {","        \/\/ Register WhatsApp if user opted in and provided number","        if preferences.whatsappEnabled, let number = preferences.whatsappNumber {","            let normalizedNumber = normalizePhoneNumber(number)","            Pushwoosh.configure.registerWhatsappNumber(normalizedNumber)","        }","","        \/\/ Update channel preferences tags","        Pushwoosh.configure.setTags([","            \"channel_push\": preferences.pushEnabled,","            \"channel_sms\": preferences.smsEnabled,","            \"channel_whatsapp\": preferences.whatsappEnabled","        ])","    }","","    private func normalizePhoneNumber(_ phone: String) -> String {","        let digits = phone.filter { $0.isNumber }","        return phone.hasPrefix(\"+\") ? \"+\\(digits)\" : \"+\\(digits)\"","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"sections":[],"metadata":{"navigatorTitle":[{"text":"registerWhatsappNumber:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"symbolKind":"method","roleHeading":"Type Method","externalID":"c:objc(pl)PWConfiguration(cm)registerWhatsappNumber:","title":"registerWhatsappNumber:","role":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"registerWhatsappNumber:","kind":"identifier"}]},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWCo