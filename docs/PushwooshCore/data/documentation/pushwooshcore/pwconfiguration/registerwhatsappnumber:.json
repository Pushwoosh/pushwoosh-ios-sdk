{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerWhatsappNumber:","interfaceLanguage":"occ"},"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"registerWhatsappNumber:","kind":"identifier"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString","text":"NSString"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"number"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"parameters":[{"name":"number","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The phone number in E.164 international format."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"Associates a WhatsApp number with the current device for WhatsApp Business API","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"messaging campaigns. This enables rich messaging with images, documents, and"},{"text":" ","type":"text"},{"type":"text","text":"interactive buttons through WhatsApp."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The phone number must be in E.164 international format:"}]},{"items":[{"content":[{"inlineContent":[{"text":"Start with ‘+’ followed by country code","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"No spaces, dashes, or parentheses","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Must be a valid WhatsApp-enabled number"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"text":"Example","anchor":"Example","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register WhatsApp during communication preferences setup:"}]},{"type":"codeListing","syntax":"swift","code":["class CommunicationPreferencesManager {","","    struct Preferences {","        var pushEnabled: Bool","        var smsEnabled: Bool","        var whatsappEnabled: Bool","        var whatsappNumber: String?","    }","","    func savePreferences(_ preferences: Preferences) {","        \/\/ Register WhatsApp if user opted in and provided number","        if preferences.whatsappEnabled, let number = preferences.whatsappNumber {","            let normalizedNumber = normalizePhoneNumber(number)","            Pushwoosh.configure.registerWhatsappNumber(normalizedNumber)","        }","","        \/\/ Update channel preferences tags","        Pushwoosh.configure.setTags([","            \"channel_push\": preferences.pushEnabled,","            \"channel_sms\": preferences.smsEnabled,","            \"channel_whatsapp\": preferences.whatsappEnabled","        ])","    }","","    private func normalizePhoneNumber(_ phone: String) -> String {","        let digits = phone.filter { $0.isNumber }","        return phone.hasPrefix(\"+\") ? \"+\\(digits)\" : \"+\\(digits)\"","    }","}"]}]}],"abstract":[{"type":"text","text":"Registers a WhatsApp number for WhatsApp Business messaging."}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"registerWhatsappNumber:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"symbolKind":"method","roleHeading":"Type Method","title":"registerWhatsappNumber:","externalID":"c:objc(pl)PWConfiguration(cm)registerWhatsappNumber:","navigatorTitle":[{"kind":"identifier","text":"registerWhatsappNumber:"}]},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerwhatsappnumber:"],"traits":[{"interfaceLang