{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/unregisterforpushnotifications:"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"text":"Unregisters the device from push notifications.","type":"text"}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/unregisterForPushNotifications:"},"metadata":{"symbolKind":"method","title":"unregisterForPushNotifications:","navigatorTitle":[{"kind":"identifier","text":"unregisterForPushNotifications:"}],"role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)unregisterForPushNotifications:","fragments":[{"text":"+ ","kind":"text"},{"text":"unregisterForPushNotifications:","kind":"identifier"}],"roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}]},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"unregisterForPushNotifications:","kind":"identifier"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":" (^","kind":"text"},{"text":")(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSError","kind":"typeIdentifier","text":"NSError"},{"kind":"text","text":" * "},{"text":"error","kind":"internalParam"},{"kind":"text","text":")) "},{"kind":"internalParam","text":"completion"},{"text":";","kind":"text"}]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Block called when unregistration completes."},{"text":" ","type":"text"},{"type":"text","text":"Receives nil on success or an NSError on failure."}]}],"name":"completion"}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Removes the device from receiving push notifications:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"text":"Notifies Pushwoosh servers to stop sending notifications to this device","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Removes the device token from Pushwoosh"}]}]}],"type":"orderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this when the user logs out, deletes their account, or explicitly disables notifications."}]},{"level":2,"text":"Example","anchor":"Example","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Unregister during user logout:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["class AuthenticationManager {","","    func logout(completion: @escaping (Result<Void, Error>) -> Void) {","        \/\/ Show loading indicator","        LoadingIndicator.show()","","        \/\/ First, unregister from push to stop receiving notifications for this user","        Pushwoosh.configure.unregisterForPushNotifications { [weak self] error in","            if let error = error {","                Logger.warning(\"Push unregistration failed: \\(error.localizedDescription)\")","                \/\/ Continue with logout even if unregistration fails","            }","","            \/\/ Clear user session","            self?.clearUserSession()","","            \/\/ Clear user tags","            Pushwoosh.configure.setTags([","                \"logged_in\": false,","                \"user_id\": NSNull(),","                \"email\": NSNull()","            ])","","            \/\/ Stop server communication if required by privacy policy","            if UserDefaults.standard.bool(forKey: \"clearDataOnLogout\") {","                Pushwoosh.configure.stopServerCommunication()","            }","","            LoadingIndicator.hide()","            completion(.success(()))","        }","    }","","    private func clearUserSession() {","        KeychainManager.shared.clearCredentials()","        UserDefaults.standard.removePersistentDomain(forName: Bundle.main.bundleIdentifier!)","        CoreDataManager.shared.clearUserData()","    }","}"]}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/unregisterForPushNotifications:":{"url":"\/documentation\/pushwooshcore\/pwconfiguration\/unregisterforpushnotifications:","title":"unregisterForPushNotifications:","abstract":[{"text":"Unregisters the device from push notifications.","type":"text"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"unregisterForPushNotifications:"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/unregisterForPushNotifications:","role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"unregisterForPushNotifications:","kind":"identifier"}],"kind":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"title":"PushwooshCore","kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","role":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"kind":"symbol","type":"topic","abstract":[]}}}