{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"navigatorTitle":[{"kind":"identifier","text":"unregisterForPushNotifications:"}],"role":"symbol","modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","symbolKind":"method","fragments":[{"kind":"text","text":"+ "},{"text":"unregisterForPushNotifications:","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)unregisterForPushNotifications:","title":"unregisterForPushNotifications:"},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/unregisterForPushNotifications:"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"unregisterForPushNotifications:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":" (^","kind":"text"},{"text":")(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSError","kind":"typeIdentifier","text":"NSError"},{"text":" * ","kind":"text"},{"text":"error","kind":"internalParam"},{"text":")) ","kind":"text"},{"kind":"internalParam","text":"completion"},{"kind":"text","text":";"}]}]},{"kind":"parameters","parameters":[{"name":"completion","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Block called when unregistration completes."},{"type":"text","text":" "},{"type":"text","text":"Receives nil on success or an NSError on failure."}]}]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Removes the device from receiving push notifications:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Notifies Pushwoosh servers to stop sending notifications to this device","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Removes the device token from Pushwoosh","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this when the user logs out, deletes their account, or explicitly disables notifications."}]},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unregister during user logout:"}]},{"type":"codeListing","code":["class AuthenticationManager {","","    func logout(completion: @escaping (Result<Void, Error>) -> Void) {","        \/\/ Show loading indicator","        LoadingIndicator.show()","","        \/\/ First, unregister from push to stop receiving notifications for this user","        Pushwoosh.configure.unregisterForPushNotifications { [weak self] error in","            if let error = error {","                Logger.warning(\"Push unregistration failed: \\(error.localizedDescription)\")","                \/\/ Continue with logout even if unregistration fails","            }","","            \/\/ Clear user session","            self?.clearUserSession()","","            \/\/ Clear user tags","            Pushwoosh.configure.setTags([","                \"logged_in\": false,","                \"user_id\": NSNull(),","                \"email\": NSNull()","            ])","","            \/\/ Stop server communication if required by privacy policy","            if UserDefaults.standard.bool(forKey: \"clearDataOnLogout\") {","                Pushwoosh.configure.stopServerCommunication()","            }","","            LoadingIndicator.hide()","            completion(.success(()))","        }","    }","","    private func clearUserSession() {","        KeychainManager.shared.clearCredentials()","        UserDefaults.standard.removePersistentDomain(forName: Bundle.main.bundleIdentifier!)","        CoreDataManager.shared.clearUserData()","    }","}"],"syntax":"swift"}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/unregisterforpushnotifications:"]}],"abstract":[{"type":"text","text":"Unregisters the device from push notifications."}],"kind":"symbol","sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","role":"collection","url":"\/documentation\/pushwooshcore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"kind":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/unregisterForPushNotifications:":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/unregisterForPushNotifications:","fragments":[{"kind":"text","text":"+ "},{"text":"unregisterForPushNotifications:","kind":"identifier"}],"type":"topic","title":"unregisterForPushNotifications:","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"unregisterForPushNotifications:"}],"abstract":[{"text":"Unregisters the device from push notifications.","type":"text"}],"role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/unregisterforpushnotifications:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"type":"topic","role":"symbol","kind":"symbol","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"}}}