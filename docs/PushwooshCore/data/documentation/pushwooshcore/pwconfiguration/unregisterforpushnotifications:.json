{"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"unregisterForPushNotifications:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":" (^","kind":"text"},{"text":")(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSError","text":"NSError","kind":"typeIdentifier"},{"kind":"text","text":" * "},{"text":"error","kind":"internalParam"},{"kind":"text","text":")) "},{"kind":"internalParam","text":"completion"},{"kind":"text","text":";"}]}]},{"kind":"parameters","parameters":[{"name":"completion","content":[{"inlineContent":[{"type":"text","text":"Block called when unregistration completes."},{"type":"text","text":" "},{"type":"text","text":"Receives nil on success or an NSError on failure."}],"type":"paragraph"}]}]},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Removes the device from receiving push notifications:"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Notifies Pushwoosh servers to stop sending notifications to this device"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Removes the device token from Pushwoosh"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this when the user logs out, deletes their account, or explicitly disables notifications."}]},{"type":"heading","text":"Example","anchor":"Example","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unregister during user logout:"}]},{"type":"codeListing","code":["class AuthenticationManager {","","    func logout(completion: @escaping (Result<Void, Error>) -> Void) {","        \/\/ Show loading indicator","        LoadingIndicator.show()","","        \/\/ First, unregister from push to stop receiving notifications for this user","        Pushwoosh.configure.unregisterForPushNotifications { [weak self] error in","            if let error = error {","                Logger.warning(\"Push unregistration failed: \\(error.localizedDescription)\")","                \/\/ Continue with logout even if unregistration fails","            }","","            \/\/ Clear user session","            self?.clearUserSession()","","            \/\/ Clear user tags","            Pushwoosh.configure.setTags([","                \"logged_in\": false,","                \"user_id\": NSNull(),","                \"email\": NSNull()","            ])","","            \/\/ Stop server communication if required by privacy policy","            if UserDefaults.standard.bool(forKey: \"clearDataOnLogout\") {","                Pushwoosh.configure.stopServerCommunication()","            }","","            LoadingIndicator.hide()","            completion(.success(()))","        }","    }","","    private func clearUserSession() {","        KeychainManager.shared.clearCredentials()","        UserDefaults.standard.removePersistentDomain(forName: Bundle.main.bundleIdentifier!)","        CoreDataManager.shared.clearUserData()","    }","}"],"syntax":"swift"}],"kind":"content"}],"kind":"symbol","identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/unregisterForPushNotifications:","interfaceLanguage":"occ"},"sections":[],"abstract":[{"text":"Unregisters the device from push notifications.","type":"text"}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/unregisterforpushnotifications:"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"modules":[{"name":"PushwooshCore"}],"role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)unregisterForPushNotifications:","navigatorTitle":[{"text":"unregisterForPushNotifications:","kind":"identifier"}],"roleHeading":"Type Method","title":"unregisterForPushNotifications:","symbolKind":"method","fragments":[{"kind":"text","text":"+ "},{"text":"unregisterForPushNotifications:","kind":"identifier"}]},"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","title":"PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","kind":"symbol","abstract":[],"role":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/unregisterForPushNotifications:":{"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"unregisterForPushNotifications:"}],"title":"unregisterForPushNotifications:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/unregisterforpushnotifications:","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/unregisterForPushNotifications:","kind":"symbol","abstract":[{"type":"text","text":"Unregisters the device from push notifications."}],"navigatorTitle":[{"text":"unregisterForPushNotifications:","kind":"identifier"}],"role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","type":"topic","kind":"symbol","url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","role":"collection","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}]}}}