{"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)unregisterForPushNotifications:","roleHeading":"Type Method","symbolKind":"method","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"unregisterForPushNotifications:"}],"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"unregisterForPushNotifications:"}],"modules":[{"name":"PushwooshCore"}],"title":"unregisterForPushNotifications:"},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"kind":"text","text":") "},{"text":"unregisterForPushNotifications:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":" (^","kind":"text"},{"text":")(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSError","text":"NSError"},{"kind":"text","text":" * "},{"kind":"internalParam","text":"error"},{"text":")) ","kind":"text"},{"kind":"internalParam","text":"completion"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"completion","content":[{"inlineContent":[{"text":"Block called when unregistration completes.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Receives nil on success or an NSError on failure."}],"type":"paragraph"}]}]},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Removes the device from receiving push notifications:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Notifies Pushwoosh servers to stop sending notifications to this device","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Removes the device token from Pushwoosh","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"Use this when the user logs out, deletes their account, or explicitly disables notifications.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"Example","anchor":"Example"},{"inlineContent":[{"text":"Unregister during user logout:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class AuthenticationManager {","","    func logout(completion: @escaping (Result<Void, Error>) -> Void) {","        \/\/ Show loading indicator","        LoadingIndicator.show()","","        \/\/ First, unregister from push to stop receiving notifications for this user","        Pushwoosh.configure.unregisterForPushNotifications { [weak self] error in","            if let error = error {","                Logger.warning(\"Push unregistration failed: \\(error.localizedDescription)\")","                \/\/ Continue with logout even if unregistration fails","            }","","            \/\/ Clear user session","            self?.clearUserSession()","","            \/\/ Clear user tags","            Pushwoosh.configure.setTags([","                \"logged_in\": false,","                \"user_id\": NSNull(),","                \"email\": NSNull()","            ])","","            \/\/ Stop server communication if required by privacy policy","            if UserDefaults.standard.bool(forKey: \"clearDataOnLogout\") {","                Pushwoosh.configure.stopServerCommunication()","            }","","            LoadingIndicator.hide()","            completion(.success(()))","        }","    }","","    private func clearUserSession() {","        KeychainManager.shared.clearCredentials()","        UserDefaults.standard.removePersistentDomain(forName: Bundle.main.bundleIdentifier!)","        CoreDataManager.shared.clearUserData()","    }","}"]}],"kind":"content"}],"kind":"symbol","abstract":[{"type":"text","text":"Unregisters the device from push notifications."}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/unregisterForPushNotifications:","interfaceLanguage":"occ"},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/unregisterforpushnotifications:"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/unregisterForPushNotifications:":{"type":"topic","abstract":[{"type":"text","text":"Unregisters the device from push notifications."}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"unregisterForPushNotifications:"}],"fragments":[{"text":"+ ","kind":"text"},{"text":"unregisterForPushNotifications:","kind":"identifier"}],"title":"unregisterForPushNotifications:","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/unregisterForPushNotifications:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/unregisterforpushnotifications:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"role":"symbol","abstract":[],"kind":"symbol","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","url":"\/documentation\/pushwooshcore","role":"collection"}}}