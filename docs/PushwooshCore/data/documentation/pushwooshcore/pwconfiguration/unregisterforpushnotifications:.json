{"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":") ","kind":"text"},{"text":"unregisterForPushNotifications:","kind":"identifier"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"text":" (^","kind":"text"},{"text":")(","kind":"text"},{"kind":"typeIdentifier","text":"NSError","preciseIdentifier":"c:objc(cs)NSError"},{"text":" * ","kind":"text"},{"text":"error","kind":"internalParam"},{"text":")) ","kind":"text"},{"kind":"internalParam","text":"completion"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"completion","content":[{"type":"paragraph","inlineContent":[{"text":"Block called when unregistration completes.","type":"text"},{"type":"text","text":" "},{"text":"Receives nil on success or an NSError on failure.","type":"text"}]}]}]},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Removes the device from receiving push notifications:"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Notifies Pushwoosh servers to stop sending notifications to this device"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Removes the device token from Pushwoosh","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"Use this when the user logs out, deletes their account, or explicitly disables notifications.","type":"text"}]},{"type":"heading","text":"Example","level":2,"anchor":"Example"},{"type":"paragraph","inlineContent":[{"text":"Unregister during user logout:","type":"text"}]},{"code":["class AuthenticationManager {","","    func logout(completion: @escaping (Result<Void, Error>) -> Void) {","        \/\/ Show loading indicator","        LoadingIndicator.show()","","        \/\/ First, unregister from push to stop receiving notifications for this user","        Pushwoosh.configure.unregisterForPushNotifications { [weak self] error in","            if let error = error {","                Logger.warning(\"Push unregistration failed: \\(error.localizedDescription)\")","                \/\/ Continue with logout even if unregistration fails","            }","","            \/\/ Clear user session","            self?.clearUserSession()","","            \/\/ Clear user tags","            Pushwoosh.configure.setTags([","                \"logged_in\": false,","                \"user_id\": NSNull(),","                \"email\": NSNull()","            ])","","            \/\/ Stop server communication if required by privacy policy","            if UserDefaults.standard.bool(forKey: \"clearDataOnLogout\") {","                Pushwoosh.configure.stopServerCommunication()","            }","","            LoadingIndicator.hide()","            completion(.success(()))","        }","    }","","    private func clearUserSession() {","        KeychainManager.shared.clearCredentials()","        UserDefaults.standard.removePersistentDomain(forName: Bundle.main.bundleIdentifier!)","        CoreDataManager.shared.clearUserData()","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"sections":[],"metadata":{"symbolKind":"method","title":"unregisterForPushNotifications:","externalID":"c:objc(pl)PWConfiguration(cm)unregisterForPushNotifications:","role":"symbol","modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"text":"unregisterForPushNotifications:","kind":"identifier"}],"roleHeading":"Type Method","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"unregisterForPushNotifications:"}]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/unregisterForPushNotifications:","interfaceLanguage":"occ"},"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"Unregisters the device from push notifications."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/unregisterforpushnotifications:"]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","abstract":[],"fragments":[{"kind":"identifier","text":"PWConfiguration"}],"title":"PWConfiguration","kind":"symbol","role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","url":"\/documentation\/pushwooshcore","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"role":"collection"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/unregisterForPushNotifications:":{"type":"topic","abstract":[{"type":"text","text":"Unregisters the device from push notifications."}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"unregisterForPushNotifications:"}],"navigatorTitle":[{"kind":"identifier","text":"unregisterForPushNotifications:"}],"title":"unregisterForPushNotifications:","kind":"symbol","role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/unregisterforpushnotifications:","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/unregisterForPushNotifications:"}}}