{"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/unregisterforpushnotifications:"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/unregisterForPushNotifications:","interfaceLanguage":"occ"},"sections":[],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Unregisters the device from push notifications."}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"title":"unregisterForPushNotifications:","fragments":[{"kind":"text","text":"+ "},{"text":"unregisterForPushNotifications:","kind":"identifier"}],"navigatorTitle":[{"text":"unregisterForPushNotifications:","kind":"identifier"}],"roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)unregisterForPushNotifications:","symbolKind":"method","role":"symbol"},"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":") ","kind":"text"},{"kind":"identifier","text":"unregisterForPushNotifications:"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":" (^"},{"text":")(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSError","text":"NSError","kind":"typeIdentifier"},{"text":" * ","kind":"text"},{"text":"error","kind":"internalParam"},{"kind":"text","text":")) "},{"kind":"internalParam","text":"completion"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"parameters":[{"name":"completion","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Block called when unregistration completes."},{"text":" ","type":"text"},{"text":"Receives nil on success or an NSError on failure.","type":"text"}]}]}],"kind":"parameters"},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Removes the device from receiving push notifications:"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Notifies Pushwoosh servers to stop sending notifications to this device","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Removes the device token from Pushwoosh","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"Use this when the user logs out, deletes their account, or explicitly disables notifications."}],"type":"paragraph"},{"text":"Example","anchor":"Example","level":2,"type":"heading"},{"inlineContent":[{"text":"Unregister during user logout:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["class AuthenticationManager {","","    func logout(completion: @escaping (Result<Void, Error>) -> Void) {","        \/\/ Show loading indicator","        LoadingIndicator.show()","","        \/\/ First, unregister from push to stop receiving notifications for this user","        Pushwoosh.configure.unregisterForPushNotifications { [weak self] error in","            if let error = error {","                Logger.warning(\"Push unregistration failed: \\(error.localizedDescription)\")","                \/\/ Continue with logout even if unregistration fails","            }","","            \/\/ Clear user session","            self?.clearUserSession()","","            \/\/ Clear user tags","            Pushwoosh.configure.setTags([","                \"logged_in\": false,","                \"user_id\": NSNull(),","                \"email\": NSNull()","            ])","","            \/\/ Stop server communication if required by privacy policy","            if UserDefaults.standard.bool(forKey: \"clearDataOnLogout\") {","                Pushwoosh.configure.stopServerCommunication()","            }","","            LoadingIndicator.hide()","            completion(.success(()))","        }","    }","","    private func clearUserSession() {","        KeychainManager.shared.clearCredentials()","        UserDefaults.standard.removePersistentDomain(forName: Bundle.main.bundleIdentifier!)","        CoreDataManager.shared.clearUserData()","    }","}"],"type":"codeListing"}],"kind":"content"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/unregisterForPushNotifications:":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/unregisterForPushNotifications:","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"unregisterForPushNotifications:"}],"navigatorTitle":[{"text":"unregisterForPushNotifications:","kind":"identifier"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/unregisterforpushnotifications:","abstract":[{"type":"text","text":"Unregisters the device from push notifications."}],"type":"topic","kind":"symbol","role":"symbol","title":"unregisterForPushNotifications:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"role":"collection","url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","title":"PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"abstract":[],"role":"symbol","title":"PWConfiguration","type":"topic","url":"\/documentation\/pushwooshcore\/pwconfiguration"}}}