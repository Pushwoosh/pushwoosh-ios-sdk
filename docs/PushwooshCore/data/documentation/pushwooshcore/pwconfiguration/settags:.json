},{"type":"text","text":" "},{"type":"text","text":"user groups."}]},{"text":"Supported Tag Types","type":"heading","anchor":"Supported-Tag-Types","level":2},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Type"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Example"}]}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"String"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"code":"\"city\": \"New York\"","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Text values"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Integer","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"age\": 25"}]}],[{"inlineContent":[{"type":"text","text":"Numeric values"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Boolean"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"code":"\"isPremium\": true","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"True\/false values"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"List"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"interests\": [\"sports\", \"music\"]"}]}],[{"inlineContent":[{"text":"Arrays of strings","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"Date","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"lastPurchase\": Date()"}]}],[{"inlineContent":[{"text":"NSDate objects","type":"text"}],"type":"paragraph"}]]],"type":"table"},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"type":"paragraph","inlineContent":[{"text":"Update user profile tags after account changes:","type":"text"}]},{"syntax":"swift","code":["class UserProfileManager {","","    func updateUserTags(for user: User) {","        var tags: [String: Any] = [","            \"user_id\": user.id,","            \"email_verified\": user.isEmailVerified,","            \"account_type\": user.accountType.rawValue,","            \"signup_date\": user.createdAt,","            \"app_version\": Bundle.main.appVersion","        ]","","        \/\/ Add subscription info if premium","        if let subscription = user.subscription {","            tags[\"subscription_tier\"] = subscription.tier.rawValue","            tags[\"subscription_expiry\"] = subscription.expiryDate","            tags[\"is_premium\"] = true","        } else {","            tags[\"is_premium\"] = false","        }","","        \/\/ Add user preferences","        if !user.interests.isEmpty {","            tags[\"interests\"] = user.interests","        }","","        \/\/ Add location if available","        if let location = user.location {","            tags[\"country\"] = location.country","            tags[\"city\"] = location.city","            tags[\"timezone\"] = location.timezone","        }","","        Pushwoosh.configure.setTags(tags)","        Logger.debug(\"User tags updated: \\(tags.keys.joined(separator: \", \"))\")","    }","","    func trackPurchase(product: Product, amount: Decimal) {","        Pushwoosh.configure.setTags([","            \"last_purchase_date\": Date(),","            \"last_purchase_amount\": NSDecimalNumber(decimal: amount),","            \"last_purchase_category\": product.category,","            \"total_purchases\": incrementTag(\"total_purchases\")","        ])","    }","}"],"type":"codeListing"}],"kind":"content"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"kind":"symbol","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setTags:":{"navigatorTitle":[{"text":"setTags:","kind":"identifier"}],"abstract":[{"type":"text","text":"Sets user tags for device segmentation."}],"kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/settags:","role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"setTags:","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setTags:","title":"setTags:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","url":"\/documentation\/pushwooshcore","role":"collection","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","title":"PushwooshCore","kind":"symbol","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}]}}}