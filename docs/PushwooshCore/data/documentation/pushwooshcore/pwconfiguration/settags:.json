{"abstract":[{"type":"text","text":"Sets user tags for device segmentation."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/settags:"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setTags:"},"metadata":{"navigatorTitle":[{"text":"setTags:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setTags:"}],"roleHeading":"Type Method","title":"setTags:","externalID":"c:objc(pl)PWConfiguration(cm)setTags:","symbolKind":"method","role":"symbol"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"setTags:","kind":"identifier"},{"kind":"text","text":"("},{"text":"NSDictionary","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSDictionary"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"tags"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Dictionary of tag names and values to set for the current device"}]}],"name":"tags"}]},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"Tags are key-value pairs that enable targeted push notifications based on user attributes","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and behavior. Use tags to segment your audience and send personalized messages to specific"},{"text":" ","type":"text"},{"text":"user groups.","type":"text"}]},{"level":2,"text":"Supported Tag Types","anchor":"Supported-Tag-Types","type":"heading"},{"type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Type"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Example"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"String"}]}],[{"type":"paragraph","inlineContent":[{"code":"\"city\": \"New York\"","type":"codeVoice"}]}],[{"inlineContent":[{"type":"text","text":"Text values"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Integer"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"age\": 25"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Numeric values"}]}]],[[{"inlineContent":[{"text":"Boolean","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"\"isPremium\": true"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"True\/false values"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"List"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"\"interests\": [\"sports\", \"music\"]"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Arrays of strings"}]}]],[[{"inlineContent":[{"type":"text","text":"Date"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"lastPurchase\": Date()"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"NSDate objects"}]}]]],"header":"row"},{"text":"Example","type":"heading","level":2,"anchor":"Example"},{"type":"paragraph","inlineContent":[{"text":"Update user profile tags after account changes:","type":"text"}]},{"code":["class UserProfileManager {","","    func updateUserTags(for user: User) {","        var tags: [String: Any] = [","            \"user_id\": user.id,","            \"email_verified\": user.isEmailVerified,","            \"account_type\": user.accountType.rawValue,","            \"signup_date\": user.createdAt,","            \"app_version\": Bundle.main.appVersion","        ]","","        \/\/ Add subscription info if premium","        if let subscription = user.subscription {","            tags[\"subscription_tier\"] = subscription.tier.rawValue","            tags[\"subscription_expiry\"] = subscription.expiryDate","            tags[\"is_premium\"] = true","        } else {","            tags[\"is_premium\"] = false","        }","","        \/\/ Add user preferences","        if !user.interests.isEmpty {","            tags[\"interests\"] = user.interests","        }","","        \/\/ Add location if available","        if let location = user.location {","            tags[\"country\"] = location.country","            tags[\"city\"] = location.city","            tags[\"timezone\"] = location.timezone","        }","","        Pushwoosh.configure.setTags(tags)","        Logger.debug(\"User tags updated: \\(tags.keys.joined(separator: \", \"))\")","    }","","    func trackPurchase(product: Product, amount: Decimal) {","        Pushwoosh.configure.setTags([","            \"last_purchase_date\": Date(),","            \"last_purchase_amount\": NSDecimalNumber(decimal: amount),","            \"last_purchase_category\": product.category,","            \"total_purchases\": incrementTag(\"total_purchases\")","        ])","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setTags:":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setTags:","role":"symbol","navigatorTitle":[{"text":"setTags:","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"text","text":"Sets user tags for device segmentation."}],"title":"setTags:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/settags:","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setTags:"}],"type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"role":"collection","title":"PushwooshCore","url":"\/documentation\/pushwooshcore","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","abstract":[],"kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"type":"topic"}}}