{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setTags:","interfaceLanguage":"occ"},"kind":"symbol","metadata":{"role":"symbol","modules":[{"name":"PushwooshCore"}],"title":"setTags:","roleHeading":"Type Method","symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)setTags:","navigatorTitle":[{"kind":"identifier","text":"setTags:"}],"fragments":[{"kind":"text","text":"+ "},{"text":"setTags:","kind":"identifier"}]},"abstract":[{"text":"Sets user tags for device segmentation.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/settags:"]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"text":"setTags:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSDictionary","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSDictionary"},{"text":" *) ","kind":"text"},{"text":"tags","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"tags","content":[{"inlineContent":[{"type":"text","text":"Dictionary of tag names and values to set for the current device"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"Tags are key-value pairs that enable targeted push notifications based on user attributes","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and behavior. Use tags to segment your audience and send personalized messages to specific"},{"type":"text","text":" "},{"type":"text","text":"user groups."}],"type":"paragraph"},{"level":2,"text":"Supported Tag Types","type":"heading","anchor":"Supported-Tag-Types"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Type","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Example"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"inlineContent":[{"type":"text","text":"String"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"code":"\"city\": \"New York\"","type":"codeVoice"}]}],[{"inlineContent":[{"type":"text","text":"Text values"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Integer"}]}],[{"inlineContent":[{"type":"codeVoice","code":"\"age\": 25"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Numeric values"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Boolean","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"isPremium\": true"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"True\/false values"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"List"}]}],[{"inlineContent":[{"type":"codeVoice","code":"\"interests\": [\"sports\", \"music\"]"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Arrays of strings"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Date","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"lastPurchase\": Date()"}]}],[{"inlineContent":[{"text":"NSDate objects","type":"text"}],"type":"paragraph"}]]],"type":"table"},{"level":2,"anchor":"Example","text":"Example","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Update user profile tags after account changes:","type":"text"}]},{"syntax":"swift","code":["class UserProfileManager {","","    func updateUserTags(for user: User) {","        var tags: [String: Any] = [","            \"user_id\": user.id,","            \"email_verified\": user.isEmailVerified,","            \"account_type\": user.accountType.rawValue,","            \"signup_date\": user.createdAt,","            \"app_version\": Bundle.main.appVersion","        ]","","        \/\/ Add subscription info if premium","        if let subscription = user.subscription {","            tags[\"subscription_tier\"] = subscription.tier.rawValue","            tags[\"subscription_expiry\"] = subscription.expiryDate","            tags[\"is_premium\"] = true","        } else {","            tags[\"is_premium\"] = false","        }","","        \/\/ Add user preferences","        if !user.interests.isEmpty {","            tags[\"interests\"] = user.interests","        }","","        \/\/ Add location if available","        if let location = user.location {","            tags[\"country\"] = location.country","            tags[\"city\"] = location.city","            tags[\"timezone\"] = location.timezone","        }","","        Pushwoosh.configure.setTags(tags)","        Logger.debug(\"User tags updated: \\(tags.keys.joined(separator: \", \"))\")","    }","","    func trackPurchase(product: Product, amount: Decimal) {","        Pushwoosh.configure.setTags([","            \"last_purchase_date\": Date(),","            \"last_purchase_amount\": NSDecimalNumber(decimal: amount),","            \"last_purchase_category\": product.category,","            \"total_purchases\": incrementTag(\"total_purchases\")","        ])","    }","}"],"type":"codeListing"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"fragments":[{"text":"PWConfiguration","kind":"identifier"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","role":"symbol","kind":"symbol","type":"topic","title":"PWConfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setTags:":{"role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/settags:","title":"setTags:","navigatorTitle":[{"text":"setTags:","kind":"identifier"}],"abstract":[{"type":"text","text":"Sets user tags for device segmentation."}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setTags:","kind":"symbol","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setTags:"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","role":"collection","title":"PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","url":"\/documentation\/pushwooshcore"}}}