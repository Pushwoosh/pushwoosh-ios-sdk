{"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setTags:"},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)setTags:","roleHeading":"Type Method","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setTags:"}],"title":"setTags:","role":"symbol","modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"kind":"identifier","text":"setTags:"}],"symbolKind":"method"},"abstract":[{"text":"Sets user tags for device segmentation.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"setTags:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSDictionary","kind":"typeIdentifier","text":"NSDictionary"},{"kind":"text","text":" *) "},{"text":"tags","kind":"internalParam"},{"kind":"text","text":";"}]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Dictionary of tag names and values to set for the current device"}]}],"name":"tags"}],"kind":"parameters"},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Tags are key-value pairs that enable targeted push notifications based on user attributes"},{"text":" ","type":"text"},{"text":"and behavior. Use tags to segment your audience and send personalized messages to specific","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"user groups."}],"type":"paragraph"},{"level":2,"text":"Supported Tag Types","type":"heading","anchor":"Supported-Tag-Types"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Type","type":"text"}]}],[{"inlineContent":[{"text":"Example","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"String"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"code":"\"city\": \"New York\"","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Text values","type":"text"}]}]],[[{"inlineContent":[{"text":"Integer","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"age\": 25"}]}],[{"inlineContent":[{"text":"Numeric values","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Boolean"}]}],[{"type":"paragraph","inlineContent":[{"code":"\"isPremium\": true","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"True\/false values"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"List"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"interests\": [\"sports\", \"music\"]"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Arrays of strings"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Date"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"lastPurchase\": Date()"}]}],[{"inlineContent":[{"text":"NSDate objects","type":"text"}],"type":"paragraph"}]]],"type":"table"},{"type":"heading","anchor":"Example","level":2,"text":"Example"},{"inlineContent":[{"type":"text","text":"Update user profile tags after account changes:"}],"type":"paragraph"},{"code":["class UserProfileManager {","","    func updateUserTags(for user: User) {","        var tags: [String: Any] = [","            \"user_id\": user.id,","            \"email_verified\": user.isEmailVerified,","            \"account_type\": user.accountType.rawValue,","            \"signup_date\": user.createdAt,","            \"app_version\": Bundle.main.appVersion","        ]","","        \/\/ Add subscription info if premium","        if let subscription = user.subscription {","            tags[\"subscription_tier\"] = subscription.tier.rawValue","            tags[\"subscription_expiry\"] = subscription.expiryDate","            tags[\"is_premium\"] = true","        } else {","            tags[\"is_premium\"] = false","        }","","        \/\/ Add user preferences","        if !user.interests.isEmpty {","            tags[\"interests\"] = user.interests","        }","","        \/\/ Add location if available","        if let location = user.location {","            tags[\"country\"] = location.country","            tags[\"city\"] = location.city","            tags[\"timezone\"] = location.timezone","        }","","        Pushwoosh.configure.setTags(tags)","        Logger.debug(\"User tags updated: \\(tags.keys.joined(separator: \", \"))\")","    }","","    func trackPurchase(product: Product, amount: Decimal) {","        Pushwoosh.configure.setTags([","            \"last_purchase_date\": Date(),","            \"last_purchase_amount\": NSDecimalNumber(decimal: amount),","            \"last_purchase_category\": product.category,","            \"total_purchases\": incrementTag(\"total_purchases\")","        ])","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/settags:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setTags:":{"kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/settags:","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setTags:","abstract":[{"text":"Sets user tags for device segmentation.","type":"text"}],"fragments":[{"text":"+ ","kind":"text"},{"text":"set