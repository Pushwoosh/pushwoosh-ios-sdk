{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/settags:"]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setTags:","interfaceLanguage":"occ"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":") ","kind":"text"},{"text":"setTags:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSDictionary","text":"NSDictionary","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"text":"tags","kind":"internalParam"},{"text":";","kind":"text"}]}]},{"parameters":[{"name":"tags","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Dictionary of tag names and values to set for the current device"}]}]}],"kind":"parameters"},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Tags are key-value pairs that enable targeted push notifications based on user attributes","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and behavior. Use tags to segment your audience and send personalized messages to specific"},{"type":"text","text":" "},{"type":"text","text":"user groups."}]},{"level":2,"text":"Supported Tag Types","anchor":"Supported-Tag-Types","type":"heading"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Type"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Example"}]}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"String","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"\"city\": \"New York\"","type":"codeVoice"}]}],[{"inlineContent":[{"text":"Text values","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"Integer","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"age\": 25"}]}],[{"inlineContent":[{"type":"text","text":"Numeric values"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Boolean","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"\"isPremium\": true"}],"type":"paragraph"}],[{"inlineContent":[{"text":"True\/false values","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"List"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"interests\": [\"sports\", \"music\"]"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Arrays of strings"}]}]],[[{"inlineContent":[{"text":"Date","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"lastPurchase\": Date()"}]}],[{"inlineContent":[{"type":"text","text":"NSDate objects"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"type":"heading","text":"Example","level":2,"anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Update user profile tags after account changes:"}]},{"type":"codeListing","syntax":"swift","code":["class UserProfileManager {","","    func updateUserTags(for user: User) {","        var tags: [String: Any] = [","            \"user_id\": user.id,","            \"email_verified\": user.isEmailVerified,","            \"account_type\": user.accountType.rawValue,","            \"signup_date\": user.createdAt,","            \"app_version\": Bundle.main.appVersion","        ]","","        \/\/ Add subscription info if premium","        if let subscription = user.subscription {","            tags[\"subscription_tier\"] = subscription.tier.rawValue","            tags[\"subscription_expiry\"] = subscription.expiryDate","            tags[\"is_premium\"] = true","        } else {","            tags[\"is_premium\"] = false","        }","","        \/\/ Add user preferences","        if !user.interests.isEmpty {","            tags[\"interests\"] = user.interests","        }","","        \/\/ Add location if available","        if let location = user.location {","            tags[\"country\"] = location.country","            tags[\"city\"] = location.city","            tags[\"timezone\"] = location.timezone","        }","","        Pushwoosh.configure.setTags(tags)","        Logger.debug(\"User tags updated: \\(tags.keys.joined(separator: \", \"))\")","    }","","    func trackPurchase(product: Product, amount: Decimal) {","        Pushwoosh.configure.setTags([","            \"last_purchase_date\": Date(),","            \"last_purchase_amount\": NSDecimalNumber(decimal: amount),","            \"last_purchase_category\": product.category,","            \"total_purchases\": incrementTag(\"total_purchases\")","        ])","    }","}"]}],"kind":"content"}],"kind":"symbol","sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"role":"symbol","roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)setTags:","symbolKind":"method","title":"setTags:","navigatorTitle":[{"kind":"identifier","text":"setTags:"}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setTags:"}]},"abstract":[{"type":"text","text":"Sets user tags for device segmentation."}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setTags:":{"type":"topic","abstract":[{"type":"text","text":"Sets user tags for device segmentation."}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setTags:"}],"navigatorTitle":[{"kind":"identifier","text":"setTags:"}],"title":"setTags:","kind":"symbol","role":"symbol","url":"\/documentation\/pushwooshcor