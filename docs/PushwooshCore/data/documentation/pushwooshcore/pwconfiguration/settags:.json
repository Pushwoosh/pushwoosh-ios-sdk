{"abstract":[{"type":"text","text":"Sets user tags for device segmentation."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"kind":"text","text":") "},{"text":"setTags:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSDictionary","kind":"typeIdentifier","text":"NSDictionary"},{"text":" *) ","kind":"text"},{"text":"tags","kind":"internalParam"},{"kind":"text","text":";"}]}]},{"parameters":[{"name":"tags","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Dictionary of tag names and values to set for the current device"}]}]}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Tags are key-value pairs that enable targeted push notifications based on user attributes"},{"type":"text","text":" "},{"type":"text","text":"and behavior. Use tags to segment your audience and send personalized messages to specific"},{"type":"text","text":" "},{"text":"user groups.","type":"text"}]},{"level":2,"type":"heading","text":"Supported Tag Types","anchor":"Supported-Tag-Types"},{"header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Type"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Example","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"String"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"city\": \"New York\""}]}],[{"type":"paragraph","inlineContent":[{"text":"Text values","type":"text"}]}]],[[{"inlineContent":[{"text":"Integer","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"code":"\"age\": 25","type":"codeVoice"}]}],[{"inlineContent":[{"text":"Numeric values","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Boolean"}]}],[{"type":"paragraph","inlineContent":[{"code":"\"isPremium\": true","type":"codeVoice"}]}],[{"inlineContent":[{"type":"text","text":"True\/false values"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"List"}]}],[{"inlineContent":[{"type":"codeVoice","code":"\"interests\": [\"sports\", \"music\"]"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Arrays of strings","type":"text"}]}]],[[{"inlineContent":[{"type":"text","text":"Date"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"code":"\"lastPurchase\": Date()","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"NSDate objects","type":"text"}]}]]],"type":"table"},{"anchor":"Example","text":"Example","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Update user profile tags after account changes:"}],"type":"paragraph"},{"code":["class UserProfileManager {","","    func updateUserTags(for user: User) {","        var tags: [String: Any] = [","            \"user_id\": user.id,","            \"email_verified\": user.isEmailVerified,","            \"account_type\": user.accountType.rawValue,","            \"signup_date\": user.createdAt,","            \"app_version\": Bundle.main.appVersion","        ]","","        \/\/ Add subscription info if premium","        if let subscription = user.subscription {","            tags[\"subscription_tier\"] = subscription.tier.rawValue","            tags[\"subscription_expiry\"] = subscription.expiryDate","            tags[\"is_premium\"] = true","        } else {","            tags[\"is_premium\"] = false","        }","","        \/\/ Add user preferences","        if !user.interests.isEmpty {","            tags[\"interests\"] = user.interests","        }","","        \/\/ Add location if available","        if let location = user.location {","            tags[\"country\"] = location.country","            tags[\"city\"] = location.city","            tags[\"timezone\"] = location.timezone","        }","","        Pushwoosh.configure.setTags(tags)","        Logger.debug(\"User tags updated: \\(tags.keys.joined(separator: \", \"))\")","    }","","    func trackPurchase(product: Product, amount: Decimal) {","        Pushwoosh.configure.setTags([","            \"last_purchase_date\": Date(),","            \"last_purchase_amount\": NSDecimalNumber(decimal: amount),","            \"last_purchase_category\": product.category,","            \"total_purchases\": incrementTag(\"total_purchases\")","        ])","    }","}"],"type":"codeListing","syntax":"swift"}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setTags:"},"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)setTags:","navigatorTitle":[{"text":"setTags:","kind":"identifier"}],"roleHeading":"Type Method","symbolKind":"method","fragments":[{"text":"+ ","kind":"text"},{"text":"setTags:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"role":"symbol","title":"setTags:"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/settags:"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setTags:":{"title":"setTags:","type":"topic","navigatorTitle":[{"text":"setTags:","kind":"identifier"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/settags:","kind":"symbol","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setTags:"}],"abstract":[{"text":"Sets user tags for device segmentation.","t