{"abstract":[{"type":"text","text":"Sets user tags for device segmentation."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/settags:"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"setTags:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"NSDictionary","preciseIdentifier":"c:objc(cs)NSDictionary"},{"kind":"text","text":" *) "},{"text":"tags","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"Dictionary of tag names and values to set for the current device"}],"type":"paragraph"}],"name":"tags"}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Tags are key-value pairs that enable targeted push notifications based on user attributes"},{"text":" ","type":"text"},{"text":"and behavior. Use tags to segment your audience and send personalized messages to specific","type":"text"},{"type":"text","text":" "},{"type":"text","text":"user groups."}],"type":"paragraph"},{"level":2,"anchor":"Supported-Tag-Types","type":"heading","text":"Supported Tag Types"},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Type"}]}],[{"inlineContent":[{"type":"text","text":"Example"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"String","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"city\": \"New York\""}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Text values"}]}]],[[{"inlineContent":[{"text":"Integer","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"age\": 25"}]}],[{"type":"paragraph","inlineContent":[{"text":"Numeric values","type":"text"}]}]],[[{"inlineContent":[{"type":"text","text":"Boolean"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"\"isPremium\": true"}],"type":"paragraph"}],[{"inlineContent":[{"text":"True\/false values","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"List","type":"text"}]}],[{"inlineContent":[{"type":"codeVoice","code":"\"interests\": [\"sports\", \"music\"]"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Arrays of strings"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"Date","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"\"lastPurchase\": Date()","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"NSDate objects"}]}]]]},{"anchor":"Example","level":2,"text":"Example","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Update user profile tags after account changes:"}]},{"type":"codeListing","syntax":"swift","code":["class UserProfileManager {","","    func updateUserTags(for user: User) {","        var tags: [String: Any] = [","            \"user_id\": user.id,","            \"email_verified\": user.isEmailVerified,","            \"account_type\": user.accountType.rawValue,","            \"signup_date\": user.createdAt,","            \"app_version\": Bundle.main.appVersion","        ]","","        \/\/ Add subscription info if premium","        if let subscription = user.subscription {","            tags[\"subscription_tier\"] = subscription.tier.rawValue","            tags[\"subscription_expiry\"] = subscription.expiryDate","            tags[\"is_premium\"] = true","        } else {","            tags[\"is_premium\"] = false","        }","","        \/\/ Add user preferences","        if !user.interests.isEmpty {","            tags[\"interests\"] = user.interests","        }","","        \/\/ Add location if available","        if let location = user.location {","            tags[\"country\"] = location.country","            tags[\"city\"] = location.city","            tags[\"timezone\"] = location.timezone","        }","","        Pushwoosh.configure.setTags(tags)","        Logger.debug(\"User tags updated: \\(tags.keys.joined(separator: \", \"))\")","    }","","    func trackPurchase(product: Product, amount: Decimal) {","        Pushwoosh.configure.setTags([","            \"last_purchase_date\": Date(),","            \"last_purchase_amount\": NSDecimalNumber(decimal: amount),","            \"last_purchase_category\": product.category,","            \"total_purchases\": incrementTag(\"total_purchases\")","        ])","    }","}"]}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"symbolKind":"method","title":"setTags:","roleHeading":"Type Method","externalID":"c:objc(pl)PWConfiguration(cm)setTags:","role":"symbol","modules":[{"name":"PushwooshCore"}],"fragments":[{"kind":"text","text":"+ "},{"text":"setTags:","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"setTags:"}]},"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setTags:"},"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setTags:":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setTags:","title":"setTags:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/settags:","role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setTags:"}],"abstract":[{"type":"text","te