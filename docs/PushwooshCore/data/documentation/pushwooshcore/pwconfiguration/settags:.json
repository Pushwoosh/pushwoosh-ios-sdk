{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setTags:","interfaceLanguage":"occ"},"kind":"symbol","abstract":[{"type":"text","text":"Sets user tags for device segmentation."}],"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"setTags:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSDictionary","text":"NSDictionary","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"tags","kind":"internalParam"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"parameters":[{"name":"tags","content":[{"inlineContent":[{"type":"text","text":"Dictionary of tag names and values to set for the current device"}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"Tags are key-value pairs that enable targeted push notifications based on user attributes","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and behavior. Use tags to segment your audience and send personalized messages to specific"},{"text":" ","type":"text"},{"text":"user groups.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"Supported-Tag-Types","text":"Supported Tag Types"},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Type"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Example"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"inlineContent":[{"type":"text","text":"String"}],"type":"paragraph"}],[{"inlineContent":[{"code":"\"city\": \"New York\"","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Text values","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Integer","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"\"age\": 25"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Numeric values"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Boolean"}]}],[{"type":"paragraph","inlineContent":[{"code":"\"isPremium\": true","type":"codeVoice"}]}],[{"inlineContent":[{"text":"True\/false values","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"List"}]}],[{"inlineContent":[{"type":"codeVoice","code":"\"interests\": [\"sports\", \"music\"]"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Arrays of strings"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Date"}]}],[{"type":"paragraph","inlineContent":[{"code":"\"lastPurchase\": Date()","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"NSDate objects","type":"text"}]}]]]},{"anchor":"Example","level":2,"type":"heading","text":"Example"},{"type":"paragraph","inlineContent":[{"text":"Update user profile tags after account changes:","type":"text"}]},{"code":["class UserProfileManager {","","    func updateUserTags(for user: User) {","        var tags: [String: Any] = [","            \"user_id\": user.id,","            \"email_verified\": user.isEmailVerified,","            \"account_type\": user.accountType.rawValue,","            \"signup_date\": user.createdAt,","            \"app_version\": Bundle.main.appVersion","        ]","","        \/\/ Add subscription info if premium","        if let subscription = user.subscription {","            tags[\"subscription_tier\"] = subscription.tier.rawValue","            tags[\"subscription_expiry\"] = subscription.expiryDate","            tags[\"is_premium\"] = true","        } else {","            tags[\"is_premium\"] = false","        }","","        \/\/ Add user preferences","        if !user.interests.isEmpty {","            tags[\"interests\"] = user.interests","        }","","        \/\/ Add location if available","        if let location = user.location {","            tags[\"country\"] = location.country","            tags[\"city\"] = location.city","            tags[\"timezone\"] = location.timezone","        }","","        Pushwoosh.configure.setTags(tags)","        Logger.debug(\"User tags updated: \\(tags.keys.joined(separator: \", \"))\")","    }","","    func trackPurchase(product: Product, amount: Decimal) {","        Pushwoosh.configure.setTags([","            \"last_purchase_date\": Date(),","            \"last_purchase_amount\": NSDecimalNumber(decimal: amount),","            \"last_purchase_category\": product.category,","            \"total_purchases\": incrementTag(\"total_purchases\")","        ])","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"roleHeading":"Type Method","externalID":"c:objc(pl)PWConfiguration(cm)setTags:","role":"symbol","navigatorTitle":[{"text":"setTags:","kind":"identifier"}],"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setTags:"}],"modules":[{"name":"PushwooshCore"}],"symbolKind":"method","title":"setTags:"},"sections":[],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/settags:"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","role":"collection","title":"PushwooshCore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfi