{"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/settags:"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setTags:"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setTags:"},{"text":"(","kind":"text"},{"text":"NSDictionary","preciseIdentifier":"c:objc(cs)NSDictionary","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"tags"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"name":"tags","content":[{"inlineContent":[{"text":"Dictionary of tag names and values to set for the current device","type":"text"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Tags are key-value pairs that enable targeted push notifications based on user attributes","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and behavior. Use tags to segment your audience and send personalized messages to specific"},{"text":" ","type":"text"},{"type":"text","text":"user groups."}]},{"text":"Supported Tag Types","level":2,"anchor":"Supported-Tag-Types","type":"heading"},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Type","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Example"}]}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"String","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"city\": \"New York\""}]}],[{"type":"paragraph","inlineContent":[{"text":"Text values","type":"text"}]}]],[[{"inlineContent":[{"text":"Integer","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"\"age\": 25"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Numeric values","type":"text"}]}]],[[{"inlineContent":[{"type":"text","text":"Boolean"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"code":"\"isPremium\": true","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"True\/false values"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"List","type":"text"}]}],[{"inlineContent":[{"type":"codeVoice","code":"\"interests\": [\"sports\", \"music\"]"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Arrays of strings","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Date","type":"text"}]}],[{"inlineContent":[{"code":"\"lastPurchase\": Date()","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"NSDate objects","type":"text"}],"type":"paragraph"}]]]},{"level":2,"type":"heading","anchor":"Example","text":"Example"},{"inlineContent":[{"type":"text","text":"Update user profile tags after account changes:"}],"type":"paragraph"},{"type":"codeListing","code":["class UserProfileManager {","","    func updateUserTags(for user: User) {","        var tags: [String: Any] = [","            \"user_id\": user.id,","            \"email_verified\": user.isEmailVerified,","            \"account_type\": user.accountType.rawValue,","            \"signup_date\": user.createdAt,","            \"app_version\": Bundle.main.appVersion","        ]","","        \/\/ Add subscription info if premium","        if let subscription = user.subscription {","            tags[\"subscription_tier\"] = subscription.tier.rawValue","            tags[\"subscription_expiry\"] = subscription.expiryDate","            tags[\"is_premium\"] = true","        } else {","            tags[\"is_premium\"] = false","        }","","        \/\/ Add user preferences","        if !user.interests.isEmpty {","            tags[\"interests\"] = user.interests","        }","","        \/\/ Add location if available","        if let location = user.location {","            tags[\"country\"] = location.country","            tags[\"city\"] = location.city","            tags[\"timezone\"] = location.timezone","        }","","        Pushwoosh.configure.setTags(tags)","        Logger.debug(\"User tags updated: \\(tags.keys.joined(separator: \", \"))\")","    }","","    func trackPurchase(product: Product, amount: Decimal) {","        Pushwoosh.configure.setTags([","            \"last_purchase_date\": Date(),","            \"last_purchase_amount\": NSDecimalNumber(decimal: amount),","            \"last_purchase_category\": product.category,","            \"total_purchases\": incrementTag(\"total_purchases\")","        ])","    }","}"],"syntax":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"modules":[{"name":"PushwooshCore"}],"role":"symbol","roleHeading":"Type Method","symbolKind":"method","navigatorTitle":[{"text":"setTags:","kind":"identifier"}],"title":"setTags:","externalID":"c:objc(pl)PWConfiguration(cm)setTags:","fragments":[{"text":"+ ","kind":"text"},{"text":"setTags:","kind":"identifier"}]},"abstract":[{"type":"text","text":"Sets user tags for device segmentation."}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"role":"collection","url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","title":"PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfi