{"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setuser:emails:"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:emails:","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"abstract":[{"text":"Sets user identifier and emails together in a single operation.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"kind":"text","text":") "},{"kind":"identifier","text":"setUser:"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSString","text":"NSString","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"userId"},{"text":" ","kind":"text"},{"kind":"identifier","text":"emails:"},{"kind":"text","text":"("},{"text":"NSArray","preciseIdentifier":"c:objc(cs)NSArray","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"emails"},{"text":";","kind":"text"}],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The custom user identifier."}],"type":"paragraph"}],"name":"userId"},{"content":[{"inlineContent":[{"text":"Array of email address strings to associate with the user.","type":"text"}],"type":"paragraph"}],"name":"emails"}]},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Convenience method that combines ","type":"text"},{"code":"setUserId:","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"setEmails:"},{"text":" into a single","type":"text"},{"text":" ","type":"text"},{"text":"server request. This is more efficient than calling both methods separately","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and ensures atomic association of user ID with emails."}]},{"type":"paragraph","inlineContent":[{"text":"Use this during login or registration flows when you have both user ID","type":"text"},{"type":"text","text":" "},{"text":"and email available simultaneously.","type":"text"}]},{"text":"Example","type":"heading","level":2,"anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Complete registration with user ID and emails:"}]},{"type":"codeListing","syntax":"swift","code":["class RegistrationManager {","","    func completeRegistration(_ registration: RegistrationData) {","        \/\/ Create user on backend","        APIClient.shared.createUser(registration) { result in","            guard case .success(let user) = result else { return }","","            \/\/ Set both user ID and emails in single operation","            var emails = [user.email]","            if let secondaryEmail = registration.secondaryEmail {","                emails.append(secondaryEmail)","            }","","            Pushwoosh.configure.setUser(user.id, emails: emails)","","            \/\/ Set initial user tags","            Pushwoosh.configure.setTags([","                \"registration_date\": ISO8601DateFormatter().string(from: Date()),","                \"registration_source\": registration.source.rawValue,","                \"account_type\": user.accountType.rawValue,","                \"has_completed_onboarding\": false","            ])","        }","    }","}"]},{"syntax":null,"code":["   when you need confirmation."],"type":"codeListing"}],"kind":"content"}],"metadata":{"roleHeading":"Type Method","role":"symbol","title":"setUser:emails:","externalID":"c:objc(pl)PWConfiguration(cm)setUser:emails:","modules":[{"name":"PushwooshCore"}],"symbolKind":"method","fragments":[{"text":"+ ","kind":"text"},{"text":"setUser:emails:"