{"metadata":{"fragments":[{"text":"+ ","kind":"text"},{"text":"setUser:emails:","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)setUser:emails:","symbolKind":"method","title":"setUser:emails:","navigatorTitle":[{"text":"setUser:emails:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","role":"symbol"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:emails:","interfaceLanguage":"occ"},"abstract":[{"text":"Sets user identifier and emails together in a single operation.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"setUser:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString","text":"NSString"},{"text":" *) ","kind":"text"},{"text":"userId","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"emails:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSArray","text":"NSArray"},{"text":" *) ","kind":"text"},{"text":"emails","kind":"internalParam"},{"kind":"text","text":";"}]}]},{"parameters":[{"name":"userId","content":[{"inlineContent":[{"type":"text","text":"The custom user identifier."}],"type":"paragraph"}]},{"name":"emails","content":[{"inlineContent":[{"type":"text","text":"Array of email address strings to associate with the user."}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Convenience method that combines "},{"code":"setUserId:","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"setEmails:"},{"type":"text","text":" into a single"},{"type":"text","text":" "},{"type":"text","text":"server request. This is more efficient than calling both methods separately"},{"type":"text","text":" "},{"type":"text","text":"and ensures atomic association of user ID with emails."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use this during login or registration flows when you have both user ID"},{"type":"text","text":" "},{"type":"text","text":"and email available simultaneously."}],"type":"paragraph"},{"text":"Example","type":"heading","level":2,"anchor":"Example"},{"inlineContent":[{"type":"text","text":"Complete registration with user ID and emails:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class RegistrationManager {","","    func completeRegistration(_ registration: RegistrationData) {","        \/\/ Create user on backend","        APIClient.shared.createUser(registration) { result in","            guard case .success(let user) = result else { return }","","            \/\/ Set both user ID and emails in single operation","            var emails = [user.email]","            if let secondaryEmail = registration.secondaryEmail {","                emails.append(secondaryEmail)","            }","","            Pushwoosh.configure.setUser(user.id, emails: emails)","","            \/\/ Set initial user tags","            Pushwoosh.configure.setTags([","                \"registration_date\": ISO8601DateFormatter().string(from: Date()),","                \"registration_source\": registration.source.rawValue,","                \"account_type\": user.accountType.rawValue,","                \"has_completed_onboarding\": false","            ])","        }","    }","}"]},{"code":["   when you need confirmation."],"type":"codeListing","syntax":null}]}],"variants":[{"traits":[{"