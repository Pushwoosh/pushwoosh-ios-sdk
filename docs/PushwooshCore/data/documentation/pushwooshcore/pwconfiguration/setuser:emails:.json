{"abstract":[{"type":"text","text":"Sets user identifier and emails together in a single operation."}],"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:emails:","interfaceLanguage":"occ"},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"setUser:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"text":"userId","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"emails:","kind":"identifier"},{"kind":"text","text":"("},{"text":"NSArray","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSArray"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"emails"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"parameters":[{"name":"userId","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The custom user identifier."}]}]},{"content":[{"inlineContent":[{"text":"Array of email address strings to associate with the user.","type":"text"}],"type":"paragraph"}],"name":"emails"}],"kind":"parameters"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Convenience method that combines "},{"code":"setUserId:","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"setEmails:","type":"codeVoice"},{"text":" into a single","type":"text"},{"text":" ","type":"text"},{"text":"server request. This is more efficient than calling both methods separately","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and ensures atomic association of user ID with emails."}]},{"inlineContent":[{"type":"text","text":"Use this during login or registration flows when you have both user ID"},{"type":"text","text":" "},{"type":"text","text":"and email available simultaneously."}],"type":"paragraph"},{"anchor":"Example","level":2,"text":"Example","type":"heading"},{"inlineContent":[{"text":"Complete registration with user ID and emails:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["class RegistrationManager {","","    func completeRegistration(_ registration: RegistrationData) {","        \/\/ Create user on backend","        APIClient.shared.createUser(registration) { result in","            guard case .success(let user) = result else { return }","","            \/\/ Set both user ID and emails in single operation","            var emails = [user.email]","            if let secondaryEmail = registration.secondaryEmail {","                emails.append(secondaryEmail)","            }","","            Pushwoosh.configure.setUser(user.id, emails: emails)","","            \/\/ Set initial user tags","            Pushwoosh.configure.setTags([","                \"registration_date\": ISO8601DateFormatter().string(from: Date()),","                \"registration_source\": registration.source.rawValue,","                \"account_type\": user.accountType.rawValue,","                \"has_completed_onboarding\": false","            ])","        }","    }","}"],"type":"codeListing"},{"code":["   when you need confirmation."],"syntax":null,"type":"codeListing"}],"kind":"content"}],"metadata":{"role":"symbol","roleHeading":"Type Method","externalID":"c:objc(pl)PWConfiguration(cm)setUser:emails:","modules":[{"name":"PushwooshCore"}],"title":"setUser:emails:","navigatorTitle":[{"text":"setUser:emails:","kind":"identifier"}],"symbolKind":"method","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setUser:emails:"}]},"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setuser:emails:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","url":"\/documentation\/pushwooshcore","kind":"symbol","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"role":"collection"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","type":"topic","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setUser:emails:":{"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setUser:emails:"}],"role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setuser:emails:","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:emails:","kind":"symbol","title":"setUser:emails:","abstract":[{"type":"text","text":"Sets user identifier and emails together in a single operation."}],"navigatorTitle":[{"text":"setUser:emails:","kind":"identifier"}],"type":"topic"}}}