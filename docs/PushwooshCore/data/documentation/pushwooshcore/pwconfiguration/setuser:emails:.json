{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:emails:"},"metadata":{"role":"symbol","navigatorTitle":[{"text":"setUser:emails:","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)setUser:emails:","modules":[{"name":"PushwooshCore"}],"title":"setUser:emails:","symbolKind":"method","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setUser:emails:"}],"roleHeading":"Type Method"},"kind":"symbol","abstract":[{"text":"Sets user identifier and emails together in a single operation.","type":"text"}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"text":") ","kind":"text"},{"text":"setUser:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"NSString","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"userId"},{"text":" ","kind":"text"},{"text":"emails:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSArray","text":"NSArray","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"text":"emails","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}]},{"parameters":[{"name":"userId","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The custom user identifier."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Array of email address strings to associate with the user.","type":"text"}]}],"name":"emails"}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Convenience method that combines ","type":"text"},{"code":"setUserId:","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"setEmails:"},{"type":"text","text":" into a single"},{"type":"text","text":" "},{"type":"text","text":"server request. This is more efficient than calling both methods separately"},{"type":"text","text":" "},{"type":"text","text":"and ensures atomic association of user ID with emails."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this during login or registration flows when you have both user ID"},{"text":" ","type":"text"},{"type":"text","text":"and email available simultaneously."}]},{"anchor":"Example","type":"heading","text":"Example","level":2},{"type":"paragraph","inlineContent":[{"text":"Complete registration with user ID and emails:","type":"text"}]},{"code":["class RegistrationManager {","","    func completeRegistration(_ registration: RegistrationData) {","        \/\/ Create user on backend","        APIClient.shared.createUser(registration) { result in","            guard case .success(let user) = result else { return }","","            \/\/ Set both user ID and emails in single operation","            var emails = [user.email]","            if let secondaryEmail = registration.secondaryEmail {","                emails.append(secondaryEmail)","            }","","            Pushwoosh.configure.setUser(user.id, emails: emails)","","            \/\/ Set initial user tags","            Pushwoosh.configure.setTags([","                \"registration_date\": ISO8601DateFormatter().string(from: Date()),","                \"registration_source\": registration.source.rawValue,","                \"account_type\": user.accountType.rawValue,","                \"has_completed_onboarding\": false","            ])","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"codeListing","syntax":null,"code":["   when you need confirmation."]}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setuser:emails:"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setUser:emails:":{"title":"setUser:emails:","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setUser:emails:"}],"kind":"symbol","role":"symbol","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:emails:","abstract":[{"text":"Sets user identifier and emails together in a single operation.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"setUser:emails:"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setuser:emails:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","abstract":[],"role":"symbol","kind":"symbol","type":"topic","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"url":"\/documentation\/pushwooshcore","role":"collection","type":"topic","title":"PushwooshCore","kind":"symbol"}}}