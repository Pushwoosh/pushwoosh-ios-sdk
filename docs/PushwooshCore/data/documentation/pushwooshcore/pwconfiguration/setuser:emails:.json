{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"fragments":[{"text":"+ ","kind":"text"},{"text":"setUser:emails:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"role":"symbol","roleHeading":"Type Method","navigatorTitle":[{"text":"setUser:emails:","kind":"identifier"}],"title":"setUser:emails:","symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)setUser:emails:"},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:emails:","interfaceLanguage":"occ"},"abstract":[{"type":"text","text":"Sets user identifier and emails together in a single operation."}],"primaryContentSections":[{"declarations":[{"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setUser:"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString","text":"NSString"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"userId"},{"text":" ","kind":"text"},{"text":"emails:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSArray","preciseIdentifier":"c:objc(cs)NSArray","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"text":"emails","kind":"internalParam"},{"kind":"text","text":";"}],"platforms":["iOS"]}],"kind":"declarations"},{"parameters":[{"name":"userId","content":[{"inlineContent":[{"type":"text","text":"The custom user identifier."}],"type":"paragraph"}]},{"name":"emails","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Array of email address strings to associate with the user."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Convenience method that combines "},{"type":"codeVoice","code":"setUserId:"},{"type":"text","text":" and "},{"type":"codeVoice","code":"setEmails:"},{"type":"text","text":" into a single"},{"text":" ","type":"text"},{"text":"server request. This is more efficient than calling both methods separately","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and ensures atomic association of user ID with emails."}]},{"inlineContent":[{"type":"text","text":"Use this during login or registration flows when you have both user ID"},{"text":" ","type":"text"},{"type":"text","text":"and email available simultaneously."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Example","anchor":"Example"},{"type":"paragraph","inlineContent":[{"text":"Complete registration with user ID and emails:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class RegistrationManager {","","    func completeRegistration(_ registration: RegistrationData) {","        \/\/ Create user on backend","        APIClient.shared.createUser(registration) { result in","            guard case .success(let user) = result else { return }","","            \/\/ Set both user ID and emails in single operation","            var emails = [user.email]","            if let secondaryEmail = registration.secondaryEmail {","                emails.append(secondaryEmail)","            }","","            Pushwoosh.configure.setUser(user.id, emails: emails)","","            \/\/ Set initial user tags","            Pushwoosh.configure.setTags([","                \"registration_date\": ISO8601DateFormatter().string(from: Date()),","                \"registration_source\": registration.source.rawValue,","                \"account_type\": user.accountType.rawValue,","                \"has_completed_onboarding\": false","            ])","        }","    }","}"]},{"type":"codeListing","syntax":null,"code":["   when you need confirmation."]}]}],"varian