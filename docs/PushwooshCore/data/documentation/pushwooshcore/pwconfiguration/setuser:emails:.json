{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:emails:"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setUser:"},{"kind":"text","text":"("},{"text":"NSString","preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"userId"},{"text":" ","kind":"text"},{"text":"emails:","kind":"identifier"},{"kind":"text","text":"("},{"text":"NSArray","preciseIdentifier":"c:objc(cs)NSArray","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"emails","kind":"internalParam"},{"text":";","kind":"text"}]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The custom user identifier."}]}],"name":"userId"},{"content":[{"inlineContent":[{"type":"text","text":"Array of email address strings to associate with the user."}],"type":"paragraph"}],"name":"emails"}]},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"Convenience method that combines ","type":"text"},{"type":"codeVoice","code":"setUserId:"},{"type":"text","text":" and "},{"code":"setEmails:","type":"codeVoice"},{"text":" into a single","type":"text"},{"type":"text","text":" "},{"type":"text","text":"server request. This is more efficient than calling both methods separately"},{"type":"text","text":" "},{"type":"text","text":"and ensures atomic association of user ID with emails."}]},{"inlineContent":[{"text":"Use this during login or registration flows when you have both user ID","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and email available simultaneously."}],"type":"paragraph"},{"level":2,"text":"Example","anchor":"Example","type":"heading"},{"inlineContent":[{"type":"text","text":"Complete registration with user ID and emails:"}],"type":"paragraph"},{"type":"codeListing","code":["class RegistrationManager {","","    func completeRegistration(_ registration: RegistrationData) {","        \/\/ Create user on backend","        APIClient.shared.createUser(registration) { result in","            guard case .success(let user) = result else { return }","","            \/\/ Set both user ID and emails in single operation","            var emails = [user.email]","            if let secondaryEmail = registration.secondaryEmail {","                emails.append(secondaryEmail)","            }","","            Pushwoosh.configure.setUser(user.id, emails: emails)","","            \/\/ Set initial user tags","            Pushwoosh.configure.setTags([","                \"registration_date\": ISO8601DateFormatter().string(from: Date()),","                \"registration_source\": registration.source.rawValue,","                \"account_type\": user.accountType.rawValue,","                \"has_completed_onboarding\": false","            ])","        }","    }","}"],"syntax":"swift"},{"syntax":null,"type":"codeListing","code":["   when you need confirmation."]}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"abstract":[{"text":"Sets user identifier and emails together in a single operation.","type":"text"}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setuser:emails:"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"symbolKind":"method","title":"setUser:emails:","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setUser:emails:"}],"externalID":"c:objc(pl)PWConfiguration(cm)setUser:ema