{"abstract":[{"type":"text","text":"Sets user identifier and emails together in a single operation."}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"roleHeading":"Type Method","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setUser:emails:"}],"symbolKind":"method","navigatorTitle":[{"kind":"identifier","text":"setUser:emails:"}],"modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)setUser:emails:","title":"setUser:emails:","role":"symbol"},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setUser:"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"NSString","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"userId"},{"text":" ","kind":"text"},{"text":"emails:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSArray","text":"NSArray","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"emails","kind":"internalParam"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"userId","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The custom user identifier."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Array of email address strings to associate with the user."}],"type":"paragraph"}],"name":"emails"}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Convenience method that combines ","type":"text"},{"code":"setUserId:","type":"codeVoice"},{"type":"text","text":" and "},{"code":"setEmails:","type":"codeVoice"},{"type":"text","text":" into a single"},{"type":"text","text":" "},{"text":"server request. This is more efficient than calling both methods separately","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and ensures atomic association of user ID with emails."}]},{"inlineContent":[{"type":"text","text":"Use this during login or registration flows when you have both user ID"},{"text":" ","type":"text"},{"type":"text","text":"and email available simultaneously."}],"type":"paragraph"},{"text":"Example","type":"heading","level":2,"anchor":"Example"},{"type":"paragraph","inlineContent":[{"text":"Complete registration with user ID and emails:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["class RegistrationManager {","","    func completeRegistration(_ registration: RegistrationData) {","        \/\/ Create user on backend","        APIClient.shared.createUser(registration) { result in","            guard case .success(let user) = result else { return }","","            \/\/ Set both user ID and emails in single operation","            var emails = [user.email]","            if let secondaryEmail = registration.secondaryEmail {","                emails.append(secondaryEmail)","            }","","            Pushwoosh.configure.setUser(user.id, emails: emails)","","            \/\/ Set initial user tags","            Pushwoosh.configure.setTags([","                \"registration_date\": ISO8601DateFormatter().string(from: Date()),","                \"registration_source\": registration.source.rawValue,","                \"account_type\": user.accountType.rawValue,","                \"has_completed_onboarding\": false","            ])","        }","    }","}"]},{"type":"codeListing","code":["   when you need confirmation."],"syntax":null}]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:emails:","interfaceLanguage":"occ"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setuser:emails:"]}],"sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setUser:emails:":{"type":"topic","abstract":[{"text":"Sets user identifier and emails together in a single operation.","type":"text"}],"title":"setUser:emails:","role":"symbol","navigatorTitle":[{"text":"setUser:emails:","kind":"identifier"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setuser:emails:","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:emails:","fragments":[{"kind":"text","text":"+ "},{"text":"setUser:emails:","kind":"identifier"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","role":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"kind":"symbol","type":"topic","abstract":[]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"title":"PushwooshCore","kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore"}}}