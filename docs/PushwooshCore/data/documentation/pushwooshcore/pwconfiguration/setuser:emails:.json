{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"abstract":[{"type":"text","text":"Sets user identifier and emails together in a single operation."}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:emails:"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"setUser:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSString","text":"NSString","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"userId","kind":"internalParam"},{"kind":"text","text":" "},{"text":"emails:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"NSArray","preciseIdentifier":"c:objc(cs)NSArray"},{"text":" *) ","kind":"text"},{"text":"emails","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The custom user identifier."}]}],"name":"userId"},{"name":"emails","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Array of email address strings to associate with the user."}]}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Convenience method that combines "},{"code":"setUserId:","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"setEmails:"},{"type":"text","text":" into a single"},{"type":"text","text":" "},{"type":"text","text":"server request. This is more efficient than calling both methods separately"},{"type":"text","text":" "},{"type":"text","text":"and ensures atomic association of user ID with emails."}]},{"inlineContent":[{"text":"Use this during login or registration flows when you have both user ID","type":"text"},{"text":" ","type":"text"},{"text":"and email available simultaneously.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"Example","anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Complete registration with user ID and emails:"}]},{"syntax":"swift","code":["class RegistrationManager {","","    func completeRegistration(_ registration: RegistrationData) {","        \/\/ Create user on backend","        APIClient.shared.createUser(registration) { result in","            guard case .success(let user) = result else { return }","","            \/\/ Set both user ID and emails in single operation","            var emails = [user.email]","            if let secondaryEmail = registration.secondaryEmail {","                emails.append(secondaryEmail)","            }","","            Pushwoosh.configure.setUser(user.id, emails: emails)","","            \/\/ Set initial user tags","            Pushwoosh.configure.setTags([","                \"registration_date\": ISO8601DateFormatter().string(from: Date()),","                \"registration_source\": registration.source.rawValue,","                \"account_type\": user.accountType.rawValue,","                \"has_completed_onboarding\": false","            ])","        }","    }","}"],"type":"codeListing"},{"code":["   when you need confirmation."],"syntax":null,"type":"codeListing"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setuser:emails:"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"title":"setUser:emails:","navigatorTitle":[{"kind":"identifier","text":"setUser:emails:"}],"role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)setUser:emails:","roleHeading":"Type Method","fragments"