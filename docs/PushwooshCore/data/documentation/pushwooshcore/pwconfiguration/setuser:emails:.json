ser."}]}],"name":"emails"}],"kind":"parameters"},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Convenience method that combines ","type":"text"},{"type":"codeVoice","code":"setUserId:"},{"type":"text","text":" and "},{"code":"setEmails:","type":"codeVoice"},{"text":" into a single","type":"text"},{"text":" ","type":"text"},{"text":"server request. This is more efficient than calling both methods separately","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and ensures atomic association of user ID with emails."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this during login or registration flows when you have both user ID"},{"text":" ","type":"text"},{"text":"and email available simultaneously.","type":"text"}]},{"level":2,"type":"heading","anchor":"Example","text":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Complete registration with user ID and emails:"}]},{"type":"codeListing","syntax":"swift","code":["class RegistrationManager {","","    func completeRegistration(_ registration: RegistrationData) {","        \/\/ Create user on backend","        APIClient.shared.createUser(registration) { result in","            guard case .success(let user) = result else { return }","","            \/\/ Set both user ID and emails in single operation","            var emails = [user.email]","            if let secondaryEmail = registration.secondaryEmail {","                emails.append(secondaryEmail)","            }","","            Pushwoosh.configure.setUser(user.id, emails: emails)","","            \/\/ Set initial user tags","            Pushwoosh.configure.setTags([","                \"registration_date\": ISO8601DateFormatter().string(from: Date()),","                \"registration_source\": registration.source.rawValue,","                \"account_type\": user.accountType.rawValue,","                \"has_completed_onboarding\": false","            ])","        }","    }","}"]},{"syntax":null,"code":["   when you need confirmation."],"type":"codeListing"}],"kind":"content"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","role":"collection","kind":"symbol","type":"topic","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setUser:emails:":{"role":"symbol","navigatorTitle":[{"text":"setUser:emails:","kind":"identifier"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:emails:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setuser:emails:","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setUser:emails:"}],"type":"topic","abstract":[{"text":"Sets user identifier and emails together in a single operation.","type":"text"}],"title":"setUser:emails:","kind":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"role":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","title":"PWConfiguration","kind":"symbol","type":"topic","abstract":[]}}}