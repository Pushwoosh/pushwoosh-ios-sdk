{"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:emails:","interfaceLanguage":"occ"},"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"abstract":[{"type":"text","text":"Sets user identifier and emails together in a single operation."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"setUser:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString","text":"NSString"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"userId"},{"kind":"text","text":" "},{"text":"emails:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSArray","preciseIdentifier":"c:objc(cs)NSArray","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"emails","kind":"internalParam"},{"kind":"text","text":";"}]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The custom user identifier."}]}],"name":"userId"},{"name":"emails","content":[{"inlineContent":[{"type":"text","text":"Array of email address strings to associate with the user."}],"type":"paragraph"}]}]},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"text":"Convenience method that combines ","type":"text"},{"code":"setUserId:","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"setEmails:"},{"text":" into a single","type":"text"},{"type":"text","text":" "},{"text":"server request. This is more efficient than calling both methods separately","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and ensures atomic association of user ID with emails."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Use this during login or registration flows when you have both user ID","type":"text"},{"type":"text","text":" "},{"text":"and email available simultaneously.","type":"text"}]},{"type":"heading","anchor":"Example","level":2,"text":"Example"},{"inlineContent":[{"type":"text","text":"Complete registration with user ID and emails:"}],"type":"paragraph"},{"code":["class RegistrationManager {","","    func completeRegistration(_ registration: RegistrationData) {","        \/\/ Create user on backend","        APIClient.shared.createUser(registration) { result in","            guard case .success(let user) = result else { return }","","            \/\/ Set both user ID and emails in single operation","            var emails = [user.email]","            if let secondaryEmail = registration.secondaryEmail {","                emails.append(secondaryEmail)","            }","","            Pushwoosh.configure.setUser(user.id, emails: emails)","","            \/\/ Set initial user tags","            Pushwoosh.configure.setTags([","                \"registration_date\": ISO8601DateFormatter().string(from: Date()),","                \"registration_source\": registration.source.rawValue,","                \"account_type\": user.accountType.rawValue,","                \"has_completed_onboarding\": false","            ])","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"syntax":null,"code":["   when you need confirmation."],"type":"codeListing"}],"kind":"content"}],"metadata":{"role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)setUser:emails:","fragments":[{"text":"+ ","kind":"text"},{"text":"setUser:emails:","kind":"identifier"}],"roleHeading":"Type Method","title":"setUser:emails:","modules":[{"name":"PushwooshCore"}],"symbolKind":"method","navigatorTitle":[{"text":"setUser:emails:","kind":"identifier"}]},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setuser:emails:"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setUser:emails:":{"navigatorTitle":[{"kind":"identifier","text":"setUser:emails:"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setuser:emails:","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Sets user identifier and emails together in a single operation."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:emails:","title":"setUser:emails:","role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"setUser:emails:","kind":"identifier"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"abstract":[],"title":"PWConfiguration","role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","role":"collection","title":"PushwooshCore"}}}