{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:emails:","interfaceLanguage":"occ"},"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setuser:emails:"]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"kind":"identifier","text":"setUser:"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"NSString","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"userId"},{"kind":"text","text":" "},{"text":"emails:","kind":"identifier"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSArray","text":"NSArray"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"emails"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"parameters":[{"name":"userId","content":[{"inlineContent":[{"type":"text","text":"The custom user identifier."}],"type":"paragraph"}]},{"name":"emails","content":[{"inlineContent":[{"type":"text","text":"Array of email address strings to associate with the user."}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Convenience method that combines "},{"code":"setUserId:","type":"codeVoice"},{"type":"text","text":" and "},{"code":"setEmails:","type":"codeVoice"},{"type":"text","text":" into a single"},{"text":" ","type":"text"},{"text":"server request. This is more efficient than calling both methods separately","type":"text"},{"text":" ","type":"text"},{"text":"and ensures atomic association of user ID with emails.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Use this during login or registration flows when you have both user ID","type":"text"},{"type":"text","text":" "},{"text":"and email available simultaneously.","type":"text"}]},{"anchor":"Example","type":"heading","text":"Example","level":2},{"type":"paragraph","inlineContent":[{"text":"Complete registration with user ID and emails:","type":"text"}]},{"code":["class RegistrationManager {","","    func completeRegistration(_ registration: RegistrationData) {","        \/\/ Create user on backend","        APIClient.shared.createUser(registration) { result in","            guard case .success(let user) = result else { return }","","            \/\/ Set both user ID and emails in single operation","            var emails = [user.email]","            if let secondaryEmail = registration.secondaryEmail {","                emails.append(secondaryEmail)","            }","","            Pushwoosh.configure.setUser(user.id, emails: emails)","","            \/\/ Set initial user tags","            Pushwoosh.configure.setTags([","                \"registration_date\": ISO8601DateFormatter().string(from: Date()),","                \"registration_source\": registration.source.rawValue,","                \"account_type\": user.accountType.rawValue,","                \"has_completed_onboarding\": false","            ])","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"code":["   when you need confirmation."],"type":"codeListing","syntax":null}]}],"abstract":[{"text":"Sets user identifier and emails together in a single operation.","type":"text"}],"kind":"symbol","sections":[],"metadata":{"modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)setUser:emails:","title":"setUser:emails:","fragments":[{"text":"+ 