ion."}],"type":"paragraph"},{"text":"Example","anchor":"Example","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Register with user attributes after sign-up:","type":"text"}]},{"syntax":"swift","code":["class SignUpCoordinator {","","    func completeSignUp(user: User, source: SignUpSource) {","        let registrationTags: [String: Any] = [","            \"user_type\": user.accountType.rawValue,","            \"signup_source\": source.analyticsValue,","            \"signup_date\": ISO8601DateFormatter().string(from: Date()),","            \"interests\": user.selectedInterests,","            \"language\": Locale.current.languageCode ?? \"en\",","            \"app_version\": Bundle.main.appVersion","        ]","","        Pushwoosh.configure.registerForPushNotifications(with: registrationTags)","","        Pushwoosh.configure.setUserId(user.id)","        Pushwoosh.configure.setEmail(user.email)","    }","}","","extension Bundle {","    var appVersion: String {","        infoDictionary?[\"CFBundleShortVersionString\"] as? String ?? \"unknown\"","    }","}"],"type":"codeListing"}],"kind":"content"}],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)registerForPushNotificationsWith:","navigatorTitle":[{"text":"registerForPushNotificationsWith:","kind":"identifier"}],"title":"registerForPushNotificationsWith:","symbolKind":"method","modules":[{"name":"PushwooshCore"}],"role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"registerForPushNotificationsWith:","kind":"identifier"}],"roleHeading":"Type Method"},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWith:"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerForPushNotificationsWith:":{"type":"topic","role":"symbol","kind":"symbol","fragments":[{"text":"+ 