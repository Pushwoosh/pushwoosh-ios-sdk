egisterForPushNotifications and setTags separately,","type":"text"},{"type":"text","text":" "},{"text":"as tags are sent to the server along with the registration request.","type":"text"}]},{"inlineContent":[{"text":"Use this method when you have user attributes available at the time of registration,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"such as during onboarding or after user authentication."}],"type":"paragraph"},{"text":"Example","level":2,"anchor":"Example","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register with user attributes after sign-up:"}]},{"type":"codeListing","syntax":"swift","code":["class SignUpCoordinator {","","    func completeSignUp(user: User, source: SignUpSource) {","        let registrationTags: [String: Any] = [","            \"user_type\": user.accountType.rawValue,","            \"signup_source\": source.analyticsValue,","            \"signup_date\": ISO8601DateFormatter().string(from: Date()),","            \"interests\": user.selectedInterests,","            \"language\": Locale.current.languageCode ?? \"en\",","            \"app_version\": Bundle.main.appVersion","        ]","","        Pushwoosh.configure.registerForPushNotifications(with: registrationTags)","","        Pushwoosh.configure.setUserId(user.id)","        Pushwoosh.configure.setEmail(user.email)","    }","}","","extension Bundle {","    var appVersion: String {","        infoDictionary?[\"CFBundleShortVersionString\"] as? String ?? \"unknown\"","    }","}"]}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerForPushNotificationsWith:":{"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"r