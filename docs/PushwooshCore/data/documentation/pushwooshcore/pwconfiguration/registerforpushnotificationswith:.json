{"abstract":[{"type":"text","text":"Registers the device for push notifications with initial tags."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswith:"]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"text":"registerForPushNotificationsWith:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSDictionary","text":"NSDictionary"},{"kind":"text","text":" *) "},{"text":"tags","kind":"internalParam"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"tags","content":[{"inlineContent":[{"type":"text","text":"Dictionary of tag names and values to set during registration."},{"type":"text","text":" "},{"text":"Supported value types: NSString, NSNumber, NSArray (for list tags).","type":"text"}],"type":"paragraph"}]}]},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Combines push notification registration with tag assignment in a single operation.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This is more efficient than calling registerForPushNotifications and setTags separately,"},{"text":" ","type":"text"},{"text":"as tags are sent to the server along with the registration request.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Use this method when you have user attributes available at the time of registration,"},{"type":"text","text":" "},{"text":"such as during onboarding or after user authentication.","type":"text"}],"type":"paragraph"},{"anchor":"Example","text":"Example","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Register with user attributes after sign-up:"}],"type":"paragraph"},{"code":["class SignUpCoordinator {","","    func completeSignUp(user: User, source: SignUpSource) {","        let registrationTags: [String: Any] = [","            \"user_type\": user.accountType.rawValue,","            \"signup_source\": source.analyticsValue,","            \"signup_date\": ISO8601DateFormatter().string(from: Date()),","            \"interests\": user.selectedInterests,","            \"language\": Locale.current.languageCode ?? \"en\",","            \"app_version\": Bundle.main.appVersion","        ]","","        Pushwoosh.configure.registerForPushNotifications(with: registrationTags)","","        Pushwoosh.configure.setUserId(user.id)","        Pushwoosh.configure.setEmail(user.email)","    }","}","","extension Bundle {","    var appVersion: String {","        infoDictionary?[\"CFBundleShortVersionString\"] as? String ?? \"unknown\"","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"kind":"symbol","identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWith:","interfaceLanguage":"occ"},"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)registerForPushNotificationsWith:","modules":[{"name":"PushwooshCore"}],"fragments":[{"text":"+ ","kind":"text"},{"text":"registerForPushNotificationsWith:","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"registerForPushNotificationsWith:"}],"roleHeading":"Type Method","title":"registerForPushNotificationsWith:","symbolKind":"method","role":"symbol"},"sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerForPushNotificationsWith:":{"kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswith:","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWith:","fragments":[{"text":"+ ","kind":"text"},{"text":"registerForPushNotificationsWith:","kind":"identifier"}],"navigatorTitle":[{"text":"registerForPushNotificationsWith:","kind":"identifier"}],"type":"topic","title":"registerForPushNotificationsWith:","abstract":[{"text":"Registers the device for push notifications with initial tags.","type":"text"}],"role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","title":"PushwooshCore","role":"collection","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"kind":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","abstract":[],"title":"PWConfiguration","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"}}}