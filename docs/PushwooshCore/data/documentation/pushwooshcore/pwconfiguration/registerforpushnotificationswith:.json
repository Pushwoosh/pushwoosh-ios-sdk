{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWith:","interfaceLanguage":"occ"},"metadata":{"roleHeading":"Type Method","navigatorTitle":[{"text":"registerForPushNotificationsWith:","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)registerForPushNotificationsWith:","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"registerForPushNotificationsWith:"}],"role":"symbol","symbolKind":"method","modules":[{"name":"PushwooshCore"}],"title":"registerForPushNotificationsWith:"},"abstract":[{"type":"text","text":"Registers the device for push notifications with initial tags."}],"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"registerForPushNotificationsWith:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"NSDictionary","preciseIdentifier":"c:objc(cs)NSDictionary"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"tags"},{"text":";","kind":"text"}]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Dictionary of tag names and values to set during registration.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Supported value types: NSString, NSNumber, NSArray (for list tags)."}]}],"name":"tags"}],"kind":"parameters"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"Combines push notification registration with tag assignment in a single operation."},{"type":"text","text":" "},{"text":"This is more efficient than calling registerForPushNotifications and setTags separately,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"as tags are sent to the server along with the registration request."}],"type":"paragraph"},{"inlineContent":[{"text":"Use this method when you have user attributes available at the time of registration,","type":"text"},{"type":"text","text":" "},{"text":"such as during onboarding or after user authentication.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Example","level":2,"anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register with user attributes after sign-up:"}]},{"code":["class SignUpCoordinator {","","    func completeSignUp(user: User, source: SignUpSource) {","        let registrationTags: [String: Any] = [","            \"user_type\": user.accountType.rawValue,","            \"signup_source\": source.analyticsValue,","            \"signup_date\": ISO8601DateFormatter().string(from: Date()),","            \"interests\": user.selectedInterests,","            \"language\": Locale.current.languageCode ?? \"en\",","            \"app_version\": Bundle.main.appVersion","        ]","","        Pushwoosh.configure.registerForPushNotifications(with: registrationTags)","","        Pushwoosh.configure.setUserId(user.id)","        Pushwoosh.configure.setEmail(user.email)","    }","}","","extension Bundle {","    var appVersion: String {","        infoDictionary?[\"CFBundleShortVersionString\"] as? String ?? \"unknown\"","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswith:"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerForPushNotificationsWith:":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWith:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswith:","abstract":[{"type":"text","text":"Registers the device for push notifications with initial tags."}],"type":"topic","navigatorTitle":[{"text":"registerForPushNotificationsWith:","kind":"identifier"}],"kind":"symbol","role":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"registerForPushNotificationsWith:","kind":"identifier"}],"title":"registerForPushNotificationsWith:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","title":"PushwooshCore","kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","abstract":[],"kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"title":"PWConfiguration"}}}