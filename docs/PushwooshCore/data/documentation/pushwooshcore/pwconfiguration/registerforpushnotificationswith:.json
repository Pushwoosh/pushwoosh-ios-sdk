ding","anchor":"Example","text":"Example"},{"type":"paragraph","inlineContent":[{"text":"Register with user attributes after sign-up:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class SignUpCoordinator {","","    func completeSignUp(user: User, source: SignUpSource) {","        let registrationTags: [String: Any] = [","            \"user_type\": user.accountType.rawValue,","            \"signup_source\": source.analyticsValue,","            \"signup_date\": ISO8601DateFormatter().string(from: Date()),","            \"interests\": user.selectedInterests,","            \"language\": Locale.current.languageCode ?? \"en\",","            \"app_version\": Bundle.main.appVersion","        ]","","        Pushwoosh.configure.registerForPushNotifications(with: registrationTags)","","        Pushwoosh.configure.setUserId(user.id)","        Pushwoosh.configure.setEmail(user.email)","    }","}","","extension Bundle {","    var appVersion: String {","        infoDictionary?[\"CFBundleShortVersionString\"] as? String ?? \"unknown\"","    }","}"]}]}],"kind":"symbol","metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)registerForPushNotificationsWith:","fragments":[{"kind":"text","text":"+ "},{"text":"registerForPushNotificationsWith:","kind":"identifier"}],"roleHeading":"Type Method","symbolKind":"method","navigatorTitle":[{"text":"registerForPushNotificationsWith:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"title":"registerForPushNotificationsWith:","role":"symbol"},"sections":[],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWith:","interfaceLanguage":"occ"},"abstract":[{"text":"Registers the device for push notifications with initial tags.","type":"text"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerForPushNotificationsWith:":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWith:","abstract":[{"text":"Registers the device for push notifications with initial tags.","type":"text"}],"kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswith:","fragments":[{"kind":"text","text":"+ "},{"text":"registerForPushNotificationsWith:","kind":"identifier"}],"navigatorTitle":[{"text":"registerForPushNotificationsWith:","kind":"identifier"}],"title":"registerForPushNotificationsWith:","role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"fragments":[{"text":"PWConfiguration","kind":"identifier"}],"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","title":"PWConfiguration","kind":"symbol","type":"topic","role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","role":"collection","kind":"symbol","title":"PushwooshCore","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","url":"\/documentation\/pushwooshcore"}}}