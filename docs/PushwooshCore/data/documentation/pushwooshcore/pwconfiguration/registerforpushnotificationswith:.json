{"abstract":[{"type":"text","text":"Registers the device for push notifications with initial tags."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswith:"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"registerForPushNotificationsWith:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSDictionary","text":"NSDictionary"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"tags"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"name":"tags","content":[{"type":"paragraph","inlineContent":[{"text":"Dictionary of tag names and values to set during registration.","type":"text"},{"type":"text","text":" "},{"text":"Supported value types: NSString, NSNumber, NSArray (for list tags).","type":"text"}]}]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"Combines push notification registration with tag assignment in a single operation."},{"text":" ","type":"text"},{"text":"This is more efficient than calling registerForPushNotifications and setTags separately,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"as tags are sent to the server along with the registration request."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Use this method when you have user attributes available at the time of registration,","type":"text"},{"text":" ","type":"text"},{"text":"such as during onboarding or after user authentication.","type":"text"}]},{"text":"Example","level":2,"type":"heading","anchor":"Example"},{"type":"paragraph","inlineContent":[{"text":"Register with user attributes after sign-up:","type":"text"}]},{"type":"codeListing","code":["class SignUpCoordinator {","","    func completeSignUp(user: User, source: SignUpSource) {","        let registrationTags: [String: Any] = [","            \"user_type\": user.accountType.rawValue,","            \"signup_source\": source.analyticsValue,","            \"signup_date\": ISO8601DateFormatter().string(from: Date()),","            \"interests\": user.selectedInterests,","            \"language\": Locale.current.languageCode ?? \"en\",","            \"app_version\": Bundle.main.appVersion","        ]","","        Pushwoosh.configure.registerForPushNotifications(with: registrationTags)","","        Pushwoosh.configure.setUserId(user.id)","        Pushwoosh.configure.setEmail(user.email)","    }","}","","extension Bundle {","    var appVersion: String {","        infoDictionary?[\"CFBundleShortVersionString\"] as? String ?? \"unknown\"","    }","}"],"syntax":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"role":"symbol","roleHeading":"Type Method","externalID":"c:objc(pl)PWConfiguration(cm)registerForPushNotificationsWith:","modules":[{"name":"PushwooshCore"}],"title":"registerForPushNotificationsWith:","navigatorTitle":[{"kind":"identifier","text":"registerForPushNotificationsWith:"}],"symbolKind":"method","fragments":[{"text":"+ ","kind":"text"},{"text":"registerForPushNotificationsWith:","kind":"identifier"}]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWith:","interfaceLanguage":"occ"},"kind":"symbol","sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerForPushNotificationsWith:":{"fragments":[{"text":"+ ","kind":"text"},{"text":"registerForPushNotifi