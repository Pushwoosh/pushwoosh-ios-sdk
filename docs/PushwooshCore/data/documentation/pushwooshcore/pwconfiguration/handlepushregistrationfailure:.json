{"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"text":"handlePushRegistrationFailure:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSError","kind":"typeIdentifier","text":"NSError"},{"text":" *) ","kind":"text"},{"text":"error","kind":"internalParam"},{"kind":"text","text":";"}]}]},{"parameters":[{"name":"error","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The NSError received from APNs registration failure"}]}]}],"kind":"parameters"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call this method from your AppDelegate’s "},{"code":"application:didFailToRegisterForRemoteNotificationsWithError:","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"to notify Pushwoosh about registration failures."}]},{"type":"paragraph","inlineContent":[{"text":"This allows Pushwoosh to:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Log the error for debugging"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Retry registration if appropriate","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Update device status in the Control Panel"}]}]}],"type":"unorderedList"},{"level":2,"anchor":"Example","type":"heading","text":"Example"},{"type":"paragraph","inlineContent":[{"text":"Handle registration failure with user feedback:","type":"text"}]},{"syntax":"swift","code":["class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(_ application: UIApplication,","                    didFailToRegisterForRemoteNotificationsWithError error: Error) {","","        \/\/ Forward to Pushwoosh","        Pushwoosh.configure.handlePushRegistrationFailure(error as NSError)","","        \/\/ Log for debugging","        Logger.error(\"Push registration failed: \\(error.localizedDescription)\")","","        \/\/ Handle specific error cases","        let nsError = error as NSError","        switch nsError.code {","        case 3010:","            \/\/ Simulator or push not supported","            Logger.warning(\"Push notifications not supported on this device\")","","        default:","            \/\/ Track error in analytics","            Analytics.track(\"push_registration_failed\", properties: [","                \"error_code\": nsError.code,","                \"error_message\": nsError.localizedDescription","            ])","","            \/\/ Optionally notify user","            if shouldShowPushError {","                showPushRegistrationError()","            }","        }","    }","}"],"type":"codeListing"}]}],"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)handlePushRegistrationFailure:","symbolKind":"method","role":"symbol","title":"handlePushRegistrationFailure:","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"handlePushRegistrationFailure:"}],"modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"kind":"identifier","text":"handlePushRegistrationFailure:"}],"roleHeading":"Type Method"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushRegistrationFailure:","interfaceLanguage":"occ"},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/handlepushregistrationfailure:"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"text":"Handles push notification registration failure.","type":"text"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/handlePushRegistrationFailure:":{"type":"topic","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushRegistrationFailure:","abstract":[{"text":"Handles push notification registration failure.","type":"text"}],"fragments":[{"text":"+ ","kind":"text"},{"text":"handlePushRegistrationFailure:","kind":"identifier"}],"navigatorTitle":[{"text":"handlePushRegistrationFailure:","kind":"identifier"}],"title":"handlePushRegistrationFailure:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/handlepushregistrationfailure:","role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"title":"PushwooshCore","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","type":"topic","url":"\/documentation\/pushwooshcore\/pwconfiguration","abstract":[],"role":"symbol","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}]}}}