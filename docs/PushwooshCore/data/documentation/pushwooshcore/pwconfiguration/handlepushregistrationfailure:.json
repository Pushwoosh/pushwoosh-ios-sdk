{"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"kind":"identifier","text":"handlePushRegistrationFailure:"}],"roleHeading":"Type Method","title":"handlePushRegistrationFailure:","externalID":"c:objc(pl)PWConfiguration(cm)handlePushRegistrationFailure:","role":"symbol","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"handlePushRegistrationFailure:"}],"symbolKind":"method"},"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"abstract":[{"type":"text","text":"Handles push notification registration failure."}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"text":"handlePushRegistrationFailure:","kind":"identifier"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"NSError","preciseIdentifier":"c:objc(cs)NSError"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"error"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The NSError received from APNs registration failure"}]}],"name":"error"}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Call this method from your AppDelegate’s ","type":"text"},{"type":"codeVoice","code":"application:didFailToRegisterForRemoteNotificationsWithError:"},{"type":"text","text":" "},{"type":"text","text":"to notify Pushwoosh about registration failures."}]},{"type":"paragraph","inlineContent":[{"text":"This allows Pushwoosh to:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Log the error for debugging"}]}]},{"content":[{"inlineContent":[{"text":"Retry registration if appropriate","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Update device status in the Control Panel","type":"text"}]}]}],"type":"unorderedList"},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle registration failure with user feedback:"}]},{"type":"codeListing","syntax":"swift","code":["class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(_ application: UIApplication,","                    didFailToRegisterForRemoteNotificationsWithError error: Error) {","","        \/\/ Forward to Pushwoosh","        Pushwoosh.configure.handlePushRegistrationFailure(error as NSError)","","        \/\/ Log for debugging","        Logger.error(\"Push registration failed: \\(error.localizedDescription)\")","","        \/\/ Handle specific error cases","        let nsError = error as NSError","        switch nsError.code {","        case 3010:","            \/\/ Simulator or push not supported","            Logger.warning(\"Push notifications not supported on this device\")","","        default:","            \/\/ Track error in analytics","            Analytics.track(\"push_registration_failed\", properties: [","                \"error_code\": nsError.code,","                \"error_message\": nsError.localizedDescription","            ])","","            \/\/ Optionally notify user","            if shouldShowPushError {","                showPushRegistrationError()","            }","        }","    }","}"]}]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushRegistrationFailure:","interfaceLanguage":"occ"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/handlepushregistrationfail