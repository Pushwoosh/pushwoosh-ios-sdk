{"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"handlePushRegistrationFailure:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSError","text":"NSError"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"error"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}]},{"parameters":[{"name":"error","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The NSError received from APNs registration failure"}]}]}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call this method from your AppDelegate’s "},{"code":"application:didFailToRegisterForRemoteNotificationsWithError:","type":"codeVoice"},{"text":" ","type":"text"},{"text":"to notify Pushwoosh about registration failures.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This allows Pushwoosh to:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Log the error for debugging","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Retry registration if appropriate"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Update device status in the Control Panel","type":"text"}]}]}]},{"level":2,"type":"heading","text":"Example","anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle registration failure with user feedback:"}]},{"code":["class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(_ application: UIApplication,","                    didFailToRegisterForRemoteNotificationsWithError error: Error) {","","        \/\/ Forward to Pushwoosh","        Pushwoosh.configure.handlePushRegistrationFailure(error as NSError)","","        \/\/ Log for debugging","        Logger.error(\"Push registration failed: \\(error.localizedDescription)\")","","        \/\/ Handle specific error cases","        let nsError = error as NSError","        switch nsError.code {","        case 3010:","            \/\/ Simulator or push not supported","            Logger.warning(\"Push notifications not supported on this device\")","","        default:","            \/\/ Track error in analytics","            Analytics.track(\"push_registration_failed\", properties: [","                \"error_code\": nsError.code,","                \"error_message\": nsError.localizedDescription","            ])","","            \/\/ Optionally notify user","            if shouldShowPushError {","                showPushRegistrationError()","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"}]}],"sections":[],"kind":"symbol","identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushRegistrationFailure:","interfaceLanguage":"occ"},"metadata":{"title":"handlePushRegistrationFailure:","modules":[{"name":"PushwooshCore"}],"role":"symbol","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"handlePushRegistrationFailure:"}],"externalID":"c:objc(pl)PWConfiguration(cm)handlePushRegistrationFailure:","navigatorTitle":[{"kind":"identifier","text":"handlePushRegistrationFailure:"}],"roleHeading":"Type Method","symbolKind":"method"},"abstract":[{"type":"text","text":"Handles push notification registration failure."}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/handlepushregistrationfailure:"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"url":"\/documentation\/pushwooshcore","role":"collection","type":"topic","title":"PushwooshCore","kind":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","abstract":[],"role":"symbol","kind":"symbol","type":"topic","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/handlePushRegistrationFailure:":{"title":"handlePushRegistrationFailure:","role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushRegistrationFailure:","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"handlePushRegistrationFailure:"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/handlepushregistrationfailure:","navigatorTitle":[{"kind":"identifier","text":"handlePushRegistrationFailure:"}],"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Handles push notification registration failure."}]}}}