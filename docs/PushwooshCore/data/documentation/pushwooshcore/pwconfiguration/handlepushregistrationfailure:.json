ineContent":[{"type":"text","text":"Handle registration failure with user feedback:"}],"type":"paragraph"},{"syntax":"swift","code":["class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(_ application: UIApplication,","                    didFailToRegisterForRemoteNotificationsWithError error: Error) {","","        \/\/ Forward to Pushwoosh","        Pushwoosh.configure.handlePushRegistrationFailure(error as NSError)","","        \/\/ Log for debugging","        Logger.error(\"Push registration failed: \\(error.localizedDescription)\")","","        \/\/ Handle specific error cases","        let nsError = error as NSError","        switch nsError.code {","        case 3010:","            \/\/ Simulator or push not supported","            Logger.warning(\"Push notifications not supported on this device\")","","        default:","            \/\/ Track error in analytics","            Analytics.track(\"push_registration_failed\", properties: [","                \"error_code\": nsError.code,","                \"error_message\": nsError.localizedDescription","            ])","","            \/\/ Optionally notify user","            if shouldShowPushError {","                showPushRegistrationError()","            }","        }","    }","}"],"type":"codeListing"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/handlepushregistrationfailure:"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"navigatorTitle":[{"kind":"identifier","text":"handlePushRegistrationFailure:"}],"roleHeading":"Type Method","role":"symbol","modules":[{"name":"PushwooshCore"}],"title":"handlePushRegistrationFailure:","fragments":[{"kind":"text","text":"+ "},{"text":"handlePushRegistrationFailure:","kind":"identifier"}],"symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)handlePushRegistrationFailure:"},"abstract":[{"type":"text","text":"Handles push notification registration fai