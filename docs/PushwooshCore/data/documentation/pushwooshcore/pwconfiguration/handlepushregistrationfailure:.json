{"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/handlepushregistrationfailure:"]}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"text":"handlePushRegistrationFailure:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSError","text":"NSError","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"text":"error","kind":"internalParam"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"parameters":[{"name":"error","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The NSError received from APNs registration failure"}]}]}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"text":"Call this method from your AppDelegate’s ","type":"text"},{"code":"application:didFailToRegisterForRemoteNotificationsWithError:","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"to notify Pushwoosh about registration failures."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This allows Pushwoosh to:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Log the error for debugging"}]}]},{"content":[{"inlineContent":[{"text":"Retry registration if appropriate","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Update device status in the Control Panel"}]}]}],"type":"unorderedList"},{"anchor":"Example","text":"Example","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle registration failure with user feedback:"}]},{"code":["class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(_ application: UIApplication,","                    didFailToRegisterForRemoteNotificationsWithError error: Error) {","","        \/\/ Forward to Pushwoosh","        Pushwoosh.configure.handlePushRegistrationFailure(error as NSError)","","        \/\/ Log for debugging","        Logger.error(\"Push registration failed: \\(error.localizedDescription)\")","","        \/\/ Handle specific error cases","        let nsError = error as NSError","        switch nsError.code {","        case 3010:","            \/\/ Simulator or push not supported","            Logger.warning(\"Push notifications not supported on this device\")","","        default:","            \/\/ Track error in analytics","            Analytics.track(\"push_registration_failed\", properties: [","                \"error_code\": nsError.code,","                \"error_message\": nsError.localizedDescription","            ])","","            \/\/ Optionally notify user","            if shouldShowPushError {","                showPushRegistrationError()","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"}]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushRegistrationFailure:","interfaceLanguage":"occ"},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"abstract":[{"type":"text","text":"Handles push notification registration failure."}],"metadata":{"navigatorTitle":[{"text":"handlePushRegistrationFailure:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"symbolKind":"method","roleHeading":"Type Method","externalID":"c:objc(pl)PWConfiguration(cm)handlePushRegistrationFailure:","title":"handlePushRegistrationFailure:","role":"symbol","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"handlePushRegistrationFailure:"}]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/handlePushRegistrationFailure:":{"fragments":[{"kind":"text","text":"+ "},{"text":"handlePushRegistrationFailure:","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"handlePushRegistrationFailure:"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/handlepushregistrationfailure:","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushRegistrationFailure:","abstract":[{"text":"Handles push notification registration failure.","type":"text"}],"title":"handlePushRegistrationFailure:","type":"topic","role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","role":"collection","url":"\/documentation\/pushwooshcore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"kind":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"type":"topic","role":"symbol","kind":"symbol","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"}}}