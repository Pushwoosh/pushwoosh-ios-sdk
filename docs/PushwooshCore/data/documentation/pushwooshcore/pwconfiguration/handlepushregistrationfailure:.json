{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","metadata":{"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"handlePushRegistrationFailure:"}],"symbolKind":"method","modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","navigatorTitle":[{"kind":"identifier","text":"handlePushRegistrationFailure:"}],"role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)handlePushRegistrationFailure:","title":"handlePushRegistrationFailure:"},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushRegistrationFailure:","interfaceLanguage":"occ"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"text":"handlePushRegistrationFailure:","kind":"identifier"},{"kind":"text","text":"("},{"text":"NSError","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSError"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"error"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The NSError received from APNs registration failure","type":"text"}]}],"name":"error"}]},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"Call this method from your AppDelegate’s "},{"type":"codeVoice","code":"application:didFailToRegisterForRemoteNotificationsWithError:"},{"type":"text","text":" "},{"type":"text","text":"to notify Pushwoosh about registration failures."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This allows Pushwoosh to:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Log the error for debugging"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Retry registration if appropriate"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Update device status in the Control Panel"}],"type":"paragraph"}]}]},{"level":2,"text":"Example","anchor":"Example","type":"heading"},{"inlineContent":[{"text":"Handle registration failure with user feedback:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(_ application: UIApplication,","                    didFailToRegisterForRemoteNotificationsWithError error: Error) {","","        \/\/ Forward to Pushwoosh","        Pushwoosh.configure.handlePushRegistrationFailure(error as NSError)","","        \/\/ Log for debugging","        Logger.error(\"Push registration failed: \\(error.localizedDescription)\")","","        \/\/ Handle specific error cases","        let nsError = error as NSError","        switch nsError.code {","        case 3010:","            \/\/ Simulator or push not supported","            Logger.warning(\"Push notifications not supported on this device\")","","        default:","            \/\/ Track error in analytics","            Analytics.track(\"push_registration_failed\", properties: [","                \"error_code\": nsError.code,","                \"error_message\": nsError.localizedDescription","            ])","","            \/\/ Optionally notify user","            if shouldShowPushError {","                showPushRegistrationError()","            }","        }","    }","}"],"syntax":"swift"}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/handlepushregistrationfailure:"]}],"abstract":[{"type":"text","text":"Handles push notification registration failure."}],"sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"role":"collection","title":"PushwooshCore","url":"\/documentation\/pushwooshcore","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","abstract":[],"kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/handlePushRegistrationFailure:":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handlePushRegistrationFailure:","role":"symbol","navigatorTitle":[{"text":"handlePushRegistrationFailure:","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"text","text":"Handles push notification registration failure."}],"title":"handlePushRegistrationFailure:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/handlepushregistrationfailure:","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"handlePushRegistrationFailure:"}],"type":"topic"}}}