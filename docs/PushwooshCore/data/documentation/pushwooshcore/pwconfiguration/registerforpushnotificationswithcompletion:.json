nil if registration failed or user denied permission."}],"type":"paragraph"}]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"This method combines system permission request with Pushwoosh server registration.","type":"text"},{"text":" ","type":"text"},{"text":"The completion handler provides feedback on both operations, allowing you to:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Update UI based on registration status","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Track registration analytics"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle errors gracefully with retry logic"}]}]},{"content":[{"inlineContent":[{"text":"Sync push token with your backend server","type":"text"}],"type":"paragraph"}]}]},{"text":"Example","level":2,"type":"heading","anchor":"Example"},{"inlineContent":[{"text":"Handle registration in onboarding flow with analytics tracking:","type":"text"}],"type":"paragraph"},{"code":["class OnboardingViewController: UIViewController {","","    func enableNotificationsTapped() {","        showLoadingState()","","        Pushwoosh.configure.registerForPushNotifications { [weak self] token, error in","            DispatchQueue.main.async {","                self?.hideLoadingState()","","                if let error = error {","                    Analytics.track(\"push_registration_failed\", properties: [","                        \"error\": error.localizedDescription","                    ])","                    self?.showRetryOption()","                    return","                }","","                if let token = token {","                    Analytics.track(\"push_registration_success\")","                    self?.syncTokenWithBackend(token)","                    self?.proceedToNextStep()","                } else {","                    Analytics.track(\"push_permission_denied\")","                    self?.showPermissionDeniedInfo()","                }","            }","        }","    }","","    private func syncTokenWithBackend(_ token: String) {","        APIClient.shared.updatePushToken(token) { result in","            if case .failure(let error) = result {","                Logger.error(\"Backend sync failed: \\(error)\")","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","kind":"symbol","title":"PWConfiguration","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","abstract":[],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","title":"PushwooshCore","role":"collection","url":"\/documentation\/pushwooshcore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerForPushNotificationsWithCompletion:":{"url":"\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswithcompletion:","role":"symbol","abstract":[{"type":"text","text":"Registers the device for push notifications with a completion handler."}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWithCompletion:","fragments":[{"kind":"text","text":"+ "},{"text":"registerForPushNotificationsWithCompletion:","kind":"identifier"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"registerForPushNotificationsWithCompletion:"}],"title"