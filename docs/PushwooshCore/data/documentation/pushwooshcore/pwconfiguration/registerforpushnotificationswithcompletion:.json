{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"navigatorTitle":[{"kind":"identifier","text":"registerForPushNotificationsWithCompletion:"}],"roleHeading":"Type Method","fragments":[{"text":"+ ","kind":"text"},{"text":"registerForPushNotificationsWithCompletion:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)registerForPushNotificationsWithCompletion:","symbolKind":"method","title":"registerForPushNotificationsWithCompletion:","role":"symbol"},"sections":[],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswithcompletion:"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"text":"Registers the device for push notifications with a completion handler.","type":"text"}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWithCompletion:","interfaceLanguage":"occ"},"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":") ","kind":"text"},{"text":"registerForPushNotificationsWithCompletion:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"void (^)(NSString *, NSError *)","preciseIdentifier":"c:BFv(#*$objc(cs)NSString#*$objc(cs)NSError)"},{"kind":"text","text":") "},{"kind":"internalParam","text":"completion"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Block called when registration completes, providing the push token or an error.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Token is nil if registration failed or user denied permission."}]}],"name":"completion"}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"This method combines system permission request with Pushwoosh server registration."},{"type":"text","text":" "},{"type":"text","text":"The completion handler provides feedback on both operations, allowing you to:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Update UI based on registration status","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Track registration analytics"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle errors gracefully with retry logic"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Sync push token with your backend server"}]}]}],"type":"unorderedList"},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle registration in onboarding flow with analytics tracking:"}]},{"code":["class OnboardingViewController: UIViewController {","","    func enableNotificationsTapped() {","        showLoadingState()","","        Pushwoosh.configure.registerForPushNotifications { [weak self] token, error in","            DispatchQueue.main.async {","                self?.hideLoadingState()","","                if let error = error {","                    Analytics.track(\"push_registration_failed\", properties: [","                        \"error\": error.localizedDescription","                    ])","                    self?.showRetryOption()","                    return","                }","","                if let token = token {","                    Analytics.track(\"push_registration_success\")","                    self?.syncTokenWithBackend(token)","                    self?.proceedToNextStep()","                } else {","                    Analytics.track(\"push_permission_denied\")","                    self?.showPermissionDeniedInfo()","                }","            }","        }","    }","","    private func syncTokenWithBackend(_ token: String) {","        APIClient.shared.updatePushToken(token) { result in","            if case .failure(let error) = result {","                Logger.error(\"Backend sync failed: \\(error)\")","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerForPushNotificationsWithCompletion:":{"role":"symbol","title":"registerForPushNotificationsWithCompletion:","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWithCompletion:","kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswithcompletion:","navigatorTitle":[{"kind":"identifier","text":"registerForPushNotificationsWithCompletion:"}],"abstract":[{"text":"Registers the device for push notifications with a completion handler.","type":"text"}],"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"registerForPushNotificationsWithCompletion:"}],"type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","kind":"symbol","type":"topic","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"abstract":[],"role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore","type":"topic","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"identifier":"doc:\/\/com.pushwoos