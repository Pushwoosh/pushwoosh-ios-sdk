{"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"abstract":[{"type":"text","text":"Registers the device for push notifications with a completion handler."}],"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"registerForPushNotificationsWithCompletion:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:BFv(#*$objc(cs)NSString#*$objc(cs)NSError)","text":"void (^)(NSString *, NSError *)"},{"kind":"text","text":") "},{"kind":"internalParam","text":"completion"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Block called when registration completes, providing the push token or an error.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Token is nil if registration failed or user denied permission."}]}],"name":"completion"}]},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method combines system permission request with Pushwoosh server registration."},{"type":"text","text":" "},{"type":"text","text":"The completion handler provides feedback on both operations, allowing you to:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Update UI based on registration status"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Track registration analytics"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Handle errors gracefully with retry logic"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Sync push token with your backend server","type":"text"}]}]}]},{"type":"heading","anchor":"Example","text":"Example","level":2},{"inlineContent":[{"type":"text","text":"Handle registration in onboarding flow with analytics tracking:"}],"type":"paragraph"},{"code":["class OnboardingViewController: UIViewController {","","    func enableNotificationsTapped() {","        showLoadingState()","","        Pushwoosh.configure.registerForPushNotifications { [weak self] token, error in","            DispatchQueue.main.async {","                self?.hideLoadingState()","","                if let error = error {","                    Analytics.track(\"push_registration_failed\", properties: [","                        \"error\": error.localizedDescription","                    ])","                    self?.showRetryOption()","                    return","                }","","                if let token = token {","                    Analytics.track(\"push_registration_success\")","                    self?.syncTokenWithBackend(token)","                    self?.proceedToNextStep()","                } else {","                    Analytics.track(\"push_permission_denied\")","                    self?.showPermissionDeniedInfo()","                }","            }","        }","    }","","    private func syncTokenWithBackend(_ token: String) {","        APIClient.shared.updatePushToken(token) { result in","            if case .failure(let error) = result {","                Logger.error(\"Backend sync failed: \\(error)\")","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"metadata":{"role":"symbol","modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)registerForPushNotificationsWithCompletion:","navigatorTitle":[{"text":"registerForPushNotificationsWithCompletion:","kind":"identifier"}],"title":"registerForPushNotificationsWithCompletion:","symbolKind":"method","fragments":[{"text":"+ ","kind":"text"},{"text":"registerForPushNotificationsWithCompletion:","kind":"identifier"}],"roleHeading":"Type Method"},"kind":"symbol","variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswithcompletion:"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWithCompletion:"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerForPushNotificationsWithCompletion:":{"url":"\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswithcompletion:","abstract":[{"text":"Registers the device for push notifications with a completion handler.","type":"text"}],"title":"registerForPushNotificationsWithCompletion:","role":"symbol","navigatorTitle":[{"text":"registerForPushNotificationsWithCompletion:","kind":"identifier"}],"fragments":[{"text":"+ ","kind":"text"},{"text":"registerForPushNotificationsWithCompletion:","kind":"identifier"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWithCompletion:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","type":"topic","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","url":"\/documentation\/pushwooshcore","kind":"symbol","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"role":"collection"}}}