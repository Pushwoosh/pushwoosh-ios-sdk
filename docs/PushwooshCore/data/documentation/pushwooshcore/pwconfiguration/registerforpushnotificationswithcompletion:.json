{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWithCompletion:"},"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"registerForPushNotificationsWithCompletion:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:BFv(#*$objc(cs)NSString#*$objc(cs)NSError)","text":"void (^)(NSString *, NSError *)"},{"text":") ","kind":"text"},{"text":"completion","kind":"internalParam"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Block called when registration completes, providing the push token or an error.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Token is nil if registration failed or user denied permission."}]}],"name":"completion"}],"kind":"parameters"},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method combines system permission request with Pushwoosh server registration."},{"text":" ","type":"text"},{"text":"The completion handler provides feedback on both operations, allowing you to:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Update UI based on registration status","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Track registration analytics"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Handle errors gracefully with retry logic","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Sync push token with your backend server"}],"type":"paragraph"}]}]},{"text":"Example","lev