enied permission."}],"type":"paragraph"}],"name":"completion"}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"This method combines system permission request with Pushwoosh server registration.","type":"text"},{"type":"text","text":" "},{"text":"The completion handler provides feedback on both operations, allowing you to:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Update UI based on registration status"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Track registration analytics","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Handle errors gracefully with retry logic","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Sync push token with your backend server","type":"text"}]}]}],"type":"unorderedList"},{"level":2,"type":"heading","anchor":"Example","text":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle registration in onboarding flow with analytics tracking:"}]},{"type":"codeListing","syntax":"swift","code":["class OnboardingViewController: UIViewController {","","    func enableNotificationsTapped() {","        showLoadingState()","","        Pushwoosh.configure.registerForPushNotifications { [weak self] token, error in","            DispatchQueue.main.async {","                self?.hideLoadingState()","","                if let error = error {","                    Analytics.track(\"push_registration_failed\", properties: [","                        \"error\": error.localizedDescription","                    ])","                    self?.showRetryOption()","                    return","                }","","                if let token = token {","                    Analytics.track(\"push_registration_success\")","                    self?.syncTokenWithBackend(token)","                    self?.proceedToNex