{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWithCompletion:","interfaceLanguage":"occ"},"sections":[],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"text":") ","kind":"text"},{"text":"registerForPushNotificationsWithCompletion:","kind":"identifier"},{"kind":"text","text":"("},{"text":"void (^)(NSString *, NSError *)","kind":"typeIdentifier","preciseIdentifier":"c:BFv(#*$objc(cs)NSString#*$objc(cs)NSError)"},{"kind":"text","text":") "},{"text":"completion","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}]},{"parameters":[{"name":"completion","content":[{"inlineContent":[{"text":"Block called when registration completes, providing the push token or an error.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Token is nil if registration failed or user denied permission."}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"This method combines system permission request with Pushwoosh server registration."},{"type":"text","text":" "},{"type":"text","text":"The completion handler provides feedback on both operations, allowing you to:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Update UI based on registration status"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Track registration analytics"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle errors gracefully with retry logic"}]}]},{"content":[{"inlineContent":[{"text":"Sync push token with your backend server","type":"text"}],"type":"paragraph"}]}]},{"level":2,"anchor":"Example","type":"heading","text":"Example"},{"type":"paragraph","inlineContent":[{"text":"Handle registration in onboarding flow with analytics tracking:","type":"text"}]},{"code":["class OnboardingViewController: UIViewController {","","    func enableNotificationsTapped() {","        showLoadingState()","","        Pushwoosh.configure.registerForPushNotifications { [weak self] token, error in","            DispatchQueue.main.async {","                self?.hideLoadingState()","","                if let error = error {","                    Analytics.track(\"push_registration_failed\", properties: [","                        \"error\": error.localizedDescription","                    ])","                    self?.showRetryOption()","                    return","                }","","                if let token = token {","                    Analytics.track(\"push_registration_success\")","                    self?.syncTokenWithBackend(token)","                    self?.proceedToNextStep()","                } else {","                    Analytics.track(\"push_permission_denied\")","                    self?.showPermissionDeniedInfo()","                }","            }","        }","    }","","    private func syncTokenWithBackend(_ token: String) {","        APIClient.shared.updatePushToken(token) { result in","            if case .failure(let error) = result {","                Logger.error(\"Backend sync failed: \\(error)\")","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)registerForPushNotificationsWithCompletion:","navigatorTitle":[{"kind":"identifier","text":"registerForPushNotificationsWithCompletion:"}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"registerForPushNotificationsWithCompletion:"}],"role":"symbol","modules":[{"name":"PushwooshCore"}],"title":"registerForPushNotificati