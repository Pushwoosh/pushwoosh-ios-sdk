ermission request with Pushwoosh server registration.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The completion handler provides feedback on both operations, allowing you to:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Update UI based on registration status","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Track registration analytics","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Handle errors gracefully with retry logic"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Sync push token with your backend server","type":"text"}]}]}]},{"level":2,"type":"heading","text":"Example","anchor":"Example"},{"inlineContent":[{"text":"Handle registration in onboarding flow with analytics tracking:","type":"text"}],"type":"paragraph"},{"code":["class OnboardingViewController: UIViewController {","","    func enableNotificationsTapped() {","        showLoadingState()","","        Pushwoosh.configure.registerForPushNotifications { [weak self] token, error in","            DispatchQueue.main.async {","                self?.hideLoadingState()","","                if let error = error {","                    Analytics.track(\"push_registration_failed\", properties: [","                        \"error\": error.localizedDescription","                    ])","                    self?.showRetryOption()","                    return","                }","","                if let token = token {","                    Analytics.track(\"push_registration_success\")","                    self?.syncTokenWithBackend(token)","                    self?.proceedToNextStep()","                } else {","                    Analytics.track(\"push_permission_denied\")","                    self?.showPermissionDeniedInfo()","                }","            }","        }","    }","","    private func syncTokenWithBackend(_ token: String) {","        APIClient.shared.updatePushToken(token) { result in","            if case .failure(let error) = result {","                Logger.error(\"Backend sync failed: \\(error)\")","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswithcompletion:"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerForPushNotificationsWithCompletion:":{"title":"registerForPushNotificationsWithCompletion:","abstract":[{"text":"Registers the device for push notifications with a completion handler.","type":"text"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotificationswithcompletion:","kind":"symbol","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"registerForPushNotificationsWithCompletion:"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotificationsWithCompletion:","type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"registerForPushNotificationsWithCompletion:"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","url":"\/documentation\/pushwooshcore","role":"collection","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","title":"PushwooshCore","kind":"symbol","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"kind":"symbol","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/