{"kind":"symbol","metadata":{"role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)setShowPushnotificationAlert:","roleHeading":"Type Method","navigatorTitle":[{"kind":"identifier","text":"setShowPushnotificationAlert:"}],"modules":[{"name":"PushwooshCore"}],"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setShowPushnotificationAlert:"}],"title":"setShowPushnotificationAlert:","symbolKind":"method"},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setShowPushnotificationAlert:"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"setShowPushnotificationAlert:","kind":"identifier"},{"kind":"text","text":"("},{"text":"BOOL","kind":"typeIdentifier","preciseIdentifier":"c:@T@BOOL"},{"text":") ","kind":"text"},{"text":"show","kind":"internalParam"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}],"kind":"declarations"},{"parameters":[{"content":[{"inlineContent":[{"text":"YES to show alerts in foreground, NO to suppress them (default)","type":"text"}],"type":"paragraph"}],"name":"show"}],"kind":"parameters"},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, iOS does not display notification banners when the app is in the foreground."},{"type":"text","text":" "},{"type":"text","text":"Enable this to show system notification alerts even when the app is active."}]},{"text":"Example","level":2,"type":"heading","anchor":"Example"},{"type":"paragraph","inlineContent":[{"text":"Configure based on app type:","type":"text"}]},{"code":["class NotificationConfigManager {","","    func configureForAppType(_ appType: AppType) {","        switch appType {","        case .messaging:","            \/\/ Messaging apps typically handle notifications in-app","            Pushwoosh.configure.setShowPushnotificationAlert(false)","","        case .ecommerce, .news:","            \/\/ E-commerce and news apps benefit from showing all notifications","            Pushwoosh.configure.setShowPushnotificationAlert(true)","","        case .game:","            \/\/ Games might want to suppress during gameplay","            Pushwoosh.configure.setShowPushnotificationAlert(false)","        }","    }","","    func temporarilyDisableForegroundAlerts(during action: () -> Void) {","        let wasEnabled = Pushwoosh.configure.getShowPushnotificationAlert()","        Pushwoosh.configure.setShowPushnotificationAlert(false)","","        action()","","        Pushwoosh.configure.setShowPushnotificationAlert(wasEnabled)","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"text":" and use ","type":"text"},{"type":"codeVoice","code":"Pushwoosh.ForegroundPush"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setshowpushnotificationalert:"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"abstract":[{"text":"Sets whether to show alert for push notifications when app is in foreground.","type":"text"}],"sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setShowPushnotificationAlert:":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setShowPushnotificationAlert:","title":"setShowPushnotificationAlert:","role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setshowpushnotificationalert:","type":"topic","kind":"