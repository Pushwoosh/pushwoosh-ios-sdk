{"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setshowpushnotificationalert:"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"fragments":[{"text":"+ ","kind":"text"},{"text":"setShowPushnotificationAlert:","kind":"identifier"}],"role":"symbol","title":"setShowPushnotificationAlert:","modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","symbolKind":"method","navigatorTitle":[{"text":"setShowPushnotificationAlert:","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)setShowPushnotificationAlert:"},"abstract":[{"type":"text","text":"Sets whether to show alert for push notifications when app is in foreground."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"setShowPushnotificationAlert:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:@T@BOOL","kind":"typeIdentifier","text":"BOOL"},{"kind":"text","text":") "},{"kind":"internalParam","text":"show"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"name":"show","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"YES to show alerts in foreground, NO to suppress them (default)"}]}]}]},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"By default, iOS does not display notification banners when the app is in the foreground.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Enable this to show system notification alerts even when the app is active."}]},{"text":"Example","level":2,"type":"heading","anchor":"Example"},{"inlineContent":[{"text":"Configure based on app type:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class NotificationConfigManager {","","    func configureForAppType(_ appType: AppType) {","        switch appType {","        case .messaging:","            \/\/ Messaging apps typically handle notifications in-app","            Pushwoosh.configure.setShowPushnotificationAlert(false)","","        case .ecommerce, .news:","            \/\/ E-commerce and news apps benefit from showing all notifications","            Pushwoosh.configure.setShowPushnotificationAlert(true)","","        case .game:","            \/\/ Games might want to suppress during gameplay","            Pushwoosh.configure.setShowPushnotificationAlert(false)","        }","    }","","    func temporarilyDisableForegroundAlerts(during action: () -> Void) {","        let wasEnabled = Pushwoosh.configure.getShowPushnotificationAlert()","        Pushwoosh.configure.setShowPushnotificationAlert(false)","","        action()","","        Pushwoosh.configure.setShowPushnotificationAlert(wasEnabled)","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"type":"text","text":" and use "},{"code":"Pushwoosh.ForegroundPush","type":"codeVoice"},{"type":"text","text":"."}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setShowPushnotificationAlert:","interfaceLanguage":"occ"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"role":"collection","title":"PushwooshCore","url":"\/documentation\/pushwooshcore","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setShowPushnotificationAlert:":{"type":"topic","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setShowPushnotificationAlert:"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setShowPushnotificationAlert:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setshowpushnotificationalert:","abstract":[{"text":"Sets whether to show alert for push notifications when app is in foreground.","type":"text"}],"title":"setShowPushnotificationAlert:","role":"symbol","kind":"symbol","navigatorTitle":[{"text":"setShowPushnotificationAlert:","kind":"identifier"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","abstract":[],"kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"type":"topic"}}}