{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setShowPushnotificationAlert:","interfaceLanguage":"occ"},"sections":[],"metadata":{"symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)setShowPushnotificationAlert:","navigatorTitle":[{"text":"setShowPushnotificationAlert:","kind":"identifier"}],"title":"setShowPushnotificationAlert:","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setShowPushnotificationAlert:"}],"roleHeading":"Type Method","role":"symbol","modules":[{"name":"PushwooshCore"}]},"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setShowPushnotificationAlert:"},{"text":"(","kind":"text"},{"text":"BOOL","kind":"typeIdentifier","preciseIdentifier":"c:@T@BOOL"},{"text":") ","kind":"text"},{"text":"show","kind":"internalParam"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"parameters":[{"name":"show","content":[{"inlineContent":[{"type":"text","text":"YES to show alerts in foreground, NO to suppress them (default)"}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, iOS does not display notification banners when the app is in the foreground."},{"type":"text","text":" "},{"text":"Enable this to show system notification alerts even when the app is active.","type":"text"}]},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"inlineContent":[{"text":"Configure based on app type:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class NotificationConfigManager {","","    func configureForAppType(_ appType: AppType) {","        switch appType {","        case .messaging:","            \/\/ Messaging apps typically handle notifications in-app","            Pushwoosh.configure.setShowPushnotificationAlert(false)","","        case .ecommerce, .news:","            \/\/ E-commerce and news apps benefit from showing all notifications","            Pushwoosh.configure.setShowPushnotificationAlert(true)","","        case .game:","            \/\/ Games might want to suppress during gameplay","            Pushwoosh.configure.setShowPushnotificationAlert(false)","        }","    }","","    func temporarilyDisableForegroundAlerts(during action: () -> Void) {","        let wasEnabled = Pushwoosh.configure.getShowPushnotificationAlert()","        Pushwoosh.configure.setShowPushnotificationAlert(false)","","        action()","","        Pushwoosh.configure.setShowPushnotificationAlert(wasEnabled)","    }","}"]},{"inlineContent":[{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"text":" and use ","type":"text"},{"code":"Pushwoosh.ForegroundPush","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"abstract":[{"text":"Sets whether to show alert for push notifications when app is in foreground.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setshowpushnotificationalert:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setShowPushnotificationAlert:":{"navigatorTitle":[{"kind":"identifier","text":"setShowPushnotificationAlert:"}],"type":"topic","title":"setShowPushnotificationAlert:","abstract":[{"type":"text","text":"Sets whether to show alert for push notifications when app is in foreground."}],"fragments":[{"text":"+ ","kind":"text"},{"ki