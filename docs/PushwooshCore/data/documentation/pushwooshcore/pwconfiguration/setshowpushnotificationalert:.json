hnotificationAlert(false)","","        case .ecommerce, .news:","            \/\/ E-commerce and news apps benefit from showing all notifications","            Pushwoosh.configure.setShowPushnotificationAlert(true)","","        case .game:","            \/\/ Games might want to suppress during gameplay","            Pushwoosh.configure.setShowPushnotificationAlert(false)","        }","    }","","    func temporarilyDisableForegroundAlerts(during action: () -> Void) {","        let wasEnabled = Pushwoosh.configure.getShowPushnotificationAlert()","        Pushwoosh.configure.setShowPushnotificationAlert(false)","","        action()","","        Pushwoosh.configure.setShowPushnotificationAlert(wasEnabled)","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"type":"text","text":" and use "},{"type":"codeVoice","code":"Pushwoosh.ForegroundPush"},{"text":".","type":"text"}],"type":"paragraph"}],"kind":"content"}],"metadata":{"modules":[{"name":"PushwooshCore"}],"fragments":[{"kind":"text","text":"+ "},{"text":"setShowPushnotificationAlert:","kind":"identifier"}],"role":"symbol","roleHeading":"Type Method","externalID":"c:objc(pl)PWConfiguration(cm)setShowPushnotificationAlert:","symbolKind":"method","title":"setShowPushnotificationAlert:","navigatorTitle":[{"text":"setShowPushnotificationAlert:","kind":"identifier"}]},"abstract":[{"type":"text","text":"Sets whether to show alert for push notifications when app is in foreground."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","role":"collection","kind":"symbol","type":"topic","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PW