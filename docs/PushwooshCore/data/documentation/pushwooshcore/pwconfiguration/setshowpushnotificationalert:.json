{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setShowPushnotificationAlert:"},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"Sets whether to show alert for push notifications when app is in foreground."}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setshowpushnotificationalert:"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":") ","kind":"text"},{"text":"setShowPushnotificationAlert:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@BOOL","text":"BOOL"},{"text":") ","kind":"text"},{"text":"show","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"YES to show alerts in foreground, NO to suppress them (default)"}]}],"name":"show"}],"kind":"parameters"},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"By default, iOS does not display notification banners when the app is in the foreground.","type":"text"},{"text":" ","type":"text"},{"text":"Enable this to show system notification alerts even when the app is active.","type":"text"}]},{"type":"heading","text":"Example","anchor":"Example","level":2},{"inlineContent":[{"type":"text","text":"Configure based on app type:"}],"type":"paragraph"},{"syntax":"swift","code":["class NotificationConfigManager {","","    func configureForAppType(_ appType: AppType) {","        switch appType {","        case .messaging:","            \/\/ Messaging apps typically handle notifications in-app","            Pushwoosh.configure.setShowPushnotificationAlert(false)","","        case .ecommerce, .news:","            \/\/ E-commerce and news apps benefit from showing all notifications","            Pushwoosh.configure.setShowPushnotificationAlert(true)","","        case .game:","            \/\/ Games might want to suppress during gameplay","            Pushwoosh.configure.setShowPushnotificationAlert(false)","        }","    }","","    func temporarilyDisableForegroundAlerts(during action: () -> Void) {","        let wasEnabled = Pushwoosh.configure.getShowPushnotificationAlert()","        Pushwoosh.configure.setShowPushnotificationAlert(false)","","        action()","","        Pushwoosh.configure.setShowPushnotificationAlert(wasEnabled)","    }","}"],"type":"codeListing"},{"inlineContent":[{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"text":" and use ","type":"text"},{"code":"Pushwoosh.ForegroundPush","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"metadata":{"role":"symbol","title":"setShowPushnotificationAlert:","roleHeading":"Type Method","symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)setShowPushnotificationAlert:","navigatorTitle":[{"text":"setShowPushnotificationAlert:","kind":"identifier"}],"fragments":[{"kind":"text","text":"+ "},{"text":"setShowPushnotificationAlert:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}]},"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setShowPushnotificationAlert:":{"abstract":[{"type":"text","text":"Sets whether to show alert for push notifications when app is in foreground."}],"title":"setShowPushnotificationAlert:","fragments":[{"kind":"text","text":"+ "},{"text":"setShowPushnotificationAlert:","kind":"identifier"}],"identifier":"doc:\/\/com.pushwoosh.P