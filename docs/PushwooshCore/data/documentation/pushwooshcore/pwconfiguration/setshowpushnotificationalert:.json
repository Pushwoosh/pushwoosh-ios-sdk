{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","abstract":[{"type":"text","text":"Sets whether to show alert for push notifications when app is in foreground."}],"sections":[],"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":") ","kind":"text"},{"kind":"identifier","text":"setShowPushnotificationAlert:"},{"text":"(","kind":"text"},{"text":"BOOL","preciseIdentifier":"c:@T@BOOL","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"show","kind":"internalParam"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"YES to show alerts in foreground, NO to suppress them (default)"}]}],"name":"show"}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, iOS does not display notification banners when the app is in the foreground."},{"type":"text","text":" "},{"type":"text","text":"Enable this to show system notification alerts even when the app is active."}]},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"type":"paragraph","inlineContent":[{"text":"Configure based on app type:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class NotificationConfigManager {","","    func configureForAppType(_ appType: AppType) {","        switch appType {","        case .messaging:","            \/\/ Messaging apps typically handle notifications in-app","            Pushwoosh.configure.setShowPushnotificationAlert(false)","","        case .ecommerce, .news:","            \/\/ E-commerce and news apps benefit from showing all notifications","            Pushwoosh.configure.setShowPushnotificationAlert(true)","","        case .game:","            \/\/ Games might want to suppress during gameplay","            Pushwoosh.configure.setShowPushnotificationAlert(false)","        }","    }","","    func temporarilyDisableForegroundAlerts(during action: () -> Void) {","        let wasEnabled = Pushwoosh.configure.getShowPushnotificationAlert()","        Pushwoosh.configure.setShowPushnotificationAlert(false)","","        action()","","        Pushwoosh.configure.setShowPushnotificationAlert(wasEnabled)","    }","}"]},{"type":"paragraph","inlineContent":[{"code":"UNUserNotificationCenterDelegate","type":"codeVoice"},{"type":"text","text":" and use "},{"type":"codeVoice","code":"Pushwoosh.ForegroundPush"},{"type":"text","text":"."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setshowpushnotificationalert:"]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setShowPushnotificationAlert:","interfaceLanguage":"occ"},"metadata":{"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setShowPushnotificationAlert:"}],"modules":[{"name":"PushwooshCore"}],"title":"setShowPushnotificationAlert:","externalID":"c:objc(pl)PWConfiguration(cm)setShowPushnotificationAlert:","navigatorTitle":[{"text":"setShowPushnotificationAlert:","kind":"identifier"}],"symbolKind":"method","roleHeading":"Type Method","role":"symbol"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","type":"topic","kind":"symbol","url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","role":"collection","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PW