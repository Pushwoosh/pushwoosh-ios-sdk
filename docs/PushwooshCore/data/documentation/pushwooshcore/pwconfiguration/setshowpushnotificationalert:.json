en when the app is active."}],"type":"paragraph"},{"anchor":"Example","type":"heading","text":"Example","level":2},{"inlineContent":[{"text":"Configure based on app type:","type":"text"}],"type":"paragraph"},{"code":["class NotificationConfigManager {","","    func configureForAppType(_ appType: AppType) {","        switch appType {","        case .messaging:","            \/\/ Messaging apps typically handle notifications in-app","            Pushwoosh.configure.setShowPushnotificationAlert(false)","","        case .ecommerce, .news:","            \/\/ E-commerce and news apps benefit from showing all notifications","            Pushwoosh.configure.setShowPushnotificationAlert(true)","","        case .game:","            \/\/ Games might want to suppress during gameplay","            Pushwoosh.configure.setShowPushnotificationAlert(false)","        }","    }","","    func temporarilyDisableForegroundAlerts(during action: () -> Void) {","        let wasEnabled = Pushwoosh.configure.getShowPushnotificationAlert()","        Pushwoosh.configure.setShowPushnotificationAlert(false)","","        action()","","        Pushwoosh.configure.setShowPushnotificationAlert(wasEnabled)","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"type":"text","text":" and use "},{"code":"Pushwoosh.ForegroundPush","type":"codeVoice"},{"type":"text","text":"."}]}]}],"abstract":[{"text":"Sets whether to show alert for push notifications when app is in foreground.","type":"text"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","abstract":[],"role":"symbol","type":"topic"},"doc://com.pushwoosh.P