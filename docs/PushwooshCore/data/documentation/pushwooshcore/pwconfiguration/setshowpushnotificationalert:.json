et wasEnabled = Pushwoosh.configure.getShowPushnotificationAlert()","        Pushwoosh.configure.setShowPushnotificationAlert(false)","","        action()","","        Pushwoosh.configure.setShowPushnotificationAlert(wasEnabled)","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"codeVoice","code":"UNUserNotificationCenterDelegate"},{"type":"text","text":" and use "},{"code":"Pushwoosh.ForegroundPush","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"sections":[],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setShowPushnotificationAlert:"},"metadata":{"title":"setShowPushnotificationAlert:","modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"kind":"identifier","text":"setShowPushnotificationAlert:"}],"role":"symbol","roleHeading":"Type Method","symbolKind":"method","fragments":[{"kind":"text","text":"+ "},{"text":"setShowPushnotificationAlert:","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)setShowPushnotificationAlert:"},"kind":"symbol","abstract":[{"text":"Sets whether to show alert for push notifications when app is in foreground.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setshowpushnotificationalert:"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","url":"\/documentation\/pushwooshcore","role":"collection","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","title":"PushwooshCore","kind":"symbol","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PW