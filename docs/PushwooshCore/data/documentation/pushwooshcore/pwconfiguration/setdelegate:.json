{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setdelegate:"]}],"metadata":{"modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)setDelegate:","symbolKind":"method","roleHeading":"Type Method","role":"symbol","title":"setDelegate:","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setDelegate:"}],"navigatorTitle":[{"kind":"identifier","text":"setDelegate:"}]},"kind":"symbol","abstract":[{"type":"text","text":"Sets the delegate for receiving push notification events."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":") ","kind":"text"},{"text":"setDelegate:","kind":"identifier"},{"kind":"text","text":"("},{"text":"id<PWMessagingDelegate>","preciseIdentifier":"c:Qoobjc(pl)PWMessagingDelegate","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"kind":"internalParam","text":"delegate"},{"text":";","kind":"text"}],"platforms":["iOS"],"languages":["occ"]}]},{"kind":"parameters","parameters":[{"name":"delegate","content":[{"inlineContent":[{"text":"Object implementing PWMessagingDelegate protocol, or nil to remove the delegate","type":"text"}],"type":"paragraph"}]}]},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The delegate will receive callbacks when:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A push notification is received (foreground or background)","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"The user taps on a push notification","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Rich media is about to be displayed","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Set the delegate before calling ","type":"text"},{"type":"codeVoice","code":"registerForPushNotifications"},{"text":" to ensure you receive","type":"text"},{"type":"text","text":" "},{"text":"all notification events, including those that launched the app.","type":"text"}]},{"anchor":"Example","text":"Example","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement comprehensive notification handling:"}]},{"type":"codeListing","code":["class NotificationCoordinator: NSObject, PWMessagingDelegate {","","    static let shared = NotificationCoordinator()","","    func setup() {","        Pushwoosh.configure.setDelegate(self)","    }","","    \/\/ MARK: - PWMessagingDelegate","","    func pushwoosh(_ pushwoosh: Pushwoosh, onMessageReceived message: PWMessage) {","        Logger.info(\"Push received: \\(message.title ?? \"No title\")\")","","        \/\/ Handle silent push","        if message.isContentAvailable {","            handleSilentPush(message)","            return","        }","","        \/\/ Handle foreground notification","        if message.isForegroundMessage {","            handleForegroundNotification(message)","        }","","        \/\/ Update badge count","        updateBadgeCount(message.badge)","","        \/\/ Track in analytics","        Analytics.track(\"push_received\", properties: buildAnalyticsProperties(from: message))","    }","","    func pushwoosh(_ pushwoosh: Pushwoosh, onMessageOpened message: PWMessage) {","        Logger.info(\"Push opened: \\(message.title ?? \"No title\")\")","","        \/\/ Track open in analytics","        Analytics.track(\"push_opened\", properties: buildAnalyticsProperties(from: message))","","        \/\/ Handle deep link","        if let link = message.link, let url = URL(string: link) {","            DeepLinkRouter.shared.route(to: url)","            return","        }","","        \/\/ Handle custom data actions","        if let customData = message.customData {","            handleCustomAction(customData)","        }","    }","","    private func buildAnalyticsProperties(from message: PWMessage) -> [String: Any] {","        return [","            \"message_id\": message.messageCode ?? \"\",","            \"campaign_id\": message.campaignId,","            \"title\": message.title ?? \"\",","            \"has_deep_link\": message.link != nil,","            \"is_inbox\": message.isInboxMessage","        ]","    }","","    private func handleCustomAction(_ data: [AnyHashable: Any]) {","        if let action = data[\"action\"] as? String {","            switch action {","            case \"open_product\":","                if let productId = data[\"product_id\"] as? String {","                    NavigationCoordinator.shared.showProduct(id: productId)","                }","            case \"open_promo\":","                if let promoCode = data[\"promo_code\"] as? String {","                    NavigationCoordinator.shared.showPromo(code: promoCode)","                }","            default:","                Logger.warning(\"Unknown custom action: \\(action)\")","            }","        }","    }","}"],"syntax":"swift"}],"kind":"content"}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setDelegate:","interfaceLanguage":"occ"},"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","role":"symbol","kind":"symbol","title":"PWConfiguration","type":"topic","fragments":[{"text":"PWConfiguration","kind":"identifier"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setDelegate:":{"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setdelegate:","navigatorTitle":[{"text":"setDelegate:","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setDelegate:","title":"setDelegate:","role":"symbol","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setDelegate:"}],"abstract":[{"text":"Sets the delegate for receiving push notification events.","type":"text"}],"kind":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","title":"PushwooshCore","kind":"symbol","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","url":"\/documentation\/pushwooshcore","role":"collection"}}}