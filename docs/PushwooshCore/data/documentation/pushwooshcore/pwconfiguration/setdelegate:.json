{"sections":[],"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)setDelegate:","title":"setDelegate:","modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"text":"setDelegate:","kind":"identifier"}],"role":"symbol","roleHeading":"Type Method","fragments":[{"text":"+ ","kind":"text"},{"text":"setDelegate:","kind":"identifier"}],"symbolKind":"method"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setDelegate:","interfaceLanguage":"occ"},"abstract":[{"type":"text","text":"Sets the delegate for receiving push notification events."}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"setDelegate:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:Qoobjc(pl)PWMessagingDelegate","kind":"typeIdentifier","text":"id<PWMessagingDelegate>"},{"text":") ","kind":"text"},{"text":"delegate","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Object implementing PWMessagingDelegate protocol, or nil to remove the delegate"}]}],"name":"delegate"}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The delegate will receive callbacks when:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"A push notification is received (foreground or background)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The user taps on a push notification"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Rich media is about to be displayed","type":"text"}]}]}]},{"inlineContent":[{"text":"Set the delegate before calling ","type":"text"},{"type":"codeVoice","code":"registerForPushNotifications"},{"type":"text","text":" to ensure you receive"},{"type":"text","text":" "},{"text":"all notification events, including those that launched the app.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"Example","anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement comprehensive notification handling:"}]},{"code":["class NotificationCoordinator: NSObject, PWMessagingDelegate {","","    static let shared = NotificationCoordinator()","","    func setup() {","        Pushwoosh.configure.setDelegate(self)","    }","","    \/\/ MARK: - PWMessagingDelegate","","    func pushwoosh(_ pushwoosh: Pushwoosh, onMessageReceived message: PWMessage) {","        Logger.info(\"Push received: \\(message.title ?? \"No title\")\")","","        \/\/ Handle silent push","        if message.isContentAvailable {","            handleSilentPush(message)","            return","        }","","        \/\/ Handle foreground notification","        if message.isForegroundMessage {","            handleForegroundNotification(message)","        }","","        \/\/ Update badge count","        updateBadgeCount(message.badge)","","        \/\/ Track in analytics","        Analytics.track(\"push_received\", properties: buildAnalyticsProperties(from: message))","    }","","    func pushwoosh(_ pushwoosh: Pushwoosh, onMessageOpened message: PWMessage) {","        Logger.info(\"Push opened: \\(message.title ?? \"No title\")\")","","        \/\/ Track open in analytics","        Analytics.track(\"push_opened\", properties: buildAnalyticsProperties(from: message))","","        \/\/ Handle deep link","        if let link = message.link, let url = URL(string: link) {","            DeepLinkRouter.shared.route(to: url)","            return","        }","","        \/\/ Handle custom data actions","        if let customData = message.customData {","            handleCustomAction(customData)","        }","    }","","    private func buildAnalyticsProperties(from message: PWMessage) -> [String: Any] {","        return [","            \"message_id\": message.messageCode ?? \"\",","            \"campaign_id\": message.campaignId,","            \"title\": message.title ?? \"\",","            \"has_deep_link\": message.link != nil,","            \"is_inbox\": message.isInboxMessage","        ]","    }","","    private func handleCustomAction(_ data: [AnyHashable: Any]) {","        if let action = data[\"action\"] as? String {","            switch action {","            case \"open_product\":","                if let productId = data[\"product_id\"] as? String {","                    NavigationCoordinator.shared.showProduct(id: productId)","                }","            case \"open_promo\":","                if let promoCode = data[\"promo_code\"] as? String {","                    NavigationCoordinator.shared.showPromo(code: promoCode)","                }","            default:","                Logger.warning(\"Unknown custom action: \\(action)\")","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"}]}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setdelegate:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","title":"PushwooshCore","kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setDelegate:":{"navigatorTitle":[{"text":"setDelegate:","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setDelegate:","abstract":[{"type":"text","text":"Sets the delegate for receiving push notification events."}],"title":"setDelegate:","kind":"symbol","role":"symbol","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setDelegate:"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setdelegate:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","abstract":[],"kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"title":"PWConfiguration"}}}