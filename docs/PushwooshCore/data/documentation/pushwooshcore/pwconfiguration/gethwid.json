{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)getHWID","fragments":[{"text":"+ ","kind":"text"},{"text":"getHWID","kind":"identifier"}],"navigatorTitle":[{"text":"getHWID","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","title":"getHWID","symbolKind":"method","role":"symbol"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/gethwid"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier","text":"NSString"},{"kind":"text","text":" *) "},{"kind":"identifier","text":"getHWID"},{"text":";","kind":"text"}]}]},{"kind":"content","content":[{"text":"Return Value","anchor":"return-value","type":"heading","level":2},{"inlineContent":[{"text":"The unique Pushwoosh device identifier (never nil)","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"The HWID is a unique device identifier used in all Pushwoosh API calls and for device tracking","type":"text"},{"text":" ","type":"text"},{"text":"in the Pushwoosh Control Panel. On iOS, this is derived from ","type":"text"},{"code":"UIDevice.identifierForVendor","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The HWID remains consistent across app launches and is used to:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Identify the device in the Pushwoosh Control Panel","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Track user behavior and engagement","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Target specific devices for push notifications"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Link devices to user accounts in your backend"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"type":"heading","text":"Example","anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Sync device with your backend for cross-platform user tracking:"}]},{"syntax":"swift","type":"codeListing","code":["class DeviceRegistrationService {","","    func registerDeviceWithBackend(userId: String) {","        let hwid = Pushwoosh.configure.getHWID()","        let pushToken = Pushwoosh.configure.getPushToken()","","        let deviceInfo: [String: Any] = [","            \"hwid\": hwid,","            \"userId\": userId,","            \"pushToken\": pushToken ?? \"\",","            \"platform\": \"ios\",","            \"appVersion\": Bundle.main.appVersion,","            \"osVersion\": UIDevice.current.systemVersion","        ]","","        APIClient.shared.post(\"\/api\/devices\/register\", body: deviceInfo) { result in","            switch result {","            case .success:","                Logger.info(\"Device registered with backend: \\(hwid)\")","            case .failure(let error):","                Logger.error(\"Device registration failed: \\(error)\")","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It may change if the user reinstalls all apps from the same vendor."}]}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","abstract":[{"text":"Returns the Pushwoosh Hardware ID (HWID) for this device.","type":"text"}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getHWID","interfaceLanguage":"occ"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"fragments":[{"text":"PWConfiguration","kind":"identifier"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","role":"symbol","kind":"symbol","type":"topic","title":"PWConfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/getHWID":{"abstract":[{"text":"Returns the Pushwoosh Hardware ID (HWID) for this device.","type":"text"}],"fragments":[{"text":"+ ","kind":"text"},{"text":"getHWID","kind":"identifier"}],"navigatorTitle":[{"text":"getHWID","kind":"identifier"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/gethwid","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getHWID","type":"topic","title":"getHWID","role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","role":"collection","title":"PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","url":"\/documentation\/pushwooshcore"}}}