{"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"text":"NSString","preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"text":"getHWID","kind":"identifier"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Return Value","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"text":"The unique Pushwoosh device identifier (never nil)","type":"text"}]}],"kind":"content"},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"The HWID is a unique device identifier used in all Pushwoosh API calls and for device tracking","type":"text"},{"type":"text","text":" "},{"text":"in the Pushwoosh Control Panel. On iOS, this is derived from ","type":"text"},{"type":"codeVoice","code":"UIDevice.identifierForVendor"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"The HWID remains consistent across app launches and is used to:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Identify the device in the Pushwoosh Control Panel","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Track user behavior and engagement","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Target specific devices for push notifications","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Link devices to user accounts in your backend"}]}]}],"type":"unorderedList"},{"level":2,"anchor":"Example","text":"Example","type":"heading"},{"inlineContent":[{"text":"Sync device with your backend for cross-platform user tracking:","type":"text"}],"type":"paragraph"},{"code":["class DeviceRegistrationService {","","    func registerDeviceWithBackend(userId: String) {","        let hwid = Pushwoosh.configure.getHWID()","        let pushToken = Pushwoosh.configure.getPushToken()","","        let deviceInfo: [String: Any] = [","            \"hwid\": hwid,","            \"userId\": userId,","            \"pushToken\": pushToken ?? \"\",","            \"platform\": \"ios\",","            \"appVersion\": Bundle.main.appVersion,","            \"osVersion\": UIDevice.current.systemVersion","        ]","","        APIClient.shared.post(\"\/api\/devices\/register\", body: deviceInfo) { result in","            switch result {","            case .success:","                Logger.info(\"Device registered with backend: \\(hwid)\")","            case .failure(let error):","                Logger.error(\"Device registration failed: \\(error)\")","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"It may change if the user reinstalls all apps from the same vendor.","type":"text"}]}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getHWID","interfaceLanguage":"occ"},"metadata":{"roleHeading":"Type Method","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"getHWID"}],"modules":[{"name":"PushwooshCore"}],"title":"getHWID","externalID":"c:objc(pl)PWConfiguration(cm)getHWID","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"getHWID"}],"symbolKind":"method"},"abstract":[{"text":"Returns the Pushwoosh Hardware ID (HWID) for this device.","type":"text"}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/gethwid"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/p