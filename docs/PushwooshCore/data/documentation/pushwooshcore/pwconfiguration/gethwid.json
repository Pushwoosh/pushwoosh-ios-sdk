{"abstract":[{"type":"text","text":"Returns the Pushwoosh Hardware ID (HWID) for this device."}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"navigatorTitle":[{"text":"getHWID","kind":"identifier"}],"roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}],"role":"symbol","title":"getHWID","fragments":[{"kind":"text","text":"+ "},{"text":"getHWID","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)getHWID","symbolKind":"method"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/gethwid"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"text":" *) ","kind":"text"},{"text":"getHWID","kind":"identifier"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"kind":"content","content":[{"text":"Return Value","anchor":"return-value","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"The unique Pushwoosh device identifier (never nil)","type":"text"}]}]},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The HWID is a unique device identifier used in all Pushwoosh API calls and for device tracking"},{"text":" ","type":"text"},{"type":"text","text":"in the Pushwoosh Control Panel. On iOS, this is derived from "},{"type":"codeVoice","code":"UIDevice.identifierForVendor"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The HWID remains consistent across app launches and is used to:"}]},{"items":[{"content":[{"inlineContent":[{"text":"Identify the device in the Pushwoosh Control Panel","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Track user behavior and engagement","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Target specific devices for push notifications"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Link devices to user accounts in your backend"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"heading","anchor":"Example","level":2,"text":"Example"},{"inlineContent":[{"type":"text","text":"Sync device with your backend for cross-platform user tracking:"}],"type":"paragraph"},{"syntax":"swift","code":["class DeviceRegistrationService {","","    func registerDeviceWithBackend(userId: String) {","        let hwid = Pushwoosh.configure.getHWID()","        let pushToken = Pushwoosh.configure.getPushToken()","","        let deviceInfo: [String: Any] = [","            \"hwid\": hwid,","            \"userId\": userId,","            \"pushToken\": pushToken ?? \"\",","            \"platform\": \"ios\",","            \"appVersion\": Bundle.main.appVersion,","            \"osVersion\": UIDevice.current.systemVersion","        ]","","        APIClient.shared.post(\"\/api\/devices\/register\", body: deviceInfo) { result in","            switch result {","            case .success:","                Logger.info(\"Device registered with backend: \\(hwid)\")","            case .failure(let error):","                Logger.error(\"Device registration failed: \\(error)\")","            }","        }","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It may change if the user reinstalls all apps from the same vendor."}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getHWID","interfaceLanguage":"occ"},"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/getHWID":{"