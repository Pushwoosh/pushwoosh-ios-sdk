{"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"text":"NSString","preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"text":"getHWID","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Return Value","type":"heading","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"text":"The unique Pushwoosh device identifier (never nil)","type":"text"}]}]},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The HWID is a unique device identifier used in all Pushwoosh API calls and for device tracking"},{"text":" ","type":"text"},{"text":"in the Pushwoosh Control Panel. On iOS, this is derived from ","type":"text"},{"code":"UIDevice.identifierForVendor","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"The HWID remains consistent across app launches and is used to:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"text":"Identify the device in the Pushwoosh Control Panel","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Track user behavior and engagement"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Target specific devices for push notifications","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Link devices to user accounts in your backend"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"inlineContent":[{"type":"text","text":"Sync device with your backend for cross-platform user tracking:"}],"type":"paragraph"},{"type":"codeListing","code":["class DeviceRegistrationService {","","    func registerDeviceWithBackend(userId: String) {","        let hwid = Pushwoosh.configure.getHWID()","        let pushToken = Pushwoosh.configure.getPushToken()","","        let deviceInfo: [String: Any] = [","            \"hwid\": hwid,","            \"userId\": userId,","            \"pushToken\": pushToken ?? \"\",","            \"platform\": \"ios\",","            \"appVersion\": Bundle.main.appVersion,","            \"osVersion\": UIDevice.current.systemVersion","        ]","","        APIClient.shared.post(\"\/api\/devices\/register\", body: deviceInfo) { result in","            switch result {","            case .success:","                Logger.info(\"Device registered with backend: \\(hwid)\")","            case .failure(let error):","                Logger.error(\"Device registration failed: \\(error)\")","            }","        }","    }","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"It may change if the user reinstalls all apps from the same vendor."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"fragments":[{"kind":"text","text":"+ "},{"text":"getHWID","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","title":"getHWID","role":"symbol","symbolKind":"method","navigatorTitle":[{"text":"getHWID","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)getHWID"},"kind":"symbol","abstract":[{"type":"text","text":"Returns the Pushwoosh Hardware ID (HWID) for this device."}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getHWID","interfaceLanguage":"occ"},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/gethwid"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"abstract":[{"type":"text