{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"text":"NSString","preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"identifier","text":"getHWID"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"return-value","type":"heading","text":"Return Value"},{"type":"paragraph","inlineContent":[{"text":"The unique Pushwoosh device identifier (never nil)","type":"text"}]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"The HWID is a unique device identifier used in all Pushwoosh API calls and for device tracking"},{"type":"text","text":" "},{"type":"text","text":"in the Pushwoosh Control Panel. On iOS, this is derived from "},{"type":"codeVoice","code":"UIDevice.identifierForVendor"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The HWID remains consistent across app launches and is used to:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Identify the device in the Pushwoosh Control Panel","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Track user behavior and engagement","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Target specific devices for push notifications"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Link devices to user accounts in your backend"}]}]}],"type":"unorderedList"},{"level":2,"text":"Example","type":"heading","anchor":"Example"},{"type":"paragraph","inlineContent":[{"text":"Sync device with your backend for cross-platform user tracking:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["class DeviceRegistrationService {","","    func registerDeviceWithBackend(userId: String) {","        let hwid = Pushwoosh.configure.getHWID()","        let pushToken = Pushwoosh.configure.getPushToken()","","        let deviceInfo: [String: Any] = [","            \"hwid\": hwid,","            \"userId\": userId,","            \"pushToken\": pushToken ?? \"\",","            \"platform\": \"ios\",","            \"appVersion\": Bundle.main.appVersion,","            \"osVersion\": UIDevice.current.systemVersion","        ]","","        APIClient.shared.post(\"\/api\/devices\/register\", body: deviceInfo) { result in","            switch result {","            case .success:","                Logger.info(\"Device registered with backend: \\(hwid)\")","            case .failure(let error):","                Logger.error(\"Device registration failed: \\(error)\")","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It may change if the user reinstalls all apps from the same vendor."}]}]}],"metadata":{"modules":[{"name":"PushwooshCore"}],"role":"symbol","symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)getHWID","fragments":[{"text":"+ ","kind":"text"},{"text":"getHWID","kind":"identifier"}],"title":"getHWID","navigatorTitle":[{"kind":"identifier","text":"getHWID"}],"roleHeading":"Type Method"},"abstract":[{"type":"text","text":"Returns the Pushwoosh Hardware ID (HWID) for this device."}],"kind":"symbol","sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getHWID","interfaceLanguage":"occ"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/gethwid"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/getHWID":{"