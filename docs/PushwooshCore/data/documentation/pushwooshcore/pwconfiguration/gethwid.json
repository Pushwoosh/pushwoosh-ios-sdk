{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getHWID"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"abstract":[{"type":"text","text":"Returns the Pushwoosh Hardware ID (HWID) for this device."}],"sections":[],"metadata":{"symbolKind":"method","modules":[{"name":"PushwooshCore"}],"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"getHWID"}],"navigatorTitle":[{"text":"getHWID","kind":"identifier"}],"roleHeading":"Type Method","title":"getHWID","externalID":"c:objc(pl)PWConfiguration(cm)getHWID","role":"symbol"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"kind":"identifier","text":"getHWID"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}]},{"kind":"content","content":[{"level":2,"anchor":"return-value","text":"Return Value","type":"heading"},{"inlineContent":[{"text":"The unique Pushwoosh device identifier (never nil)","type":"text"}],"type":"paragraph"}]},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"The HWID is a unique device identifier used in all Pushwoosh API calls and for device tracking"},{"type":"text","text":" "},{"text":"in the Pushwoosh Control Panel. On iOS, this is derived from ","type":"text"},{"code":"UIDevice.identifierForVendor","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The HWID remains consistent across app launches and is used to:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Identify the device in the Pushwoosh Control Panel"}]}]},{"content":[{"inlineContent":[{"text":"Track user behavior and engagement","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Target specific devices for push notifications"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Link devices to user accounts in your backend","type":"text"}]}]}]},{"type":"heading","anchor":"Example","level":2,"text":"Example"},{"inlineContent":[{"text":"Sync device with your backend for cross-platform user tracking:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["class DeviceRegistrationService {","","    func registerDeviceWithBackend(userId: String) {","        let hwid = Pushwoosh.configure.getHWID()","        let pushToken = Pushwoosh.configure.getPushToken()","","        let deviceInfo: [String: Any] = [","            \"hwid\": hwid,","            \"userId\": userId,","            \"pushToken\": pushToken ?? \"\",","            \"platform\": \"ios\",","            \"appVersion\": Bundle.main.appVersion,","            \"osVersion\": UIDevice.current.systemVersion","        ]","","        APIClient.shared.post(\"\/api\/devices\/register\", body: deviceInfo) { result in","            switch result {","            case .success:","                Logger.info(\"Device registered with backend: \\(hwid)\")","            case .failure(let error):","                Logger.error(\"Device registration failed: \\(error)\")","            }","        }","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"It may change if the user reinstalls all apps from the same vendor.","type":"text"}]}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/gethwid"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/getHWID":{"