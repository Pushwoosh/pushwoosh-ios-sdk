{"abstract":[{"type":"text","text":"Returns the Pushwoosh Hardware ID (HWID) for this device."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/gethwid"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"text":"getHWID","kind":"identifier"},{"text":";","kind":"text"}],"platforms":["iOS"]}]},{"kind":"content","content":[{"type":"heading","text":"Return Value","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"text":"The unique Pushwoosh device identifier (never nil)","type":"text"}]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The HWID is a unique device identifier used in all Pushwoosh API calls and for device tracking","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in the Pushwoosh Control Panel. On iOS, this is derived from "},{"type":"codeVoice","code":"UIDevice.identifierForVendor"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"The HWID remains consistent across app launches and is used to:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Identify the device in the Pushwoosh Control Panel"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Track user behavior and engagement"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Target specific devices for push notifications"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Link devices to user accounts in your backend","type":"text"}]}]}],"type":"unorderedList"},{"level":2,"text":"Example","anchor":"Example","type":"heading"},{"inlineContent":[{"text":"Sync device with your backend for cross-platform user tracking:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class DeviceRegistrationService {","","    func registerDeviceWithBackend(userId: String) {","        let hwid = Pushwoosh.configure.getHWID()","        let pushToken = Pushwoosh.configure.getPushToken()","","        let deviceInfo: [String: Any] = [","            \"hwid\": hwid,","            \"userId\": userId,","            \"pushToken\": pushToken ?? \"\",","            \"platform\": \"ios\",","            \"appVersion\": Bundle.main.appVersion,","            \"osVersion\": UIDevice.current.systemVersion","        ]","","        APIClient.shared.post(\"\/api\/devices\/register\", body: deviceInfo) { result in","            switch result {","            case .success:","                Logger.info(\"Device registered with backend: \\(hwid)\")","            case .failure(let error):","                Logger.error(\"Device registration failed: \\(error)\")","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"It may change if the user reinstalls all apps from the same vendor.","type":"text"}]}]}],"metadata":{"fragments":[{"kind":"text","text":"+ "},{"text":"getHWID","kind":"identifier"}],"role":"symbol","symbolKind":"method","navigatorTitle":[{"text":"getHWID","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)getHWID","modules":[{"name":"PushwooshCore"}],"title":"getHWID","roleHeading":"Type Method"},"kind":"symbol","identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getHWID","interfaceLanguage":"occ"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"title":"PushwooshCore","kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/getHWID":{"url":"\/documentation\/pushwooshcore\/pwconfiguration\/gethwid","title":"getHWID","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getHWID","navigatorTitle":[{"text":"getHWID","kind":"identifier"}],"role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"getHWID"}],"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Returns the Pushwoosh Hardware ID (HWID) for this device."}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","role":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"kind":"symbol","type":"topic","abstract":[]}}}