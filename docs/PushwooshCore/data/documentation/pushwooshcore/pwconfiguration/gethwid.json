{"metadata":{"symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)getHWID","roleHeading":"Type Method","navigatorTitle":[{"kind":"identifier","text":"getHWID"}],"role":"symbol","modules":[{"name":"PushwooshCore"}],"title":"getHWID","fragments":[{"text":"+ ","kind":"text"},{"text":"getHWID","kind":"identifier"}]},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getHWID","interfaceLanguage":"occ"},"abstract":[{"text":"Returns the Pushwoosh Hardware ID (HWID) for this device.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"NSString","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString"},{"kind":"text","text":" *) "},{"text":"getHWID","kind":"identifier"},{"text":";","kind":"text"}]}]},{"content":[{"level":2,"anchor":"return-value","text":"Return Value","type":"heading"},{"inlineContent":[{"type":"text","text":"The unique Pushwoosh device identifier (never nil)"}],"type":"paragraph"}],"kind":"content"},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"The HWID is a unique device identifier used in all Pushwoosh API calls and for device tracking","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in the Pushwoosh Control Panel. On iOS, this is derived from "},{"type":"codeVoice","code":"UIDevice.identifierForVendor"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"The HWID remains consistent across app launches and is used to:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Identify the device in the Pushwoosh Control Panel"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Track user behavior and engagement"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Target specific devices for push notifications"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Link devices to user accounts in your backend","type":"text"}],"type":"paragraph"}]}]},{"text":"Example","level":2,"anchor":"Example","type":"heading"},{"inlineContent":[{"type":"text","text":"Sync device with your backend for cross-platform user tracking:"}],"type":"paragraph"},{"code":["class DeviceRegistrationService {","","    func registerDeviceWithBackend(userId: String) {","        let hwid = Pushwoosh.configure.getHWID()","        let pushToken = Pushwoosh.configure.getPushToken()","","        let deviceInfo: [String: Any] = [","            \"hwid\": hwid,","            \"userId\": userId,","            \"pushToken\": pushToken ?? \"\",","            \"platform\": \"ios\",","            \"appVersion\": Bundle.main.appVersion,","            \"osVersion\": UIDevice.current.systemVersion","        ]","","        APIClient.shared.post(\"\/api\/devices\/register\", body: deviceInfo) { result in","            switch result {","            case .success:","                Logger.info(\"Device registered with backend: \\(hwid)\")","            case .failure(let error):","                Logger.error(\"Device registration failed: \\(error)\")","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"It may change if the user reinstalls all apps from the same vendor.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/gethwid"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/getHWID":{"