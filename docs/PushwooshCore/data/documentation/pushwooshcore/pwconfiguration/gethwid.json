{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getHWID"},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSString","kind":"typeIdentifier","text":"NSString"},{"kind":"text","text":" *) "},{"kind":"identifier","text":"getHWID"},{"kind":"text","text":";"}],"languages":["occ"]}],"kind":"declarations"},{"content":[{"text":"Return Value","anchor":"return-value","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The unique Pushwoosh device identifier (never nil)"}]}],"kind":"content"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The HWID is a unique device identifier used in all Pushwoosh API calls and for device tracking"},{"type":"text","text":" "},{"type":"text","text":"in the Pushwoosh Control Panel. On iOS, this is derived from "},{"type":"codeVoice","code":"UIDevice.identifierForVendor"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"The HWID remains consistent across app launches and is used to:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Identify the device in the Pushwoosh Control Panel","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Track user behavior and engagement","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Target specific devices for push notifications"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Link devices to user accounts in your backend","type":"text"}]}]}]},{"text":"Example","anchor":"Example","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Sync device with your backend for cross-platform user tracking:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class DeviceRegistrationService {","","    func registerDeviceWithBackend(userId: String) {","        let hwid = Pushwoosh.configure.getHWID()","        let pushToken = Pushwoosh.configure.getPushToken()","","        let deviceInfo: [String: Any] = [","            \"hwid\": hwid,","            \"userId\": userId,","            \"pushToken\": pushToken ?? \"\",","            \"platform\": \"ios\",","            \"appVersion\": Bundle.main.appVersion,","            \"osVersion\": UIDevice.current.systemVersion","        ]","","        APIClient.shared.post(\"\/api\/devices\/register\", body: deviceInfo) { result in","            switch result {","            case .success:","                Logger.info(\"Device registered with backend: \\(hwid)\")","            case .failure(let error):","                Logger.error(\"Device registration failed: \\(error)\")","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It may change if the user reinstalls all apps from the same vendor."}]}]}],"metadata":{"symbolKind":"method","role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)getHWID","roleHeading":"Type Method","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"getHWID"}],"navigatorTitle":[{"kind":"identifier","text":"getHWID"}],"modules":[{"name":"PushwooshCore"}],"title":"getHWID"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/gethwid"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"Returns the Pushwoosh Hardware ID (HWID) for this device.","type":"text"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/getHWID":{"