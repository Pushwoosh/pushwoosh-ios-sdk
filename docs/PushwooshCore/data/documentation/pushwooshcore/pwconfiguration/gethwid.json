{"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/gethwid"]}],"abstract":[{"type":"text","text":"Returns the Pushwoosh Hardware ID (HWID) for this device."}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getHWID","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString","text":"NSString"},{"text":" *) ","kind":"text"},{"kind":"identifier","text":"getHWID"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"content":[{"anchor":"return-value","text":"Return Value","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The unique Pushwoosh device identifier (never nil)"}],"type":"paragraph"}],"kind":"content"},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The HWID is a unique device identifier used in all Pushwoosh API calls and for device tracking","type":"text"},{"text":" ","type":"text"},{"text":"in the Pushwoosh Control Panel. On iOS, this is derived from ","type":"text"},{"code":"UIDevice.identifierForVendor","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The HWID remains consistent across app launches and is used to:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Identify the device in the Pushwoosh Control Panel","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Track user behavior and engagement"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Target specific devices for push notifications","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Link devices to user accounts in your backend"}]}]}]},{"text":"Example","level":2,"anchor":"Example","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Sync device with your backend for cross-platform user tracking:"}]},{"syntax":"swift","type":"codeListing","code":["class DeviceRegistrationService {","","    func registerDeviceWithBackend(userId: String) {","        let hwid = Pushwoosh.configure.getHWID()","        let pushToken = Pushwoosh.configure.getPushToken()","","        let deviceInfo: [String: Any] = [","            \"hwid\": hwid,","            \"userId\": userId,","            \"pushToken\": pushToken ?? \"\",","            \"platform\": \"ios\",","            \"appVersion\": Bundle.main.appVersion,","            \"osVersion\": UIDevice.current.systemVersion","        ]","","        APIClient.shared.post(\"\/api\/devices\/register\", body: deviceInfo) { result in","            switch result {","            case .success:","                Logger.info(\"Device registered with backend: \\(hwid)\")","            case .failure(let error):","                Logger.error(\"Device registration failed: \\(error)\")","            }","        }","    }","}"]},{"inlineContent":[{"text":"It may change if the user reinstalls all apps from the same vendor.","type":"text"}],"type":"paragraph"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"metadata":{"modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"text":"getHWID","kind":"identifier"}],"roleHeading":"Type Method","role":"symbol","title":"getHWID","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"getHWID"}],"externalID":"c:objc(pl)PWConfiguration(cm)getHWID","symbolKind":"method"},"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"t