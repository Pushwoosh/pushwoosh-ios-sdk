{"abstract":[{"type":"text","text":"Registers the device for push notifications."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"text":"registerForPushNotifications","kind":"identifier"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method initiates the push notification registration process:"}]},{"items":[{"content":[{"inlineContent":[{"text":"Requests user permission to display notifications (alert, badge, sound)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Registers the device with Apple Push Notification service (APNs)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Sends the device token to Pushwoosh servers","type":"text"}]}]}],"type":"orderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The permission dialog is shown only once per app installation. If the user denies permission,"},{"text":" ","type":"text"},{"type":"text","text":"subsequent calls will not show the dialog. Users must manually enable notifications in Settings."}]},{"anchor":"Example","text":"Example","level":2,"type":"heading"},{"inlineContent":[{"text":"Standard registration in AppDelegate:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class AppDelegate: UIResponder, UIApplicationDelegate, PWMessagingDelegate {","","    func application(_ application: UIApplication,","                    didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","        \/\/ Configure delegate first to receive callbacks","        Pushwoosh.configure.setDelegate(self)","","        \/\/ Enable foreground notification display","        Pushwoosh.configure.setShowPushnotificationAlert(true)","","        \/\/ Register for push notifications","        Pushwoosh.configure.registerForPushNotifications()","","        return true","    }","","    \/\/ MARK: - PWMessagingDelegate","","    func pushwoosh(_ pushwoosh: Pushwoosh, onMessageReceived message: PWMessage) {","        Logger.info(\"Push received: \\(message.title ?? \"No title\")\")","","        \/\/ Handle silent push or update UI","        if message.isContentAvailable {","            performBackgroundFetch()","        }","    }","","    func pushwoosh(_ pushwoosh: Pushwoosh, onMessageOpened message: PWMessage) {","        Logger.info(\"Push opened: \\(message.title ?? \"No title\")\")","","        \/\/ Handle deep link if present","        if let link = message.link, let url = URL(string: link) {","            DeepLinkHandler.shared.handle(url)","        }","","        \/\/ Track notification open in analytics","        Analytics.track(\"notification_opened\", properties: [","            \"message_id\": message.messageCode ?? \"\",","            \"campaign_id\": message.campaignId","        ])","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Deferred registration after onboarding:"}]},{"code":["class OnboardingViewController: UIViewController {","","    @IBAction func enableNotificationsTapped(_ sender: UIButton) {","        \/\/ Show explanation before system prompt","        showNotificationBenefits { [weak self] in","            Pushwoosh.configure.registerForPushNotifications()","            self?.proceedToNextStep()","        }","    }","","    private func showNotificationBenefits(completion: @escaping () -> Void) {","        let alert = UIAlertController(","            title: \"Stay Updated\",","            message: \"Enable notifications to receive order updates, exclusive offers, and important alerts.\",","            preferredStyle: .alert","        )","        alert.addAction(UIAlertAction(title: \"Enable\", style: .default) { _ in","            completion()","        })","        alert.addAction(UIAlertAction(title: \"Not Now\", style: .cancel) { _ in","            self.proceedToNextStep()","        })","        present(alert, animated: true)","    }","}"],"syntax":"swift","type":"codeListing"}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotifications"},"sections":[],"metadata":{"symbolKind":"method","fragments":[{"kind":"text","text":"+ "},{"text":"registerForPushNotifications","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"registerForPushNotifications"}],"roleHeading":"Type Method","externalID":"c:objc(pl)PWConfiguration(cm)registerForPushNotifications","modules":[{"name":"PushwooshCore"}],"title":"registerForPushNotifications"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotifications"]}],"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","title":"PushwooshCore","role":"collection","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"kind":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","title":"PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"role":"symbol","abstract":[]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerForPushNotifications":{"url":"\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotifications","type":"topic","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotifications","title":"registerForPushNotifications","fragments":[{"text":"+ ","kind":"text"},{"text":"registerForPushNotifications","kind":"identifier"}],"navigatorTitle":[{"text":"registerForPushNotifications","kind":"identifier"}],"abstract":[{"type":"text","text":"Registers the device for push notifications."}],"role":"symbol"}}}