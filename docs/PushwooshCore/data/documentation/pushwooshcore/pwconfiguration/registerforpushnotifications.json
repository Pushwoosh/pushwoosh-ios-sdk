{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:v","kind":"typeIdentifier","text":"void"},{"kind":"text","text":") "},{"text":"registerForPushNotifications","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method initiates the push notification registration process:"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Requests user permission to display notifications (alert, badge, sound)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Registers the device with Apple Push Notification service (APNs)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Sends the device token to Pushwoosh servers","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The permission dialog is shown only once per app installation. If the user denies permission,"},{"text":" ","type":"text"},{"type":"text","text":"subsequent calls will not show the dialog. Users must manually enable notifications in Settings."}]},{"text":"Example","level":2,"type":"heading","anchor":"Example"},{"inlineContent":[{"text":"Standard registration in AppDelegate:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class AppDelegate: UIResponder, UIApplicationDelegate, PWMessagingDelegate {","","    func application(_ application: UIApplication,","                    didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","","        \/\/ Configure delegate first to receive callbacks","        Pushwoosh.configure.setDelegate(self)","","        \/\/ Enable foreground notification display","        Pushwoosh.configure.setShowPushnotificationAlert(true)","","        \/\/ Register for push notifications","        Pushwoosh.configure.registerForPushNotifications()","","        return true","    }","","    \/\/ MARK: - PWMessagingDelegate","","    func pushwoosh(_ pushwoosh: Pushwoosh, onMessageReceived message: PWMessage) {","        Logger.info(\"Push received: \\(message.title ?? \"No title\")\")","","        \/\/ Handle silent push or update UI","        if message.isContentAvailable {","            performBackgroundFetch()","        }","    }","","    func pushwoosh(_ pushwoosh: Pushwoosh, onMessageOpened message: PWMessage) {","        Logger.info(\"Push opened: \\(message.title ?? \"No title\")\")","","        \/\/ Handle deep link if present","        if let link = message.link, let url = URL(string: link) {","            DeepLinkHandler.shared.handle(url)","        }","","        \/\/ Track notification open in analytics","        Analytics.track(\"notification_opened\", properties: [","            \"message_id\": message.messageCode ?? \"\",","            \"campaign_id\": message.campaignId","        ])","    }","}"]},{"inlineContent":[{"type":"text","text":"Deferred registration after onboarding:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class OnboardingViewController: UIViewController {","","    @IBAction func enableNotificationsTapped(_ sender: UIButton) {","        \/\/ Show explanation before system prompt","        showNotificationBenefits { [weak self] in","            Pushwoosh.configure.registerForPushNotifications()","            self?.proceedToNextStep()","        }","    }","","    private func showNotificationBenefits(completion: @escaping () -> Void) {","        let alert = UIAlertController(","            title: \"Stay Updated\",","            message: \"Enable notifications to receive order updates, exclusive offers, and important alerts.\",","            preferredStyle: .alert","        )","        alert.addAction(UIAlertAction(title: \"Enable\", style: .default) { _ in","            completion()","        })","        alert.addAction(UIAlertAction(title: \"Not Now\", style: .cancel) { _ in","            self.proceedToNextStep()","        })","        present(alert, animated: true)","    }","}"]}]}],"abstract":[{"text":"Registers the device for push notifications.","type":"text"}],"sections":[],"metadata":{"role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)registerForPushNotifications","roleHeading":"Type Method","symbolKind":"method","modules":[{"name":"PushwooshCore"}],"title":"registerForPushNotifications","fragments":[{"kind":"text","text":"+ "},{"text":"registerForPushNotifications","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"registerForPushNotifications"}]},"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotifications"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotifications"]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","abstract":[],"fragments":[{"kind":"identifier","text":"PWConfiguration"}],"title":"PWConfiguration","kind":"symbol","role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","url":"\/documentation\/pushwooshcore","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"role":"collection"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/registerForPushNotifications":{"kind":"symbol","abstract":[{"text":"Registers the device for push notifications.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"registerForPushNotifications"}],"type":"topic","role":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"registerForPushNotifications","kind":"identifier"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/registerforpushnotifications","title":"registerForPushNotifications","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/registerForPushNotifications"}}}