{"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handleOpenURL:"},"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/handleopenurl:"]}],"abstract":[{"type":"text","text":"Processes deep link URLs for Pushwoosh SDK functionality."}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","sections":[],"metadata":{"roleHeading":"Type Method","symbolKind":"method","navigatorTitle":[{"text":"handleOpenURL:","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)handleOpenURL:","title":"handleOpenURL:","modules":[{"name":"PushwooshCore"}],"fragments":[{"kind":"text","text":"+ "},{"text":"handleOpenURL:","kind":"identifier"}],"role":"symbol"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@BOOL","text":"BOOL"},{"kind":"text","text":") "},{"kind":"identifier","text":"handleOpenURL:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSURL","text":"NSURL","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"text":"url","kind":"internalParam"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"The URL to process.","type":"text"}],"type":"paragraph"}],"name":"url"}]},{"kind":"content","content":[{"type":"heading","anchor":"return-value","level":2,"text":"Return Value"},{"inlineContent":[{"type":"text","text":"YES if the URL was handled by Pushwoosh, NO otherwise."}],"type":"paragraph"}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"Handles special Pushwoosh URLs, primarily used for:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Test device registration"}]},{"type":"text","text":": Register device for push testing via QR code"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Deep link tracking"}]},{"type":"text","text":": Process tracked deep links from push notifications"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"Should be called from your app’s URL handling methods. Returns YES if the URL","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"was a Pushwoosh URL and was handled, NO if it should be processed by your app."}]},{"level":2,"text":"Example","type":"heading","anchor":"Example"},{"inlineContent":[{"text":"Handle URLs in SceneDelegate (iOS 13+):","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class SceneDelegate: UIResponder, UIWindowSceneDelegate {","","    func scene(_ scene: UIScene, openURLContexts URLContexts: Set<UIOpenURLContext>) {","        guard let url = URLContexts.first?.url else { return }","","        \/\/ First, check if Pushwoosh handles this URL","        if Pushwoosh.configure.handleOpenURL(url) {","            Logger.info(\"URL handled by Pushwoosh\")","            return","        }","","        \/\/ Handle other deep links","        DeepLinkRouter.shared.handle(url)","    }","","    func scene(_ scene: UIScene, continue userActivity: NSUserActivity) {","        guard userActivity.activityType == NSUserActivityTypeBrowsingWeb,","              let url = userActivity.webpageURL else { return }","","        if Pushwoosh.configure.handleOpenURL(url) {","            return","        }","","        UniversalLinkRouter.shared.handle(url)","    }","}","","\/\/ Legacy AppDelegate support","class AppDelegate: UIApplicationDelegate {","","    func application(_ app: UIApplication,","                    open url: URL,","                    options: [UIApplication.OpenURLOptionsKey: Any] = [:]) -> Bool {","","        if Pushwoosh.configure.handleOpenURL(url) {","            return true","        }","","        return DeepLinkRouter.shared.handle(url)","    }","}"]}]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","kind":"symbol","title":"PWConfiguration","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","abstract":[],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/handleOpenURL:":{"role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/handleopenurl:","kind":"symbol","abstract":[{"type":"text","text":"Processes deep link URLs for Pushwoosh SDK functionality."}],"navigatorTitle":[{"text":"handleOpenURL:","kind":"identifier"}],"title":"handleOpenURL:","type":"topic","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"handleOpenURL:"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handleOpenURL:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","title":"PushwooshCore","role":"collection","url":"\/documentation\/pushwooshcore"}}}