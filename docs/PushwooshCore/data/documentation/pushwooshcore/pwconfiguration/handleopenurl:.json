{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handleOpenURL:","interfaceLanguage":"occ"},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/handleopenurl:"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"symbolKind":"method","fragments":[{"text":"+ ","kind":"text"},{"text":"handleOpenURL:","kind":"identifier"}],"roleHeading":"Type Method","navigatorTitle":[{"text":"handleOpenURL:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)handleOpenURL:","title":"handleOpenURL:"},"sections":[],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"BOOL","kind":"typeIdentifier","preciseIdentifier":"c:@T@BOOL"},{"kind":"text","text":") "},{"kind":"identifier","text":"handleOpenURL:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSURL","text":"NSURL","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"url"},{"kind":"text","text":";"}]}]},{"kind":"parameters","parameters":[{"name":"url","content":[{"inlineContent":[{"type":"text","text":"The URL to process."}],"type":"paragraph"}]}]},{"content":[{"type":"heading","anchor":"return-value","text":"Return Value","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"YES if the URL was handled by Pushwoosh, NO otherwise."}]}],"kind":"content"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handles special Pushwoosh URLs, primarily used for:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Test device registration","type":"text"}]},{"text":": Register device for push testing via QR code","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Deep link tracking","type":"text"}],"type":"strong"},{"text":": Process tracked deep links from push notifications","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Should be called from your app’s URL handling methods. Returns YES if the URL"},{"type":"text","text":" "},{"type":"text","text":"was a Pushwoosh URL and was handled, NO if it should be processed by your app."}],"type":"paragraph"},{"anchor":"Example","level":2,"text":"Example","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle URLs in SceneDelegate (iOS 13+):"}]},{"syntax":"swift","code":["class SceneDelegate: UIResponder, UIWindowSceneDelegate {","","    func scene(_ scene: UIScene, openURLContexts URLContexts: Set<UIOpenURLContext>) {","        guard let url = URLContexts.first?.url else { return }","","        \/\/ First, check if Pushwoosh handles this URL","        if Pushwoosh.configure.handleOpenURL(url) {","            Logger.info(\"URL handled by Pushwoosh\")","            return","        }","","        \/\/ Handle other deep links","        DeepLinkRouter.shared.handle(url)","    }","","    func scene(_ scene: UIScene, continue userActivity: NSUserActivity) {","        guard userActivity.activityType == NSUserActivityTypeBrowsingWeb,","              let url = userActivity.webpageURL else { return }","","        if Pushwoosh.configure.handleOpenURL(url) {","            return","        }","","        UniversalLinkRouter.shared.handle(url)","    }","}","","\/\/ Legacy AppDelegate support","class AppDelegate: UIApplicationDelegate {","","    func application(_ app: UIApplication,","                    open url: URL,","                    options: [UIApplication.OpenURLOptionsKey: Any] = [:]) -> Bool {","","        if Pushwoosh.configure.handleOpenURL(url) {","            return true","        }","","        return DeepLinkRouter.shared.handle(url)","    }","}"],"type":"codeListing"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"abstract":[{"type":"text","text":"Processes deep link URLs for Pushwoosh SDK functionality."}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"role":"symbol","abstract":[],"title":"PWConfiguration","kind":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/handleOpenURL:":{"role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/handleopenurl:","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"handleOpenURL:"}],"navigatorTitle":[{"text":"handleOpenURL:","kind":"identifier"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handleOpenURL:","type":"topic","title":"handleOpenURL:","kind":"symbol","abstract":[{"type":"text","text":"Processes deep link URLs for Pushwoosh SDK functionality."}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","title":"PushwooshCore","role":"collection","type":"topic"}}}