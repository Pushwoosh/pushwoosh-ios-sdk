{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handleOpenURL:","interfaceLanguage":"occ"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"text":"BOOL","kind":"typeIdentifier","preciseIdentifier":"c:@T@BOOL"},{"text":") ","kind":"text"},{"text":"handleOpenURL:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSURL","kind":"typeIdentifier","text":"NSURL"},{"text":" *) ","kind":"text"},{"text":"url","kind":"internalParam"},{"kind":"text","text":";"}],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"name":"url","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The URL to process."}]}]}]},{"content":[{"level":2,"type":"heading","text":"Return Value","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"YES if the URL was handled by Pushwoosh, NO otherwise."}]}],"kind":"content"},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handles special Pushwoosh URLs, primarily used for:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Test device registration","type":"text"}],"type":"strong"},{"text":": Register device for push testing via QR code","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Deep link tracking","type":"text"}]},{"text":": Process tracked deep links from push notifications","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Should be called from your app’s URL handling methods. Returns YES if the URL"},{"type":"text","text":" "},{"text":"was a Pushwoosh URL and was handled, NO if it should be processed by your app.","type":"text"}]},{"text":"Example","type":"heading","anchor":"Example","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle URLs in SceneDelegate (iOS 13+):"}]},{"code":["class SceneDelegate: UIResponder, UIWindowSceneDelegate {","","    func scene(_ scene: UIScene, openURLContexts URLContexts: Set<UIOpenURLContext>) {","        guard let url = URLContexts.first?.url else { return }","","        \/\/ First, check if Pushwoosh handles this URL","        if Pushwoosh.configure.handleOpenURL(url) {","            Logger.info(\"URL handled by Pushwoosh\")","            return","        }","","        \/\/ Handle other deep links","        DeepLinkRouter.shared.handle(url)","    }","","    func scene(_ scene: UIScene, continue userActivity: NSUserActivity) {","        guard userActivity.activityType == NSUserActivityTypeBrowsingWeb,","              let url = userActivity.webpageURL else { return }","","        if Pushwoosh.configure.handleOpenURL(url) {","            return","        }","","        UniversalLinkRouter.shared.handle(url)","    }","}","","\/\/ Legacy AppDelegate support","class AppDelegate: UIApplicationDelegate {","","    func application(_ app: UIApplication,","                    open url: URL,","                    options: [UIApplication.OpenURLOptionsKey: Any] = [:]) -> Bool {","","        if Pushwoosh.configure.handleOpenURL(url) {","            return true","        }","","        return DeepLinkRouter.shared.handle(url)","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"metadata":{"role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)handleOpenURL:","symbolKind":"method","navigatorTitle":[{"text":"handleOpenURL:","kind":"identifier"}],"title":"handleOpenURL:","modules":[{"name":"PushwooshCore"}],"roleHeading":"Type Method","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"handleOpenURL:"}]},"sections":[],"abstract":[{"type":"text","text":"Processes deep link URLs for Pushwoosh SDK functionality."}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/handleopenurl:"]}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/handleOpenURL:":{"role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handleOpenURL:","navigatorTitle":[{"kind":"identifier","text":"handleOpenURL:"}],"type":"topic","url":"\/documentation\/pushwooshcore\/pwconfiguration\/handleopenurl:","fragments":[{"kind":"text","text":"+ "},{"text":"handleOpenURL:","kind":"identifier"}],"abstract":[{"type":"text","text":"Processes deep link URLs for Pushwoosh SDK functionality."}],"kind":"symbol","title":"handleOpenURL:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","title":"PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","kind":"symbol","abstract":[],"role":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","type":"topic","kind":"symbol","url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","role":"collection","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}]}}}