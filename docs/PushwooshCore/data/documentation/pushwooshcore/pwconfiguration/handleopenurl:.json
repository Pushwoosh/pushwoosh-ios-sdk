{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"symbolKind":"method","modules":[{"name":"PushwooshCore"}],"fragments":[{"text":"+ ","kind":"text"},{"text":"handleOpenURL:","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"handleOpenURL:"}],"roleHeading":"Type Method","title":"handleOpenURL:","externalID":"c:objc(pl)PWConfiguration(cm)handleOpenURL:","role":"symbol"},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/handleopenurl:"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"abstract":[{"text":"Processes deep link URLs for Pushwoosh SDK functionality.","type":"text"}],"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handleOpenURL:"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:@T@BOOL","kind":"typeIdentifier","text":"BOOL"},{"kind":"text","text":") "},{"text":"handleOpenURL:","kind":"identifier"},{"kind":"text","text":"("},{"text":"NSURL","preciseIdentifier":"c:objc(cs)NSURL","kind":"typeIdentifier"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"url"},{"text":";","kind":"text"}]}]},{"kind":"parameters","parameters":[{"name":"url","content":[{"type":"paragraph","inlineContent":[{"text":"The URL to process.","type":"text"}]}]}]},{"content":[{"level":2,"anchor":"return-value","text":"Return Value","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"YES if the URL was handled by Pushwoosh, NO otherwise.","type":"text"}]}],"kind":"content"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"Handles special Pushwoosh URLs, primarily used for:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Test device registration","type":"text"}]},{"type":"text","text":": Register device for push testing via QR code"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Deep link tracking","type":"text"}],"type":"strong"},{"text":": Process tracked deep links from push notifications","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Should be called from your app’s URL handling methods. Returns YES if the URL","type":"text"},{"type":"text","text":" "},{"type":"text","text":"was a Pushwoosh URL and was handled, NO if it should be processed by your app."}]},{"text":"Example","type":"heading","level":2,"anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle URLs in SceneDelegate (iOS 13+):"}]},{"syntax":"swift","code":["class SceneDelegate: UIResponder, UIWindowSceneDelegate {","","    func scene(_ scene: UIScene, openURLContexts URLContexts: Set<UIOpenURLContext>) {","        guard let url = URLContexts.first?.url else { return }","","        \/\/ First, check if Pushwoosh handles this URL","        if Pushwoosh.configure.handleOpenURL(url) {","            Logger.info(\"URL handled by Pushwoosh\")","            return","        }","","        \/\/ Handle other deep links","        DeepLinkRouter.shared.handle(url)","    }","","    func scene(_ scene: UIScene, continue userActivity: NSUserActivity) {","        guard userActivity.activityType == NSUserActivityTypeBrowsingWeb,","              let url = userActivity.webpageURL else { return }","","        if Pushwoosh.configure.handleOpenURL(url) {","            return","        }","","        UniversalLinkRouter.shared.handle(url)","    }","}","","\/\/ Legacy AppDelegate support","class AppDelegate: UIApplicationDelegate {","","    func application(_ app: UIApplication,","                    open url: URL,","                    options: [UIApplication.OpenURLOptionsKey: Any] = [:]) -> Bool {","","        if Pushwoosh.configure.handleOpenURL(url) {","            return true","        }","","        return DeepLinkRouter.shared.handle(url)","    }","}"],"type":"codeListing"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"role":"symbol","abstract":[],"kind":"symbol","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","url":"\/documentation\/pushwooshcore","role":"collection"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/handleOpenURL:":{"abstract":[{"text":"Processes deep link URLs for Pushwoosh SDK functionality.","type":"text"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/handleopenurl:","role":"symbol","navigatorTitle":[{"text":"handleOpenURL:","kind":"identifier"}],"title":"handleOpenURL:","kind":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"handleOpenURL:","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/handleOpenURL:"}}}