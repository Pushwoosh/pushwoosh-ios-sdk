{"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemail:"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Associates an email address with the current device."}],"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmail:"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"kind":"identifier","text":"setEmail:"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSString","text":"NSString"},{"kind":"text","text":" *) "},{"kind":"internalParam","text":"email"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"parameters":[{"name":"email","content":[{"inlineContent":[{"text":"The user’s email address (must be valid and non-empty)","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Register an email for the current user to enable:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Email-based campaigns and targeting"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cross-device user identification"}]}]},{"content":[{"inlineContent":[{"text":"Email channel for multi-channel messaging","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Example","level":2,"text":"Example","type":"heading"},{"inlineContent":[{"text":"Set email after user verification:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class UserAccountManager {","","    func handleEmailVerification(email: String, verificationCode: String) async throws {","        \/\/ Verify email with backend","        try await APIClient.shared.verifyEmail(email: email, code: verificationCode)","","        \/\/ Update Pushwoosh with verified email","        Pushwoosh.configure.setEmail(email)","","        \/\/ Update tags to reflect verified status","        Pushwoosh.configure.setTags([","            \"email_verified\": true,","            \"email_verified_date\": Date()","        ])","","        Logger.info(\"Email verified and synced with Pushwoosh: \\(email)\")","    }","","    func handleProfileUpdate(email: String?, phone: String?) {","        if let email = email, !email.isEmpty {","            Pushwoosh.configure.setEmail(email)","        }","","        \/\/ Update other contact methods via tags","        var tags: [String: Any] = [:]","        if let phone = phone {","            tags[\"phone_number\"] = phone","        }","        if !tags.isEmpty {","            Pushwoosh.configure.setTags(tags)","        }","    }","}"]}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)setEmail:","symbolKind":"method","title":"setEmail:","modules":[{"name":"PushwooshCore"}],"fragments":[{"text":"+ ","kind":"text"},{"text":"setEmail:","kind":"identifier"}],"roleHeading":"Type Method","navigatorTitle":[{"kind":"identifier","text":"setEmail:"}],"role":"symbol"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmail:":{"abstract":[{"type":"text","text":"Associates an email address with the current device."}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setEmail:"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemail:","kind":"symbol","navigatorTitle":[{"text":"setEmail:","kind":"identifier"}],"type":"topic","identifier":"doc:\/\