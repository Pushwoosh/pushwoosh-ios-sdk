ed_date\": Date()","        ])","","        Logger.info(\"Email verified and synced with Pushwoosh: \\(email)\")","    }","","    func handleProfileUpdate(email: String?, phone: String?) {","        if let email = email, !email.isEmpty {","            Pushwoosh.configure.setEmail(email)","        }","","        \/\/ Update other contact methods via tags","        var tags: [String: Any] = [:]","        if let phone = phone {","            tags[\"phone_number\"] = phone","        }","        if !tags.isEmpty {","            Pushwoosh.configure.setTags(tags)","        }","    }","}"]}]}],"sections":[],"kind":"symbol","abstract":[{"type":"text","text":"Associates an email address with the current device."}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setemail:"]}],"metadata":{"navigatorTitle":[{"kind":"identifier","text":"setEmail:"}],"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setEmail:"}],"externalID":"c:objc(pl)PWConfiguration(cm)setEmail:","title":"setEmail:","symbolKind":"method","roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}],"role":"symbol"},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmail:","interfaceLanguage":"occ"},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setEmail:":{"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setEmail:"}],"title":"setEmail:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setemail:","type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setEmail:","kind":"symbol","abstract":[{"text":"Associates an email ad