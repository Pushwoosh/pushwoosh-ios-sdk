{"abstract":[{"type":"text","text":"Retrieves the current device’s tags from the Pushwoosh server."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"getTags:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:BFv(#*$objc(cs)NSDictionary)","text":"void (^)(NSDictionary *)"},{"kind":"text","text":") "},{"kind":"internalParam","text":"successHandler"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onFailure:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:BFv(#*$objc(cs)NSError)","kind":"typeIdentifier","text":"void (^)(NSError *)"},{"text":") ","kind":"text"},{"text":"errorHandler","kind":"internalParam"},{"kind":"text","text":";"}]}]},{"parameters":[{"name":"successHandler","content":[{"type":"paragraph","inlineContent":[{"text":"Block called when tags are successfully retrieved.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Receives a dictionary containing all device tags, or nil if no tags are set."}]}]},{"name":"errorHandler","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Block called if the request fails."},{"type":"text","text":" "},{"text":"Receives an NSError describing the failure.","type":"text"}]}]}],"kind":"parameters"},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Alternative method name for "},{"type":"codeVoice","code":"loadTags:error:"},{"text":" following common SDK naming conventions.","type":"text"},{"type":"text","text":" "},{"text":"Fetches all tags currently associated with this device from the Pushwoosh server.","type":"text"}],"type":"paragraph"},{"text":"Example","anchor":"Example","level":2,"type":"heading"},{"inlineContent":[{"text":"Verify tag updates were applied:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["class TagVerificationService {","","    func verifyTagsApplied(expectedTags: [String: Any],","                          completion: @escaping (Bool) -> Void) {","","        Pushwoosh.configure.getTags({ tags in","            guard let serverTags = tags else {","                completion(false)","                return","            }","","            let allMatch = expectedTags.allSatisfy { key, expectedValue in","                guard let serverValue = serverTags[key] else { return false }","","                if let expected = expectedValue as? String,","                   let server = serverValue as? String {","                    return expected == server","                }","                if let expected = expectedValue as? NSNumber,","                   let server = serverValue as? NSNumber {","                    return expected == server","                }","                return false","            }","","            completion(allMatch)","","        }, onFailure: { error in","            Logger.error(\"Tag verification failed: \\(error?.localizedDescription ?? \"Unknown\")\")","            completion(false)","        })","    }","}"],"syntax":"swift"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"roleHeading":"Type Method","navigatorTitle":[{"kind":"identifier","text":"getTags:onFailure:"}],"title":"getTags:onFailure:","symbolKind":"method","externalID":"c:objc(pl)PWConfiguration(cm)getTags:onFailure:","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"getTags:onFailure:"}],"role":"symbol","modules":[{"name":"PushwooshCore"}]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/gettags:onfailure: