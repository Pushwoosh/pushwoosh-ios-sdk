{"sections":[],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getTags:onFailure:"},"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","abstract":[{"type":"text","text":"Retrieves the current device’s tags from the Pushwoosh server."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"getTags:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"void (^)(NSDictionary *)","preciseIdentifier":"c:BFv(#*$objc(cs)NSDictionary)"},{"kind":"text","text":") "},{"kind":"internalParam","text":"successHandler"},{"text":" ","kind":"text"},{"text":"onFailure:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:BFv(#*$objc(cs)NSError)","kind":"typeIdentifier","text":"void (^)(NSError *)"},{"text":") ","kind":"text"},{"text":"errorHandler","kind":"internalParam"},{"text":";","kind":"text"}]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"Block called when tags are successfully retrieved."},{"type":"text","text":" "},{"type":"text","text":"Receives a dictionary containing all device tags, or nil if no tags are set."}],"type":"paragraph"}],"name":"successHandler"},{"content":[{"inlineContent":[{"type":"text","text":"Block called if the request fails."},{"type":"text","text":" "},{"type":"text","text":"Receives an NSError describing the failure."}],"type":"paragraph"}],"name":"errorHandler"}]},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Alternative method name for ","type":"text"},{"type":"codeVoice","code":"loadTags:error:"},{"text":" following common SDK naming conventions.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Fetches all tags currently associated with this device from the Pushwoosh server."}]},{"anchor":"Example","type":"heading","text":"Example","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Verify tag updates were applied:"}]},{"syntax":"swift","type":"codeListing","code":["class TagVerificationService {","","    func verifyTagsApplied(expectedTags: [String: Any],","                          completion: @escaping (Bool) -> Void) {","","        Pushwoosh.configure.getTags({ tags in","            guard let serverTags = tags else {","                completion(false)","                return","            }","","            let allMatch = expectedTags.allSatisfy { key, expectedValue in","                guard let serverValue = serverTags[key] else { return false }","","                if let expected = expectedValue as? String,","                   let server = serverValue as? String {","                    return expected == server","                }","                if let expected = expectedValue as? NSNumber,","                   let server = serverValue as? NSNumber {","                    return expected == server","                }","                return false","            }","","            completion(allMatch)","","        }, onFailure: { error in","            Logger.error(\"Tag verification failed: \\(error?.localizedDescription ?? \"Unknown\")\")","            completion(false)","        })","    }","}"]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/gettags:onfailure:"]}],"metadata":{"symbolKind":"method","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"getTags:onFailure:"}],"modules":[{"name":"PushwooshCore"}],"role":"symbol","ex