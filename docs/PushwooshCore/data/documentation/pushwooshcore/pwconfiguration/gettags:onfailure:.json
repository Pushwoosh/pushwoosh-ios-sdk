{"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getTags:onFailure:"},"sections":[],"abstract":[{"text":"Retrieves the current device’s tags from the Pushwoosh server.","type":"text"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"declarations":[{"languages":["occ"],"tokens":[{"kind":"text","text":"+ ("},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"getTags:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"void (^)(NSDictionary *)","kind":"typeIdentifier","preciseIdentifier":"c:BFv(#*$objc(cs)NSDictionary)"},{"kind":"text","text":") "},{"text":"successHandler","kind":"internalParam"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onFailure:"},{"kind":"text","text":"("},{"preciseIdentifier":"c:BFv(#*$objc(cs)NSError)","text":"void (^)(NSError *)","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"errorHandler","kind":"internalParam"},{"text":";","kind":"text"}],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"successHandler","content":[{"type":"paragraph","inlineContent":[{"text":"Block called when tags are successfully retrieved.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Receives a dictionary containing all device tags, or nil if no tags are set."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Block called if the request fails."},{"type":"text","text":" "},{"type":"text","text":"Receives an NSError describing the failure."}]}],"name":"errorHandler"}]},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Alternative method name for "},{"code":"loadTags:error:","type":"codeVoice"},{"type":"text","text":" following common SDK naming conventions."},{"text":" ","type":"text"},{"type":"text","text":"Fetches all tags currently associated with this device from the Pushwoosh server."}],"type":"paragraph"},{"text":"Example","type":"heading","anchor":"Example","level":2},{"inlineContent":[{"text":"Verify tag updates were applied:","type":"text"}],"type":"paragraph"},{"code":["class TagVerificationService {","","    func verifyTagsApplied(expectedTags: [String: Any],","                          completion: @escaping (Bool) -> Void) {","","        Pushwoosh.configure.getTags({ tags in","            guard let serverTags = tags else {","                completion(false)","                return","            }","","            let allMatch = expectedTags.allSatisfy { key, expectedValue in","                guard let serverValue = serverTags[key] else { return false }","","                if let expected = expectedValue as? String,","                   let server = serverValue as? String {","                    return expected == server","                }","                if let expected = expectedValue as? NSNumber,","                   let server = serverValue as? NSNumber {","                    return expected == server","                }","                return false","            }","","            completion(allMatch)","","        }, onFailure: { error in","            Logger.error(\"Tag verification failed: \\(error?.localizedDescription ?? \"Unknown\")\")","            completion(false)","        })","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/gettags:onfailure:"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"symbolKind":"method","title":"getTags:onFailure:","navigatorTitle":[{"text":"getTags:onFailure:","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)getTags