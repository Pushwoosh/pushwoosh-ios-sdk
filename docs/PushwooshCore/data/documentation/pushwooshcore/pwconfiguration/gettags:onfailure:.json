a dictionary containing all device tags, or nil if no tags are set.","type":"text"}]}],"name":"successHandler"},{"name":"errorHandler","content":[{"inlineContent":[{"text":"Block called if the request fails.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Receives an NSError describing the failure."}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Alternative method name for "},{"type":"codeVoice","code":"loadTags:error:"},{"type":"text","text":" following common SDK naming conventions."},{"type":"text","text":" "},{"text":"Fetches all tags currently associated with this device from the Pushwoosh server.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Example","type":"heading","anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Verify tag updates were applied:"}]},{"type":"codeListing","syntax":"swift","code":["class TagVerificationService {","","    func verifyTagsApplied(expectedTags: [String: Any],","                          completion: @escaping (Bool) -> Void) {","","        Pushwoosh.configure.getTags({ tags in","            guard let serverTags = tags else {","                completion(false)","                return","            }","","            let allMatch = expectedTags.allSatisfy { key, expectedValue in","                guard let serverValue = serverTags[key] else { return false }","","                if let expected = expectedValue as? String,","                   let server = serverValue as? String {","                    return expected == server","                }","                if let expected = expectedValue as? NSNumber,","                   let server = serverValue as? NSNumber {","                    return expected == server","                }","                return false","            }","","            completion(allMatch)","","        }, on