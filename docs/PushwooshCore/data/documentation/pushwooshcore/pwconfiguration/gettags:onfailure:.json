{"abstract":[{"text":"Retrieves the current device’s tags from the Pushwoosh server.","type":"text"}],"kind":"symbol","sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"metadata":{"role":"symbol","symbolKind":"method","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"getTags:onFailure:"}],"navigatorTitle":[{"kind":"identifier","text":"getTags:onFailure:"}],"modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)getTags:onFailure:","roleHeading":"Type Method","title":"getTags:onFailure:"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"text":") ","kind":"text"},{"text":"getTags:","kind":"identifier"},{"kind":"text","text":"("},{"text":"void (^)(NSDictionary *)","kind":"typeIdentifier","preciseIdentifier":"c:BFv(#*$objc(cs)NSDictionary)"},{"kind":"text","text":") "},{"text":"successHandler","kind":"internalParam"},{"text":" ","kind":"text"},{"text":"onFailure:","kind":"identifier"},{"kind":"text","text":"("},{"text":"void (^)(NSError *)","kind":"typeIdentifier","preciseIdentifier":"c:BFv(#*$objc(cs)NSError)"},{"kind":"text","text":") "},{"kind":"internalParam","text":"errorHandler"},{"text":";","kind":"text"}],"languages":["occ"],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"name":"successHandler","content":[{"inlineContent":[{"type":"text","text":"Block called when tags are successfully retrieved."},{"text":" ","type":"text"},{"type":"text","text":"Receives a dictionary containing all device tags, or nil if no tags are set."}],"type":"paragraph"}]},{"name":"errorHandler","content":[{"inlineContent":[{"type":"text","text":"Block called if the request fails."},{"text":" ","type":"text"},{"text":"Receives an NSError describing the failure.","type":"text"}],"type":"paragraph"}]}]},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Alternative method name for ","type":"text"},{"type":"codeVoice","code":"loadTags:error:"},{"type":"text","text":" following common SDK naming conventions."},{"type":"text","text":" "},{"type":"text","text":"Fetches all tags currently associated with this device from the Pushwoosh server."}]},{"anchor":"Example","level":2,"type":"heading","text":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Verify tag updates were applied:"}]},{"code":["class TagVerificationService {","","    func verifyTagsApplied(expectedTags: [String: Any],","                          completion: @escaping (Bool) -> Void) {","","        Pushwoosh.configure.getTags({ tags in","            guard let serverTags = tags else {","                completion(false)","                return","            }","","            let allMatch = expectedTags.allSatisfy { key, expectedValue in","                guard let serverValue = serverTags[key] else { return false }","","                if let expected = expectedValue as? String,","                   let server = serverValue as? String {","                    return expected == server","                }","                if let expected = expectedValue as? NSNumber,","                   let server = serverValue as? NSNumber {","                    return expected == server","                }","                return false","            }","","            completion(allMatch)","","        }, onFailure: { error in","            Logger.error(\"Tag verification failed: \\(error?.localizedDescription ?? \"Unknown\")\")","            completion(false)","        })","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwcon