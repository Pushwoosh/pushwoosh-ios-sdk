{"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getTags:onFailure:"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"abstract":[{"type":"text","text":"Retrieves the current device’s tags from the Pushwoosh server."}],"primaryContentSections":[{"declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"text":"getTags:","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","text":"void (^)(NSDictionary *)","preciseIdentifier":"c:BFv(#*$objc(cs)NSDictionary)"},{"kind":"text","text":") "},{"kind":"internalParam","text":"successHandler"},{"text":" ","kind":"text"},{"text":"onFailure:","kind":"identifier"},{"text":"(","kind":"text"},{"text":"void (^)(NSError *)","preciseIdentifier":"c:BFv(#*$objc(cs)NSError)","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"errorHandler","kind":"internalParam"},{"kind":"text","text":";"}]}],"kind":"declarations"},{"parameters":[{"name":"successHandler","content":[{"inlineContent":[{"text":"Block called when tags are successfully retrieved.","type":"text"},{"text":" ","type":"text"},{"text":"Receives a dictionary containing all device tags, or nil if no tags are set.","type":"text"}],"type":"paragraph"}]},{"name":"errorHandler","content":[{"inlineContent":[{"text":"Block called if the request fails.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Receives an NSError describing the failure."}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Alternative method name for "},{"code":"loadTags:error:","type":"codeVoice"},{"text":" following common SDK naming conventions.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Fetches all tags currently associated with this device from the Pushwoosh server."}]},{"anchor":"Example","type":"heading","level":2,"text":"Example"},{"type":"paragraph","inlineContent":[{"text":"Verify tag updates were applied:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class TagVerificationService {","","    func verifyTagsApplied(expectedTags: [String: Any],","                          completion: @escaping (Bool) -> Void) {","","        Pushwoosh.configure.getTags({ tags in","            guard let serverTags = tags else {","                completion(false)","                return","            }","","            let allMatch = expectedTags.allSatisfy { key, expectedValue in","                guard let serverValue = serverTags[key] else { return false }","","                if let expected = expectedValue as? String,","                   let server = serverValue as? String {","                    return expected == server","                }","                if let expected = expectedValue as? NSNumber,","                   let server = serverValue as? NSNumber {","                    return expected == server","                }","                return false","            }","","            completion(allMatch)","","        }, onFailure: { error in","            Logger.error(\"Tag verification failed: \\(error?.localizedDescription ?? \"Unknown\")\")","            completion(false)","        })","    }","}"]}],"kind":"content"}],"metadata":{"modules":[{"name":"PushwooshCore"}],"role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)getTags:onFailure:","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"getTags:onFailure:"}],"title":"getTags:onFailure:","navigatorTitle":[{"text":"getTags:onFailure:","kind":"identifier"}],"symbolKind"