"","    func verifyTagsApplied(expectedTags: [String: Any],","                          completion: @escaping (Bool) -> Void) {","","        Pushwoosh.configure.getTags({ tags in","            guard let serverTags = tags else {","                completion(false)","                return","            }","","            let allMatch = expectedTags.allSatisfy { key, expectedValue in","                guard let serverValue = serverTags[key] else { return false }","","                if let expected = expectedValue as? String,","                   let server = serverValue as? String {","                    return expected == server","                }","                if let expected = expectedValue as? NSNumber,","                   let server = serverValue as? NSNumber {","                    return expected == server","                }","                return false","            }","","            completion(allMatch)","","        }, onFailure: { error in","            Logger.error(\"Tag verification failed: \\(error?.localizedDescription ?? \"Unknown\")\")","            completion(false)","        })","    }","}"],"syntax":"swift"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getTags:onFailure:","interfaceLanguage":"occ"},"sections":[],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/gettags:onfailure:"]}],"abstract":[{"type":"text","text":"Retrieves the current device’s tags from the Pushwoosh server."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"symbolKind":"method","role":"symbol","externalID":"c:objc(pl)PWConfiguration(cm)getTags:onFailure:","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":