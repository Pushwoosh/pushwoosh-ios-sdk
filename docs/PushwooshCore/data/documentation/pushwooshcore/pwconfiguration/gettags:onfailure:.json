{"type":"paragraph","inlineContent":[{"type":"text","text":"Alternative method name for "},{"type":"codeVoice","code":"loadTags:error:"},{"text":" following common SDK naming conventions.","type":"text"},{"text":" ","type":"text"},{"text":"Fetches all tags currently associated with this device from the Pushwoosh server.","type":"text"}]},{"level":2,"type":"heading","anchor":"Example","text":"Example"},{"type":"paragraph","inlineContent":[{"text":"Verify tag updates were applied:","type":"text"}]},{"code":["class TagVerificationService {","","    func verifyTagsApplied(expectedTags: [String: Any],","                          completion: @escaping (Bool) -> Void) {","","        Pushwoosh.configure.getTags({ tags in","            guard let serverTags = tags else {","                completion(false)","                return","            }","","            let allMatch = expectedTags.allSatisfy { key, expectedValue in","                guard let serverValue = serverTags[key] else { return false }","","                if let expected = expectedValue as? String,","                   let server = serverValue as? String {","                    return expected == server","                }","                if let expected = expectedValue as? NSNumber,","                   let server = serverValue as? NSNumber {","                    return expected == server","                }","                return false","            }","","            completion(allMatch)","","        }, onFailure: { error in","            Logger.error(\"Tag verification failed: \\(error?.localizedDescription ?? \"Unknown\")\")","            completion(false)","        })","    }","}"],"type":"codeListing","syntax":"swift"}]}],"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/gettags:onfailure:"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getTags:onFailure:","interfaceLanguage":"occ"},"abstract":[{"type":"text","text":"Retrieves the current device’s tags from the Pushwoosh server."}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"kind":"symbol","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/getTags:onFailure:":{"navigatorTitle":[{"text":"getTags:onFailure:","kind":"identifier"}],"title":"getTags:onFailure:","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/getTags:onFailure:","type":"topic","abstract":[{"text":"Retrieves the current device’s tags from the Pushwoosh server.","type":"text"}],"kind":"symbol","role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/gettags:onfailure:","fragments":[{"kind":"text","text":"+ "},{"text":"getTags:onFailure:","kind":"identifier"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","url":"\/documentation\/pushwooshcore","role":"collection","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","title":"PushwooshCore","kind":"symbol","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}]}}}