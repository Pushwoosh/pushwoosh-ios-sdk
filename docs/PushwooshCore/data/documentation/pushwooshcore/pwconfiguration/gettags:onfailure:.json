:[{"type":"text","text":"Block called if the request fails."},{"text":" ","type":"text"},{"type":"text","text":"Receives an NSError describing the failure."}],"type":"paragraph"}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"Alternative method name for ","type":"text"},{"type":"codeVoice","code":"loadTags:error:"},{"text":" following common SDK naming conventions.","type":"text"},{"text":" ","type":"text"},{"text":"Fetches all tags currently associated with this device from the Pushwoosh server.","type":"text"}],"type":"paragraph"},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Verify tag updates were applied:"}]},{"syntax":"swift","code":["class TagVerificationService {","","    func verifyTagsApplied(expectedTags: [String: Any],","                          completion: @escaping (Bool) -> Void) {","","        Pushwoosh.configure.getTags({ tags in","            guard let serverTags = tags else {","                completion(false)","                return","            }","","            let allMatch = expectedTags.allSatisfy { key, expectedValue in","                guard let serverValue = serverTags[key] else { return false }","","                if let expected = expectedValue as? String,","                   let server = serverValue as? String {","                    return expected == server","                }","                if let expected = expectedValue as? NSNumber,","                   let server = serverValue as? NSNumber {","                    return expected == server","                }","                return false","            }","","            completion(allMatch)","","        }, onFailure: { error in","            Logger.error(\"Tag verification failed: \\(error?.localizedDescription ?? \"Unknown\")\")","            completion(false)","        })","    }","}"],"type":"codeListing"