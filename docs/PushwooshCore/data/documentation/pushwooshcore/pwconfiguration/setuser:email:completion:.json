,"level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Convenience method for the common case of associating a user ID with a single","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"email address. Equivalent to calling "},{"type":"codeVoice","code":"setUser:emails:completion:"},{"type":"text","text":" with a"},{"type":"text","text":" "},{"text":"single-element array.","type":"text"}]},{"text":"Example","level":2,"type":"heading","anchor":"Example"},{"inlineContent":[{"type":"text","text":"Simple login flow with single email:"}],"type":"paragraph"},{"syntax":"swift","code":["class SimpleAuthManager {","","    func loginWithEmail(_ email: String, password: String,","                       completion: @escaping (Result<Void, Error>) -> Void) {","","        APIClient.shared.authenticate(email: email, password: password) { result in","            switch result {","            case .success(let authResponse):","                Pushwoosh.configure.setUser(authResponse.userId, email: email) { error in","                    if let error = error {","                        Logger.warning(\"Pushwoosh sync failed: \\(error)\")","                        \/\/ Don't fail login for Pushwoosh errors","                    }","","                    self.saveSession(authResponse)","                    completion(.success(()))","                }","","            case .failure(let error):","                completion(.failure(error))","            }","        }","    }","}"],"type":"codeListing"}]}],"metadata":{"fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setUser:email:completion:"}],"title":"setUser:email:completion:","roleHeading":"Type Method","role":"symbol","modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"kind":"identifier","text":"setUser:email:completion:"}],"externalID":"c:objc(pl)PWConfiguration(cm)setUser:email:completion:","symbolKind":"method"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths