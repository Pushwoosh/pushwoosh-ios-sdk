alParam","text":"completion"},{"text":";","kind":"text"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"userId","content":[{"inlineContent":[{"type":"text","text":"The custom user identifier."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The user’s email address."}]}],"name":"email"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Block called when the operation completes.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Receives nil on success, or an NSError on failure."}]}],"name":"completion"}]},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Convenience method for the common case of associating a user ID with a single","type":"text"},{"type":"text","text":" "},{"type":"text","text":"email address. Equivalent to calling "},{"code":"setUser:emails:completion:","type":"codeVoice"},{"type":"text","text":" with a"},{"text":" ","type":"text"},{"type":"text","text":"single-element array."}]},{"level":2,"text":"Example","anchor":"Example","type":"heading"},{"inlineContent":[{"type":"text","text":"Simple login flow with single email:"}],"type":"paragraph"},{"syntax":"swift","code":["class SimpleAuthManager {","","    func loginWithEmail(_ email: String, password: String,","                       completion: @escaping (Result<Void, Error>) -> Void) {","","        APIClient.shared.authenticate(email: email, password: password) { result in","            switch result {","            case .success(let authResponse):","                Pushwoosh.configure.setUser(authResponse.userId, email: email) { error in","                    if let error = error {","                        Logger.warning(\"Pushwoosh sync failed: \\(error)\")","                        \/\/ Don't fail login for Pushwoosh errors","                    }","","                    self.saveSession(authResponse)","                    