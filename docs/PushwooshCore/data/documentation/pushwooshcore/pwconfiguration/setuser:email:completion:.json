ror on failure.","type":"text"}],"type":"paragraph"}],"name":"completion"}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"text":"Convenience method for the common case of associating a user ID with a single","type":"text"},{"type":"text","text":" "},{"text":"email address. Equivalent to calling ","type":"text"},{"type":"codeVoice","code":"setUser:emails:completion:"},{"type":"text","text":" with a"},{"text":" ","type":"text"},{"type":"text","text":"single-element array."}],"type":"paragraph"},{"text":"Example","type":"heading","level":2,"anchor":"Example"},{"inlineContent":[{"type":"text","text":"Simple login flow with single email:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class SimpleAuthManager {","","    func loginWithEmail(_ email: String, password: String,","                       completion: @escaping (Result<Void, Error>) -> Void) {","","        APIClient.shared.authenticate(email: email, password: password) { result in","            switch result {","            case .success(let authResponse):","                Pushwoosh.configure.setUser(authResponse.userId, email: email) { error in","                    if let error = error {","                        Logger.warning(\"Pushwoosh sync failed: \\(error)\")","                        \/\/ Don't fail login for Pushwoosh errors","                    }","","                    self.saveSession(authResponse)","                    completion(.success(()))","                }","","            case .failure(let error):","                completion(.failure(error))","            }","        }","    }","}"]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"roleHeading":"Type Method","role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"text":"setUser:email:completion:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}],"title":"setUser:email:completion:","externalID":"c:objc(pl)PWConfigur