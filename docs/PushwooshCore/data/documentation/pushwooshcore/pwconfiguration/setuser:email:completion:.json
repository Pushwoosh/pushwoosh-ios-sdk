mail address. Equivalent to calling "},{"code":"setUser:emails:completion:","type":"codeVoice"},{"type":"text","text":" with a"},{"type":"text","text":" "},{"text":"single-element array.","type":"text"}]},{"text":"Example","level":2,"anchor":"Example","type":"heading"},{"inlineContent":[{"text":"Simple login flow with single email:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class SimpleAuthManager {","","    func loginWithEmail(_ email: String, password: String,","                       completion: @escaping (Result<Void, Error>) -> Void) {","","        APIClient.shared.authenticate(email: email, password: password) { result in","            switch result {","            case .success(let authResponse):","                Pushwoosh.configure.setUser(authResponse.userId, email: email) { error in","                    if let error = error {","                        Logger.warning(\"Pushwoosh sync failed: \\(error)\")","                        \/\/ Don't fail login for Pushwoosh errors","                    }","","                    self.saveSession(authResponse)","                    completion(.success(()))","                }","","            case .failure(let error):","                completion(.failure(error))","            }","        }","    }","}"]}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setuser:email:completion:"]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:email:completion:","interfaceLanguage":"occ"},"abstract":[{"type":"text","text":"Sets user identifier and single email with completion handler."}],"sections":[],"metadata":{"navigatorTitle":[{"kind":"identifier","text":"setUser:e