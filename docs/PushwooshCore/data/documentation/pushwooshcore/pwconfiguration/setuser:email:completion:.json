{"kind":"symbol","sections":[],"metadata":{"role":"symbol","roleHeading":"Type Method","symbolKind":"method","navigatorTitle":[{"text":"setUser:email:completion:","kind":"identifier"}],"title":"setUser:email:completion:","externalID":"c:objc(pl)PWConfiguration(cm)setUser:email:completion:","fragments":[{"kind":"text","text":"+ "},{"text":"setUser:email:completion:","kind":"identifier"}],"modules":[{"name":"PushwooshCore"}]},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:email:completion:"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"kind":"text","text":") "},{"text":"setUser:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSString","text":"NSString","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"userId"},{"text":" ","kind":"text"},{"text":"email:","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"c:objc(cs)NSString","text":"NSString","kind":"typeIdentifier"},{"text":" *) ","kind":"text"},{"kind":"internalParam","text":"email"},{"kind":"text","text":" "},{"text":"completion:","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"text":" (^","kind":"text"},{"text":")(","kind":"text"},{"preciseIdentifier":"c:objc(cs)NSError","text":"NSError","kind":"typeIdentifier"},{"kind":"text","text":" * "},{"kind":"internalParam","text":"error"},{"text":")) ","kind":"text"},{"text":"completion","kind":"internalParam"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"userId","content":[{"inlineContent":[{"type":"text","text":"The custom user identifier."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The user’s email address."}]}],"name":"email"},{"name":"completion","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Block called when the operation completes."},{"type":"text","text":" "},{"type":"text","text":"Receives nil on success, or an NSError on failure."}]}]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Convenience method for the common case of associating a user ID with a single"},{"type":"text","text":" "},{"type":"text","text":"email address. Equivalent to calling "},{"code":"setUser:emails:completion:","type":"codeVoice"},{"type":"text","text":" with a"},{"type":"text","text":" "},{"text":"single-element array.","type":"text"}]},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"inlineContent":[{"text":"Simple login flow with single email:","type":"text"}],"type":"paragraph"},{"code":["class SimpleAuthManager {","","    func loginWithEmail(_ email: String, password: String,","                       completion: @escaping (Result<Void, Error>) -> Void) {","","        APIClient.shared.authenticate(email: email, password: password) { result in","            switch result {","            case .success(let authResponse):","                Pushwoosh.configure.setUser(authResponse.userId, email: email) { error in","                    if let error = error {","                        Logger.warning(\"Pushwoosh sync failed: \\(error)\")","                        \/\/ Don't fail login for Pushwoosh errors","                    }","","                    self.saveSession(authResponse)","                    completion(.success(()))","                }","","            case .failure(let error):","                completion(.failure(error))","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"}]}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setuser:email:completion:"],"traits":[{"interfaceLanguage":"occ"}]}],"abstract":[{"text":"Sets user identifier and single email with completion handler.","type":"text"}],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setUser:email:completion:":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:email:completion:","role":"symbol","navigatorTitle":[{"text":"setUser:email:completion:","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"text","text":"Sets user identifier and single email with completion handler."}],"title":"setUser:email:completion:","url":"\/documentation\/pushwooshcore\/pwconfiguration\/setuser:email:completion:","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"setUser:email:completion:"}],"type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"role":"collection","title":"PushwooshCore","url":"\/documentation\/pushwooshcore","kind":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","abstract":[],"kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration","role":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"type":"topic"}}}