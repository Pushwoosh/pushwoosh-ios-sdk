oosh errors","                    }","","                    self.saveSession(authResponse)","                    completion(.success(()))","                }","","            case .failure(let error):","                completion(.failure(error))","            }","        }","    }","}"],"type":"codeListing"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/setUser:email:completion:":{"type":"topic","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:email:completion:","role":"symbol","title":"setUser:email:completion:","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"setUser:email:completion:"}],"navigatorTitle":[{"text":"setUser:email:completion:","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"text","text":"Sets user identifier and single email with completion handler."}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/setuser:email:completion:"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"type":"topic","role":"collection","kind":"symbol","title":"PushwooshCore","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","url":"\/documentation\/pushwooshcore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"fragments":[{"text":"PWConfiguration","kind":"identifier"}],"abstract":[],"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","title":"PWConfiguration","kind":"symbol","type":"topic","role":"symbol"}}}