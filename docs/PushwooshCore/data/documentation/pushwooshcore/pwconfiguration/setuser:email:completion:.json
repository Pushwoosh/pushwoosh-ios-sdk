},{"inlineContent":[{"type":"text","text":"Convenience method for the common case of associating a user ID with a single"},{"type":"text","text":" "},{"type":"text","text":"email address. Equivalent to calling "},{"type":"codeVoice","code":"setUser:emails:completion:"},{"type":"text","text":" with a"},{"text":" ","type":"text"},{"type":"text","text":"single-element array."}],"type":"paragraph"},{"text":"Example","anchor":"Example","type":"heading","level":2},{"inlineContent":[{"text":"Simple login flow with single email:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class SimpleAuthManager {","","    func loginWithEmail(_ email: String, password: String,","                       completion: @escaping (Result<Void, Error>) -> Void) {","","        APIClient.shared.authenticate(email: email, password: password) { result in","            switch result {","            case .success(let authResponse):","                Pushwoosh.configure.setUser(authResponse.userId, email: email) { error in","                    if let error = error {","                        Logger.warning(\"Pushwoosh sync failed: \\(error)\")","                        \/\/ Don't fail login for Pushwoosh errors","                    }","","                    self.saveSession(authResponse)","                    completion(.success(()))","                }","","            case .failure(let error):","                completion(.failure(error))","            }","        }","    }","}"]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/setUser:email:completion:","interfaceLanguage":"occ"},"abstract":[{"type":"text","text":"Sets user identifier and single email with completion handler."}],"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/setuser:email:completion:"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"symbol","metadata":{"symbolK