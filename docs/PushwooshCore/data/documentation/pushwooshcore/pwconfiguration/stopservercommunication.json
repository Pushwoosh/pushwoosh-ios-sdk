{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"stopServerCommunication","kind":"identifier"},{"kind":"text","text":";"}],"languages":["occ"]}]},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Stops all communication with Pushwoosh servers. The SDK will not send or receive any data"},{"type":"text","text":" "},{"text":"including device registration, tags, push tokens, and analytics.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Use this method to comply with privacy regulations (GDPR, CCPA) or honor user preferences","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for data transmission. Push notifications will still be delivered to the device by APNs,"},{"text":" ","type":"text"},{"type":"text","text":"but no tracking or analytics data will be sent to Pushwoosh."}]},{"type":"heading","text":"Example","level":2,"anchor":"Example"},{"inlineContent":[{"text":"Handle GDPR opt-out in settings:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["class PrivacySettingsViewController: UIViewController {","","    @IBOutlet weak var dataCollectionSwitch: UISwitch!","","    @IBAction func dataCollectionToggled(_ sender: UISwitch) {","        if sender.isOn {","            showConsentDialog { accepted in","                if accepted {","                    Pushwoosh.configure.startServerCommunication()","                    self.showToast(\"Data collection enabled\")","                } else {","                    sender.isOn = false","                }","            }","        } else {","            Pushwoosh.configure.stopServerCommunication()","","            \/\/ Also unregister from push if required by your privacy policy","            Pushwoosh.configure.unregisterForPushNotifications { error in","                if error == nil {","                    self.showToast(\"Data collection disabled\")","                }","            }","        }","    }","","    private func showConsentDialog(completion: @escaping (Bool) -> Void) {","        let alert = UIAlertController(","            title: \"Data Collection\",","            message: \"We collect data to personalize your experience and send relevant notifications.\",","            preferredStyle: .alert","        )","        alert.addAction(UIAlertAction(title: \"Accept\", style: .default) { _ in","            completion(true)","        })","        alert.addAction(UIAlertAction(title: \"Decline\", style: .cancel) { _ in","            completion(false)","        })","        present(alert, animated: true)","    }","}"],"type":"codeListing"}],"kind":"content"}],"abstract":[{"text":"Disables communication with Pushwoosh servers.","type":"text"}],"kind":"symbol","variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/stopservercommunication"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/stopServerCommunication","interfaceLanguage":"occ"},"metadata":{"title":"stopServerCommunication","fragments":[{"kind":"text","text":"+ "},{"text":"stopServerCommunication","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)stopServerCommunication","symbolKind":"method","modules":[{"name":"PushwooshCore"}],"navigatorTitle":[{"kind":"identifier","text":"stopServerCommunication"}],"role":"symbol","roleHeading":"Type Method"},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/stopServerCommunication":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/stopServerCommunication","type":"topic","title":"stopServerCommunication","url":"\/documentation\/pushwooshcore\/pwconfiguration\/stopservercommunication","kind":"symbol","role":"symbol","fragments":[{"kind":"text","text":"+ "},{"text":"stopServerCommunication","kind":"identifier"}],"abstract":[{"type":"text","text":"Disables communication with Pushwoosh servers."}],"navigatorTitle":[{"kind":"identifier","text":"stopServerCommunication"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"abstract":[],"type":"topic","role":"symbol","kind":"symbol","title":"PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","type":"topic","role":"collection","url":"\/documentation\/pushwooshcore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"kind":"symbol"}}}