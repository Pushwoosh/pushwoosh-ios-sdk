{"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/stopServerCommunication"},"metadata":{"externalID":"c:objc(pl)PWConfiguration(cm)stopServerCommunication","symbolKind":"method","fragments":[{"kind":"text","text":"+ "},{"text":"stopServerCommunication","kind":"identifier"}],"navigatorTitle":[{"text":"stopServerCommunication","kind":"identifier"}],"role":"symbol","title":"stopServerCommunication","roleHeading":"Type Method","modules":[{"name":"PushwooshCore"}]},"abstract":[{"text":"Disables communication with Pushwoosh servers.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"preciseIdentifier":"c:v","text":"void","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"stopServerCommunication","kind":"identifier"},{"text":";","kind":"text"}]}]},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Stops all communication with Pushwoosh servers. The SDK will not send or receive any data"},{"type":"text","text":" "},{"text":"including device registration, tags, push tokens, and analytics.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this method to comply with privacy regulations (GDPR, CCPA) or honor user preferences"},{"text":" ","type":"text"},{"type":"text","text":"for data transmission. Push notifications will still be delivered to the device by APNs,"},{"type":"text","text":" "},{"text":"but no tracking or analytics data will be sent to Pushwoosh.","type":"text"}]},{"level":2,"type":"heading","anchor":"Example","text":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle GDPR opt-out in settings:"}]},{"code":["class PrivacySettingsViewController: UIViewController {","","    @IBOutlet weak var dataCollectionSwitch: UISwitch!","","    @IBAction func dataCollectionToggled(_ sender: UISwitch) {","        if sender.isOn {","            showConsentDialog { accepted in","                if accepted {","                    Pushwoosh.configure.startServerCommunication()","                    self.showToast(\"Data collection enabled\")","                } else {","                    sender.isOn = false","                }","            }","        } else {","            Pushwoosh.configure.stopServerCommunication()","","            \/\/ Also unregister from push if required by your privacy policy","            Pushwoosh.configure.unregisterForPushNotifications { error in","                if error == nil {","                    self.showToast(\"Data collection disabled\")","                }","            }","        }","    }","","    private func showConsentDialog(completion: @escaping (Bool) -> Void) {","        let alert = UIAlertController(","            title: \"Data Collection\",","            message: \"We collect data to personalize your experience and send relevant notifications.\",","            preferredStyle: .alert","        )","        alert.addAction(UIAlertAction(title: \"Accept\", style: .default) { _ in","            completion(true)","        })","        alert.addAction(UIAlertAction(title: \"Decline\", style: .cancel) { _ in","            completion(false)","        })","        present(alert, animated: true)","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/stopservercommunication"]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/stopServerCommunication":{"navigatorTitle":[{"kind":"identifier","text":"stopServerCommunication"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/stopservercommunication","kind":"symbol","type":"topic","abstract":[{"text":"Disables communication with Pushwoosh servers.","type":"text"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/stopServerCommunication","title":"stopServerCommunication","role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"stopServerCommunication"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","role":"collection","title":"PushwooshCore"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"type":"topic","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"abstract":[],"title":"PWConfiguration","role":"symbol","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration"}}}