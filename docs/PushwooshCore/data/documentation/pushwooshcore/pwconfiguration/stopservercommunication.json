{"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/stopservercommunication"]}],"abstract":[{"type":"text","text":"Disables communication with Pushwoosh servers."}],"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/stopServerCommunication","interfaceLanguage":"occ"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"+ (","kind":"text"},{"kind":"typeIdentifier","text":"void","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"text":"stopServerCommunication","kind":"identifier"},{"kind":"text","text":";"}],"languages":["occ"],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Stops all communication with Pushwoosh servers. The SDK will not send or receive any data"},{"text":" ","type":"text"},{"type":"text","text":"including device registration, tags, push tokens, and analytics."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this method to comply with privacy regulations (GDPR, CCPA) or honor user preferences"},{"type":"text","text":" "},{"type":"text","text":"for data transmission. Push notifications will still be delivered to the device by APNs,"},{"type":"text","text":" "},{"type":"text","text":"but no tracking or analytics data will be sent to Pushwoosh."}]},{"level":2,"type":"heading","text":"Example","anchor":"Example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle GDPR opt-out in settings:"}]},{"type":"codeListing","syntax":"swift","code":["class PrivacySettingsViewController: UIViewController {","","    @IBOutlet weak var dataCollectionSwitch: UISwitch!","","    @IBAction func dataCollectionToggled(_ sender: UISwitch) {","        if sender.isOn {","            showConsentDialog { accepted in","                if accepted {","                    Pushwoosh.configure.startServerCommunication()","                    self.showToast(\"Data collection enabled\")","                } else {","                    sender.isOn = false","                }","            }","        } else {","            Pushwoosh.configure.stopServerCommunication()","","            \/\/ Also unregister from push if required by your privacy policy","            Pushwoosh.configure.unregisterForPushNotifications { error in","                if error == nil {","                    self.showToast(\"Data collection disabled\")","                }","            }","        }","    }","","    private func showConsentDialog(completion: @escaping (Bool) -> Void) {","        let alert = UIAlertController(","            title: \"Data Collection\",","            message: \"We collect data to personalize your experience and send relevant notifications.\",","            preferredStyle: .alert","        )","        alert.addAction(UIAlertAction(title: \"Accept\", style: .default) { _ in","            completion(true)","        })","        alert.addAction(UIAlertAction(title: \"Decline\", style: .cancel) { _ in","            completion(false)","        })","        present(alert, animated: true)","    }","}"]}]}],"kind":"symbol","sections":[],"metadata":{"title":"stopServerCommunication","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"stopServerCommunication"}],"roleHeading":"Type Method","role":"symbol","modules":[{"name":"PushwooshCore"}],"symbolKind":"method","navigatorTitle":[{"kind":"identifier","text":"stopServerCommunication"}],"externalID":"c:objc(pl)PWConfiguration(cm)stopServerCommunication"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/stopServerCommunication":{"title":"stopServerCommunication","fragments":[{"kind":"text","text":"+ "},{"kind":"identifier","text":"stopServerCommunication"}],"type":"topic","role":"symbol","url":"\/documentation\/pushwooshcore\/pwconfiguration\/stopservercommunication","kind":"symbol","abstract":[{"type":"text","text":"Disables communication with Pushwoosh servers."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/stopServerCommunication","navigatorTitle":[{"kind":"identifier","text":"stopServerCommunication"}]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"role":"collection","url":"\/documentation\/pushwooshcore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","kind":"symbol","title":"PushwooshCore","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"type":"topic"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","kind":"symbol","fragments":[{"text":"PWConfiguration","kind":"identifier"}],"abstract":[],"role":"symbol","title":"PWConfiguration","type":"topic","url":"\/documentation\/pushwooshcore\/pwconfiguration"}}}