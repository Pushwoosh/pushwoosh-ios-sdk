{"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/stopServerCommunication","interfaceLanguage":"occ"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"platforms":["iOS"],"tokens":[{"kind":"text","text":"+ ("},{"kind":"typeIdentifier","preciseIdentifier":"c:v","text":"void"},{"kind":"text","text":") "},{"text":"stopServerCommunication","kind":"identifier"},{"text":";","kind":"text"}]}]},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Stops all communication with Pushwoosh servers. The SDK will not send or receive any data","type":"text"},{"type":"text","text":" "},{"text":"including device registration, tags, push tokens, and analytics.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this method to comply with privacy regulations (GDPR, CCPA) or honor user preferences"},{"type":"text","text":" "},{"type":"text","text":"for data transmission. Push notifications will still be delivered to the device by APNs,"},{"type":"text","text":" "},{"text":"but no tracking or analytics data will be sent to Pushwoosh.","type":"text"}]},{"text":"Example","type":"heading","anchor":"Example","level":2},{"type":"paragraph","inlineContent":[{"text":"Handle GDPR opt-out in settings:","type":"text"}]},{"code":["class PrivacySettingsViewController: UIViewController {","","    @IBOutlet weak var dataCollectionSwitch: UISwitch!","","    @IBAction func dataCollectionToggled(_ sender: UISwitch) {","        if sender.isOn {","            showConsentDialog { accepted in","                if accepted {","                    Pushwoosh.configure.startServerCommunication()","                    self.showToast(\"Data collection enabled\")","                } else {","                    sender.isOn = false","                }","            }","        } else {","            Pushwoosh.configure.stopServerCommunication()","","            \/\/ Also unregister from push if required by your privacy policy","            Pushwoosh.configure.unregisterForPushNotifications { error in","                if error == nil {","                    self.showToast(\"Data collection disabled\")","                }","            }","        }","    }","","    private func showConsentDialog(completion: @escaping (Bool) -> Void) {","        let alert = UIAlertController(","            title: \"Data Collection\",","            message: \"We collect data to personalize your experience and send relevant notifications.\",","            preferredStyle: .alert","        )","        alert.addAction(UIAlertAction(title: \"Accept\", style: .default) { _ in","            completion(true)","        })","        alert.addAction(UIAlertAction(title: \"Decline\", style: .cancel) { _ in","            completion(false)","        })","        present(alert, animated: true)","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"abstract":[{"text":"Disables communication with Pushwoosh servers.","type":"text"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/stopservercommunication"]}],"metadata":{"roleHeading":"Type Method","symbolKind":"method","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"stopServerCommunication"}],"modules":[{"name":"PushwooshCore"}],"title":"stopServerCommunication","fragments":[{"kind":"text","text":"+ "},{"text":"stopServerCommunication","kind":"identifier"}],"externalID":"c:objc(pl)PWConfiguration(cm)stopServerCommunication"},"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"kind":"symbol","id