{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/stopservercommunication"]}],"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/stopServerCommunication","interfaceLanguage":"occ"},"metadata":{"role":"symbol","fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"stopServerCommunication"}],"modules":[{"name":"PushwooshCore"}],"symbolKind":"method","title":"stopServerCommunication","navigatorTitle":[{"kind":"identifier","text":"stopServerCommunication"}],"roleHeading":"Type Method","externalID":"c:objc(pl)PWConfiguration(cm)stopServerCommunication"},"abstract":[{"type":"text","text":"Disables communication with Pushwoosh servers."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","preciseIdentifier":"c:v","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"stopServerCommunication","kind":"identifier"},{"text":";","kind":"text"}],"languages":["occ"]}]},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"Stops all communication with Pushwoosh servers. The SDK will not send or receive any data","type":"text"},{"text":" ","type":"text"},{"text":"including device registration, tags, push tokens, and analytics.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this method to comply with privacy regulations (GDPR, CCPA) or honor user preferences"},{"text":" ","type":"text"},{"type":"text","text":"for data transmission. Push notifications will still be delivered to the device by APNs,"},{"text":" ","type":"text"},{"text":"but no tracking or analytics data will be sent to Pushwoosh.","type":"text"}]},{"anchor":"Example","type":"heading","level":2,"text":"Example"},{"inlineContent":[{"type":"text","text":"Handle GDPR opt-out in settings:"}],"type":"paragraph"},{"code":["class PrivacySettingsViewController: UIViewController {","","    @IBOutlet weak var dataCollectionSwitch: UISwitch!","","    @IBAction func dataCollectionToggled(_ sender: UISwitch) {","        if sender.isOn {","            showConsentDialog { accepted in","                if accepted {","                    Pushwoosh.configure.startServerCommunication()","                    self.showToast(\"Data collection enabled\")","                } else {","                    sender.isOn = false","                }","            }","        } else {","            Pushwoosh.configure.stopServerCommunication()","","            \/\/ Also unregister from push if required by your privacy policy","            Pushwoosh.configure.unregisterForPushNotifications { error in","                if error == nil {","                    self.showToast(\"Data collection disabled\")","                }","            }","        }","    }","","    private func showConsentDialog(completion: @escaping (Bool) -> Void) {","        let alert = UIAlertController(","            title: \"Data Collection\",","            message: \"We collect data to personalize your experience and send relevant notifications.\",","            preferredStyle: .alert","        )","        alert.addAction(UIAlertAction(title: \"Accept\", style: .default) { _ in","            completion(true)","        })","        alert.addAction(UIAlertAction(title: \"Decline\", style: .cancel) { _ in","            completion(false)","        })","        present(alert, animated: true)","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/stopServerCommunication":{"type":"topic","fragments":[{"text":"+ ","kind":"text"},{"text":"stopServerCommunication","kind":"identifier"}],"url":"\/documentation\/pushwooshcore\/pwconfiguration\/stopservercommunication","abstract":[{"text":"Disables communication with Pushwoosh servers.","type":"text"}],"kind":"symbol","title":"stopServerCommunication","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/stopServerCommunication","navigatorTitle":[{"kind":"identifier","text":"stopServerCommunication"}],"role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"url":"\/documentation\/pushwooshcore\/pwconfiguration","kind":"symbol","type":"topic","title":"PWConfiguration","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"abstract":[],"role":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"title":"PushwooshCore","kind":"symbol","role":"collection","url":"\/documentation\/pushwooshcore","type":"topic","abstract":[{"type":"text","text":"Core foundation module for Pushwoosh SDK."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore"}}}