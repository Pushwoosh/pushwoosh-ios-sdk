{"hierarchy":{"paths":[["doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore","doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/stopServerCommunication"},"variants":[{"paths":["\/documentation\/pushwooshcore\/pwconfiguration\/stopservercommunication"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"stopServerCommunication"}],"navigatorTitle":[{"text":"stopServerCommunication","kind":"identifier"}],"role":"symbol","modules":[{"name":"PushwooshCore"}],"externalID":"c:objc(pl)PWConfiguration(cm)stopServerCommunication","title":"stopServerCommunication","roleHeading":"Type Method","symbolKind":"method"},"primaryContentSections":[{"declarations":[{"languages":["occ"],"tokens":[{"text":"+ (","kind":"text"},{"text":"void","kind":"typeIdentifier","preciseIdentifier":"c:v"},{"text":") ","kind":"text"},{"kind":"identifier","text":"stopServerCommunication"},{"text":";","kind":"text"}],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Stops all communication with Pushwoosh servers. The SDK will not send or receive any data"},{"type":"text","text":" "},{"type":"text","text":"including device registration, tags, push tokens, and analytics."}]},{"type":"paragraph","inlineContent":[{"text":"Use this method to comply with privacy regulations (GDPR, CCPA) or honor user preferences","type":"text"},{"text":" ","type":"text"},{"text":"for data transmission. Push notifications will still be delivered to the device by APNs,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"but no tracking or analytics data will be sent to Pushwoosh."}]},{"level":2,"anchor":"Example","text":"Example","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle GDPR opt-out in settings:"}]},{"code":["class PrivacySettingsViewController: UIViewController {","","    @IBOutlet weak var dataCollectionSwitch: UISwitch!","","    @IBAction func dataCollectionToggled(_ sender: UISwitch) {","        if sender.isOn {","            showConsentDialog { accepted in","                if accepted {","                    Pushwoosh.configure.startServerCommunication()","                    self.showToast(\"Data collection enabled\")","                } else {","                    sender.isOn = false","                }","            }","        } else {","            Pushwoosh.configure.stopServerCommunication()","","            \/\/ Also unregister from push if required by your privacy policy","            Pushwoosh.configure.unregisterForPushNotifications { error in","                if error == nil {","                    self.showToast(\"Data collection disabled\")","                }","            }","        }","    }","","    private func showConsentDialog(completion: @escaping (Bool) -> Void) {","        let alert = UIAlertController(","            title: \"Data Collection\",","            message: \"We collect data to personalize your experience and send relevant notifications.\",","            preferredStyle: .alert","        )","        alert.addAction(UIAlertAction(title: \"Accept\", style: .default) { _ in","            completion(true)","        })","        alert.addAction(UIAlertAction(title: \"Decline\", style: .cancel) { _ in","            completion(false)","        })","        present(alert, animated: true)","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"abstract":[{"type":"text","text":"Disables communication with Pushwoosh servers."}],"kind":"symbol","references":{"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration/stopServerCommunication":{"fragments":[{"text":"+ ","kind":"text"},{"kind":"identifier","text":"stopServerCommunication"}],"type":"topic","abstract":[{"type":"text","text":"Disables communication with Pushwoosh servers."}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration\/stopServerCommunication","url":"\/documentation\/pushwooshcore\/pwconfiguration\/stopservercommunication","title":"stopServerCommunication","role":"symbol","navigatorTitle":[{"text":"stopServerCommunication","kind":"identifier"}],"kind":"symbol"},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore/PWConfiguration":{"role":"symbol","fragments":[{"kind":"identifier","text":"PWConfiguration"}],"identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore\/PWConfiguration","url":"\/documentation\/pushwooshcore\/pwconfiguration","title":"PWConfiguration","kind":"symbol","type":"topic","abstract":[]},"doc://com.pushwoosh.PushwooshCore/documentation/PushwooshCore":{"url":"\/documentation\/pushwooshcore","role":"collection","kind":"symbol","type":"topic","abstract":[{"text":"Core foundation module for Pushwoosh SDK.","type":"text"}],"title":"PushwooshCore","identifier":"doc:\/\/com.pushwoosh.PushwooshCore\/documentation\/PushwooshCore"}}}